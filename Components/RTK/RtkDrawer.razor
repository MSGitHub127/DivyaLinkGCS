@* Components/RTK/RtkDrawer.razor
   Pure content component — no fixed positioning, no backdrop, no toggle button.
   Designed to be placed exclusively inside <OverlayDrawer> in Setup.razor.
   OverlayDrawer owns the slide animation; this component owns the RTK logic.

   REPLACES the self-contained RtkBaseStationDrawer.razor which had its own
   fixed-position panel and floating toggle button (removed per Q3).
*@

@using BlazorApp3.Models
@using BlazorApp3.Services
@inject RtkBaseStationService Rtk
@inject NtripService          Ntrip
@inject IJSRuntime            JS
@implements IDisposable

@{
    var s     = _state;
    var phase = s.Phase;
}

@* Root — fills the OverlayDrawer body (flex-1 min-h-0 from OverlayDrawer) *@
<div class="flex h-full overflow-hidden bg-[#0d1117]">

    @* ════════════════════════════════════════════════════════════════
       LEFT PANEL  (340 px — connection config + survey + profiles)
       ════════════════════════════════════════════════════════════════ *@
    <div class="w-[340px] shrink-0 border-r border-[#21262d]
                flex flex-col overflow-y-auto no-scrollbar">

        @* ── Phase banner ──────────────────────────────────────────── *@
        <div class="flex items-center gap-[10px] px-[16px] py-[12px]
                    border-b border-[#21262d] bg-[#0d1117]">
            <span class="text-[0.6rem] font-bold uppercase tracking-widest
                         px-[8px] py-[2px] rounded-full border
                         @PhaseBadgeClass(phase)
                         @(phase is RtkPhase.Connecting or RtkPhase.Survey ? "animate-pulse" : "")">
                @phase.ToString().ToUpperInvariant()
            </span>
            <div class="flex-1"></div>
            @if (phase == RtkPhase.Idle)
            {
                <button class="text-[0.72rem] font-bold px-[12px] py-[5px]
                               rounded-[5px] bg-[#238636] hover:bg-[#2ea043]
                               text-white border-none cursor-pointer transition-colors"
                        disabled="@string.IsNullOrWhiteSpace(_cfg.ComPort)"
                        @onclick="HandleConnect">
                    Connect
                </button>
            }
            else
            {
                <button class="text-[0.72rem] font-bold px-[12px] py-[5px]
                               rounded-[5px] bg-[#f85149]/20 hover:bg-[#f85149]/30
                               text-[#f85149] border border-[#f85149]/40
                               cursor-pointer transition-colors"
                        @onclick="HandleDisconnect">
                    Disconnect
                </button>
            }
        </div>

        @* ── Error message ─────────────────────────────────────────── *@
        @if (s.ErrorMessage is not null)
        {
            <div class="bg-[#f85149]/10 border-b border-[#f85149]/30
                        px-[16px] py-[8px] text-[0.7rem] text-[#f85149]">
                <i class="bi bi-exclamation-triangle mr-[5px]"></i>@s.ErrorMessage
            </div>
        }

        @* ── Connection config ─────────────────────────────────────── *@
        <div class="p-[16px] border-b border-[#21262d]">
            <div class="text-[0.58rem] font-bold text-[#8b949e] uppercase
                        tracking-widest mb-[10px]">Connection</div>
            <div class="flex gap-[8px] mb-[8px]">
                <div class="flex-1">
                    <label class="text-[0.58rem] text-[#8b949e] block mb-[3px]">Port</label>
                    <select class="w-full bg-[#161b22] border border-[#30363d] rounded-[5px]
                                   px-[8px] py-[5px] text-[0.75rem] text-white
                                   focus:outline-none focus:border-[#58a6ff]"
                            disabled="@(phase != RtkPhase.Idle)"
                            @bind="_cfg.ComPort">
                        @foreach (var p in _availablePorts)
                        { <option value="@p">@p</option> }
                    </select>
                </div>
                <div class="w-[100px]">
                    <label class="text-[0.58rem] text-[#8b949e] block mb-[3px]">Baud</label>
                    <select class="w-full bg-[#161b22] border border-[#30363d] rounded-[5px]
                                   px-[8px] py-[5px] text-[0.75rem] text-white font-mono
                                   focus:outline-none focus:border-[#58a6ff]"
                            disabled="@(phase != RtkPhase.Idle)"
                            @bind="_cfg.BaudRate">
                        @foreach (var b in new[] { 9600,115200,230400,460800,921600 })
                        { <option value="@b">@b</option> }
                    </select>
                </div>
            </div>
            <label class="flex items-center gap-[6px] cursor-pointer mb-[3px]">
                <input type="checkbox" class="accent-[#58a6ff]"
                       disabled="@(phase != RtkPhase.Idle)"
                       @bind="_cfg.AutoConfig" />
                <span class="text-[0.72rem] text-[#e6edf3]">UBlox M8P/F9P autoconfig</span>
            </label>
            <label class="flex items-center gap-[6px] cursor-pointer">
                <input type="checkbox" class="accent-[#58a6ff]"
                       disabled="@(phase != RtkPhase.Idle)"
                       @bind="_cfg.M8p130Plus" />
                <span class="text-[0.72rem] text-[#8b949e]">M8P fw 130+ / F9P (MSM4)</span>
            </label>
        </div>

        @* ── Survey-In thresholds ──────────────────────────────────── *@
        <div class="p-[16px] border-b border-[#21262d]">
            <div class="text-[0.58rem] font-bold text-[#8b949e] uppercase
                        tracking-widest mb-[10px]">Survey-In Thresholds</div>
            <div class="grid grid-cols-2 gap-[8px]">
                <div>
                    <label class="text-[0.58rem] text-[#8b949e] block mb-[3px]">Target Acc (m)</label>
                    <input type="number" step="0.01" min="0.01" max="50"
                           class="w-full bg-[#161b22] border border-[#30363d] rounded-[5px]
                                  px-[8px] py-[5px] text-[0.75rem] text-white font-mono
                                  focus:outline-none focus:border-[#58a6ff]"
                           disabled="@(phase > RtkPhase.Connecting)"
                           @bind="_cfg.TargetAccuracyM" />
                </div>
                <div>
                    <label class="text-[0.58rem] text-[#8b949e] block mb-[3px]">Min Duration (s)</label>
                    <input type="number" step="10" min="10" max="3600"
                           class="w-full bg-[#161b22] border border-[#30363d] rounded-[5px]
                                  px-[8px] py-[5px] text-[0.75rem] text-white font-mono
                                  focus:outline-none focus:border-[#58a6ff]"
                           disabled="@(phase > RtkPhase.Connecting)"
                           @bind="_cfg.MinDurationSec" />
                </div>
            </div>
            @if (phase == RtkPhase.Survey)
            {
                <button class="mt-[8px] w-full text-[0.7rem] font-bold py-[5px]
                               rounded-[5px] border border-[#f0b429]/40
                               bg-[#f0b429]/10 hover:bg-[#f0b429]/20 text-[#f0b429]
                               cursor-pointer transition-colors"
                        @onclick="HandleRestartSurvey">
                    <i class="bi bi-arrow-counterclockwise mr-[4px]"></i>Restart Survey
                </button>
            }
        </div>

        @* ── Survey-In live metrics ────────────────────────────────── *@
        @if (phase >= RtkPhase.Survey)
        {
            var sv = s.Survey;
            <div class="p-[16px] border-b border-[#21262d]">
                <div class="text-[0.58rem] font-bold text-[#8b949e] uppercase
                            tracking-widest mb-[10px]">Survey-In Progress</div>
                <div class="flex items-center gap-[14px]">

                    @* AccuracyRing SVG *@
                    @{
                        double prog  = sv.AccuracyM <= 0 ? 0
                            : Math.Min(100.0, (_cfg.TargetAccuracyM / sv.AccuracyM) * 100.0);
                        double r     = 34;
                        double circ  = 2 * Math.PI * r;
                        double dash  = prog / 100.0 * circ;
                        string rColor = sv.Valid ? "#3fb950"
                            : sv.AccuracyM <= _cfg.TargetAccuracyM * 2 ? "#f0b429"
                            : "#58a6ff";
                    }
                    <svg width="82" height="82" viewBox="0 0 82 82" class="shrink-0">
                        <circle cx="41" cy="41" r="@r" fill="none"
                                stroke="rgba(255,255,255,0.06)" stroke-width="5"/>
                        <circle cx="41" cy="41" r="@r" fill="none"
                                stroke="@rColor" stroke-width="5"
                                stroke-linecap="round"
                                transform="rotate(-90 41 41)"
                                stroke-dasharray="@dash.ToString("F1", System.Globalization.CultureInfo.InvariantCulture) @circ.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"/>
                        <text x="41" y="38" text-anchor="middle" font-size="11"
                              font-family="monospace" fill="@rColor" font-weight="bold">
                            @sv.AccuracyM.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)
                        </text>
                        <text x="41" y="50" text-anchor="middle" font-size="8"
                              font-family="monospace" fill="#8b949e">metres</text>
                    </svg>

                    @* Stats *@
                    <div class="flex flex-col gap-[5px] flex-1 min-w-0">
                        @foreach (var (lbl, val, col) in new[] {
                            ("Duration",   $"{sv.DurationSec} s",     "text-white"),
                            ("Obs",        $"{sv.Observations}",       "text-white"),
                            ("Status",     sv.Valid ? "✓ VALID" : sv.Active ? "IN PROGRESS" : "—",
                                           sv.Valid ? "text-[#3fb950]" : "text-[#f0b429]"),
                        })
                        {
                            <div class="flex justify-between">
                                <span class="text-[0.62rem] text-[#8b949e]">@lbl</span>
                                <span class="text-[0.7rem] font-bold font-mono @col">@val</span>
                            </div>
                        }
                    </div>
                </div>

                @* Save position *@
                @if (sv.Valid && s.FixedPosition != null)
                {
                    <div class="flex gap-[6px] mt-[10px]">
                        <input type="text" placeholder="Profile name…"
                               class="flex-1 bg-[#161b22] border border-[#30363d] rounded-[5px]
                                      px-[8px] py-[4px] text-[0.72rem] text-white
                                      focus:outline-none focus:border-[#58a6ff]"
                               @bind="_saveProfileName" />
                        <button class="text-[0.68rem] font-bold px-[10px] py-[4px]
                                       rounded-[5px] bg-[#238636] hover:bg-[#2ea043]
                                       text-white border-none cursor-pointer"
                                disabled="@string.IsNullOrWhiteSpace(_saveProfileName)"
                                @onclick="HandleSaveProfile">
                            Save
                        </button>
                    </div>
                }
            </div>
        }

        @* ── Saved profiles ────────────────────────────────────────── *@
        <div class="p-[16px] flex-1">
            <div class="text-[0.58rem] font-bold text-[#8b949e] uppercase
                        tracking-widest mb-[10px]">Saved Profiles</div>
            @if (!s.SavedProfiles.Any())
            {
                <p class="text-[0.7rem] text-[#484f58] italic">
                    Complete a Survey-In and save the position.
                </p>
            }
            else
            {
                <div class="flex flex-col gap-[6px]">
                    @foreach (var profile in s.SavedProfiles)
                    {
                        bool isActive = s.ActiveProfileName == profile.Name;
                        <div class="bg-[#161b22] border @(isActive ? "border-[#3fb950]" : "border-[#21262d]")
                                    rounded-[6px] px-[10px] py-[8px]">
                            <div class="flex items-center justify-between mb-[2px]">
                                <span class="text-[0.72rem] font-semibold text-white truncate">
                                    @profile.Name
                                </span>
                                @if (isActive)
                                {
                                    <span class="text-[0.58rem] text-[#3fb950] font-bold">✓ ACTIVE</span>
                                }
                            </div>
                            <div class="text-[0.6rem] font-mono text-[#8b949e] mb-[5px]">
                                @profile.Lat.ToString("F6", System.Globalization.CultureInfo.InvariantCulture),
                                @profile.Lng.ToString("F6", System.Globalization.CultureInfo.InvariantCulture)
                                · @profile.Alt.ToString("F1", System.Globalization.CultureInfo.InvariantCulture) m
                            </div>
                            <div class="flex gap-[5px]">
                                <button class="flex-1 text-[0.63rem] font-bold py-[4px]
                                               rounded-[4px] bg-[#238636] hover:bg-[#2ea043]
                                               text-white border-none cursor-pointer"
                                        disabled="@(phase == RtkPhase.Idle)"
                                        @onclick="() => HandleUseProfile(profile)">
                                    Use
                                </button>
                                <button class="text-[0.63rem] px-[8px] py-[4px] rounded-[4px]
                                               bg-[#f85149]/10 hover:bg-[#f85149]/20
                                               text-[#f85149] border border-[#f85149]/30
                                               cursor-pointer"
                                        @onclick="() => HandleDeleteProfile(profile.Name)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    @* ════════════════════════════════════════════════════════════════
       RIGHT PANEL  (flex-1 — tabs: Satellite / Fixed Coords / RTCM)
       ════════════════════════════════════════════════════════════════ *@
    <div class="flex-1 min-w-0 flex flex-col overflow-hidden">

        @* Tab strip *@
        <div class="flex border-b border-[#21262d] shrink-0 px-[4px] pt-[4px]">
            @foreach (var (label, idx) in new[] { ("Satellite View", 0), ("Fixed Coords", 1), ("RTCM Stream", 2) })
            {
                <button class="px-[16px] py-[8px] text-[0.75rem] font-semibold
                               border-b-2 transition-colors cursor-pointer
                               bg-transparent border-x-0 border-t-0
                               @(_tab == idx
                                   ? "border-[#58a6ff] text-white"
                                   : "border-transparent text-[#8b949e] hover:text-white")"
                        @onclick="() => { _tab = idx; _ = DrawChartIfVisible(); }">
                    @label
                </button>
            }
        </div>

        @* ── TAB 0: Satellite View ──────────────────────────────────── *@
        @if (_tab == 0)
        {
            <div class="flex-1 min-h-0 overflow-hidden p-[16px] flex flex-col gap-[12px]">

                @* Constellation badges *@
                <div class="flex gap-[6px] flex-wrap shrink-0">
                    @foreach (var c in s.Constellations)
                    {
                        <span class="text-[0.58rem] font-bold uppercase tracking-widest
                                     px-[8px] py-[2px] rounded-full border
                                     @(c.IsActive
                                         ? "bg-[#3fb950]/15 text-[#3fb950] border-[#3fb950]/40"
                                         : "bg-[#21262d] text-[#484f58] border-[#30363d]")">
                            @c.Label
                        </span>
                    }
                </div>

                @* SNR chart canvas *@
                <div class="flex-1 min-h-0 bg-[#161b22] border border-[#21262d]
                            rounded-[8px] overflow-hidden relative">
                    <canvas id="rtk-snr-canvas" class="w-full h-full block"
                            style="min-height:160px"></canvas>
                </div>

                @* Link status + messages *@
                <div class="flex gap-[10px] shrink-0">
                    <div class="bg-[#161b22] border border-[#21262d] rounded-[8px]
                                p-[10px] w-[150px] shrink-0">
                        <div class="text-[0.55rem] text-[#8b949e] uppercase tracking-widest mb-[5px]">
                            Link
                        </div>
                        <div class="flex justify-between mb-[2px]">
                            <span class="text-[0.62rem] text-[#8b949e]">RX</span>
                            <span class="text-[0.62rem] font-mono text-white">@s.Stream.RxBps bps</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-[0.62rem] text-[#8b949e]">TX</span>
                            <span class="text-[0.62rem] font-mono text-[#3fb950]">@s.Stream.TxBps bps</span>
                        </div>
                    </div>
                    <div class="flex-1 bg-[#161b22] border border-[#21262d]
                                rounded-[8px] p-[10px] overflow-y-auto no-scrollbar max-h-[76px]">
                        <div class="text-[0.55rem] text-[#8b949e] uppercase tracking-widest mb-[3px]">
                            Messages Seen
                        </div>
                        <div class="flex flex-wrap gap-x-[10px] gap-y-[1px]">
                            @foreach (var m in s.Messages)
                            {
                                <span class="text-[0.58rem] font-mono text-[#8b949e]">
                                    <span class="text-white">@m.Name</span>=@m.Count
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        @* ── TAB 1: Fixed Coords ─────────────────────────────────────── *@
        @if (_tab == 1)
        {
            var pos = s.FixedPosition;
            <div class="flex-1 overflow-y-auto no-scrollbar p-[20px]">
                @if (pos == null)
                {
                    <div class="flex items-center justify-center h-full">
                        <div class="text-center text-[#8b949e]">
                            <div class="text-[2rem] mb-[8px]">📍</div>
                            <div class="text-[0.8rem]">Waiting for Survey-In to complete…</div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="flex flex-col gap-[14px]">
                        <div class="bg-[#161b22] border border-[#30363d] rounded-[8px] p-[14px]">
                            <div class="text-[0.58rem] text-[#8b949e] uppercase tracking-widest mb-[8px]">
                                Geodetic (WGS-84)
                            </div>
                            @foreach (var (lbl, val) in new[] {
                                ("Latitude",  pos.Lat.ToString("F7", System.Globalization.CultureInfo.InvariantCulture) + "°"),
                                ("Longitude", pos.Lng.ToString("F7", System.Globalization.CultureInfo.InvariantCulture) + "°"),
                                ("Altitude",  pos.Alt.ToString("F3", System.Globalization.CultureInfo.InvariantCulture) + " m"),
                            })
                            {
                                <div class="flex justify-between py-[5px] border-b border-[#21262d] last:border-0">
                                    <span class="text-[0.68rem] text-[#8b949e]">@lbl</span>
                                    <span class="text-[0.72rem] font-mono text-white">@val</span>
                                </div>
                            }
                        </div>
                        <div class="bg-[#161b22] border border-[#30363d] rounded-[8px] p-[14px]">
                            <div class="text-[0.58rem] text-[#8b949e] uppercase tracking-widest mb-[8px]">
                                ECEF (metres)
                            </div>
                            @foreach (var (lbl, val) in new[] {
                                ("X", pos.EcefX.ToString("F4", System.Globalization.CultureInfo.InvariantCulture)),
                                ("Y", pos.EcefY.ToString("F4", System.Globalization.CultureInfo.InvariantCulture)),
                                ("Z", pos.EcefZ.ToString("F4", System.Globalization.CultureInfo.InvariantCulture)),
                            })
                            {
                                <div class="flex justify-between py-[5px] border-b border-[#21262d] last:border-0">
                                    <span class="text-[0.68rem] text-[#8b949e]">@lbl</span>
                                    <span class="text-[0.72rem] font-mono text-white">@val</span>
                                </div>
                            }
                        </div>
                        <div class="bg-[#3fb950]/10 border border-[#3fb950]/30
                                    rounded-[8px] p-[12px] flex items-center gap-[10px]">
                            <i class="bi bi-check-circle text-[#3fb950] text-[1rem]"></i>
                            <div>
                                <div class="text-[0.68rem] font-bold text-[#3fb950]">Position Locked</div>
                                <div class="text-[0.6rem] text-[#3fb950]/70">
                                    Acc @s.Survey.AccuracyM.ToString("F3", System.Globalization.CultureInfo.InvariantCulture) m
                                    · @s.Survey.DurationSec s · @s.Survey.Observations obs
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        @* ── TAB 2: RTCM Stream ──────────────────────────────────────── *@
        @if (_tab == 2)
        {
            var st = s.Stream;
            <div class="flex-1 overflow-y-auto no-scrollbar p-[16px] flex flex-col gap-[14px]">

                @* Fragment visualiser *@
                <div class="bg-[#161b22] border border-[#21262d] rounded-[8px] p-[14px]">
                    <div class="text-[0.58rem] text-[#8b949e] uppercase tracking-widest mb-[8px]">
                        GPS_RTCM_DATA Fragmentation
                    </div>
                    <div class="flex gap-[5px] mb-[6px]">
                        @for (int f = 0; f < 4; f++)
                        {
                            bool used = f < st.FragmentsUsed;
                            <div class="flex-1 h-[26px] rounded-[4px] border flex items-center
                                        justify-center text-[0.58rem] font-bold font-mono
                                        @(used ? "bg-[#58a6ff]/20 border-[#58a6ff] text-[#58a6ff]"
                                               : "bg-[#21262d] border-[#30363d] text-[#484f58]")">
                                @(used ? $"F{f}" : "·")
                            </div>
                        }
                    </div>
                    <div class="flex justify-between text-[0.62rem]">
                        <span class="text-[#8b949e]">Largest frame</span>
                        <span class="font-mono @(st.HasOverflow ? "text-[#f0b429]" : "text-white")">
                            @st.LargestRtcmBytes B @(st.HasOverflow ? "⚠" : "")
                        </span>
                    </div>
                </div>

                @* Stats grid *@
                <div class="grid grid-cols-2 gap-[8px]">
                    @foreach (var (lbl, val, sub) in new[] {
                        ("Total Frames",    st.TotalMessages.ToString("N0"), "UBX + RTCM"),
                        ("Inject Rate",     $"{st.TxBps} bps",              "to vehicle"),
                        ("Serial Rate",     $"{st.RxBps} bps",              "from base"),
                        ("Fragments Used",  $"{st.FragmentsUsed} / 4",      "per frame"),
                    })
                    {
                        <div class="bg-[#161b22] border border-[#21262d] rounded-[8px] p-[10px]">
                            <div class="text-[0.58rem] text-[#8b949e] mb-[3px]">@lbl</div>
                            <div class="text-[0.95rem] font-bold font-mono text-white">@val</div>
                            <div class="text-[0.55rem] text-[#484f58] mt-[1px]">@sub</div>
                        </div>
                    }
                </div>

                @if (st.HasOverflow)
                {
                    <div class="bg-[#f0b429]/10 border border-[#f0b429]/30 rounded-[8px]
                                p-[10px] text-[0.7rem] text-[#f0b429]">
                        <i class="bi bi-exclamation-triangle mr-[5px]"></i>
                        Frame @st.LargestRtcmBytes B exceeds 540 B. Consider switching to MSM4.
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private RtkState _state    = new();
    private int      _tab      = 0;
    private string   _saveProfileName = "";
    private IReadOnlyList<string> _availablePorts = [];

    private sealed class CfgLocal
    {
        public string ComPort         { get; set; } = "";
        public int    BaudRate        { get; set; } = 460800;
        public bool   AutoConfig      { get; set; } = true;
        public bool   M8p130Plus      { get; set; } = false;
        public double TargetAccuracyM { get; set; } = 0.200;
        public int    MinDurationSec  { get; set; } = 60;

        public RtkConfig ToConfig() => new(ComPort, BaudRate, AutoConfig,
            M8p130Plus, TargetAccuracyM, MinDurationSec);
    }
    private readonly CfgLocal _cfg = new();

    protected override void OnInitialized()
    {
        _state = Rtk.State;
        Rtk.OnStateChanged += HandleStateChanged;
        RefreshPorts();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await DrawChartIfVisible();
    }

    public void Dispose() => Rtk.OnStateChanged -= HandleStateChanged;

    private void HandleStateChanged()
    {
        try
        {
            _ = InvokeAsync(async () =>
            {
                _state = Rtk.State;
                StateHasChanged();
                await DrawChartIfVisible();
            });
        }
        catch (ObjectDisposedException) { }
    }

    private async Task HandleConnect()
    {
        RefreshPorts();
        await Rtk.ConnectAsync(_cfg.ToConfig());
    }

    private async Task HandleDisconnect()  => await Rtk.DisconnectAsync();
    private async Task HandleRestartSurvey() => await Rtk.RestartSurveyAsync();
    private async Task HandleUseProfile(SavedBaseProfile p) => await Rtk.UseProfileAsync(p);
    private async Task HandleDeleteProfile(string name)     => await Rtk.DeleteProfileAsync(name);

    private async Task HandleSaveProfile()
    {
        if (string.IsNullOrWhiteSpace(_saveProfileName)) return;
        await Rtk.SaveCurrentPositionAsync(_saveProfileName.Trim());
        _saveProfileName = "";
    }

    private async Task DrawChartIfVisible()
    {
        if (_tab != 0) return;
        var sats = _state.Satellites.Select(s => new
            { id = s.Id, snr = (int)s.Snr, active = s.Active }).ToArray();
        try { await JS.InvokeVoidAsync("rtk.drawSnrChart", "rtk-snr-canvas", sats); }
        catch { }
    }

    private void RefreshPorts()
    {
        try { _availablePorts = RtkBaseStationService.GetAvailableComPorts(); }
        catch { _availablePorts = []; }
        if (string.IsNullOrEmpty(_cfg.ComPort) && _availablePorts.Count > 0)
            _cfg.ComPort = _availablePorts[0];
    }

    private static string PhaseBadgeClass(RtkPhase p) => p switch
    {
        RtkPhase.Idle       => "bg-[#21262d] text-[#8b949e] border-[#30363d]",
        RtkPhase.Connecting => "bg-[#58a6ff]/10 text-[#58a6ff] border-[#58a6ff]/40",
        RtkPhase.Survey     => "bg-[#f0b429]/10 text-[#f0b429] border-[#f0b429]/40",
        RtkPhase.Fixed      => "bg-[#3fb950]/10 text-[#3fb950] border-[#3fb950]/40",
        RtkPhase.Injecting  => "bg-[#00f2ff]/10 text-[#00f2ff] border-[#00f2ff]/40",
        _                   => ""
    };
}
