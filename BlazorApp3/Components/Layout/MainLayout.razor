@inherits LayoutComponentBase
@inject MavlinkService Drone
@implements IDisposable
@using System.IO.Ports
@using System.Linq

<div class="gcs-wrapper flex flex-col h-screen bg-transparent overflow-hidden relative">

    <header class="header fixed top-0 left-0 w-full h-[60px] z-[100] shrink-0 bg-[rgba(18,20,26,0.6)] backdrop-blur-md border-b border-[#242731] flex items-center justify-between px-2 md:px-5 transition-all duration-300">
        <div class="flex items-center gap-2 md:gap-[15px]">
            <div class="leading-[0.8] hidden sm:block">
                <span class="bg-gradient-to-r from-[#3a86ff] to-[#ff00c8] bg-clip-text text-transparent font-black text-lg md:text-[1.6rem] tracking-[-0.5px] inline-block">DIVYALINK</span>
                <div class="text-[0.55rem] text-[#888] tracking-[1.2px] uppercase mt-1">by Vayunotics</div>
            </div>

            <div class="flex items-center gap-1.5 flex-nowrap overflow-x-auto no-scrollbar pb-1 sm:pb-0">
                @{
                    var pillBase = "inline-flex items-center gap-1 px-2 py-1 rounded-[4px] text-[0.58rem] font-extrabold tracking-[0.8px] whitespace-nowrap transition-all duration-300 border";
                }
                <div class="@pillBase @(IsDroneActuallyTalking ? "bg-[rgba(0,200,80,0.12)] border-[#2ea043] text-[#3fb950]" : "bg-[rgba(80,80,80,0.10)] border-[#484f58] text-[#8b949e]")">
                    <i class="bi bi-router-fill"></i>
                    <span class="hidden sm:inline">@(IsDroneActuallyTalking ? "TELEM" : "NO LINK")</span>
                </div>
                <div class="@pillBase @(Drone.State.GpsFixType >= 3 ? "bg-[rgba(0,200,80,0.10)] border-[#2ea043] text-[#3fb950]" : Drone.State.GpsFixType >= 2 ? "bg-[rgba(210,153,34,0.12)] border-[#d29922] text-[#e3a820]" : "bg-[rgba(80,80,80,0.10)] border-[#484f58] text-[#8b949e]")">
                    <i class="bi bi-reception-4"></i>
                    <span class="hidden sm:inline">@(Drone.State.SatCount > 0 ? $"{Drone.State.SatCount} SAT" : "NO GPS")</span>
                </div>
                <div class="@pillBase @(Drone.State.IsRcConnected ? "bg-[rgba(0,220,80,0.20)] border-[#00cc55] text-[#00ee66]" : "bg-[rgba(220,60,60,0.18)] border-[#cc3333] text-[#ff6666]")">
                    <i class="bi bi-controller"></i>
                    <span class="hidden sm:inline">@(Drone.State.IsRcConnected ? "RC" : "NO RC")</span>
                </div>
                @if (IsDroneActuallyTalking && Drone.State.FlightMode != "Unknown")
                {
                    <div class="@pillBase bg-[rgba(88,166,255,0.10)] border-[#58a6ff] text-[#58a6ff]">
                        <i class="bi bi-airplane-fill"></i>
                        <span class="hidden sm:inline">@Drone.State.FlightMode</span>
                    </div>
                }
                @if (IsDroneActuallyTalking)
                {
                    <div class="@pillBase @(Drone.State.IsArmed ? "bg-[rgba(248,81,73,0.15)] border-[#f85149] text-[#ff8080]" : "bg-[rgba(46,160,67,0.10)] border-[#2ea043] text-[#3fb950]")">
                        <i class="bi @(Drone.State.IsArmed ? "bi-shield-fill-exclamation" : "bi-shield-fill-check")"></i>
                        <span class="hidden sm:inline">@(Drone.State.IsArmed ? "ARMED" : "DISARMED")</span>
                    </div>
                }
            </div>
        </div>

        <div class="flex items-center gap-1.5 md:gap-[10px] overflow-x-auto no-scrollbar">
            @{
                var inputBase = "bg-[#08090b] border border-[#242731] text-white py-1 px-1.5 md:py-[5px] md:px-[10px] rounded-[4px] text-xs md:text-[0.8rem] outline-none focus:border-[#58a6ff]";
            }

            <select class="@inputBase hidden md:block" @bind="selectedType">
                <option value="Serial">SERIAL</option>
                <option value="UDP">UDP</option>
                <option value="TCP">TCP</option>
            </select>

            @if (selectedType == "Serial")
            {
                <select class="@inputBase" @onchange="OnPortChanged" value="@selectedPort">
                    @if (availablePorts.Count == 0)
                    {
                        <option value="" disabled selected>Scanning...</option>
                    }
                    else
                    {
                        <option value="" disabled selected="@(string.IsNullOrEmpty(selectedPort))">-- Port --</option>
                        @foreach (var port in Drone.GetAvailablePorts())
                        {
                            <option value="@port.PortId">@port.DisplayName</option>
                        }
                    }
                </select>
            }
            else
            {
                <input class="@inputBase w-[100px] md:w-[120px]" @bind="selectedPort" placeholder="127.0.0.1" />
            }

            <select class="@inputBase hidden md:block" @bind="selectedBaud">
                <option value="9600">9600</option>
                <option value="57600">57600</option>
                <option value="115200">115200</option>
            </select>

            <span class="w-[10px] h-[10px] rounded-full shrink-0 ml-1 @(IsDroneActuallyTalking ? "bg-[#00ff00] shadow-[0_0_8px_#00ff00]" : "bg-[#ff0000]")"></span>

            <button class="shrink-0 border-none px-3 md:px-[20px] py-1.5 md:py-[8px] rounded-[4px] font-bold cursor-pointer text-[0.7rem] md:text-sm transition-colors @(IsDroneActuallyTalking ? "bg-[#ff3a3a] text-white hover:bg-red-600" : "bg-[#2b58ff] text-white hover:bg-blue-600")"
                    @onclick="ToggleConnection" disabled="@isAttempting">
                @if (isAttempting)
                {
                    <span>VERIFYING...</span>
                }
                else
                {

                    @(IsDroneActuallyTalking ? "DISCONNECT" : "CONNECT")
                }
            </button>
        </div>
    </header>

    <main class="flex-1 relative z-10 overflow-hidden pt-[60px] pointer-events-none">
        <CascadingValue Value="activeTab">
            <div class="pointer-events-auto h-full w-full">
                @Body
            </div>
        </CascadingValue>
    </main>

    @* <div class="fixed top-[60px] w-full sm:w-[540px] h-[calc(100vh-60px)] bg-[#0b0c10] border-r-2 border-[#7e3ff2] z-[1500] transition-all duration-300 overflow-y-auto overflow-x-hidden @(string.IsNullOrEmpty(activeTab) ? "-left-full sm:-left-[580px]" : "left-0")"> *@
    <div class="fixed top-[var(--header-height)] w-full sm:w-[540px] h-[calc(100vh-var(--header-height))] bg-[rgba(15,17,23,0.7)] backdrop-blur-xl border-r border-[rgba(255,255,255,0.1)] z-[1500] transition-all duration-300 shadow-[20px_0_50px_rgba(0,0,0,0.3)] overflow-y-auto overflow-x-hidden @(string.IsNullOrEmpty(activeTab) ? "-left-full sm:-left-[580px]" : "left-0")"> 
        <button class="absolute top-[5px] right-[5px] bg-transparent border-none text-[rgba(255,255,255,0.7)] text-[26px] font-bold p-0 cursor-pointer z-[2000] leading-none transition-all duration-200 hover:text-[#ff3a3a] hover:scale-125" @onclick='() => activeTab = ""'>&times;</button>
        <div class="min-w-full sm:min-w-[480px] p-0 box-border">
            @if (activeTab == "Quick")
            {
                <Quick />
            }
            else if (activeTab == "Actions")
            {

                <Actions />
            }
            else if (activeTab == "Messages")
            {

                <Messages />
            }
            else if (activeTab == "FlightPlan")
            {

                <FlightPlan />
            }
            else if (activeTab == "Pre Flight")
            {

                <PreFlight />
            }
            else if (activeTab == "Setup")
            {

                <Setup />
            }
            else if (activeTab == "Swarm")
            {

                <Swarm />
            }
        </div>
    </div>

    @* FLOATING FOOTER OVER MAP *@
    <footer class="footer absolute bottom-0 left-0 w-full p-[15px_10px] flex justify-center z-[1000] transition-all duration-300 pointer-events-none">
        <div class="flex gap-2 md:gap-[10px] w-full max-w-[750px] justify-center overflow-x-auto no-scrollbar pointer-events-auto px-2">
            @foreach (var tab in tabs)
            {
                var isActive = activeTab == tab;
                <button class="min-w-[65px] md:min-w-[80px] flex-1 rounded-[8px] text-white py-[8px] px-1 flex flex-col items-center justify-center cursor-pointer transition-all duration-200 shadow-lg @(isActive ? "bg-gradient-to-br from-[#2b58ff] to-[#7e3ff2] border border-transparent shadow-[0_0_15px_rgba(126,63,242,0.4)]" : "bg-[rgba(10,11,14,0.85)] backdrop-blur-md border border-[#30363d] hover:bg-[#1a1f2e] hover:border-[#58a6ff]")"
                        @onclick="() => HandleTabClick(tab)">
                    <i class="not-italic mb-[4px] text-[1.1rem] @(isActive ? "text-white" : "text-[#00f2ff]")">@GetIcon(tab)</i>
                    <span class="text-[0.6rem] md:text-[0.7rem] font-bold tracking-wider whitespace-nowrap">@tab</span>
                </button>
            }
        </div>
    </footer>

    <ConnectionDialog />
    <ToastContainer />
</div>

<style>
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }

    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

    .gcs-wrapper.map-fullscreen .header {
        transform: translateY(-100%);
        opacity: 0;
        pointer-events: none;
    }

    .gcs-wrapper.map-fullscreen .footer {
        transform: translateY(100%);
        opacity: 0;
        pointer-events: none;
    }

    .gcs-wrapper.map-fullscreen main {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 900;
    }

    .map-fullscreen-drawer {
        top: 0 !important;
        height: 100vh !important;
    }
</style>

@code {
    private string activeTab = "";
    private string selectedType = "Serial";
    private string selectedPort = "";
    private int selectedBaud = 57600;

    private List<string> availablePorts = new();
    private bool isManualConnected = false;
    private bool isAttempting = false;
    private System.Threading.Timer? _autoDetectTimer;
    private string[] tabs = { "Quick", "Actions", "Messages", "FlightPlan", "Pre Flight", "Setup", "Swarm" };

    private bool IsConnected => Drone.State.ConnectionStatus.Contains("Receiving");
    private bool IsDroneActuallyTalking => Drone.IsLinkHealthy;

    protected override void OnInitialized()
    {
        _autoDetectTimer = new System.Threading.Timer(AutoDetectPorts, null, 0, 1000);
        Drone.OnTelemetryUpdated += RefreshUi;
        Drone.OnRcChannelsUpdated += OnRcUpdated;
    }

    private void AutoDetectPorts(object? state)
    {
        try
        {
            var currentPhysicalPorts = SerialPort.GetPortNames().Distinct().OrderBy(x => x).ToList();
            InvokeAsync(() =>
            {
                if (isManualConnected && !string.IsNullOrEmpty(selectedPort))
                {
                    if (!currentPhysicalPorts.Contains(selectedPort))
                    {
                        Drone.StopConnection();
                        isManualConnected = false;
                        selectedPort = "";
                    }
                }
                if (!currentPhysicalPorts.SequenceEqual(availablePorts.OrderBy(x => x)))
                {
                    availablePorts = currentPhysicalPorts;
                    if (!isManualConnected && !string.IsNullOrEmpty(selectedPort) && !availablePorts.Contains(selectedPort))
                    {
                        selectedPort = "";
                    }
                }
                StateHasChanged();
            });
        }
        catch { }
    }

    private void OnPortChanged(ChangeEventArgs e)
    {
        selectedPort = e.Value?.ToString() ?? "";
        StateHasChanged();
    }

    private async Task ToggleConnection()
    {
        if (isAttempting) return;
        if (selectedType == "Serial" && string.IsNullOrEmpty(selectedPort)) return;

        isAttempting = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            if (isManualConnected)
            {
                Drone.StopConnection();
                isManualConnected = false;
            }
            else
            {
                Drone.Connect(Enum.Parse<ConnectionType>(selectedType), selectedPort, selectedBaud);
                for (int i = 0; i < 60; i++)
                {
                    bool hasData = Drone.State.Roll != 0 || Drone.State.SatCount > 0 || Drone.State.Altitude != 0;
                    if (IsDroneActuallyTalking && hasData) break;
                    if (Drone.State.ConnectionStatus == "Disconnected") break;
                    await Task.Delay(500);
                }
                if (IsDroneActuallyTalking)
                {
                    isManualConnected = true;
                    Drone.RequestDataStreams();
                }
                else
                {
                    Drone.StopConnection();
                    isManualConnected = false;
                }
            }
        }
        catch (Exception) { isManualConnected = false; }
        finally { isAttempting = false; await InvokeAsync(StateHasChanged); }
    }

    private string GetIcon(string t) => t switch
    {
        "Quick" => "⚡",
        "Actions" => "⚙️",
        "Messages" => "✉️",
        "FlightPlan" => "✈️",
        "Pre Flight" => "📋",
        "Setup" => "🛠️",
        "Swarm" => "🐝",
        _ => "❓"
    };

    private DateTime _lastHeaderRender = DateTime.MinValue;
    private void RefreshUi()
    {
        var now = DateTime.UtcNow;
        if ((now - _lastHeaderRender).TotalMilliseconds < 500) return;
        _lastHeaderRender = now;
        InvokeAsync(StateHasChanged);
    }

    private bool _lastRcState = false;
    private void OnRcUpdated(ushort[] _)
    {
        bool current = Drone.State.IsRcConnected;
        if (current == _lastRcState) return;
        _lastRcState = current;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _autoDetectTimer?.Dispose();
        Drone.OnTelemetryUpdated -= RefreshUi;
        Drone.OnRcChannelsUpdated -= OnRcUpdated;
    }

    private void HandleTabClick(string tab)
    {
        activeTab = (activeTab == tab) ? "" : tab;
    }
}