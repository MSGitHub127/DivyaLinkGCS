        }

        .nav-btn span {
            font-size: 0.75rem;
        }

        .nav-btn.active {
            background: linear-gradient(135deg, var(--accent-blue) 0%, var(--accent-purple) 100%);
            border: none;
        }

            .nav-btn.active i {
                color: white;
            }
</style>

@code {
    private string activeTab = "";
    private string selectedType = "Serial";
    private string selectedPort = "";
    private int selectedBaud = 57600;

    // UI State
    private List<string> availablePorts = new();
    private bool isManualConnected = false;
    private bool isAttempting = false;

    private System.Threading.Timer? _autoDetectTimer;

    private string[] tabs = { "Quick", "Actions", "Messages", "FlightPlan", "Pre Flight", "Setup", "Swarm" };

    // Helpers
    private bool IsConnected => Drone.State.ConnectionStatus.Contains("Receiving");

    // Use the stable cached IsLinkHealthy flag from MavlinkService.
    // This only flips after 3 confirmed consecutive heartbeat misses (1.5s).
    // Drone.IsConnected re-evaluates DateTime.UtcNow on every call which causes
    // the TELEM pill to flicker every render tick during normal SiK heartbeat gaps.
    private bool IsDroneActuallyTalking => Drone.IsLinkHealthy;

    protected override void OnInitialized()
    {
        _autoDetectTimer = new System.Threading.Timer(AutoDetectPorts, null, 0, 1000);
        Drone.OnTelemetryUpdated += RefreshUi;
        // RC state changes come via OnRcChannelsUpdated, NOT OnTelemetryUpdated.
        // Without this subscription the RC pill never turns green even when RC is connected.
        Drone.OnRcChannelsUpdated += OnRcUpdated;
        // DO NOT add: Drone.OnToast += _ => InvokeAsync(StateHasChanged);
        // Anonymous lambdas cannot be unsubscribed. Every Blazor reconnect stacks
        // another copy on the singleton service -> crash loop. ToastContainer owns OnToast.
    }

    // Runs on a background thread, so we must use InvokeAsync for UI updates
    private void AutoDetectPorts(object? state)
    {
        try
        {
            // 1. Get the raw list from Windows
            var currentPhysicalPorts = SerialPort.GetPortNames().Distinct().OrderBy(x => x).ToList();

            InvokeAsync(() =>
            {
                // 2. SAFETY CHECK: Is our active port currently missing?
                // We check this EVERY time, independent of the dropdown list update.
                if (isManualConnected && !string.IsNullOrEmpty(selectedPort))
                {
                    if (!currentPhysicalPorts.Contains(selectedPort))
                    {
                        // CABLE UNPLUGGED! Force Disconnect immediately.
                        Console.WriteLine($"Port {selectedPort} lost! Disconnecting...");

                        Drone.StopConnection();
                        isManualConnected = false;
                        selectedPort = "";

                        // Force button to update to "CONNECT" instantly
                        // StateHasChanged();
                    }
                }

                // 3. UI LIST UPDATE: Only update dropdown if list changed (Prevents flickering)
                if (!currentPhysicalPorts.SequenceEqual(availablePorts.OrderBy(x => x)))
                {
                    availablePorts = currentPhysicalPorts;

                    // If we weren't connected but had a port selected that is now gone, clear it
                    if (!isManualConnected && !string.IsNullOrEmpty(selectedPort) && !availablePorts.Contains(selectedPort))
                    {
                        selectedPort = "";
                    }
                }
                StateHasChanged();
            });
        }
        catch { /* Ignore scanning errors */ }
    }

    private void OnPortChanged(ChangeEventArgs e)
    {
        selectedPort = e.Value?.ToString() ?? "";
        StateHasChanged();
    }

    private async Task ToggleConnection()
    {
        if (isAttempting) return; // Prevent double clicks

        // 1. Validation: If Serial mode, must have a port
        if (selectedType == "Serial" && string.IsNullOrEmpty(selectedPort))
        {
            Console.WriteLine("No port selected!");
            return;
        }

        isAttempting = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            if (isManualConnected)
            {
                // DISCONNECT
                Drone.StopConnection();
                isManualConnected = false;
            }
            else
            {
                // CONNECT
                Drone.Connect(Enum.Parse<ConnectionType>(selectedType), selectedPort, selectedBaud);

                // ============================================================
                // REPLACE THE OLD "await Task.Delay(3000)" WITH THIS LOOP:
                // ============================================================

                // Smart Wait Loop: Checks every 0.5s for up to 30 seconds
                // --- UNIFIED 30-SECOND TIMER LOOP ---
                for (int i = 0; i < 60; i++)
                {
                    // 1. CHECK FOR "FULL" CONNECTION (Data is Flowing)
                    // We check specifically for Attitude or Satellites
                    bool hasData = Drone.State.Roll != 0 || Drone.State.SatCount > 0 || Drone.State.Altitude != 0;

                    if (IsDroneActuallyTalking && hasData)
                    {
                        break; // SUCCESS! Exit loop immediately.
                    }

                    // 2. CHECK FOR USER CANCEL
                    if (Drone.State.ConnectionStatus == "Disconnected") break;

                    // 3. CALCULATE TIME LEFT
                    int secondsLeft = 30 - (i / 2);

                    // 4. DISPLAY SITUATIONAL STATUS
                    if (!IsDroneActuallyTalking)
                    {
                        // PHASE 1: No Heartbeat yet (Radio warming up)
                        Drone.ReportStatus($"Connecting... ({secondsLeft}s)");
                    }
                    else
                    {
                        // PHASE 2: Heartbeat found, but waiting for Telemetry
                        Drone.ReportStatus($"Link Established! Waiting for Data... ({secondsLeft}s)");
                    }

                    await Task.Delay(500);
                }
                // ============================================================

                // Final Verification after the loop finishes or breaks
                if (IsDroneActuallyTalking)
                {
                    isManualConnected = true;
                    Drone.RequestDataStreams(); // Request Telemetry
                }
                else
                {
                    // If we timed out or were cancelled, ensure everything is clean
                    Drone.StopConnection();
                    isManualConnected = false;
                    Console.WriteLine("Connection timed out (No Heartbeat)");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Toggle Error: {ex.Message}");
            isManualConnected = false;
        }
        finally
        {
            // Always re-enable button
            isAttempting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string GetIcon(string t) => t switch
    {
        "Quick" => "⚡",
        "Actions" => "⚙️",
        "Messages" => "✉️",
        "FlightPlan" => "✈️",
        "Pre Flight" => "📋",
        "Setup" => "🛠️",
        "Swarm" => "🐝",
        _ => "❓"
    };

    private DateTime _lastHeaderRender = DateTime.MinValue;
    private void RefreshUi()
    {
        // Throttled to 2Hz — header only shows sat count / arm state, no need for 10Hz
        var now = DateTime.UtcNow;
        if ((now - _lastHeaderRender).TotalMilliseconds < 500) return;
        _lastHeaderRender = now;
        InvokeAsync(StateHasChanged);
    }

    // RC state change handler. MavlinkService writes IsRcConnected BEFORE firing
    // this event, so Drone.State.IsRcConnected is already correct when we read it.
    // Only re-renders on actual transitions (connected <-> disconnected).
    private bool _lastRcState = false;
    private void OnRcUpdated(ushort[] _)
    {
        bool current = Drone.State.IsRcConnected;
        if (current == _lastRcState) return;
        _lastRcState = current;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _autoDetectTimer?.Dispose();
        Drone.OnTelemetryUpdated -= RefreshUi;
        Drone.OnRcChannelsUpdated -= OnRcUpdated;
    }

    private void HandleTabClick(string tab)
    {
        activeTab = (activeTab == tab) ? "" : tab;
    }
}

