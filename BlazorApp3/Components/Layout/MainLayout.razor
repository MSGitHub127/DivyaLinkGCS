@inherits LayoutComponentBase
@inject MavlinkService Drone
@implements IDisposable
@using System.IO.Ports
@using System.Linq

<div class="gcs-wrapper">
    <header class="header">
        <div class="brand-section">
            <div class="logo">
                <span class="logo-text">DIVYALINK</span>
                <div class="tagline">by Vayunotics</div>
            </div>
            <div class="sat-status">
                <span class="sat-icon">📡</span>
                <span>Sat-Count: @Drone.State.SatCount</span>
            </div>
        </div>

        <div class="connection-controls">
            <select class="gcs-input" @bind="selectedType">
                <option value="Serial">SERIAL</option>
                <option value="UDP">UDP</option>
                <option value="TCP">TCP</option>
            </select>

            @if (selectedType == "Serial")
            {
                <select class="gcs-input" @onchange="OnPortChanged" value="@selectedPort">
                    @if (availablePorts.Count == 0)
                    {
                        <option value="" disabled selected>Scanning...</option>
                    }
                    else
                    {
                        <option value="" disabled selected="@(string.IsNullOrEmpty(selectedPort))">-- Select Port --</option>
                        @foreach (var p in availablePorts)
                        {
                            <option value="@p">@p</option>
                        }
                    }
                </select>
            }
            else
            {
                <input class="gcs-input" @bind="selectedPort" placeholder="127.0.0.1" style="width:120px;" />
            }

            <select class="gcs-input" @bind="selectedBaud">
                <option value="57600">57600</option>
                <option value="115200">115200</option>
                <option value="14550">14550 (SITL)</option>
            </select>

            <div class="v-divider"></div>
            <span class="status-indicator @(IsDroneActuallyTalking ? "online" : "offline")"></span>

            <button class="connect-btn @(IsDroneActuallyTalking ? "online-red" : "offline-blue")"
                    @onclick="ToggleConnection"
                    disabled="@isAttempting">
                @if (isAttempting)
                {
                    <span>VERIFYING...</span>
                }
                else
                {
                    @(IsDroneActuallyTalking ? "DISCONNECT" : "CONNECT")
                }
            </button>
        </div>
    </header>

    <main class="viewport">
        <CascadingValue Value="activeTab">
            @Body
        </CascadingValue>
    </main>

    <div class="gcs-drawer @(string.IsNullOrEmpty(activeTab) ? "" : "open")">
        <button class="close-overlay" @onclick='() => activeTab = ""'>&times;</button>
        <div class="drawer-content">
            @if (activeTab == "Quick")
            {
                <Quick />
            }
            else if (activeTab == "Actions")
            {
                <Actions />
            }
            else if (activeTab == "Messages")
            {
                <Messages />
            }
            else if (activeTab == "FlightPlan")
            {
                <FlightPlan />
            }
            else if (activeTab == "Pre Flight")
            {
                <PreFlight />
            }
            else if (activeTab == "Setup")
            {
                <Setup />
            }
        </div>
    </div>

    <footer class="footer">
        <div class="sub-nav">
            @foreach (var tab in tabs)
            {
                <button class="nav-btn @(activeTab == tab ? "active" : "")"
                        @onclick="() => HandleTabClick(tab)">
                    <i class="cyan-icon">@GetIcon(tab)</i>
                    <span>@tab</span>
                </button>
            }
        </div>
    </footer>
    <ConnectionDialog />
</div>

<style>
    :root {
        --bg-dark: #0a0b0d;
        --panel-bg: #12141a;
        --border: #242731;
        --accent-blue: #2b58ff;
        --accent-purple: #7e3ff2;
        --cyan: #00f2ff;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', sans-serif;
    }

    .gcs-wrapper {
        display: flex;
        flex-direction: column;
        height: 100vh;
        background: var(--bg-dark);
        overflow: hidden; /* Prevents double scrollbars */
    }

    /* THE DRAWER (Left Side) */
    .gcs-drawer {
        position: fixed;
        top: 60px;
        /* FIX: Increased to 540px to fit the 500px content comfortably */
        width: 540px;
        left: -580px;
        height: calc(100vh - 120px);
        background: #0b0c10;
        border-right: 2px solid #7e3ff2;
        z-index: 1500;
        transition: left 0.3s ease-in-out;
        /* Keep the scrollbar always visible to prevent jumping */
        overflow-y: auto;
        overflow-x: hidden;
    }

    .gcs-drawer.open {
            left: 0; /* Slide in */
        }

    .drawer-content {
        min-width: 480px;
        padding: 0; /* Slight padding so the X doesn't cover text immediately */
        box-sizing: border-box;
    }

    /* Sidebar Header Layout */
    .drawer-header {
        display: flex;
        justify-content: space-between; /* Pushes Title Left, X Right */
        align-items: center; /* Centers them vertically */
        padding: 15px 20px; /* Adds breathing room */
        background: #12141a; /* Darker header background */
        border-bottom: 1px solid #7e3ff2; /* Neon purple separator */
        min-height: 50px;
    }

        /* Title Styling */
    .drawer-header span {
            font-size: 1.1rem;
            font-weight: bold;
            color: white;
            letter-spacing: 1px;
        }

    .close-overlay {
        position: absolute; /* Floats over content */
        top: 5px;
        right: 5px;
        background: transparent; /* No background color */
        border: none;
        color: rgba(255, 255, 255, 0.7); /* Semi-transparent white */
        font-size: 26px; /* Large and easy to hit */
        font-weight: bold;
        padding: 0;
        cursor: pointer;
        z-index: 2000; /* Ensures it sits ON TOP of your HUD/Map */
        line-height: 1;
        transition: all 0.2s ease;
    }

        /* Hover Effect */
    .close-overlay:hover {
            color: #ff3a3a; /* Bright red on hover */
            transform: scale(1.2);
        }
    /* HEADER STYLING */
    .header {
        height: 60px;
        z-index: 100;
        flex-shrink: 0;
        background: var(--panel-bg);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
    }

    /* Ensure these specific styles are present for the connection bar */
    .v-divider {
        width: 1px;
        height: 20px;
        background: #333;
        margin: 0 10px;
    }

    .status-indicator {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 5px;
    }

    .online {
        background: #00ff00;
        box-shadow: 0 0 8px #00ff00;
    }

    .offline {
        background: #ff0000;
    }

    .offline-blue {
        background: #2b58ff;
        color: white;
    }

    .online-red {
        background: #ff3a3a;
        color: white;
    }

    .brand-section {
        display: flex; /* Forces children (Logo and Sat-Count) to be side-by-side */
        align-items: center; /* Vertically aligns them in the center of the 60px header */
        gap: 15px; /* Space between logo and sat-count */
    }

    .logo {
        line-height: 0.8; /* Keeps the tagline close to the brand name */
    }

    .logo-text {
        background: linear-gradient(to right, #3a86ff, #ff00c8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 900;
        font-size: 1.6rem;
        letter-spacing: -0.5px;
        display: inline-block;
    }

    .tagline {
        font-size: 0.55rem;
        color: #888;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        margin-top: 4px;
    }

    .sat-status {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.8rem;
        color: #ddd;
        padding-bottom: 5px; /* Adjusts vertical "feeling" to match logo baseline */
    }

    .sat-icon {
        font-size: 1rem;
        color: #ffffff;
    }

    .connection-controls {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .gcs-input {
        background: #08090b;
        border: 1px solid var(--border);
        color: white;
        padding: 5px 10px;
        border-radius: 4px;
        font-size: 0.8rem;
    }

    .divider {
        width: 1px;
        height: 25px;
        background: var(--border);
        margin: 0 10px;
    }

    .status-indicator {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .online {
        background: #00ff00;
        box-shadow: 0 0 10px #00ff00;
    }

    .offline {
        background: #ff0000;
    }

    .connect-btn {
        background: var(--accent-blue);
        color: white;
        border: none;
        padding: 8px 20px;
        border-radius: 4px;
        font-weight: bold;
        cursor: pointer;
    }

    /* VIEWPORT */
    .viewport {
        flex: 1;
        position: relative;
        z-index: 10;
        overflow: hidden;
    }

    /* FOOTER STYLING */
    .footer {
        background: var(--panel-bg); /* Was var(--bg-dark) in some versions, using panel for contrast */
        border-top: 1px solid var(--border);
        padding: 10px;
        display: flex;
        justify-content: center;
        z-index: 2000; /* Ensure it stays on top of the map */
        flex-shrink: 0; /* CRITICAL: Prevents footer from being squashed */
    }

    .sub-nav {
        display: flex;
        gap: 10px;
        width: 100%;
        max-width: 1400px;
    }

    .nav-btn {
        flex: 1;
        background: #090a0c;
        border: 1px solid var(--border);
        border-radius: 6px;
        color: white;
        padding: 12px 5px;
        display: flex;
        flex-direction: column;
        align-items: center;
        cursor: pointer;
        transition: 0.2s;
    }

    .nav-btn i.cyan {
            color: var(--cyan);
            font-style: normal;
            margin-bottom: 5px;
        }

    .nav-btn span {
            font-size: 0.75rem;
        }

    .nav-btn.active {
            background: linear-gradient(135deg, var(--accent-blue) 0%, var(--accent-purple) 100%);
            border: none;
        }

    .nav-btn.active i {
                color: white;
            }
</style>

@code {
    private string activeTab = "";
    private string selectedType = "Serial";
    private string selectedPort = "";
    private int selectedBaud = 57600;

    // UI State
    private List<string> availablePorts = new();
    private bool isManualConnected = false;
    private bool isAttempting = false;

    private System.Threading.Timer? _autoDetectTimer;

    private string[] tabs = { "Quick", "Actions", "Messages", "FlightPlan", "Pre Flight", "Setup" };

    // Helpers
    private bool IsConnected => Drone.State.ConnectionStatus.Contains("Receiving");

    // Robust check for connection health
    private bool IsDroneActuallyTalking =>
        Drone.IsConnected && (DateTime.UtcNow - Drone.State.LastHeartbeat).TotalSeconds < 3;

    protected override void OnInitialized()
    {
        // Start the timer to scan for ports every 1s
        _autoDetectTimer = new System.Threading.Timer(AutoDetectPorts, null, 0, 1000);
    }

    // Runs on a background thread, so we must use InvokeAsync for UI updates
    private void AutoDetectPorts(object? state)
    {
        try
        {
            // 1. Get the raw list from Windows
            var currentPhysicalPorts = SerialPort.GetPortNames().Distinct().OrderBy(x => x).ToList();

            InvokeAsync(() =>
            {
                // 2. SAFETY CHECK: Is our active port currently missing?
                // We check this EVERY time, independent of the dropdown list update.
                if (isManualConnected && !string.IsNullOrEmpty(selectedPort))
                {
                    if (!currentPhysicalPorts.Contains(selectedPort))
                    {
                        // CABLE UNPLUGGED! Force Disconnect immediately.
                        Console.WriteLine($"Port {selectedPort} lost! Disconnecting...");

                        Drone.StopConnection();
                        isManualConnected = false;
                        selectedPort = "";

                        // Force button to update to "CONNECT" instantly
                        // StateHasChanged();
                    }
                }

                // 3. UI LIST UPDATE: Only update dropdown if list changed (Prevents flickering)
                if (!currentPhysicalPorts.SequenceEqual(availablePorts.OrderBy(x => x)))
                {
                    availablePorts = currentPhysicalPorts;

                    // If we weren't connected but had a port selected that is now gone, clear it
                    if (!isManualConnected && !string.IsNullOrEmpty(selectedPort) && !availablePorts.Contains(selectedPort))
                    {
                        selectedPort = "";
                    }
                }
                StateHasChanged();
            });
        }
        catch { /* Ignore scanning errors */ }
    }

    private void OnPortChanged(ChangeEventArgs e)
    {
        selectedPort = e.Value?.ToString() ?? "";
        StateHasChanged();
    }

    private async Task ToggleConnection()
    {
        if (isAttempting) return; // Prevent double clicks

        // 1. Validation: If Serial mode, must have a port
        if (selectedType == "Serial" && string.IsNullOrEmpty(selectedPort))
        {
            Console.WriteLine("No port selected!");
            return;
        }

        isAttempting = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            if (isManualConnected)
            {
                // DISCONNECT
                Drone.StopConnection();
                isManualConnected = false;
            }
            else
            {
                // CONNECT
                Drone.Connect(Enum.Parse<ConnectionType>(selectedType), selectedPort, selectedBaud);

                // ============================================================
                // REPLACE THE OLD "await Task.Delay(3000)" WITH THIS LOOP:
                // ============================================================

                // Smart Wait Loop: Checks every 0.5s for up to 30 seconds
                // --- UNIFIED 30-SECOND TIMER LOOP ---
                for (int i = 0; i < 60; i++)
                {
                    // 1. CHECK FOR "FULL" CONNECTION (Data is Flowing)
                    // We check specifically for Attitude or Satellites
                    bool hasData = Drone.State.Roll != 0 || Drone.State.SatCount > 0 || Drone.State.Altitude != 0;

                    if (IsDroneActuallyTalking && hasData)
                    {
                        break; // SUCCESS! Exit loop immediately.
                    }

                    // 2. CHECK FOR USER CANCEL
                    if (Drone.State.ConnectionStatus == "Disconnected") break;

                    // 3. CALCULATE TIME LEFT
                    int secondsLeft = 30 - (i / 2);

                    // 4. DISPLAY SITUATIONAL STATUS
                    if (!IsDroneActuallyTalking)
                    {
                        // PHASE 1: No Heartbeat yet (Radio warming up)
                        Drone.ReportStatus($"Connecting... ({secondsLeft}s)");
                    }
                    else
                    {
                        // PHASE 2: Heartbeat found, but waiting for Telemetry
                        Drone.ReportStatus($"Link Established! Waiting for Data... ({secondsLeft}s)");
                    }

                    await Task.Delay(500);
                }
                // ============================================================

                // Final Verification after the loop finishes or breaks
                if (IsDroneActuallyTalking)
                {
                    isManualConnected = true;
                    Drone.RequestDataStreams(); // Request Telemetry
                }
                else
                {
                    // If we timed out or were cancelled, ensure everything is clean
                    Drone.StopConnection();
                    isManualConnected = false;
                    Console.WriteLine("Connection timed out (No Heartbeat)");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Toggle Error: {ex.Message}");
            isManualConnected = false;
        }
        finally
        {
            // Always re-enable button
            isAttempting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string GetIcon(string t) => t switch
    {
        "Quick" => "⚡",
        "Actions" => "⚙️",
        "Messages" => "✉️",
        "FlightPlan" => "✈️",
        "Pre Flight" => "📋",
        "Setup" => "🛠️",
        _ => "❓"
    };

    public void Dispose() => _autoDetectTimer?.Dispose();

    private void HandleTabClick(string tab)
    {
        activeTab = (activeTab == tab) ? "" : tab;
    }
}

