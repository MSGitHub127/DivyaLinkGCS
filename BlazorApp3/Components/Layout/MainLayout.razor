@inherits LayoutComponentBase
@inject MavlinkService Drone
@implements IDisposable
@using System.IO.Ports
@using System.Linq

<div class="gcs-wrapper">
    <header class="header">
        <div class="brand-section">
            <div class="logo">
                <span class="logo-text">DIVYALINK</span>
                <div class="tagline">by Vayunotics</div>
            </div>
            <div class="header-status-bar">
                @* Telemetry link indicator *@
                <div class="hdr-status-pill pill-telem @(IsDroneActuallyTalking ? "pill-online" : "pill-offline")">
                    <i class="bi bi-router-fill"></i>
                    <span>@(IsDroneActuallyTalking ? "TELEM" : "NO LINK")</span>
                </div>

                @* GPS fix status *@
                <div class="hdr-status-pill @(Drone.State.GpsFixType >= 3 ? "pill-gps-fix" : Drone.State.GpsFixType >= 2 ? "pill-gps-weak" : "pill-gps-none")">
                    <i class="bi bi-reception-4"></i>
                    <span>@(Drone.State.SatCount > 0 ? $"{Drone.State.SatCount} SAT" : "NO GPS")</span>
                </div>

                @* RC controller status *@
                <div class="hdr-status-pill @(Drone.State.IsRcConnected ? "pill-rc-on" : "pill-rc-off")">
                    <i class="bi bi-controller"></i>
                    <span>@(Drone.State.IsRcConnected ? "RC" : "NO RC")</span>
                </div>

                @* Flight mode badge (only when connected) *@
                @if (IsDroneActuallyTalking && Drone.State.FlightMode != "Unknown")
                {
                    <div class="hdr-status-pill pill-mode">
                        <i class="bi bi-airplane-fill"></i>
                        <span>@Drone.State.FlightMode</span>
                    </div>
                }

                @* Arm state *@
                @if (IsDroneActuallyTalking)
                {
                    <div class="hdr-status-pill @(Drone.State.IsArmed ? "pill-armed" : "pill-disarmed")">
                        <i class="bi @(Drone.State.IsArmed ? "bi-shield-fill-exclamation" : "bi-shield-fill-check")"></i>
                        <span>@(Drone.State.IsArmed ? "ARMED" : "DISARMED")</span>
                    </div>
                }
            </div>
        </div>

        <div class="connection-controls">
            <select class="gcs-input" @bind="selectedType">
                <option value="Serial">SERIAL</option>
                <option value="UDP">UDP</option>
                <option value="TCP">TCP</option>
            </select>

            @if (selectedType == "Serial")
            {
                <select class="gcs-input" @onchange="OnPortChanged" value="@selectedPort">
                    @if (availablePorts.Count == 0)
                    {
                        <option value="" disabled selected>Scanning...</option>
                    }
                    else
                    {
                        <option value="" disabled selected="@(string.IsNullOrEmpty(selectedPort))">-- Select Port --</option>
                        @foreach (var port in Drone.GetAvailablePorts())
                        {
                            <option value="@port.PortId">@port.DisplayName</option>
                        }
                    }
                </select>
            }
            else
            {
                <input class="gcs-input" @bind="selectedPort" placeholder="127.0.0.1" style="width:120px;" />
            }

            <select class="gcs-input" @bind="selectedBaud">
                <option value="9600">9600 (Legacy)</option>
                <option value="19200">19200</option>
                <option value="38400">38400</option>
                <option value="57600">57600 (SiK Telemetry Radio)</option>
                <option value="115200">115200 (Direct USB Standard)</option>
                <option value="230400">230400</option>
                <option value="460800">460800</option>
                <option value="921600">921600 (High-Speed ESP Bridge)</option>
                <option value="1500000">1500000 (Advanced/Custom)</option>
            </select>

            <div class="v-divider"></div>
            <span class="status-indicator @(IsDroneActuallyTalking ? "online" : "offline")"></span>

            <button class="connect-btn @(IsDroneActuallyTalking ? "online-red" : "offline-blue")"
                    @onclick="ToggleConnection"
                    disabled="@isAttempting">
                @if (isAttempting)
                {
                    <span>VERIFYING...</span>
                }
                else
                {
                    @(IsDroneActuallyTalking ? "DISCONNECT" : "CONNECT")
                }
            </button>
        </div>
    </header>

    <main class="viewport">
        <CascadingValue Value="activeTab">
            @Body
        </CascadingValue>
    </main>

    <div class="gcs-drawer @(string.IsNullOrEmpty(activeTab) ? "" : "open")">
        <button class="close-overlay" @onclick='() => activeTab = ""'>&times;</button>
        <div class="drawer-content">
            @if (activeTab == "Quick")
            {
                <Quick />
            }
            else if (activeTab == "Actions")
            {
                <Actions />
            }
            else if (activeTab == "Messages")
            {
                <Messages />
            }
            else if (activeTab == "FlightPlan")
            {
                <FlightPlan />
            }
            else if (activeTab == "Pre Flight")
            {
                <PreFlight />
            }
            else if (activeTab == "Setup")
            {
                <Setup />
            }
            else if(activeTab == "Swarm")
            {
                <Swarm />
            }
")
        </div>
    </div>

    <footer class="footer">
        <div class="sub-nav">
            @foreach (var tab in tabs)
            {
                <button class="nav-btn @(activeTab == tab ? "active" : "")"
                        @onclick="() => HandleTabClick(tab)">
                    <i class="cyan-icon">@GetIcon(tab)</i>
                    <span>@tab</span>
                </button>
            }
        </div>
    </footer>
    <ConnectionDialog />
    <ToastContainer />
</div>

<style>
    :root {
        --bg-dark: #0a0b0d;
        --panel-bg: #12141a;
        --border: #242731;
        --accent-blue: #2b58ff;
        --accent-purple: #7e3ff2;
        --cyan: #00f2ff;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', sans-serif;
    }

    .gcs-wrapper {
        display: flex;
        flex-direction: column;
        height: 100vh;
        background: var(--bg-dark);
        overflow: hidden; /* Prevents double scrollbars */
    }

    /* THE DRAWER (Left Side) */
    .gcs-drawer {
        position: fixed;
        top: 60px;
        /* FIX: Increased to 540px to fit the 500px content comfortably */
        width: 540px;
        left: -580px;
        height: calc(100vh - 120px);
        background: #0b0c10;
        border-right: 2px solid #7e3ff2;
        z-index: 1500;
        transition: left 0.3s ease-in-out;
        /* Keep the scrollbar always visible to prevent jumping */
        overflow-y: auto;
        overflow-x: hidden;
    }

        .gcs-drawer.open {
            left: 0; /* Slide in */
        }

    .drawer-content {
        min-width: 480px;
        padding: 0; /* Slight padding so the X doesn't cover text immediately */
        box-sizing: border-box;
    }

    /* Sidebar Header Layout */
    .drawer-header {
        display: flex;
        justify-content: space-between; /* Pushes Title Left, X Right */
        align-items: center; /* Centers them vertically */
        padding: 15px 20px; /* Adds breathing room */
        background: #12141a; /* Darker header background */
        border-bottom: 1px solid #7e3ff2; /* Neon purple separator */
        min-height: 50px;
    }

        /* Title Styling */
        .drawer-header span {
            font-size: 1.1rem;
            font-weight: bold;
            color: white;
            letter-spacing: 1px;
        }

    .close-overlay {
        position: absolute; /* Floats over content */
        top: 5px;
        right: 5px;
        background: transparent; /* No background color */
        border: none;
        color: rgba(255, 255, 255, 0.7); /* Semi-transparent white */
        font-size: 26px; /* Large and easy to hit */
        font-weight: bold;
        padding: 0;
        cursor: pointer;
        z-index: 2000; /* Ensures it sits ON TOP of your HUD/Map */
        line-height: 1;
        transition: all 0.2s ease;
    }

        /* Hover Effect */
        .close-overlay:hover {
            color: #ff3a3a; /* Bright red on hover */
            transform: scale(1.2);
        }
    /* HEADER STYLING */
    .header {
        height: 60px;
        z-index: 100;
        flex-shrink: 0;
        background: var(--panel-bg);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
    }

    /* Ensure these specific styles are present for the connection bar */
    .v-divider {
        width: 1px;
        height: 20px;
        background: #333;
        margin: 0 10px;
    }

    .status-indicator {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 5px;
    }

    .online {
        background: #00ff00;
        box-shadow: 0 0 8px #00ff00;
    }

    .offline {
        background: #ff0000;
    }

    .offline-blue {
        background: #2b58ff;
        color: white;
    }

    .online-red {
        background: #ff3a3a;
        color: white;
    }

    .brand-section {
        display: flex; /* Forces children (Logo and Sat-Count) to be side-by-side */
        align-items: center; /* Vertically aligns them in the center of the 60px header */
        gap: 15px; /* Space between logo and sat-count */
    }

    .logo {
        line-height: 0.8; /* Keeps the tagline close to the brand name */
    }

    .logo-text {
        background: linear-gradient(to right, #3a86ff, #ff00c8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 900;
        font-size: 1.6rem;
        letter-spacing: -0.5px;
        display: inline-block;
    }

    .tagline {
        font-size: 0.55rem;
        color: #888;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        margin-top: 4px;
    }

    .header-status-bar {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: nowrap;
    }

    .hdr-status-pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 8px;
        border-radius: 4px;
        font-size: 0.58rem;
        font-weight: 800;
        letter-spacing: 0.8px;
        border: 1px solid transparent;
        white-space: nowrap;
        transition: background 0.3s, border-color 0.3s, color 0.3s;
    }

    /* Telemetry */
    .pill-online {
        background: rgba(0,200,80,0.12);
        border-color: #2ea043;
        color: #3fb950;
    }

    .pill-offline {
        background: rgba(80,80,80,0.10);
        border-color: #484f58;
        color: #8b949e;
    }

    /* GPS */
    .pill-gps-fix {
        background: rgba(0,200,80,0.10);
        border-color: #2ea043;
        color: #3fb950;
    }

    .pill-gps-weak {
        background: rgba(210,153,34,0.12);
        border-color: #d29922;
        color: #e3a820;
    }

    .pill-gps-none {
        background: rgba(80,80,80,0.10);
        border-color: #484f58;
        color: #8b949e;
    }

    /* RC — green when bound, red when not (red = danger, not just absent) */
    .pill-rc-on {
        background: rgba(0,220,80,0.20);
        border-color: #00cc55;
        color: #00ee66;
    }

    .pill-rc-off {
        background: rgba(220,60,60,0.18);
        border-color: #cc3333;
        color: #ff6666;
    }

    /* Flight mode */
    .pill-mode {
        background: rgba(88,166,255,0.10);
        border-color: #58a6ff;
        color: #58a6ff;
    }

    /* Arm state */
    .pill-armed {
        background: rgba(248,81,73,0.15);
        border-color: #f85149;
        color: #ff8080;
    }

    .pill-disarmed {
        background: rgba(46,160,67,0.10);
        border-color: #2ea043;
        color: #3fb950;
    }

    .connection-controls {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .gcs-input {
        background: #08090b;
        border: 1px solid var(--border);
        color: white;
        padding: 5px 10px;
        border-radius: 4px;
        font-size: 0.8rem;
    }

    .divider {
        width: 1px;
        height: 25px;
        background: var(--border);
        margin: 0 10px;
    }

    .status-indicator {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .online {
        background: #00ff00;
        box-shadow: 0 0 10px #00ff00;
    }

    .offline {
        background: #ff0000;
    }

    .connect-btn {
        background: var(--accent-blue);
        color: white;
        border: none;
        padding: 8px 20px;
        border-radius: 4px;
        font-weight: bold;
        cursor: pointer;
    }

    /* VIEWPORT */
    .viewport {
        flex: 1;
        position: relative;
        z-index: 10;
        overflow: hidden;
    }

    /* MAP FULLSCREEN MODE ─────────────────────────────────────────────────
           When .map-fullscreen is on .gcs-wrapper, header and footer slide away
           and the viewport fills the entire screen. The map then reflows via JS. */
    .gcs-wrapper.map-fullscreen .header {
        transform: translateY(-100%);
        opacity: 0;
        pointer-events: none;
        transition: transform 0.3s ease, opacity 0.3s ease;
    }

    .gcs-wrapper.map-fullscreen .footer {
        transform: translateY(100%);
        opacity: 0;
        pointer-events: none;
        transition: transform 0.3s ease, opacity 0.3s ease;
    }

    .gcs-wrapper.map-fullscreen .viewport {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 900;
    }

    /* Drawer stays on top in fullscreen */
    .map-fullscreen-drawer {
        top: 0 !important;
        height: 100vh !important;
    }

    /* Header and footer get transitions always so collapse is smooth too */
    .header {
        transition: transform 0.3s ease, opacity 0.3s ease;
    }

    .footer {
        transition: transform 0.3s ease, opacity 0.3s ease;
    }

    /* FOOTER STYLING */
    .footer {
        background: var(--panel-bg); /* Was var(--bg-dark) in some versions, using panel for contrast */
        border-top: 1px solid var(--border);
        padding: 10px;
        display: flex;
        justify-content: center;
        z-index: 2000; /* Ensure it stays on top of the map */
        flex-shrink: 0; /* CRITICAL: Prevents footer from being squashed */
