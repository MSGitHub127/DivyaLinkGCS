@inherits LayoutComponentBase
@inject MavlinkService Drone
@implements IDisposable
@using System.IO.Ports
@using System.Linq

<div class="gcs-wrapper">
    <header class="header">
        <div class="brand-section">
            <div class="logo">
                <span class="logo-text">DIVYALINK</span>
                <div class="tagline">by Vayunotics</div>
            </div>
            <div class="sat-status">
                <span class="sat-icon">📡</span>
                <span>Sat-Count: @Drone.State.SatCount</span>
            </div>
        </div>

        <div class="connection-controls">
            <select class="gcs-input" @bind="selectedType">
                <option value="Serial">SERIAL</option>
                <option value="UDP">UDP</option>
                <option value="TCP">TCP</option>
            </select>

            @if (selectedType == "Serial")
            {
                <select class="gcs-input" @onchange="OnPortChanged" autocomplete="off">
                    <option value="" selected="@(string.IsNullOrEmpty(selectedPort))" disabled>-- Select Port --</option>

                    @foreach (var p in availablePorts)
                    {
                        <option value="@p" selected="@(p == selectedPort)">@p</option>
                    }
                </select>
            }
            else
            {
                <input class="gcs-input" @bind="selectedPort" placeholder="127.0.0.1" style="width:120px;" />
            }

            <select class="gcs-input" @bind="selectedBaud">
                <option value="57600">57600</option>
                <option value="115200">115200</option>
                <option value="14550">14550 (SITL)</option>
            </select>

            <div class="v-divider"></div>
            <span class="status-indicator @(IsConnected ? "online" : "offline")"></span>
            <button class="connect-btn @(isManualConnected ? "online-red" : "offline-blue")"
                    @onclick="ToggleConnection"
                    disabled="@isAttempting">
                @if (isAttempting)
                {
                    <span>VERIFYING...</span>
                }
                else
                {
                    @(isManualConnected ? "DISCONNECT" : "CONNECT")
                }
            </button>
        </div>
    </header>

    <main class="viewport">
        <CascadingValue Value="activeTab">
            @Body
        </CascadingValue>
    </main>

    <div class="gcs-drawer @(string.IsNullOrEmpty(activeTab) ? "" : "open")">
        <button class="close-overlay" @onclick='() => activeTab = ""'>&times;</button>
        <div class="drawer-content">
            @if (activeTab == "Quick")
            {
                <Quick />
            }
            @* Other tabs here *@
        </div>
    </div>

    <footer class="footer">
        <div class="sub-nav">
            @foreach (var tab in tabs)
            {
                <button class="nav-btn @(activeTab == tab ? "active" : "")"
                        @onclick="() => HandleTabClick(tab)">
                    <i class="cyan-icon">@GetIcon(tab)</i>
                    <span>@tab</span>
                </button>
            }
        </div>
    </footer>
</div>

<style>
    :root {
        --bg-dark: #0a0b0d;
        --panel-bg: #12141a;
        --border: #242731;
        --accent-blue: #2b58ff;
        --accent-purple: #7e3ff2;
        --cyan: #00f2ff;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', sans-serif;
    }

    .gcs-wrapper {
        display: flex;
        flex-direction: column;
        height: 100vh;
        background: var(--bg-dark);
        overflow: hidden; /* Prevents double scrollbars */
    }

    /* THE DRAWER (Left Side) */
    .gcs-drawer {
        position: fixed;
        top: 60px;
        /* FIX: Increased to 540px to fit the 500px content comfortably */
        width: 540px;
        left: -580px;
        height: calc(100vh - 120px);
        background: #0b0c10;
        border-right: 2px solid #7e3ff2;
        z-index: 1500;
        transition: left 0.3s ease-in-out;
        /* Keep the scrollbar always visible to prevent jumping */
        overflow-y: auto;
        overflow-x: hidden;
    }

    .gcs-drawer.open {
        left: 0; /* Slide in */
    }

    .drawer-content {
        min-width: 480px;
        padding: 10px; /* Slight padding so the X doesn't cover text immediately */
        box-sizing: border-box;
    }

    /* Sidebar Header Layout */
    .drawer-header {
        display: flex;
        justify-content: space-between; /* Pushes Title Left, X Right */
        align-items: center; /* Centers them vertically */
        padding: 15px 20px; /* Adds breathing room */
        background: #12141a; /* Darker header background */
        border-bottom: 1px solid #7e3ff2; /* Neon purple separator */
        min-height: 50px;
    }

        /* Title Styling */
    .drawer-header span {
        font-size: 1.1rem;
        font-weight: bold;
        color: white;
        letter-spacing: 1px;
    }

    .close-overlay {
        position: absolute; /* Floats over content */
        top: 5px;
        right: 5px;
        background: transparent; /* No background color */
        border: none;
        color: rgba(255, 255, 255, 0.7); /* Semi-transparent white */
        font-size: 26px; /* Large and easy to hit */
        font-weight: bold;
        padding: 0;
        cursor: pointer;
        z-index: 2000; /* Ensures it sits ON TOP of your HUD/Map */
        line-height: 1;
        transition: all 0.2s ease;
    }

        /* Hover Effect */
    .close-overlay:hover {
        color: #ff3a3a; /* Bright red on hover */
        transform: scale(1.2);
    }
    /* HEADER STYLING */
    .header {
        height: 60px;
        z-index: 100;
        flex-shrink: 0;
        background: var(--panel-bg);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
    }

    .brand-section {
        display: flex; /* Forces children (Logo and Sat-Count) to be side-by-side */
        align-items: center; /* Vertically aligns them in the center of the 60px header */
        gap: 15px; /* Space between logo and sat-count */
    }

    .logo {
        line-height: 0.8; /* Keeps the tagline close to the brand name */
    }

    .logo-text {
        background: linear-gradient(to right, #3a86ff, #ff00c8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 900;
        font-size: 1.6rem;
        letter-spacing: -0.5px;
        display: inline-block;
    }

    .tagline {
        font-size: 0.55rem;
        color: #888;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        margin-top: 4px;
    }

    .sat-status {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.8rem;
        color: #ddd;
        padding-bottom: 5px; /* Adjusts vertical "feeling" to match logo baseline */
    }

    .sat-icon {
        font-size: 1rem;
        color: #ffffff;
    }

    .connection-controls {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .gcs-input {
        background: #08090b;
        border: 1px solid var(--border);
        color: white;
        padding: 5px 10px;
        border-radius: 4px;
        font-size: 0.8rem;
    }

    .divider {
        width: 1px;
        height: 25px;
        background: var(--border);
        margin: 0 10px;
    }

    .status-indicator {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .online {
        background: #00ff00;
        box-shadow: 0 0 10px #00ff00;
    }

    .offline {
        background: #ff0000;
    }

    .connect-btn {
        background: var(--accent-blue);
        color: white;
        border: none;
        padding: 8px 20px;
        border-radius: 4px;
        font-weight: bold;
        cursor: pointer;
    }

    /* VIEWPORT */
    .viewport {
        flex: 1;
        position: relative;
        z-index: 10;
        overflow: hidden;
    }

    /* FOOTER STYLING */
    .footer {
        background: var(--panel-bg); /* Was var(--bg-dark) in some versions, using panel for contrast */
        border-top: 1px solid var(--border);
        padding: 10px;
        display: flex;
        justify-content: center;
        z-index: 2000; /* Ensure it stays on top of the map */
        flex-shrink: 0; /* CRITICAL: Prevents footer from being squashed */
    }

    .sub-nav {
        display: flex;
        gap: 10px;
        width: 100%;
        max-width: 1400px;
    }

    .nav-btn {
        flex: 1;
        background: #090a0c;
        border: 1px solid var(--border);
        border-radius: 6px;
        color: white;
        padding: 12px 5px;
        display: flex;
        flex-direction: column;
        align-items: center;
        cursor: pointer;
        transition: 0.2s;
    }

    .nav-btn i.cyan {
        color: var(--cyan);
        font-style: normal;
        margin-bottom: 5px;
    }

    .nav-btn span {
        font-size: 0.75rem;
    }

    .nav-btn.active {
        background: linear-gradient(135deg, var(--accent-blue) 0%, var(--accent-purple) 100%);
        border: none;
    }

    .nav-btn.active i {
        color: white;
    }
</style>

@code {
    private string activeTab = "";
    private string selectedType = "Serial";
    private string selectedPort = "";
    private int selectedBaud = 57600;
    private List<string> availablePorts = new();
    private System.Threading.Timer? _autoDetectTimer;
    // This is the key: It returns all ports EXCEPT the one we are using/just used
    private IEnumerable<string> FilteredPorts => availablePorts
        .Where(p => p != selectedPort);
    private bool isManualConnected = false; // Tracks the button state

    private string ConnectionButtonText => isManualConnected ? "DISCONNECT" : "CONNECT";
    private string ConnectionButtonClass => isManualConnected ? "btn-disconnect" : "btn-connect";

    private string[] tabs = { "Quick", "Actions", "Messages", "FlightPlan", "Pre Flight", "Setup" };
    private bool IsConnected => Drone.State.ConnectionStatus.Contains("Receiving");

    private bool isAttempting = false;

    // A connection is only "Online" if MAVLink data is flowing
    private bool IsDroneActuallyTalking =>
        Drone.IsConnected && (DateTime.UtcNow - Drone.State.LastHeartbeat).TotalSeconds < 3;

    // Explicit handler to lock the value immediately when you click
    private void OnPortChanged(ChangeEventArgs e)
    {
        selectedPort = e.Value?.ToString() ?? "";
        StateHasChanged(); // Force UI to update immediately
    }

    protected override void OnInitialized()
    {
        _autoDetectTimer = new System.Threading.Timer(async _ =>
        {
            // 1. Get ONLY what is physically plugged in right now
            var currentPhysicalPorts = SerialPort.GetPortNames().Distinct().ToList();

            // 2. Clear the internal list and rebuild it from scratch
            // This prevents "History" from sticking around
            if (!currentPhysicalPorts.OrderBy(x => x).SequenceEqual(availablePorts.OrderBy(x => x)))
            {
                availablePorts = currentPhysicalPorts;

                // 3. If the selected port was unplugged, wipe the selection
                if (!string.IsNullOrEmpty(selectedPort) && !availablePorts.Contains(selectedPort))
                {
                    selectedPort = "";
                    Drone.StopConnection();
                    isManualConnected = false;
                }

                await InvokeAsync(StateHasChanged);
            }

            // 4. HEARTBEAT CHECK: If it's plugged in but "Ghosting" (No Heartbeat)
            if (isManualConnected && !Drone.IsConnected)
            {
                var deadPort = selectedPort;
                Drone.StopConnection();
                selectedPort = "";
                isManualConnected = false;

                // Remove it so it doesn't show in the dropdown anymore
                availablePorts.Remove(deadPort);
                await InvokeAsync(StateHasChanged);
            }
        }, null, 0, 1000);
    }

    private async Task ToggleConnection()
    {
        if (isManualConnected)
        {
            // DISCONNECT
            Drone.StopConnection();
            availablePorts.Clear();
            selectedPort = ""; // This clears the dropdown selection
            isManualConnected = false;
            isAttempting = false;

            await InvokeAsync(StateHasChanged);
        }
        else
        {
            // CONNECT
            if (string.IsNullOrEmpty(selectedPort)) return;

            isAttempting = true;
            Drone.Connect(Enum.Parse<ConnectionType>(selectedType), selectedPort, selectedBaud);

            // Wait 3 seconds to see if a heartbeat arrives
            await Task.Delay(3000);

            if (IsDroneActuallyTalking)
            {
                isManualConnected = true;
                // This tells the Pixhawk: "Please send me Altitude, Attitude, and Battery info!"
                Drone.RequestDataStreams();
            }
            else
            {
                // It's a ghost port (like COM1) or wrong Baud Rate
                Drone.StopConnection();
                isManualConnected = false;
            }
            isAttempting = false;
        }
    }

    private string GetIcon(string t) => t switch
    {
        "Quick" => "⚡",
        "Actions" => "⚙️",
        "Messages" => "✉️",
        "FlightPlan" => "✈️",
        "Pre Flight" => "✈️",
        "Setup" => "🛠️",
        _ => "❓"
    };

    public void Dispose() => _autoDetectTimer?.Dispose();

    private void HandleTabClick(string tab)
    {
        if (tab == "Quick")
        {
            // If it's already open, clicking again closes it (Toggle)
            activeTab = (activeTab == "Quick") ? "" : "Quick";
        }
        else
        {
            // For now, other buttons just close the sidebar
            // until we build their specific panels
            activeTab = "";
            Console.WriteLine($"Clicked {tab} - Logic coming soon");
        }
    }
}

