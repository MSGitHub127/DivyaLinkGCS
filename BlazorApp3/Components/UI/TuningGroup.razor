@using BlazorApp3.Services
@using BlazorApp3.Models

<div class="bg-[#0d1117] border border-[#30363d] rounded-[8px] flex flex-col w-full transition-colors duration-200 shrink-0 hover:border-[#58a6ff]">

    @* ── Interactive Group Header ── *@
    <div class="px-[14px] py-[12px] flex items-center gap-[8px] cursor-pointer select-none transition-all duration-200 hover:bg-[rgba(255,255,255,0.03)] @(_isGroupExpanded ? "border-b border-[#30363d] rounded-t-[8px]" : "rounded-[8px]")" 
         @onclick="() => _isGroupExpanded = !_isGroupExpanded">
        <i class="bi @Icon text-[#58a6ff] text-[0.85rem]"></i>
        <span class="text-[0.75rem] font-bold text-[#e6edf3] uppercase tracking-widest">
            @Title
        </span>
        <div class="flex-1"></div>
        <i class="bi @(_isGroupExpanded ? "bi-chevron-up text-[#58a6ff] rotate-180" : "bi-chevron-down text-[#8b949e]") text-[0.75rem] transition-all duration-200"></i>
    </div>

    @* ── Parameter rows (Toggled by header state) ── *@
    @if (_isGroupExpanded)
    {
        <div class="flex flex-col divide-y divide-[#21262d] bg-[#161b22]/50 rounded-b-[8px]">
            @foreach (var p in Params)
            {
                var (label, modern, legacy, unit, step) = p;

                string activeKey = modern;
                if (ParamManager != null)
                {
                    if (!ParamManager.GetValue(modern).HasValue && legacy != null && ParamManager.GetValue(legacy).HasValue)
                    {
                        activeKey = legacy;
                    }
                }

                float currentVal = TuningValues.TryGetValue(activeKey, out var tv) ? tv : ParamManager?.GetValue(activeKey) ?? 0f;
                bool isDirty = DirtyParams.Contains(activeKey);
                var capturedKey = activeKey;
                var capturedLegacy = legacy;

                <div class="flex items-center px-[14px] py-[12px] gap-[12px] hover:bg-[#1c2128] transition-colors group">

                    @* Label + parameter name *@
                    <div class="flex-1 min-w-0">
                        <div class="text-[0.8rem] font-semibold text-[#e6edf3]">@label</div>
                        <div class="text-[0.65rem] text-[#8b949e] font-mono mt-[2px]">
                            @activeKey
                            @if (legacy != null && activeKey == legacy)
                            {
                                <span class="text-[#f0b429] ml-[4px]">(legacy)</span>
                            }
                        </div>
                    </div>

                    @* Number input + unit + per-row write button *@
                    <div class="flex items-center gap-[8px]">
                        <input type="number"
                               step="@step.ToString("G6", System.Globalization.CultureInfo.InvariantCulture)"
                               value="@currentVal.ToString("G6", System.Globalization.CultureInfo.InvariantCulture)"
                               class="w-[90px] bg-[#010409] border text-right font-mono
                                      rounded-[6px] px-[8px] py-[6px] text-[0.8rem] text-white
                                      focus:outline-none focus:border-[#58a6ff] transition-colors
                                      @(isDirty ? "border-[#f0b429]" : "border-[#30363d]")"
                                  @onchange="@(e => {
                                      if (float.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out float v))
                                      {
                                          OnParamChanged(capturedKey, capturedLegacy, v);
                                      }
                                  })" />

                        @if (!string.IsNullOrEmpty(unit))
                        {
                            <span class="text-[0.65rem] text-[#8b949e] w-[32px]">@unit</span>
                        }

                        @* Per-row write button *@
                        <button class="opacity-0 group-hover:opacity-100 transition-all duration-200
                                       text-[0.6rem] px-[8px] py-[5px] rounded-[4px]
                                       bg-[#238636] hover:bg-[#2ea043] text-white
                                       border-none cursor-pointer font-bold tracking-widest"
                                title="Write to Flight Controller"
                                @onclick="() => OnWrite(capturedKey, capturedLegacy)">
                            WRITE
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private bool _isGroupExpanded = false;

    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Icon { get; set; } = string.Empty;
    [Parameter, EditorRequired] public (string Label, string Modern, string? Legacy, string Unit, float Step)[] Params { get; set; } = Array.Empty<(string, string, string?, string, float)>();
    [Parameter, EditorRequired] public Dictionary<string, float> TuningValues { get; set; } = new();
    [Parameter, EditorRequired] public HashSet<string> DirtyParams { get; set; } = new();
    [Parameter, EditorRequired] public Action<string, string?, float> OnParamChanged { get; set; } = default!;
    [Parameter, EditorRequired] public Func<string, string?, Task> OnWrite { get; set; } = default!;
    [Parameter] public ParameterManager? ParamManager { get; set; }
}