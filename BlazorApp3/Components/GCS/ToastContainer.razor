@inject MavlinkService Drone
@implements IDisposable
@using System.Collections.Concurrent

@if (_toasts.Count > 0)
{
    <div class="fixed bottom-[70px] right-[16px] left-auto z-[9999] flex flex-col gap-[8px] pointer-events-none max-w-[360px]">
        @foreach (var t in _toasts.Values.OrderBy(x => x.CreatedAt))
        {
            <div class="flex items-start gap-[9px] p-[10px_13px] rounded-[7px] border-l-[3px] backdrop-blur-[8px] text-[0.68rem] font-semibold leading-[1.4] pointer-events-auto shadow-[0_4px_18px_rgba(0,0,0,0.5)] min-w-[260px] relative overflow-hidden @GetColorClasses(t.Level) @(t.Exiting ? "toast-exit" : "toast-enter")">
                <span class="text-[0.95rem] shrink-0 mt-[1px]">@t.Icon</span>
                <span class="flex-1">@t.Text</span>
                <button class="bg-transparent border-none text-inherit opacity-45 text-[1rem] leading-none cursor-pointer pl-[4px] shrink-0 transition-opacity duration-150 hover:opacity-100" @onclick="() => Remove(t.Id)">×</button>
            </div>
        }
    </div>
}

<style>
    .toast-enter {
        animation: toastIn 0.25s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .toast-exit {
        animation: toastOut 0.18s ease-in both;
    }
    @@keyframes toastIn {
        from {
            opacity: 0;
            transform: translateX(24px) scale(0.96);
        }

        to {
            opacity: 1;
            transform: translateX(0) scale(1);
        }
    }
    @@keyframes toastOut {
        from {
            opacity: 1;
            transform: translateX(0) scale(1);
            max-height: 80px;
            margin-bottom: 0;
        }

        to {
            opacity: 0;
            transform: translateX(20px) scale(0.95);
            max-height: 0;
            margin-bottom: -8px;
        }
    }
</style>

@code {
    private class ToastEntry
    {
        public Guid Id { get; } = Guid.NewGuid();
        public string Text { get; set; } = "";
        public MavlinkService.ToastLevel Level { get; set; }
        public string Icon { get; set; } = "ℹ️";
        public DateTime CreatedAt { get; } = DateTime.UtcNow;
        public bool Exiting { get; set; }
        public System.Threading.Timer? Timer { get; set; }
    }

    private readonly ConcurrentDictionary<Guid, ToastEntry> _toasts = new();
    private bool _disposed = false;

    protected override void OnInitialized()
    {
        Drone.OnToast += HandleToast;
    }

    private string GetColorClasses(MavlinkService.ToastLevel level) => level switch
    {
        MavlinkService.ToastLevel.Success => "bg-[rgba(14,24,16,0.95)] border-l-[#3fb950] text-[#aff7bc]",
        MavlinkService.ToastLevel.Warning => "bg-[rgba(26,22,10,0.95)] border-l-[#d29922] text-[#f0c060]",
        MavlinkService.ToastLevel.Error => "bg-[rgba(26,10,10,0.95)] border-l-[#f85149] text-[#ffa8a4]",
        _ => "bg-[rgba(18,22,30,0.95)] border-l-[#58a6ff] text-[#c9d1d9]"
    };

    private void HandleToast(MavlinkService.ToastMessage msg)
    {
        if (_disposed) return;

        var entry = new ToastEntry
        {
            Text = msg.Text,
            Level = msg.Level,
            Icon = msg.Icon ?? msg.Level switch
            {
                MavlinkService.ToastLevel.Success => "✅",
                MavlinkService.ToastLevel.Warning => "⚠️",
                MavlinkService.ToastLevel.Error => "❌",
                _ => "ℹ️"
            }
        };

        // Auto-dismiss timer: errors stay 8s, warnings 6s, others 4s
        double dismissMs = msg.Level switch
        {
            MavlinkService.ToastLevel.Error => 8000,
            MavlinkService.ToastLevel.Warning => 6000,
            _ => 4000
        };

        entry.Timer = new System.Threading.Timer(_ => BeginExit(entry.Id), null,
                          (int)dismissMs, System.Threading.Timeout.Infinite);

        _toasts[entry.Id] = entry;
        InvokeAsync(StateHasChanged);
    }

    private void BeginExit(Guid id)
    {
        if (_disposed) return;
        if (_toasts.TryGetValue(id, out var t))
        {
            t.Exiting = true;
            try { InvokeAsync(StateHasChanged); } catch { return; }
            t.Timer?.Dispose();
            t.Timer = new System.Threading.Timer(_ => Remove(id), null, 200, System.Threading.Timeout.Infinite);
        }
    }

    private void Remove(Guid id)
    {
        if (_disposed) return;
        if (_toasts.TryRemove(id, out var t))
            t.Timer?.Dispose();
        try { InvokeAsync(StateHasChanged); } catch { }
    }

    public void Dispose()
    {
        _disposed = true;
        Drone.OnToast -= HandleToast;
        foreach (var t in _toasts.Values) t.Timer?.Dispose();
        _toasts.Clear();
    }
}