@page "/messages"
@inject MavlinkService Drone
@inject IJSRuntime JS
@implements IDisposable

<div class="messages-view-container">

    <div class="hud-wrapper">
        <Hud />
    </div>

    <div class="console-section">
        <div class="header-strip">
            <span class="icon">📟</span> SYSTEM TERMINAL (@Drone.StatusMessages.Count)
        </div>

        <div id="terminal-scroll" class="console-window" @ref="_consoleWindow">
            @if (Drone.StatusMessages.Count == 0)
            {
                <div class="empty-state">
                    <span class="pulse-dot"></span>
                    WAITING FOR SYSTEM DATA...
                </div>
            }
            else
            {
                <div class="log-list">
                    @foreach (var msg in Drone.GetSafeStatusMessages())
                    {
                        @* Logic to highlight Arming/PreArm failures in Red *@
                        <div class="log-entry @(msg.Contains("Arm") ? "critical-log" : "")">
                            @msg
                        </div>
                    }
                </div>
            }
        </div>

        <button class="action-btn-clear" @onclick="ClearLogs">
            CLEAR SYSTEM LOGS
        </button>
    </div>
</div>

<style>
    /* Main container matches the width of your other drawer components [cite: 31] */
    .messages-view-container {
        display: flex;
        flex-direction: column;
        height: 100%;
        gap: 16px;
        padding: 20px;
        background: transparent;
        width: 100%;
        max-width: 500px;
        margin: 0 auto;
        overflow: hidden;
    }

    /* HUD WRAPPER: Exact dimensions from Quick/Actions [cite: 33, 34] */
    .hud-wrapper {
        height: 300px;
        width: 100%;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.4);
        border: 1px solid #333;
        flex-shrink: 0;
    }

    .console-section {
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        gap: 10px;
        min-height: 0;
    }

    .header-strip {
        background: rgba(18, 20, 28, 0.8);
        border: 1px solid rgba(0, 242, 255, 0.2);
        border-radius: 6px;
        padding: 8px;
        text-align: center;
        color: #00f2ff;
        font-weight: 800;
        font-size: 0.85rem;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        backdrop-filter: blur(4px);
    }

    .console-window {
        flex-grow: 1;
        background: rgba(5, 5, 10, 0.9);
        border: 1px solid #222;
        border-radius: 6px;
        padding: 12px;
        overflow-y: auto;
        font-family: 'Consolas', 'Courier New', monospace;
        box-shadow: inset 0 0 15px rgba(0,0,0,0.8);
    }

    .log-entry {
        font-size: 0.85rem;
        color: #00ff00; /* Terminal Green [cite: 41] */
        border-bottom: 1px solid #111;
        padding-bottom: 4px;
        line-height: 1.4;
    }

        .log-entry.critical-log {
            color: #ff3a3a; /* Highlight critical errors in Red */
            font-weight: bold;
        }

    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: #444;
        font-size: 0.8rem;
    }

    .pulse-dot {
        width: 8px;
        height: 8px;
        background: #444;
        border-radius: 50%;
        margin-bottom: 10px;
        animation: pulse 1.5s infinite;
    }

    @@keyframes pulse {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.3;
        }

        100% {
            opacity: 1;
        }
    }

    .action-btn-clear {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid #333;
        color: #888;
        padding: 8px;
        border-radius: 4px;
        font-size: 0.7rem;
        cursor: pointer;
    }
</style>

@code {
    private ElementReference _consoleWindow;
    private bool _shouldScroll = false;

    protected override void OnInitialized()
    {
        Drone.OnMessageReceived += RefreshUi;
    }

    private void RefreshUi(string msg)
    {
        _shouldScroll = true;
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldScroll || firstRender)
        {
            _shouldScroll = false;
            try
            {
                // Instant jump — no animation, matches terminal/MAVLink log behaviour
                await JS.InvokeVoidAsync("eval",
                    "var el=document.getElementById('terminal-scroll'); if(el) el.scrollTop=el.scrollHeight;");
            }
            catch { }
        }
    }

    private void ClearLogs()
    {
        lock (Drone.StatusMessages) { Drone.StatusMessages.Clear(); }
        // _shouldScroll = true;
        StateHasChanged();
    }

    public void Dispose() => Drone.OnMessageReceived -= RefreshUi;
}