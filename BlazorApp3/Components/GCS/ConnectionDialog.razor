@inject MavlinkService Drone
@implements IDisposable

@if (_isOpen)
{
    <div class="conn-overlay">
        <div class="conn-box @(_isError ? "error-box" : "")">

            @if (_isError)
            {
                <div class="icon-area error-anim">⚠️</div>
            }
            else
            {
                <div class="spinner"></div>
            }

            <div class="conn-title">
                @(_isError ? "CONNECTION FAILED" : "CONNECTING TO DRONE")
            </div>

            <div class="conn-status @(_isError ? "text-red" : "")">
                @_statusMessage
            </div>

            <div class="btn-row">
                @if (_isError)
                {
                    <button class="action-btn close-btn" @onclick="ForceClose">CLOSE</button>
                }
                else
                {
                    <button class="action-btn cancel-btn" @onclick="UserCancel">CANCEL</button>
                }
            </div>
        </div>
    </div>
}

<style>
    /* 1. OVERLAY: Dark & Blurred */
    .conn-overlay {
        position: fixed;
        inset: 0;
        background: rgba(5, 6, 8, 0.85);
        backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 99999;
        animation: fadeIn 0.2s ease-out;
    }

    /* 2. MAIN BOX */
    .conn-box {
        width: 380px;
        background: #0b0c10;
        border: 1px solid #2b58ff; /* Default Blue */
        border-radius: 8px;
        padding: 30px 20px;
        box-shadow: 0 0 50px rgba(43, 88, 255, 0.15);
        text-align: center;
        color: white;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 15px;
        transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }

        /* ERROR STATE */
        .conn-box.error-box {
            border-color: #ff3a3a;
            box-shadow: 0 0 50px rgba(255, 58, 58, 0.2);
        }

    /* 3. ANIMATIONS & ICONS */
    .spinner {
        width: 45px;
        height: 45px;
        border: 3px solid rgba(0, 242, 255, 0.1);
        border-top: 3px solid #00f2ff;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    .icon-area {
        font-size: 3rem;
        line-height: 1;
    }

    .error-anim {
        animation: popIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    /* 4. TEXT */
    .conn-title {
        font-weight: 800;
        font-size: 1.1rem;
        letter-spacing: 1px;
    }

    .conn-status {
        font-family: 'Consolas', monospace;
        font-size: 0.9rem;
        color: #888;
        min-height: 1.2em;
    }

    .text-red {
        color: #ff3a3a;
        font-weight: bold;
    }

    /* 5. BUTTONS */
    .btn-row {
        margin-top: 10px;
        display: flex;
        gap: 10px;
    }

    .action-btn {
        padding: 8px 25px;
        border-radius: 4px;
        cursor: pointer;
        font-weight: bold;
        font-size: 0.8rem;
        transition: 0.2s;
        text-transform: uppercase;
    }

    .cancel-btn {
        background: transparent;
        border: 1px solid #555;
        color: #ccc;
    }

        .cancel-btn:hover {
            border-color: white;
            color: white;
        }

    .close-btn {
        background: #3a0d0d;
        border: 1px solid #ff3a3a;
        color: #ff3a3a;
    }

        .close-btn:hover {
            background: #ff3a3a;
            color: white;
        }

    .hud-container.link-dead {
        border: 3px solid #ff3a3a;
        animation: flash-red 1s infinite;
    }

    /* Fix for Line 164 (and others) in ConnectionDialog.razor */
    @@keyframes spin {
        100% {
            transform: rotate(360deg);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes popIn {
        from {
            transform: scale(0);
        }

        to {
            transform: scale(1);
        }
    }

    /* If you added the HUD flash alert, do the same there: */
    @@keyframes flash-red {
        0% {
            opacity: 1;
            border-color: rgba(255, 58, 58, 1);
        }

        50% {
            opacity: 0.5;
            border-color: rgba(255, 58, 58, 0.2);
        }

        100% {
            opacity: 1;
            border-color: rgba(255, 58, 58, 1);
        }
    }
</style>

@code {
    // State
    private bool _isOpen = false;
    private bool _isError = false;
    private bool _heartbeatReceived = false;
    private bool _userCancelled = false;
    private DateTime _heartbeatConfirmedAt = DateTime.MinValue;
    private string _statusMessage = "Initializing...";

    protected override void OnInitialized()
    {
        Drone.OnConnectionDialog += HandleDialogSignal;
        Drone.OnConnectionStatus += UpdateStatusMessage;
        Drone.OnTelemetryUpdated += CheckForValidData;
    }

    // Called by service: true = open dialog, false = close/update
    private void HandleDialogSignal(bool show)
    {
        if (show)
        {
            // Fresh open — reset everything
            _isOpen = true;
            _isError = false;
            _heartbeatReceived = false;
            _userCancelled = false;
            _heartbeatConfirmedAt = DateTime.MinValue;
            _statusMessage = Drone.IsWireless
                                    ? "Searching for telemetry radio..."
                                    : "Initializing...";
        }
        else
        {
            if (_userCancelled)
            {
                _isOpen = false;
            }
            else if (Drone.IsConnected)
            {
                // Service confirmed link is stable — mark heartbeat received,
                // CheckForValidData will close the dialog once telemetry flows.
                _heartbeatReceived = true;
            }
            else if (!_heartbeatReceived)
            {
                // Timed out before getting any heartbeat
                _isError = true;
                _statusMessage = Drone.IsWireless
                                   ? "No response from telemetry radio"
                                   : "Connection timed out";
            }
            else
            {
                _isOpen = false;
            }
        }
        InvokeAsync(StateHasChanged);
    }

    // Status text from service ("Opening COM7 @ 57600...")
    private void UpdateStatusMessage(string msg)
    {
        if (_isError) return;
        _statusMessage = msg;
        InvokeAsync(StateHasChanged);
    }

    // Fired every time telemetry arrives — decides when to actually close
    private void CheckForValidData()
    {
        if (!_isOpen || _isError || !_heartbeatReceived) return;

        // Stamp when heartbeat was first confirmed this connect attempt
        if (_heartbeatConfirmedAt == DateTime.MinValue)
        {
            _heartbeatConfirmedAt = DateTime.UtcNow;
            _statusMessage = Drone.IsWireless
                ? "Radio link confirmed ✅ — loading telemetry..."
                : "Connected ✅";
            InvokeAsync(StateHasChanged);
        }

        // Close as soon as any real telemetry arrives
        bool hasTelemetry = Drone.State.Roll != 0
                         || Drone.State.Altitude != 0
                         || Drone.State.SatCount > 0
                         || Drone.State.Voltage > 0;

        // Fallback: close after grace period even if bench drone shows all-zero
        double grace = Drone.IsWireless ? 5.0 : 2.0;
        bool graceUp = (DateTime.UtcNow - _heartbeatConfirmedAt).TotalSeconds > grace;

        if (hasTelemetry || graceUp)
        {
            _isOpen = false;
            InvokeAsync(StateHasChanged);
        }
    }

    private void UserCancel()
    {
        _userCancelled = true;
        Drone.StopConnection();
        _isOpen = false;
        InvokeAsync(StateHasChanged);
    }

    private void ForceClose()
    {
        _isOpen = false;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Drone.OnConnectionDialog -= HandleDialogSignal;
        Drone.OnConnectionStatus -= UpdateStatusMessage;
        Drone.OnTelemetryUpdated -= CheckForValidData;
    }
}