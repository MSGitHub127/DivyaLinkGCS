@page "/quick"
@inject MavlinkService Drone
@implements IDisposable

<div class="flex flex-col h-full gap-[16px] p-[20px] bg-transparent w-full max-w-[500px] mx-auto">

    <div class="h-[300px] w-full rounded-[8px] overflow-hidden shadow-[0_4px_20px_rgba(0,0,0,0.4)] border border-[#333] shrink-0">
        <Hud />
    </div>

    <div class="grid grid-cols-3 gap-[8px] w-full">

        @* FLIGHT MODE CARD (Updated for strict boundary limits) *@
        <div class="bg-[rgba(18,20,28,0.8)] border border-[rgba(255,255,255,0.15)] rounded-[6px] py-[10px] px-[8px] flex flex-col items-center justify-center min-h-[70px] backdrop-blur-[4px] overflow-hidden">
            <div class="text-[0.65rem] font-bold text-[#6c757d] tracking-[0.5px] mb-1 uppercase text-center w-full truncate">FLIGHT MODE</div>
            <div class="flex flex-col items-center w-full min-w-0">
                <div class="text-[1rem] font-extrabold uppercase mb-1 drop-shadow-[0_0_10px_rgba(0,0,0,0.5)] w-full text-center truncate" style="color: @GetModeColor(Drone.State.FlightMode);">
                    @(Drone.State.FlightMode == "Unknown" ? "--" : Drone.State.FlightMode)
                </div>
                <div class="flex items-stretch justify-center gap-[4px] w-full mt-[4px] h-[26px]">
                    <select class="min-w-0 flex-1 bg-[rgba(0,0,0,0.5)] text-[#aaa] border border-[#444] rounded-[4px] text-[0.65rem] px-1 cursor-pointer outline-none h-full box-border hover:border-[#00f2ff] hover:text-white transition-colors [&>option]:bg-[#0b0c10]" @bind="targetFlightMode">
                        <option value="" disabled>MODE</option>
                        <option value="STABILIZE">STABILIZE</option>
                        <option value="LOITER">LOITER</option>
                        <option value="ALT_HOLD">ALT HOLD</option>
                        <option value="RTL">RTL</option>
                        <option value="LAND">LAND</option>
                        <option value="AUTO">AUTO</option>
                        <option value="GUIDED">GUIDED</option>
                    </select>
                    <button class="shrink-0 flex items-center justify-center px-2 text-[0.65rem] rounded-[4px] border-none bg-[#2b58ff] text-white font-bold cursor-pointer h-full box-border hover:brightness-120 transition-all" @onclick="ChangeFlightMode">SET</button>
                </div>
            </div>
        </div>

        <div class="bg-[rgba(18,20,28,0.6)] border border-[rgba(255,255,255,0.08)] rounded-[6px] py-[10px] px-[8px] flex flex-col items-center justify-center min-h-[70px] backdrop-blur-[4px]">
            <div class="text-[0.65rem] font-bold text-[#6c757d] tracking-[0.5px] mb-1 uppercase">ALTITUDE</div>
            <div class="flex items-baseline gap-[2px] text-[#e0e0e0]">
                <span class="text-[1.2rem] font-semibold font-mono">@Drone.State.Altitude.ToString("0.0")</span>
                <span class="text-[0.7rem] text-[#888] font-normal">m</span>
            </div>
        </div>

        <div class="bg-[rgba(18,20,28,0.6)] border border-[rgba(255,255,255,0.08)] rounded-[6px] py-[10px] px-[8px] flex flex-col items-center justify-center min-h-[70px] backdrop-blur-[4px]">
            <div class="text-[0.65rem] font-bold text-[#6c757d] tracking-[0.5px] mb-1 uppercase">HEADING</div>
            <div class="flex items-baseline gap-[2px] text-[#e0e0e0]">
                <span class="text-[1.2rem] font-semibold font-mono">@Drone.State.Yaw.ToString("0")</span>
                <span class="text-[0.7rem] text-[#888] font-normal">deg</span>
            </div>
        </div>

        <div class="bg-[rgba(18,20,28,0.6)] border border-[rgba(255,255,255,0.08)] rounded-[6px] py-[10px] px-[8px] flex flex-col items-center justify-center min-h-[70px] backdrop-blur-[4px]">
            <div class="text-[0.65rem] font-bold text-[#6c757d] tracking-[0.5px] mb-1 uppercase">BATTERY</div>
            <div class="flex items-baseline gap-[2px] @(Drone.State.BatteryPercent < 20 ? "text-[#ff3a3a]" : "text-[#00ff00]")">
                <span class="text-[1.2rem] font-semibold font-mono">@Drone.State.BatteryPercent</span>
                <span class="text-[0.7rem] text-[#888] font-normal">%</span>
            </div>
        </div>

        <div class="bg-[rgba(18,20,28,0.6)] border border-[rgba(255,255,255,0.08)] rounded-[6px] py-[10px] px-[8px] flex flex-col items-center justify-center min-h-[70px] backdrop-blur-[4px]">
            <div class="text-[0.65rem] font-bold text-[#6c757d] tracking-[0.5px] mb-1 uppercase">SATELLITES</div>
            <div class="flex items-baseline gap-[2px] text-[#e0e0e0]">
                <span class="text-[1.2rem] font-semibold font-mono">@(Drone.State.SatCount > 0 ? Drone.State.SatCount : "--")</span>
                <span class="text-[0.7rem] text-[#888] font-normal">sats</span>
            </div>
        </div>

        <div class="bg-[rgba(18,20,28,0.6)] border border-[rgba(255,255,255,0.08)] rounded-[6px] py-[10px] px-[8px] flex flex-col items-center justify-center min-h-[70px] backdrop-blur-[4px]">
            <div class="text-[0.65rem] font-bold text-[#6c757d] tracking-[0.5px] mb-1 uppercase">SPEED</div>
            <div class="flex items-baseline gap-[2px] text-[#e0e0e0]">
                <span class="text-[1.2rem] font-semibold font-mono">@Drone.State.GroundSpeed.ToString("0.0")</span>
                <span class="text-[0.7rem] text-[#888] font-normal">m/s</span>
            </div>
        </div>

        <div class="bg-[rgba(18,20,28,0.6)] border border-[rgba(255,255,255,0.08)] rounded-[6px] py-[10px] px-[8px] flex flex-col items-center justify-center min-h-[70px] backdrop-blur-[4px]">
            <div class="text-[0.65rem] font-bold text-[#6c757d] tracking-[0.5px] mb-1 uppercase">VOLTAGE</div>
            <div class="flex items-baseline gap-[2px] text-[#e0e0e0]">
                <span class="text-[1.2rem] font-semibold font-mono">@Drone.State.Voltage.ToString("0.0")</span>
                <span class="text-[0.7rem] text-[#888] font-normal">V</span>
            </div>
        </div>

        <div class="bg-[rgba(18,20,28,0.6)] border border-[rgba(255,255,255,0.08)] rounded-[6px] py-[10px] px-[8px] flex flex-col items-center justify-center min-h-[70px] backdrop-blur-[4px]">
            <div class="text-[0.65rem] font-bold text-[#6c757d] tracking-[0.5px] mb-1 uppercase">LATITUDE</div>
            <div class="flex items-baseline gap-[2px] text-[#e0e0e0]">
                <span class="text-[0.9rem] font-semibold font-mono">@Drone.State.Latitude.ToString("F6")</span>
            </div>
        </div>

        <div class="bg-[rgba(18,20,28,0.6)] border border-[rgba(255,255,255,0.08)] rounded-[6px] py-[10px] px-[8px] flex flex-col items-center justify-center min-h-[70px] backdrop-blur-[4px]">
            <div class="text-[0.65rem] font-bold text-[#6c757d] tracking-[0.5px] mb-1 uppercase">LONGITUDE</div>
            <div class="flex items-baseline gap-[2px] text-[#e0e0e0]">
                <span class="text-[0.9rem] font-semibold font-mono">@Drone.State.Longitude.ToString("F6")</span>
            </div>
        </div>

        <div class="bg-[rgba(18,20,28,0.6)] border border-[rgba(255,255,255,0.08)] rounded-[6px] py-[10px] px-[8px] flex flex-col items-center justify-center min-h-[70px] backdrop-blur-[4px]">
            <div class="text-[0.65rem] font-bold text-[#6c757d] tracking-[0.5px] mb-1 uppercase">ACCELEROMETER</div>
            <div class="flex items-baseline gap-[2px] @GetCalColor(Drone.LiveAccelStatus)">
                <span class="text-[0.9rem] font-semibold font-mono">@GetCalDisplayText(Drone.LiveAccelStatus)</span>
            </div>
        </div>

        <div class="bg-[rgba(18,20,28,0.6)] border border-[rgba(255,255,255,0.08)] rounded-[6px] py-[10px] px-[8px] flex flex-col items-center justify-center min-h-[70px] backdrop-blur-[4px]">
            <div class="text-[0.65rem] font-bold text-[#6c757d] tracking-[0.5px] mb-1 uppercase">GYROSCOPE</div>
            <div class="flex items-baseline gap-[2px] @GetCalColor(Drone.LiveGyroStatus)">
                <span class="text-[0.9rem] font-semibold font-mono">@GetCalDisplayText(Drone.LiveGyroStatus)</span>
            </div>
        </div>

        <div class="bg-[rgba(18,20,28,0.6)] border border-[rgba(255,255,255,0.08)] rounded-[6px] py-[10px] px-[8px] flex flex-col items-center justify-center min-h-[70px] backdrop-blur-[4px]">
            <div class="text-[0.65rem] font-bold text-[#6c757d] tracking-[0.5px] mb-1 uppercase">MAGNETOMETER</div>
            <div class="flex items-baseline gap-[2px] @GetCalColor(Drone.LiveMagStatus)">
                <span class="text-[0.9rem] font-semibold font-mono">@GetCalDisplayText(Drone.LiveMagStatus)</span>
            </div>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized() => Drone.OnTelemetryUpdated += RefreshUi;
    private DateTime _lastUiUpdate = DateTime.MinValue;
    private void RefreshUi()
    {
        var now = DateTime.UtcNow;
        // Throttle UI updates to 10Hz (100ms).
        // The human eye can't read numbers changing faster than this anyway!
        if ((now - _lastUiUpdate).TotalMilliseconds < 100) return;
        _lastUiUpdate = now;

        InvokeAsync(StateHasChanged);
    }
    public void Dispose() => Drone.OnTelemetryUpdated -= RefreshUi;

    private void HandleArmClick() => Drone.SendArmRequest(!Drone.State.IsArmed);

    private void ChangeMode(ChangeEventArgs e)
    {
        if (e.Value is string s && !string.IsNullOrEmpty(s)) Drone.SetFlightMode(s);
    }

    private string GetModeColor(string mode) => mode.ToUpper() switch
    {
        "RTL" or "LAND" => "#ff3a3a",
        "LOITER" or "POSHOLD" => "#00ff00",
        "AUTO" or "GUIDED" => "#d946ef",
        "STABILIZE" or "ALT_HOLD" => "#ffcc00",
        "UNKNOWN" => "#666666",
        _ => "#00f2ff"
    };

    private string targetFlightMode = "";

    private void ChangeFlightMode()
    {
        if (!string.IsNullOrEmpty(targetFlightMode))
        {
            Drone.SetFlightMode(targetFlightMode);
            Console.WriteLine($"[QUICK TAB] Sending Mode Change: {targetFlightMode}");
            targetFlightMode = "";
        }
    }

    private string GetCalColor(string status) => status?.ToUpper() switch
    {
        var s when s.Contains("SUCCESS") || s.Contains("CALIBRATED") || s.Contains("DONE") => "text-[#3fb950]",
        var s when s.Contains("FAIL") || s.Contains("ERROR") || s.Contains("DENIED") || s.Contains("NO RESPONSE") => "text-[#f85149]",
        var s when s.Contains("STANDBY") || s.Contains("NONE") => "text-[#555]",
        _ => "text-[#f0b429]"
    };

    private string GetCalDisplayText(string status) => status?.ToUpper() switch
    {
        var s when s.Contains("STANDBY") => "STANDBY",
        var s when s.Contains("SUCCESS") => "CALIBRATED",
        var s when s.Contains("FAIL") => "FAILED",
        var s when s.Contains("COMPUTING") => "COMPUTING...",
        var s when s.Contains("RECORDING") => "RECORDING...",
        var s when s.Contains("CANCELLED") => "CANCELLED",
        var s when s.Contains("DENIED") => "DENIED",
        _ => status ?? "STANDBY"
    };
}