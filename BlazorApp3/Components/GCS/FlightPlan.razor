        font-weight: bold;
        cursor: pointer;
    }

    .blue {
        background: #2b58ff;
    }

    .green {
        background: #238636;
    }

    .red {
        background: #ff3a3a;
    }

    .mission-action-group {
        display: flex;
        gap: 10px;
        margin-top: auto;
    }

    .action-btn {
        flex: 1;
        padding: 12px;
        border: none;
        border-radius: 6px;
        color: white;
        font-weight: 900;
        font-size: 0.85rem;
        cursor: pointer;
    }

    .upload-btn {
        background: #2b58ff;
        border: 1px solid #333;
    }

    .start-btn.disabled {
        background: #222;
        color: #444;
        cursor: not-allowed;
    }

    .start-btn.ready {
        background: #238636;
        box-shadow: 0 0 10px rgba(35, 134, 54, 0.3);
    }

    .icon-btn {
        background: transparent;
        border: none;
        color: #666;
        cursor: pointer;
        font-size: 0.8rem;
        padding: 2px 4px;
    }

    .icon-btn:hover {
            color: #00f2ff;
        }
</style>

@code {
    private static List<MissionItem> MissionItems = new();
    private static event Action? OnMissionChanged;
    private bool isUploaded = false;

    public class MissionItem
    {
        public int Sequence { get; set; }
        public string Command { get; set; } = "WAYPOINT";
        public double Lat { get; set; }
        public double Lng { get; set; }
        public double Alt { get; set; } = 50;
        public bool IsHome { get; set; } = false;
    }

    protected override void OnInitialized()
    {
        OnMissionChanged += TriggerMapRedraw;
        Drone.OnTelemetryUpdated += StateHasChanged;
        if (!MissionItems.Any())
        {
            MissionItems.Add(new MissionItem { IsHome = true, Sequence = 0, Command = "WAYPOINT", Alt = 0 });
        }
        TriggerMapRedraw();
    }

    private void TriggerMapRedraw() => InvokeAsync(async () =>
    {
        isUploaded = false;
        StateHasChanged();
        await JS.InvokeVoidAsync("drawMission", MissionItems);
    });

    [JSInvokable]
    public static void AddWaypointFromMap(double lat, double lng)
    {
        if (MissionItems.Count == 1 && MissionItems[0].IsHome && MissionItems[0].Lat == 0)
        {
            MissionItems[0].Lat = lat; MissionItems[0].Lng = lng;
        }
        else
        {
            MissionItems.Add(new MissionItem { Lat = lat, Lng = lng, Sequence = MissionItems.Count, Alt = 50 });
        }
        OnMissionChanged?.Invoke();
    }

    private void SetHomeToDrone()
    {
        var home = MissionItems.FirstOrDefault(x => x.IsHome);
        if (home != null) { home.Lat = Drone.State.Latitude; home.Lng = Drone.State.Longitude; TriggerMapRedraw(); }
    }

    private void MoveUp(MissionItem item)
    {
        int idx = MissionItems.IndexOf(item);
        if (idx > 1) { MissionItems.RemoveAt(idx); MissionItems.Insert(idx - 1, item); Resequence(); }
    }

    private void MoveDown(MissionItem item)
    {
        int idx = MissionItems.IndexOf(item);
        if (idx > 0 && idx < MissionItems.Count - 1) { MissionItems.RemoveAt(idx); MissionItems.Insert(idx + 1, item); Resequence(); }
    }

    private void RemoveItem(MissionItem item)
    {
        if (!item.IsHome) { MissionItems.Remove(item); Resequence(); }
    }

    private void Resequence()
    {
        for (int i = 0; i < MissionItems.Count; i++) MissionItems[i].Sequence = i;
        OnMissionChanged?.Invoke();
    }

    private void ClearAll()
    {
        var home = MissionItems.FirstOrDefault(x => x.IsHome);
        MissionItems.Clear(); if (home != null) MissionItems.Add(home);
        OnMissionChanged?.Invoke();
    }

    private double CalculateTotalDistance()
    {
        double total = 0;
        for (int i = 0; i < MissionItems.Count - 1; i++) total += GetHaversineDistance(MissionItems[i], MissionItems[i + 1]);
        return total;
    }

    private double GetHaversineDistance(MissionItem w1, MissionItem w2)
    {
        double r = 6371000;
        double dLat = (w2.Lat - w1.Lat) * Math.PI / 180;
        double dLng = (w2.Lng - w1.Lng) * Math.PI / 180;
        double a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2) + Math.Cos(w1.Lat * Math.PI / 180) * Math.Cos(w2.Lat * Math.PI / 180) * Math.Sin(dLng / 2) * Math.Sin(dLng / 2);
        return r * 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
    }

    private async Task HandleImport(InputFileChangeEventArgs e)
    {
        try
        {
            using var stream = e.File.OpenReadStream();
            var imported = await JsonSerializer.DeserializeAsync<List<MissionItem>>(stream);
            if (imported != null) { MissionItems = imported; Resequence(); }
        }
        catch { }
    }

    private async Task ExportWaypoints()
    {
        if (MissionItems.Count <= 1) return;
        var json = JsonSerializer.Serialize(MissionItems, new JsonSerializerOptions { WriteIndented = true });
        await JS.InvokeVoidAsync("downloadFile", "mission.json", json);
    }

    private void UploadMission() { if (MissionItems.Count > 1) { isUploaded = true; StateHasChanged(); } }
    private void StartMission() { if (isUploaded) Drone.SetFlightMode("AUTO"); }
    public void Dispose() { OnMissionChanged -= TriggerMapRedraw; Drone.OnTelemetryUpdated -= StateHasChanged; }
}