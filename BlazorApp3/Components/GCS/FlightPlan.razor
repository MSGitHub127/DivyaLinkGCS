@page "/flightplan"
@using BlazorApp3
@using System.Text.Json
@inject MavlinkService Drone
@inject IJSRuntime JS
@implements IDisposable

<InputFile id="importFile" OnChange="HandleImport" style="display:none" accept=".json" />

<div class="flightplan-view-container">
    <div class="hud-wrapper">
        <Hud />
    </div>

    <div class="editor-section">
        <div class="header-strip">
            <span class="icon">🛰️</span> FLIGHT PLANNER
        </div>

        <div class="toolbar-row">
            <div class="toolbar-left">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="margin-right: 6px; vertical-align: middle; color: mediumpurple">
                    <path d="M21 7L13 15L9 11L3 17" />
                    <circle cx="21" cy="7" r="2" fill="currentColor" />
                    <circle cx="3" cy="17" r="2" fill="currentColor" />
                </svg>
                <span class="status-badge-primary">WAYPOINTS</span>
            </div>
            <div class="tool-group">
                <button class="mini-btn blue" @onclick='() => JS.InvokeVoidAsync("triggerFilePicker", "importFile")'>IMPORT JSON</button>
                <button class="mini-btn green" @onclick="ExportWaypoints">EXPORT JSON</button>
                @if (MissionItems.Count > 1)
                {
                    <button class="mini-btn red" @onclick="ClearAll">CLEAR ALL</button>
                }
            </div>
        </div>

        <div class="mission-table-container">
            <table class="mission-planner-table">
                <thead>
                    <tr>
                        <th style="width: 35px;">#</th>
                        <th>Command</th>
                        <th>Latitude</th>
                        <th>Longitude</th>
                        <th style="width: 60px;">Alt</th>
                        <th style="width: 80px;">Order</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in MissionItems)
                    {
                        <tr class="@(item.IsHome ? "home-row" : "")">
                            <td class="seq-col">@(item.IsHome ? "H" : item.Sequence.ToString())</td>
                            <td>
                                @if (item.IsHome)
                                {
                                    <div class="home-text">HOME</div>
                                }
                                else
                                {
                                    <select @bind="item.Command" class="table-select" @bind:after="TriggerMapRedraw">
                                        <option value="WAYPOINT">WAYPOINT</option>
                                        <option value="TAKEOFF">TAKEOFF</option>
                                        <option value="LAND">LAND</option>
                                        <option value="RTL">RTL</option>
                                    </select>
                                }
                            </td>
                            <td><input type="number" step="0.0000001" @bind="item.Lat" @bind:after="TriggerMapRedraw" class="table-input" /></td>
                            <td><input type="number" step="0.0000001" @bind="item.Lng" @bind:after="TriggerMapRedraw" class="table-input" /></td>
                            <td><input type="number" @bind="item.Alt" @bind:after="TriggerMapRedraw" class="table-input" /></td>
                            <td class="actions-cell">
                                @if (!item.IsHome)
                                {
                                    <button class="icon-btn" @onclick="() => MoveUp(item)">▲</button>
                                    <button class="icon-btn" @onclick="() => MoveDown(item)">▼</button>
                                    <button class="icon-btn red-text" @onclick="() => RemoveItem(item)">✕</button>
                                }
                                else
                                {
                                    <button class="icon-btn sync-btn" @onclick="SetHomeToDrone">🛰️</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mission-action-group">
            <button class="action-btn upload-btn" @onclick="UploadMission">UPLOAD MISSION</button>
            <button class="action-btn start-btn @(isUploaded ? "ready" : "disabled")"
                    @onclick="StartMission" disabled="@(!isUploaded)">
                START MISSION
            </button>
        </div>
    </div>
</div>

<style>
