@page "/flightplan"
@using BlazorApp3
@using System.Text.Json
@inject MavlinkService Drone
@inject IJSRuntime JS
@implements IAsyncDisposable

<InputFile id="importFile" OnChange="HandleImport" style="display:none" accept=".json" />

<div class="flightplan-view-container">

    <div class="hud-wrapper">
        <Hud />
    </div>

    <div class="flightplan-content">
        <div class="header-strip">
            <span class="icon">✈️</span> FLIGHT PLAN EDITOR
        </div>

        <div class="flightplan-body">

            @* 1. MAP VIEWPORT (Fixed) *@
            <div class="map-viewport">
                <div id="map-element"></div>
                <div class="map-controls">
                    <button class="map-btn" @onclick="SetHomeToDrone" title="Sync Home to Drone Location">
                        <i class="bi bi-house-door-fill"></i> SYNC HOME
                    </button>
                    <button class="map-btn" @onclick="CenterMapOnDrone" title="Center Map on Drone">
                        <i class="bi bi-crosshair"></i> CENTER DRONE
                    </button>
                </div>
            </div>

            @* 2. TELEMETRY GRID (Fixed) *@
            <div class="param-grid">
                <div class="param-tile">
                    <label><i class="bi bi-speedometer2"></i> SPEED</label>
                    <div class="readout">@Drone.State.GroundSpeed.ToString("0.0") <span class="unit">m/s</span></div>
                </div>
                <div class="param-tile">
                    <label><i class="bi bi-rulers"></i> DISTANCE</label>
                    <div class="readout">@CalculateTotalDistance().ToString("0") <span class="unit">m</span></div>
                </div>
                <div class="param-tile">
                    <label><i class="bi bi-stopwatch"></i> EST. TIME</label>
                    <div class="readout">~@((CalculateTotalDistance() / 5 / 60).ToString("0")) <span class="unit">min</span></div>
                </div>
                <div class="param-tile">
                    <label><i class="bi bi-arrows-vertical"></i> DEF. ALT</label>
                    <div class="alt-input-wrapper">
                        <input type="number" @bind="globalAlt" class="editor-input" @bind:after="ApplyGlobalAlt" />
                        <span class="unit">m</span>
                    </div>
                </div>
            </div>

            @* 3. WAYPOINT EDITOR (Flex-Grow, Internally Scrolls) *@
            <div class="wp-section">
                <div class="wp-header">
                    <span>WAYPOINTS (@(MissionItems.Count > 0 ? MissionItems.Count - 1 : 0))</span>
                    <div class="wp-header-actions">
                        <button class="icon-btn text-success" @onclick='() => JS.InvokeVoidAsync("triggerFilePicker", "importFile")' title="Import Mission">
                            <i class="bi bi-folder2-open"></i>
                        </button>
                        <button class="icon-btn text-cyan" @onclick="ExportWaypoints" title="Export Mission">
                            <i class="bi bi-download"></i>
                        </button>
                        @if (MissionItems.Count > 1)
                        {
                            <button class="icon-btn text-danger" @onclick="ClearAllWaypoints" title="Clear All">
                                <i class="bi bi-trash3"></i>
                            </button>
                        }
                    </div>
                </div>

                <div class="wp-scroll-area">
                    @if (MissionItems.Count <= 1)
                    {
                        <div class="empty-notif">
                            <i class="bi bi-cursor-fill" style="font-size: 1.5rem; color: #333; margin-bottom: 8px; display: block;"></i>
                            No waypoints added.<br />Click the map to define a flight path.
                        </div>
                    }
                    else
                    {
                        @foreach (var mi in MissionItems.Where(x => !x.IsHome))
                        {
                            <div class="wp-card @(activeWpIndex == mi.Index ? "active" : "")" @onclick="() => activeWpIndex = mi.Index">
                                <div class="wp-idx">@(mi.Index == 0 ? "H" : mi.Index.ToString())</div>
                                <div class="wp-data">
                                    <span class="wp-coord">@mi.Lat.ToString("F5"), @mi.Lng.ToString("F5")</span>
                                    <div class="wp-edit-row">
                                        <label>ALT (m):</label>
                                        <input type="number" @bind="mi.Alt" class="mini-input"/>
                                    </div>
                                </div>
                                <select class="cmd-select" value="@mi.Command"
                                        @onchange="@(e => { mi.Command = e.Value?.ToString() ?? "WAYPOINT"; TriggerMapRedraw(); })"
                                        @onclick="() => {}"
                                        @onclick:stopPropagation="true">
                                    <option value="WAYPOINT">WAYPOINT</option>
                                    <option value="TAKEOFF">TAKEOFF</option>
                                    <option value="LOITER">LOITER</option>
                                    <option value="LAND">LAND</option>
                                    <option value="RTL">RTL</option>
                                </select>
                                <button class="wp-del" @onclick:stopPropagation="true" @onclick="() => RemoveItem(mi)">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        }
                    }
                </div>
            </div>

            @* 4. FOOTER ACTIONS (Fixed) *@
            <div class="sidebar-footer">
                <button class="action-btn upload" @onclick="UploadMission">
                    <i class="bi bi-cloud-arrow-up-fill"></i> UPLOAD
                </button>
                <button class="action-btn start @(isUploaded ? "ready" : "disabled")" @onclick="StartMission" disabled="@(!isUploaded)">
                    <i class="bi bi-rocket-takeoff-fill"></i> START
                </button>
            </div>

        </div>
    </div>
</div>

<style>
    :root {
        --gcs-border: #30363d;
        --gcs-cyan: #00f2ff;
        --gcs-green: #3fb950;
        --gcs-red: #f85149;
    }

    /* MASTER LAYOUT */
    .flightplan-view-container {
        display: flex;
        flex-direction: column;
        height: 100%;
        gap: 16px;
        padding: 20px;
        background: transparent;
        width: 100%;
        max-width: 500px;
        margin: 0 auto;
        overflow: hidden; /* STRICT LOCK: No outer scrollbars */
    }

    /* HUD */
    .hud-wrapper {
        height: 300px;
        width: 100%;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.4);
        border: 1px solid #333;
        flex-shrink: 0;
        background: #000;
    }

    /* MAIN CONTENT WRAPPER */
    .flightplan-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 8px;
        min-height: 0; /* Critical for flex scrolling */
        background: rgba(18, 20, 28, 0.6);
        border: 1px solid var(--gcs-border);
        border-radius: 8px;
        padding: 12px 14px;
        backdrop-filter: blur(4px);
    }

    .header-strip {
        padding-bottom: 8px;
        border-bottom: 1px solid var(--gcs-border);
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 900;
        font-size: 0.78rem;
        text-transform: uppercase;
        color: white;
        letter-spacing: 1.5px;
        flex-shrink: 0;
    }

    .flightplan-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 10px;
        overflow: hidden; /* Keep all elements contained */
        min-height: 0;
        padding-top: 4px;
    }

    /* MAP VIEWPORT */
    .map-viewport {
        height: 50px;
        width: 100%;
        position: relative;
        border-radius: 6px;
        overflow: hidden;
        border: 1px solid #242731;
        flex-shrink: 0;
    }

    .map-viewport #map-element {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
        }

    .map-controls {
        position: absolute;
        top: 8px;
        left: 8px;
        right: 8px;
        display: flex;
        justify-content: space-between;
        z-index: 10;
        pointer-events: none;
    }

    .map-btn {
        pointer-events: auto;
        height: 32px;
        padding: 0 12px;
        border-radius: 4px;
        background: rgba(18, 20, 28, 0.85);
        border: 1px solid #242731;
        color: var(--gcs-cyan);
        cursor: pointer;
        transition: all 0.2s ease;
        backdrop-filter: blur(4px);
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .map-btn:hover {
            background: var(--gcs-cyan);
            color: #0b0c10;
        }

    /* COMPACT PARAMS */
    .param-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 8px;
        flex-shrink: 0;
    }

    .param-tile {
        background: #010409;
        border: 1px solid #242731;
        border-radius: 6px;
        padding: 8px 4px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 4px;
    }

    .param-tile label {
            font-size: 0.55rem;
            color: #888;
            font-weight: 800;
            text-transform: uppercase;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 4px;
        }

    .readout {
        font-size: 0.85rem;
        font-weight: 800;
        color: var(--gcs-cyan);
        display: flex;
        align-items: baseline;
        gap: 2px;
    }

    .unit {
        font-size: 0.6rem;
        color: #888;
        font-weight: 600;
    }

    .alt-input-wrapper {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .editor-input {
        width: 40px;
        background: #08090b;
        border: 1px solid #333;
        color: #00ff66;
        padding: 2px;
        border-radius: 4px;
        font-weight: bold;
        font-size: 0.8rem;
        text-align: center;
        outline: none;
        transition: 0.2s;
        font-family: 'Consolas', monospace;
    }

    .editor-input:focus {
            border-color: var(--gcs-cyan);
        }

    /* WAYPOINTS SECTION (Flexed to fill remaining space) */
    .wp-section {
        flex: 1; /* This takes all remaining vertical space */
        display: flex;
        flex-direction: column;
        gap: 8px;
        min-height: 0; /* Critical for internal scrolling */
        background: #010409;
        border: 1px solid #242731;
        border-radius: 6px;
        padding: 8px;
    }

    .wp-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 6px;
        border-bottom: 1px solid #242731;
        flex-shrink: 0;
    }

    .wp-header span {
            font-size: 0.7rem;
            font-weight: 800;
            color: #888;
        }

    .wp-header-actions {
        display: flex;
        gap: 12px;
    }

    .icon-btn {
        background: transparent;
        border: none;
        cursor: pointer;
        font-size: 1rem;
        padding: 0;
        transition: filter 0.2s;
    }

    .icon-btn:hover {
            filter: brightness(1.3);
        }

    .text-success {
        color: var(--gcs-green);
    }

    .text-cyan {
        color: var(--gcs-cyan);
    }

    .text-danger {
        color: var(--gcs-red);
    }

    /* The only scrolling element on the page */
    .wp-scroll-area {
        flex: 1;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding-right: 4px;
    }

    .wp-scroll-area::-webkit-scrollbar {
            width: 4px;
        }

    .wp-scroll-area::-webkit-scrollbar-thumb {
            background: #333;
            border-radius: 3px;
        }

    .empty-notif {
        padding: 20px 10px;
        text-align: center;
        color: #666;
        font-size: 0.75rem;
        font-weight: 600;
    }

    /* WAYPOINT CARDS (Enlarged) */
    .wp-card {
        background: rgba(18, 20, 28, 0.8);
        border: 1px solid #333;
        border-radius: 8px; /* Slightly rounder corners */
        padding: 16px 20px; /* Increased padding for taller cards */
        font-size: 1.05rem; /* Increased font size */
        display: flex;
        align-items: center;
        gap: 16px; /* Increased gap between elements */
        cursor: pointer;
        transition: all 0.2s ease;
        flex-shrink: 0;
    }

    .wp-card:hover {
            border-color: #555;
        }

    .wp-card.active {
            border-color: var(--gcs-cyan);
            background: rgba(0, 242, 255, 0.05);
            box-shadow: inset 3px 0 0 var(--gcs-cyan);
        }

    .wp-idx {
        width: 32px; /* Increased from 24px */
        height: 32px; /* Increased from 24px */
        background: #0b0c10;
        color: #888;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem; /* Increased from 0.7rem */
        font-weight: 800;
        border: 1px solid #333;
        transition: 0.2s;
    }

    .wp-card.active .wp-idx {
        background: var(--gcs-cyan);
        color: #0b0c10;
        border-color: var(--gcs-cyan);
    }

    .wp-data {
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .wp-coord {
        font-size: 0.75rem; /* Increased from 0.65rem */
        font-family: 'Consolas', monospace;
        color: #ccc;
        font-weight: 600;
    }

    .wp-edit-row {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-top: 6px; /* Slightly more breathing room */
    }

    .wp-edit-row label {
            font-size: 0.65rem; /* Increased from 0.55rem */
            color: #888;
            font-weight: 800;
            margin: 0;
        }

    .mini-input {
        width: 75px; /* Increased from 60px */
        background: #08090b;
        border: 1px solid #333;
        color: #00ff66;
        padding: 4px 6px; /* Increased vertical padding */
        border-radius: 4px;
        font-size: 0.85rem; /* Increased from 0.7rem */
        font-weight: bold;
        outline: none;
        transition: 0.2s;
    }

    .mini-input:focus {
            border-color: #00ff66;
        }

    .wp-del {
        margin-left: auto;
        background: transparent;
        border: none;
        color: #666;
        font-size: 1.3rem; /* Larger icon size */
        cursor: pointer;
        padding: 8px; /* Larger click target area */
        transition: 0.2s;
        border-radius: 6px;
    }

    .wp-del:hover {
            color: var(--gcs-red);
            background: rgba(255, 58, 58, 0.1);
        }

    /* FOOTER ACTIONS */
    .sidebar-footer {
        display: flex;
        gap: 10px;
        flex-shrink: 0;
    }

    .action-btn {
        flex: 1;
        padding: 12px;
        border-radius: 6px;
        border: none;
        font-weight: 800;
        font-size: 0.75rem;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
    }

    .action-btn.upload {
            background: #21262d;
            border: 1px solid #333;
            color: #ccc;
        }

    .action-btn.upload:hover {
                background: #333;
                color: #fff;
            }

    .action-btn.start {
            background: #0d3a1a;
            color: #888;
            border: 1px solid #238636;
        }

    .action-btn.start.disabled {
                cursor: not-allowed;
            }

    .action-btn.start.ready {
                background: linear-gradient(90deg, #0d3a1a 0%, #00ff66 100%);
                color: #0b0c10;
                border: none;
                box-shadow: 0 4px 15px rgba(0, 255, 102, 0.2);
            }

    .action-btn.start.ready:hover {
                    filter: brightness(1.1);
                    transform: translateY(-1px);
                }

    /* NEW: Command Dropdown Styling */
    .cmd-select {
        background: #08090b;
        border: 1px solid #333;
        color: var(--gcs-cyan);
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 800;
        outline: none;
        cursor: pointer;
        margin-left: auto; /* Pushes the dropdown and delete button to the far right */
        margin-right: 8px;
        transition: border-color 0.2s;
    }

        .cmd-select:focus {
            border-color: var(--gcs-cyan);
        }

        .cmd-select option {
            background: #08090b;
            color: white;
        }

    /* UPDATE: Adjust the delete button margin */
    .wp-del {
        margin-left: 0; /* Changed from auto, since cmd-select now handles the push */
        background: transparent;
        border: none;
        color: #666;
        font-size: 1.3rem;
        cursor: pointer;
        padding: 8px;
        transition: 0.2s;
        border-radius: 6px;
    }
</style>

@code {
    private static List<MissionItem> MissionItems = new();
    private static event Action? OnMissionChanged;
    private bool isUploaded = false;
    private bool isUploading = false;
    private int globalAlt = 50;
    private int activeWpIndex = -1;

    public class MissionItem
    {
        public int Index { get; set; }
        public string Command { get; set; } = "WAYPOINT";
        public double Lat { get; set; }
        public double Lng { get; set; }
        public double Alt { get; set; } = 50;
        public bool IsHome { get; set; } = false;
    }

    private void RefreshUi() => InvokeAsync(StateHasChanged);

    protected override void OnInitialized()
    {
        OnMissionChanged += TriggerMapRedraw;
        Drone.OnTelemetryUpdated += RefreshUi;

        if (!MissionItems.Any())
        {
            MissionItems.Add(new MissionItem { IsHome = true, Index = 0, Command = "WAYPOINT", Alt = 0 });
        }
        TriggerMapRedraw();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("initMap", Drone.State.Latitude, Drone.State.Longitude);
            }
            catch { }
        }
    }

    [JSInvokable]
    public static void AddWaypointFromMap(double lat, double lng)
    {
        if (MissionItems.Count == 1 && MissionItems[0].IsHome && MissionItems[0].Lat == 0)
        {
            MissionItems[0].Lat = lat;
            MissionItems[0].Lng = lng;
        }
        else
        {
            MissionItems.Add(new MissionItem { Lat = lat, Lng = lng, Index = MissionItems.Count, Alt = 50 });
            for (int i = 0; i < MissionItems.Count; i++) MissionItems[i].Index = i;
        }
        OnMissionChanged?.Invoke();
    }

    [JSInvokable]
    public static void UpdateWaypointPosition(int listIndex, double newLat, double newLng)
    {
        if (listIndex >= 0 && listIndex < MissionItems.Count)
        {
            MissionItems[listIndex].Lat = newLat;
            MissionItems[listIndex].Lng = newLng;
            OnMissionChanged?.Invoke();
        }
    }

    private void ApplyGlobalAlt()
    {
        foreach (var wp in MissionItems.Where(x => !x.IsHome)) wp.Alt = globalAlt;
        TriggerMapRedraw();
    }

    private void TriggerMapRedraw() => InvokeAsync(async () =>
        {
            try
            {
                isUploaded = false;
                StateHasChanged();
                await JS.InvokeVoidAsync("drawMission", MissionItems);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Map Redraw Error: {ex.Message}");
            }
        });

    private async Task CenterMapOnDrone()
    {
        await JS.InvokeVoidAsync("jumpToDrone", Drone.State.Latitude, Drone.State.Longitude, Drone.State.Yaw);
    }

    private void SetHomeToDrone()
    {
        var home = MissionItems.FirstOrDefault(x => x.IsHome);
        if (home != null)
        {
            home.Lat = Drone.State.Latitude;
            home.Lng = Drone.State.Longitude;
            TriggerMapRedraw();
        }
    }

    private void RemoveItem(MissionItem item)
    {
        if (!item.IsHome)
        {
            MissionItems.Remove(item);
            Resequence();
        }
    }

    private void ClearAllWaypoints()
    {
        var home = MissionItems.FirstOrDefault(x => x.IsHome);
        MissionItems.Clear();
        if (home != null) MissionItems.Add(home);
        OnMissionChanged?.Invoke();
    }

    private void Resequence()
    {
        for (int i = 0; i < MissionItems.Count; i++) MissionItems[i].Index = i;
        OnMissionChanged?.Invoke();
    }

    private double CalculateTotalDistance()
    {
        double total = 0;
        for (int i = 0; i < MissionItems.Count - 1; i++)
            total += GetHaversineDistance(MissionItems[i], MissionItems[i + 1]);
        return total;
    }

    private double GetHaversineDistance(MissionItem w1, MissionItem w2)
    {
        double r = 6371000;
        double dLat = (w2.Lat - w1.Lat) * Math.PI / 180;
        double dLng = (w2.Lng - w1.Lng) * Math.PI / 180;
        double a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2) +
                   Math.Cos(w1.Lat * Math.PI / 180) * Math.Cos(w2.Lat * Math.PI / 180) * Math.Sin(dLng / 2) * Math.Sin(dLng / 2);
        return r * 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
    }

    private async Task HandleImport(InputFileChangeEventArgs e)
    {
        try
        {
            using var stream = e.File.OpenReadStream();
            var imported = await JsonSerializer.DeserializeAsync<List<MissionItem>>(stream);
            if (imported != null)
            {
                MissionItems = imported;
                Resequence();
            }
        }
        catch { }
    }

    private async Task ExportWaypoints()
    {
        if (MissionItems.Count <= 1) return;
        var json = JsonSerializer.Serialize(MissionItems, new JsonSerializerOptions { WriteIndented = true });
        await JS.InvokeVoidAsync("downloadFile", "mission.json", json);
    }

    private async Task UploadMission()
    {
        if (MissionItems.Count > 1)
        {
            isUploading = true;
            StateHasChanged();

            var waypoints = MissionItems.Select(mi => new WaypointModel
            {
                Index = mi.Index,
                Command = mi.Command,
                Lat = mi.Lat,
                Lng = mi.Lng,
                Alt = (int)mi.Alt,
                IsHome = mi.IsHome
            }).ToList();

            bool success = await Drone.UploadMissionAsync(waypoints);
            if (success)
            {
                isUploaded = true;
            }
            else
            {
                isUploaded = false;
                await JS.InvokeVoidAsync("alert", "Mission Upload Failed. Check telemetry connection.");
            }

            isUploading = false;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        OnMissionChanged -= TriggerMapRedraw;
        Drone.OnTelemetryUpdated -= RefreshUi;

        try
        {
            await JS.InvokeVoidAsync("preserveMap");
        }
        catch { }
    }

    private void StartMission()
    {
        if (isUploaded) Drone.SetFlightMode("AUTO");
    }
}