        display: flex;
        flex-direction: column;
        height: 100%;
        gap: 16px;
        padding: 20px;
        background: transparent;
        width: 100%;
        max-width: 500px;
        margin: 0 auto;
        overflow: hidden;
    }

    /* HUD WRAPPER: Exact match to Messages tab [cite: 189, 190] */
    .hud-wrapper {
        height: 300px;
        width: 100%;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.4);
        border: 1px solid #333;
        flex-shrink: 0;
    }

    .editor-section {
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        gap: 10px;
        min-height: 0;
    }

    .header-strip {
        background: rgba(18, 20, 28, 0.8);
        border: 1px solid rgba(0, 242, 255, 0.2);
        border-radius: 6px;
        padding: 8px;
        text-align: center;
        color: #00f2ff;
        font-weight: 800;
        font-size: 0.85rem;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        backdrop-filter: blur(4px);
    }

    /* TABLE CONTAINER: Matches the Console Window style  */
    .mission-table-container {
        flex-grow: 1;
        background: rgba(5, 5, 10, 0.9);
        border: 1px solid #222;
        border-radius: 6px;
        padding: 10px;
        overflow-y: auto;
        box-shadow: inset 0 0 15px rgba(0,0,0,0.8);
    }

    .mission-planner-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.75rem;
