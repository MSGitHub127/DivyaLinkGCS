    }

    .mission-planner-table th {
            background: #111;
            color: #666;
            padding: 8px;
            text-align: left;
            position: sticky;
            top: 0;
            border-bottom: 1px solid #222;
            font-size: 0.65rem;
        }

    .mission-planner-table td {
            padding: 4px;
            border-bottom: 1px solid #111;
            vertical-align: middle;
        }

    .table-input, .table-select {
        background: #000;
        border: 1px solid #222;
        color: #00ff00;
        border-radius: 4px;
        padding: 2px;
        width: 100%;
        font-size: 0.7rem;
    }

    .home-row {
        background: rgba(0, 242, 255, 0.05);
    }

    .home-text {
        color: #00f2ff;
        font-weight: bold;
    }

    .seq-col {
        color: #00f2ff;
        font-weight: bold;
        text-align: center;
    }

    .toolbar-row {
        display: flex;
        justify-content: flex-end;
    }

    .toolbar-left {
        flex-shrink: 0;
        margin-right: auto;
    }

    .status-badge-primary {
        background: rgba(5, 5, 10, 0.9);
