@page "/flightplan"
@using BlazorApp3
@using System.Text.Json
@inject MavlinkService Drone
@inject IJSRuntime JS
@implements IDisposable

<InputFile id="importFile" OnChange="HandleImport" style="display:none" accept=".json" />

<div class="flight-plan-master">
    <div class="hud-viewport">
        <Hud />
    </div>

    <div class="main-interface">
        <div class="map-viewport">
            <div id="map-element"></div>
            <div class="map-controls">
                <button class="map-btn" @onclick="SetHomeToDrone" title="Sync Home to Drone Location">
                    <i class="bi bi-house-door-fill"></i>
                </button>
                <button class="map-btn" @onclick="CenterMapOnDrone" title="Center Map on Drone">
                    <i class="bi bi-crosshair"></i>
                </button>
            </div>
        </div>

        <div class="editor-sidebar">
            <div class="sidebar-header">
                <i class="bi bi-geo-alt-fill text-primary"></i> FLIGHT PLAN EDITOR
            </div>

            <div class="param-grid">
                <div class="param-tile">
                    <label><i class="bi bi-arrows-vertical"></i> DEFAULT ALT (m)</label>
                    <input type="number" @bind="globalAlt" class="editor-input" @bind:after="ApplyGlobalAlt" />
                </div>
                <div class="param-tile">
                    <label><i class="bi bi-speedometer2"></i> SPEED</label>
                    <div class="readout">@Drone.State.GroundSpeed.ToString("0.0") <span class="unit">m/s</span></div>
                </div>
                <div class="param-tile">
                    <label><i class="bi bi-rulers"></i> DISTANCE</label>
                    <div class="readout">@CalculateTotalDistance().ToString("0") <span class="unit">m</span></div>
                </div>
                <div class="param-tile">
                    <label><i class="bi bi-stopwatch"></i> EST. TIME</label>
                    <div class="readout">~@((CalculateTotalDistance() / 5 / 60).ToString("0")) <span class="unit">min</span></div>
                </div>
            </div>

            <div class="wp-section">
                <div class="wp-header">
                    <span>WAYPOINTS (@(MissionItems.Count > 0 ? MissionItems.Count - 1 : 0))</span>
                    @if (MissionItems.Count > 1)
                    {
                        <button class="clear-btn" @onclick="ClearAllWaypoints"><i class="bi bi-trash3"></i> Clear All</button>
                    }
                </div>

                <div class="wp-actions">
                    <button class="wp-btn import" @onclick='() => JS.InvokeVoidAsync("triggerFilePicker", "importFile")'>
                        <i class="bi bi-folder2-open"></i> IMPORT
                    </button>
                    <button class="wp-btn export" @onclick="ExportWaypoints">
                        <i class="bi bi-download"></i> EXPORT
                    </button>
                </div>

                <div class="wp-scroll-area">
                    @if (MissionItems.Count <= 1)
                    {
                        <div class="empty-notif">
                            <i class="bi bi-cursor-fill" style="font-size: 1.5rem; color: #30363d; margin-bottom: 8px; display: block;"></i>
                            No waypoints added.<br />Click the map to define a flight path.
                        </div>
                    }
                    else
                    {
                        @foreach (var wp in MissionItems.Where(x => !x.IsHome))
                        {
                            <div class="wp-card @(activeWpIndex == wp.Index ? "active" : "")" @onclick="() => activeWpIndex = wp.Index">
                                <div class="wp-idx">@wp.Index</div>
                                <div class="wp-data">
                                    <span class="wp-coord">@wp.Lat.ToString("F5"), @wp.Lng.ToString("F5")</span>
                                    <div class="wp-edit-row">
                                        <label>ALT (m):</label>
                                        <input type="number" @bind="wp.Alt" class="mini-input" @bind:after="TriggerMapRedraw" />
                                    </div>
                                </div>
                                <button class="wp-del" @onclick="() => RemoveItem(wp)" title="Remove Waypoint">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="sidebar-footer">
                <button class="action-btn upload" @onclick="UploadMission">
                    <i class="bi bi-cloud-arrow-up-fill"></i> UPLOAD TO DRONE
                </button>
                <button class="action-btn start @(isUploaded ? "ready" : "disabled")"
                        @onclick="StartMission" disabled="@(!isUploaded)">
                    <i class="bi bi-rocket-takeoff-fill"></i> START MISSION
                </button>
            </div>
        </div>
    </div>
</div>

<style>
