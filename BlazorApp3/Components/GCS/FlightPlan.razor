@page "/flightplan"
@using BlazorApp3
@using System.Text.Json
@inject MavlinkService Drone
@inject IJSRuntime JS
@implements IAsyncDisposable

<InputFile id="importFile" OnChange="HandleImport" style="display:none" accept=".json" />

<div class="flex flex-col h-full gap-4 p-5 bg-transparent w-full max-w-[500px] mx-auto overflow-hidden">

    <div class="h-[300px] w-full rounded-lg overflow-hidden shadow-[0_4px_20px_rgba(0,0,0,0.4)] border border-[#333] shrink-0 bg-black">
        <Hud />
    </div>

    <div class="flex-1 flex flex-col gap-2 min-h-0 bg-[rgba(18,20,28,0.6)] border border-[#30363d] rounded-lg py-3 px-[14px] backdrop-blur-[4px]">
        <div class="pb-2 border-b border-[#30363d] flex items-center gap-[10px] font-black text-[0.78rem] uppercase text-white tracking-[1.5px] shrink-0">
            <span class="text-[1rem]">✈️</span> FLIGHT PLAN EDITOR
        </div>

        <div class="flex-1 flex flex-col gap-[10px] overflow-hidden min-h-0 pt-1">

            @* 1. MAP VIEWPORT (Fixed) *@
            <div class="h-[50px] w-full relative rounded-[6px] overflow-hidden border border-[#242731] shrink-0">
                <div id="map-element" class="absolute inset-0 w-full h-full"></div>
                <div class="absolute top-2 left-2 right-2 flex justify-between z-10 pointer-events-none">
                    <button class="pointer-events-auto h-8 px-3 rounded bg-[rgba(18,20,28,0.85)] border border-[#242731] text-[#00f2ff] cursor-pointer transition-all duration-200 backdrop-blur-[4px] text-[0.65rem] font-extrabold tracking-[1px] flex items-center gap-[6px] hover:bg-[#00f2ff] hover:text-[#0b0c10]" @onclick="SetHomeToDrone" title="Sync Home to Drone Location">
                        <i class="bi bi-house-door-fill"></i> SYNC HOME
                    </button>
                    <button class="pointer-events-auto h-8 px-3 rounded bg-[rgba(18,20,28,0.85)] border border-[#242731] text-[#00f2ff] cursor-pointer transition-all duration-200 backdrop-blur-[4px] text-[0.65rem] font-extrabold tracking-[1px] flex items-center gap-[6px] hover:bg-[#00f2ff] hover:text-[#0b0c10]" @onclick="CenterMapOnDrone" title="Center Map on Drone">
                        <i class="bi bi-crosshair"></i> CENTER DRONE
                    </button>
                </div>
            </div>

            @* 2. TELEMETRY GRID (Fixed) *@
            <div class="grid grid-cols-4 gap-2 shrink-0">
                <div class="bg-[#010409] border border-[#242731] rounded-[6px] py-2 px-1 flex flex-col items-center justify-center gap-1">
                    <label class="text-[0.55rem] text-[#888] font-extrabold uppercase m-0 flex items-center gap-1"><i class="bi bi-speedometer2"></i> SPEED</label>
                    <div class="text-[0.85rem] font-extrabold text-[#00f2ff] flex items-baseline gap-[2px]">@Drone.State.GroundSpeed.ToString("0.0") <span class="text-[0.6rem] text-[#888] font-semibold">m/s</span></div>
                </div>
                <div class="bg-[#010409] border border-[#242731] rounded-[6px] py-2 px-1 flex flex-col items-center justify-center gap-1">
                    <label class="text-[0.55rem] text-[#888] font-extrabold uppercase m-0 flex items-center gap-1"><i class="bi bi-rulers"></i> DISTANCE</label>
                    <div class="text-[0.85rem] font-extrabold text-[#00f2ff] flex items-baseline gap-[2px]">@CalculateTotalDistance().ToString("0") <span class="text-[0.6rem] text-[#888] font-semibold">m</span></div>
                </div>
                <div class="bg-[#010409] border border-[#242731] rounded-[6px] py-2 px-1 flex flex-col items-center justify-center gap-1">
                    <label class="text-[0.55rem] text-[#888] font-extrabold uppercase m-0 flex items-center gap-1"><i class="bi bi-stopwatch"></i> EST. TIME</label>
                    <div class="text-[0.85rem] font-extrabold text-[#00f2ff] flex items-baseline gap-[2px]">~@((CalculateTotalDistance() / 5 / 60).ToString("0")) <span class="text-[0.6rem] text-[#888] font-semibold">min</span></div>
                </div>
                <div class="bg-[#010409] border border-[#242731] rounded-[6px] py-2 px-1 flex flex-col items-center justify-center gap-1">
                    <label class="text-[0.55rem] text-[#888] font-extrabold uppercase m-0 flex items-center gap-1"><i class="bi bi-arrows-vertical"></i> DEF. ALT</label>
                    <div class="flex items-center gap-1">
                        <input type="number" @bind="globalAlt" class="w-[40px] bg-[#08090b] border border-[#333] text-[#00ff66] p-[2px] rounded font-bold text-[0.8rem] text-center outline-none transition-all duration-200 font-mono focus:border-[#00f2ff]" @bind:after="ApplyGlobalAlt" />
                        <span class="text-[0.6rem] text-[#888] font-semibold">m</span>
                    </div>
                </div>
            </div>

            @* 3. WAYPOINT EDITOR (Flex-Grow, Internally Scrolls) *@
            <div class="flex-1 flex flex-col gap-2 min-h-0 bg-[#010409] border border-[#242731] rounded-[6px] p-2">
                <div class="flex justify-between items-center pb-[6px] border-b border-[#242731] shrink-0">
                    <span class="text-[0.7rem] font-extrabold text-[#888]">WAYPOINTS (@(MissionItems.Count > 0 ? MissionItems.Count - 1 : 0))</span>
                    <div class="flex gap-3">
                        <button class="bg-transparent border-none cursor-pointer text-[1rem] p-0 transition-all hover:brightness-110 text-[#3fb950]" @onclick='() => JS.InvokeVoidAsync("triggerFilePicker", "importFile")' title="Import Mission">
                            <i class="bi bi-folder2-open"></i>
                        </button>
                        <button class="bg-transparent border-none cursor-pointer text-[1rem] p-0 transition-all hover:brightness-110 text-[#00f2ff]" @onclick="ExportWaypoints" title="Export Mission">
                            <i class="bi bi-download"></i>
                        </button>
                        @if (MissionItems.Count > 1)
                        {
                            <button class="bg-transparent border-none cursor-pointer text-[1rem] p-0 transition-all hover:brightness-110 text-[#f85149]" @onclick="ClearAllWaypoints" title="Clear All">
                                <i class="bi bi-trash3"></i>
                            </button>
                        }
                    </div>
                </div>

                <div class="flex-1 overflow-y-auto flex flex-col gap-2 pr-1 [&::-webkit-scrollbar]:w-1 [&::-webkit-scrollbar-thumb]:bg-[#333] [&::-webkit-scrollbar-thumb]:rounded-[3px]">
                    @if (MissionItems.Count <= 1)
                    {
                        <div class="py-5 px-[10px] text-center text-[#666] text-[0.75rem] font-semibold">
                            <i class="bi bi-cursor-fill" style="font-size: 1.5rem; color: #333; margin-bottom: 8px; display: block;"></i>
                            No waypoints added.<br />Click the map to define a flight path.
                        </div>
                    }
                    else
                    {
                        @foreach (var mi in MissionItems.Where(x => !x.IsHome))
                        {
                            <div class="group bg-[rgba(18,20,28,0.8)] border border-[#333] rounded-lg py-4 px-5 text-[1.05rem] flex items-center gap-4 cursor-pointer transition-all duration-200 shrink-0 hover:border-[#555] @(activeWpIndex == mi.Index ? "border-[#00f2ff] bg-[rgba(0,242,255,0.05)] shadow-[inset_3px_0_0_#00f2ff]" : "")" @onclick="() => activeWpIndex = mi.Index">
                                <div class="w-8 h-8 bg-[#0b0c10] text-[#888] rounded-full flex items-center justify-center text-[0.9rem] font-extrabold border border-[#333] transition-all duration-200 @(activeWpIndex == mi.Index ? "bg-[#00f2ff] text-[#0b0c10] border-[#00f2ff]" : "")">@(mi.Index == 0 ? "H" : mi.Index.ToString())</div>
                                <div class="flex flex-col flex-1">
                                    <span class="text-[0.75rem] font-mono text-[#ccc] font-semibold">@mi.Lat.ToString("F5"), @mi.Lng.ToString("F5")</span>
                                    <div class="flex items-center gap-[6px] mt-[6px]">
                                        <label class="text-[0.65rem] text-[#888] font-extrabold m-0">ALT (m):</label>
                                        <input type="number" @bind="mi.Alt" class="w-[75px] bg-[#08090b] border border-[#333] text-[#00ff66] px-[6px] py-1 rounded text-[0.85rem] font-bold outline-none transition-all duration-200 focus:border-[#00ff66]" />
                                    </div>
                                </div>
                                <select class="bg-[#08090b] border border-[#333] text-[#00f2ff] py-1 px-2 rounded text-[0.75rem] font-extrabold outline-none cursor-pointer ml-auto mr-2 transition-colors focus:border-[#00f2ff] [&>option]:bg-[#08090b] [&>option]:text-white" value="@mi.Command"
                                        @onchange="@(e => { mi.Command = e.Value?.ToString() ?? "WAYPOINT"; TriggerMapRedraw(); })"
                                        @onclick="() => { }"
                                        @onclick:stopPropagation="true">
                                    <option value="WAYPOINT">WAYPOINT</option>
                                    <option value="TAKEOFF">TAKEOFF</option>
                                    <option value="LOITER">LOITER</option>
                                    <option value="LAND">LAND</option>
                                    <option value="RTL">RTL</option>
                                </select>
                                <button class="ml-0 bg-transparent border-none text-[#666] text-[1.3rem] cursor-pointer p-2 transition-all duration-200 rounded-[6px] hover:text-[#f85149] hover:bg-[rgba(255,58,58,0.1)]" @onclick:stopPropagation="true" @onclick="() => RemoveItem(mi)">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        }
                    }
                </div>
            </div>

            @* 4. FOOTER ACTIONS (Fixed) *@
            <div class="flex gap-[10px] shrink-0">
                <button class="flex-1 p-3 rounded-[6px] border border-[#333] font-extrabold text-[0.75rem] tracking-[1px] cursor-pointer transition-all duration-200 flex justify-center items-center gap-2 bg-[#21262d] text-[#ccc] hover:bg-[#333] hover:text-white" @onclick="UploadMission">
                    <i class="bi bi-cloud-arrow-up-fill"></i> UPLOAD
                </button>
                <button class="flex-1 p-3 rounded-[6px] font-extrabold text-[0.75rem] tracking-[1px] transition-all duration-200 flex justify-center items-center gap-2 @(isUploaded ? "bg-gradient-to-r from-[#0d3a1a] to-[#00ff66] text-[#0b0c10] border-none shadow-[0_4px_15px_rgba(0,255,102,0.2)] hover:brightness-110 hover:-translate-y-[1px] cursor-pointer" : "bg-[#0d3a1a] text-[#888] border border-[#238636] cursor-not-allowed")" @onclick="StartMission" disabled="@(!isUploaded)">
                    <i class="bi bi-rocket-takeoff-fill"></i> START
                </button>
            </div>

        </div>
    </div>
</div>

@code {
    private static List<MissionItem> MissionItems = new();
    private static event Action? OnMissionChanged;
    private bool isUploaded = false;
    private bool isUploading = false;
    private int globalAlt = 50;
    private int activeWpIndex = -1;
    public class MissionItem
    {
        public int Index { get; set; }
        public string Command { get; set; } = "WAYPOINT";
        public double Lat { get; set; }
        public double Lng { get; set; }
        public double Alt { get; set; } = 50;
        public bool IsHome { get; set; } = false;
    }

    private void RefreshUi() => InvokeAsync(StateHasChanged);
    protected override void OnInitialized()
    {
        OnMissionChanged += TriggerMapRedraw;
        Drone.OnTelemetryUpdated += RefreshUi;

        if (!MissionItems.Any())
        {
            MissionItems.Add(new MissionItem { IsHome = true, Index = 0, Command = "WAYPOINT", Alt = 0 });
        }
        TriggerMapRedraw();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("initMap", Drone.State.Latitude, Drone.State.Longitude);
            }
            catch { }
        }
    }

    [JSInvokable]
    public static void AddWaypointFromMap(double lat, double lng)
    {
        if (MissionItems.Count == 1 && MissionItems[0].IsHome && MissionItems[0].Lat == 0)
        {
            MissionItems[0].Lat = lat;
            MissionItems[0].Lng = lng;
        }
        else
        {
            MissionItems.Add(new MissionItem { Lat = lat, Lng = lng, Index = MissionItems.Count, Alt = 50 });
            for (int i = 0; i < MissionItems.Count; i++) MissionItems[i].Index = i;
        }
        OnMissionChanged?.Invoke();
    }

    [JSInvokable]
    public static void UpdateWaypointPosition(int listIndex, double newLat, double newLng)
    {
        if (listIndex >= 0 && listIndex < MissionItems.Count)
        {
            MissionItems[listIndex].Lat = newLat;
            MissionItems[listIndex].Lng = newLng;
            OnMissionChanged?.Invoke();
        }
    }

    private void ApplyGlobalAlt()
    {
        foreach (var wp in MissionItems.Where(x => !x.IsHome)) wp.Alt = globalAlt;
        TriggerMapRedraw();
    }

    private void TriggerMapRedraw() => InvokeAsync(async () =>
        {
            try
            {
                isUploaded = false;
                StateHasChanged();
                await JS.InvokeVoidAsync("drawMission", MissionItems);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Map Redraw Error: {ex.Message}");
            }
        });
    private async Task CenterMapOnDrone()
    {
        await JS.InvokeVoidAsync("jumpToDrone", Drone.State.Latitude, Drone.State.Longitude, Drone.State.Yaw);
    }

    private void SetHomeToDrone()
    {
        var home = MissionItems.FirstOrDefault(x => x.IsHome);
        if (home != null)
        {
            home.Lat = Drone.State.Latitude;
            home.Lng = Drone.State.Longitude;
            TriggerMapRedraw();
        }
    }

    private void RemoveItem(MissionItem item)
    {
        if (!item.IsHome)
        {
            MissionItems.Remove(item);
            Resequence();
        }
    }

    private void ClearAllWaypoints()
    {
        var home = MissionItems.FirstOrDefault(x => x.IsHome);
        MissionItems.Clear();
        if (home != null) MissionItems.Add(home);
        OnMissionChanged?.Invoke();
    }

    private void Resequence()
    {
        for (int i = 0; i < MissionItems.Count; i++) MissionItems[i].Index = i;
        OnMissionChanged?.Invoke();
    }

    private double CalculateTotalDistance()
    {
        double total = 0;
        for (int i = 0; i < MissionItems.Count - 1; i++)
            total += GetHaversineDistance(MissionItems[i], MissionItems[i + 1]);
        return total;
    }

    private double GetHaversineDistance(MissionItem w1, MissionItem w2)
    {
        double r = 6371000;
        double dLat = (w2.Lat - w1.Lat) * Math.PI / 180;
        double dLng = (w2.Lng - w1.Lng) * Math.PI / 180;
        double a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2) +
                   Math.Cos(w1.Lat * Math.PI / 180) * Math.Cos(w2.Lat * Math.PI / 180) * Math.Sin(dLng / 2) * Math.Sin(dLng / 2);
        return r * 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
    }

    private async Task HandleImport(InputFileChangeEventArgs e)
    {
        try
        {
            using var stream = e.File.OpenReadStream();
            var imported = await JsonSerializer.DeserializeAsync<List<MissionItem>>(stream);
            if (imported != null)
            {
                MissionItems = imported;
                Resequence();
            }
        }
        catch { }
    }

    private async Task ExportWaypoints()
    {
        if (MissionItems.Count <= 1) return;
        var json = JsonSerializer.Serialize(MissionItems, new JsonSerializerOptions { WriteIndented = true });
        await JS.InvokeVoidAsync("downloadFile", "mission.json", json);
    }

    private async Task UploadMission()
    {
        if (MissionItems.Count > 1)
        {
            isUploading = true;
            StateHasChanged();

            var waypoints = MissionItems.Select(mi => new WaypointModel
            {
                Index = mi.Index,
                Command = mi.Command,
                Lat = mi.Lat,
                Lng = mi.Lng,
                Alt = (int)mi.Alt,
                IsHome = mi.IsHome
            }).ToList();
            bool success = await Drone.UploadMissionAsync(waypoints);
            if (success)
            {
                isUploaded = true;
            }
            else
            {
                isUploaded = false;
                await JS.InvokeVoidAsync("alert", "Mission Upload Failed. Check telemetry connection.");
            }

            isUploading = false;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        OnMissionChanged -= TriggerMapRedraw;
        Drone.OnTelemetryUpdated -= RefreshUi;

        try
        {
            await JS.InvokeVoidAsync("preserveMap");
        }
        catch { }
    }

    private void StartMission()
    {
        if (isUploaded) Drone.SetFlightMode("AUTO");
    }
}