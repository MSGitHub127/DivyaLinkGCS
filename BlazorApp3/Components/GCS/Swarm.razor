@inject MavlinkService Drone
@implements IDisposable

<div class="flex flex-col h-full bg-[#0d1117] text-[#c9d1d9] font-sans">

    @* HEADER *@
    <div class="flex justify-between items-center px-[16px] py-[10px] border-b border-[#30363d] shrink-0">
        <div class="flex gap-[8px] items-center text-[#8b949e]">
            <i class="bi bi-diagram-3-fill"></i>
            <span class="font-bold text-[0.8rem] tracking-wider">SWARM COMMANDER</span>
        </div>
        <div class="flex items-center gap-[6px]">
            <span class="w-[6px] h-[6px] bg-[#3fb950] rounded-full shadow-[0_0_4px_#3fb950]"></span>
            <span class="text-[0.6rem] font-mono text-[#3fb950] tracking-[1px] font-bold">DATALINK ACTIVE</span>
        </div>
    </div>

    @* MAIN CONTAINER *@
    <div class="p-[16px] flex flex-col gap-[16px] flex-1 overflow-hidden">

        @* --- TACTICAL FLEET SUMMARY --- *@
        <div class="grid grid-cols-3 gap-[12px] shrink-0">
            <div class="bg-[#161b22] border border-[#30363d] border-t-2 border-t-[#444c56] p-[12px] flex flex-col items-start">
                <span class="text-[0.6rem] color-[#8b949e] font-bold tracking-[1px] mb-[4px] text-[#8b949e]">SYS.NODES</span>
                <span class="text-[1.5rem] font-mono font-bold leading-none">@GetActiveDroneCount()</span>
            </div>
            <div class="bg-[#161b22] border border-[#30363d] border-t-2 border-t-[#444c56] p-[12px] flex flex-col items-start">
                <span class="text-[0.6rem] color-[#8b949e] font-bold tracking-[1px] mb-[4px] text-[#8b949e]">AIRBORNE</span>
                <span class="text-[1.5rem] font-mono font-bold leading-none text-[#58a6ff]">@GetAirborneCount()</span>
            </div>
            <div class="bg-[#161b22] border border-[#30363d] border-t-2 border-t-[#444c56] p-[12px] flex flex-col items-start">
                <span class="text-[0.6rem] color-[#8b949e] font-bold tracking-[1px] mb-[4px] text-[#8b949e]">AVG BATT</span>
                <span class="text-[1.5rem] font-mono font-bold leading-none @(GetAvgBattery() < 30 ? "text-[#f85149]" : "text-[#3fb950]")">
                    @GetAvgBattery() <span class="text-[0.8rem] text-[#8b949e]">%</span>
                </span>
            </div>
        </div>

        @* --- GLOBAL OPERATIONS (FLAT TACTICAL UI) --- *@
        <div class="bg-[#161b22] border border-[#30363d] flex flex-col shrink-0">
            <div class="bg-[#21262d] px-[12px] py-[6px] text-[0.65rem] font-bold text-[#8b949e] border-b border-[#30363d] tracking-[0.5px]">GLOBAL BROADCAST COMMANDS</div>
            <div class="grid grid-cols-2 gap-[8px] p-[12px]">
                <button class="flex-1 bg-[#21262d] border border-[rgba(248,81,73,0.4)] text-[#ff8080] text-[0.75rem] font-semibold cursor-pointer flex items-center justify-center gap-[8px] h-[36px] transition-all duration-100 hover:bg-[rgba(248,81,73,0.1)] active:bg-[#161b22] active:border-[#8b949e]" @onclick="() => SwarmArm(true)">
                    <i class="bi bi-shield-fill-exclamation"></i> ARM FLEET
                </button>
                <button class="flex-1 bg-[#21262d] border border-[rgba(46,160,67,0.4)] text-[#3fb950] text-[0.75rem] font-semibold cursor-pointer flex items-center justify-center gap-[8px] h-[36px] transition-all duration-100 hover:bg-[#30363d] active:bg-[#161b22] active:border-[#8b949e]" @onclick="() => SwarmArm(false)">
                    <i class="bi bi-shield-slash-fill"></i> DISARM FLEET
                </button>

                <div class="col-span-2 flex bg-[#0d1117] border border-[#30363d] h-[36px]">
                    <input type="number" class="bg-transparent border-none text-[#58a6ff] w-[60px] text-right font-mono text-[1rem] font-bold outline-none" @bind="takeoffAlt" min="2" max="100" />
                    <span class="text-[#8b949e] text-[0.8rem] px-[10px] pl-[4px] self-center">m</span>
                    <button class="flex-1 bg-[#1f6feb] border-none text-white text-[0.75rem] font-semibold cursor-pointer flex items-center justify-center gap-[8px] h-full transition-all duration-100 hover:bg-[#388bfd]" @onclick="SwarmTakeoff">
                        TAKEOFF ALL
                    </button>
                </div>

                <button class="flex-1 bg-[#21262d] border border-[#363b42] text-[#d29922] text-[0.75rem] font-semibold cursor-pointer flex items-center justify-center gap-[8px] h-[36px] transition-all duration-100 hover:bg-[#30363d] active:bg-[#161b22] active:border-[#8b949e]" @onclick="SwarmRTL">
                    <i class="bi bi-house-door-fill"></i> RTL ALL
                </button>
                <button class="flex-1 bg-[#21262d] border border-[#363b42] text-[#58a6ff] text-[0.75rem] font-semibold cursor-pointer flex items-center justify-center gap-[8px] h-[36px] transition-all duration-100 hover:bg-[#30363d] active:bg-[#161b22] active:border-[#8b949e]" @onclick="SwarmLand">
                    <i class="bi bi-arrow-down-square-fill"></i> LAND ALL
                </button>
            </div>
        </div>

        @* --- FLEET DATAGRID --- *@
        <div class="flex-1 bg-[#161b22] border border-[#30363d] flex flex-col overflow-hidden min-h-0">
            <div class="bg-[#21262d] px-[12px] py-[6px] text-[0.65rem] font-bold text-[#8b949e] border-b border-[#30363d] tracking-[0.5px] shrink-0">FLEET TELEMETRY ROSTER</div>

            <div class="flex flex-col h-full overflow-hidden">
                <div class="grid grid-cols-[50px_60px_1fr_60px_50px_60px] items-center px-[12px] font-mono h-[28px] text-[0.65rem] text-[#8b949e] border-b border-[#30363d] bg-[#0d1117] shrink-0">
                    <div class="text-[#8b949e]">SYS</div>
                    <div>STATE</div>
                    <div class="text-[#58a6ff]">MODE</div>
                    <div>ALT(m)</div>
                    <div>BATT</div>
                    <div class="text-center">PRIMARY</div>
                </div>

                <div class="flex-1 overflow-y-auto no-scrollbar">
                    @if (!Drone.State.HasVehicleId && Drone.ActiveSwarm.IsEmpty)
                    {
                        <div class="flex flex-col items-center justify-center h-[100px] text-[#444c56] font-sans text-[0.75rem] font-bold">
                            <i class="bi bi-broadcast text-[1.5rem] mb-[8px]"></i>
                            <span>NO MAVLINK NODES DETECTED</span>
                        </div>
                    }
                    else
                    {
                        @* Primary Drone Row *@
                        @if (Drone.State.HasVehicleId)
                        {
                            var isTarget = Drone.target_sysid == Drone.State.SystemId;
                            <div class="grid grid-cols-[50px_60px_1fr_60px_50px_60px] items-center px-[12px] font-mono h-[36px] border-b border-[#21262d] cursor-pointer text-[0.8rem] transition-colors duration-100 hover:bg-[#21262d] @(isTarget ? "bg-[rgba(88,166,255,0.1)] border-l-[3px] border-l-[#58a6ff] !pl-[9px]" : "")" @onclick="() => SetTargetSysId(Drone.State.SystemId)">
                                <div class="@(isTarget ? "text-white font-bold" : "text-[#8b949e]")">@Drone.State.SystemId.ToString("D3")</div>
                                <div><span class="text-[0.6rem] px-[4px] py-[2px] rounded-[2px] font-bold font-sans @(Drone.State.IsArmed ? "bg-[#490202] text-[#ff8080] border border-[#f85149]" : "bg-[#04260f] text-[#3fb950] border border-[#2ea043]")">@(Drone.State.IsArmed ? "ARM" : "STBY")</span></div>
                                <div class="text-[#58a6ff]">@Drone.State.FlightMode</div>
                                <div>@Drone.State.Altitude.ToString("0.0")</div>
                                <div class="@(Drone.State.BatteryPercent < 20 ? "text-[#f85149] font-bold" : "")">@Drone.State.BatteryPercent%</div>
                                <div class="text-center">
                                    <div class="w-[14px] h-[14px] border-2 rounded-full mx-auto relative @(isTarget ? "border-[#58a6ff] after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:right-[2px] after:bottom-[2px] after:bg-[#58a6ff] after:rounded-full" : "border-[#555]")"></div>
                                </div>
                            </div>
                        }

                        @* Swarm Dictionary Rows *@
                        @foreach (var kvp in Drone.ActiveSwarm.Where(x => x.Key != Drone.State.SystemId))
                        {
                            var sys = kvp.Value;
                            var isTarget = Drone.target_sysid == kvp.Key;
                            <div class="grid grid-cols-[50px_60px_1fr_60px_50px_60px] items-center px-[12px] font-mono h-[36px] border-b border-[#21262d] cursor-pointer text-[0.8rem] transition-colors duration-100 hover:bg-[#21262d] @(isTarget ? "bg-[rgba(88,166,255,0.1)] border-l-[3px] border-l-[#58a6ff] !pl-[9px]" : "")" @onclick="() => SetTargetSysId(kvp.Key)">
                                <div class="@(isTarget ? "text-white font-bold" : "text-[#8b949e]")">@kvp.Key.ToString("D3")</div>
                                <div><span class="text-[0.6rem] px-[4px] py-[2px] rounded-[2px] font-bold font-sans @(sys.IsArmed ? "bg-[#490202] text-[#ff8080] border border-[#f85149]" : "bg-[#04260f] text-[#3fb950] border border-[#2ea043]")">@(sys.IsArmed ? "ARM" : "STBY")</span></div>
                                <div class="text-[#58a6ff]">@sys.FlightMode</div>
                                <div>@sys.Altitude.ToString("0.0")</div>
                                <div class="@(sys.BatteryPercent < 20 ? "text-[#f85149] font-bold" : "")">@sys.BatteryPercent%</div>
                                <div class="text-center">
                                    <div class="w-[14px] h-[14px] border-2 rounded-full mx-auto relative @(isTarget ? "border-[#58a6ff] after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:right-[2px] after:bottom-[2px] after:bg-[#58a6ff] after:rounded-full" : "border-[#555]")"></div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int takeoffAlt = 10;

    protected override void OnInitialized()
    {
        Drone.OnTelemetryUpdated += RefreshUi;
    }

    private void RefreshUi()
    {
        // Safely routes the background telemetry update back to the main UI thread
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Drone.OnTelemetryUpdated -= RefreshUi;
    }

    private int GetActiveDroneCount()
    {
        int count = Drone.ActiveSwarm.Count;
        if (Drone.State.HasVehicleId && !Drone.ActiveSwarm.ContainsKey(Drone.State.SystemId)) count++;
        return count;
    }

    private int GetAirborneCount()
    {
        int count = Drone.ActiveSwarm.Values.Count(d => d.Altitude > 2.0);
        if (Drone.State.HasVehicleId && Drone.State.Altitude > 2.0 && !Drone.ActiveSwarm.ContainsKey(Drone.State.SystemId)) count++;
        return count;
    }

    private int GetAvgBattery()
    {
        var drones = Drone.ActiveSwarm.Values.ToList();
        if (Drone.State.HasVehicleId && !Drone.ActiveSwarm.ContainsKey(Drone.State.SystemId)) drones.Add(Drone.State);

        if (!drones.Any()) return 0;
        return (int)drones.Average(d => d.BatteryPercent);
    }

    private void SetTargetSysId(byte sysId)
    {
        Drone.target_sysid = sysId;
        Drone.Toast($"GCS Primary Target set to SysID {sysId}", MavlinkService.ToastLevel.Info, "🎯");
    }

    // --- Swarm Commands ---
    private void SwarmArm(bool arm)
    {
        Drone.BroadcastArmRequest(arm);
        Drone.Toast(arm ? "SWARM COMMAND: ARMING" : "SWARM COMMAND: DISARMING",
            arm ? MavlinkService.ToastLevel.Warning : MavlinkService.ToastLevel.Success,
            arm ? "🔴" : "🟢");
    }

    private void SwarmTakeoff()
    {
        Drone.BroadcastFlightMode("GUIDED");
        Task.Delay(500).ContinueWith(_ =>
        {
            Drone.BroadcastCommand(MAVLink.MAV_CMD.TAKEOFF, 0, 0, 0, 0, 0, 0, takeoffAlt);
            Drone.Toast($"SWARM COMMAND: TAKEOFF TO {takeoffAlt}m", MavlinkService.ToastLevel.Warning, "🚀");
        });
    }

    private void SwarmRTL()
    {
        Drone.BroadcastFlightMode("RTL");
        Drone.Toast("SWARM COMMAND: RTL TRIGGERED", MavlinkService.ToastLevel.Warning, "🏠");
    }

    private void SwarmLand()
    {
        Drone.BroadcastFlightMode("LAND");
        Drone.Toast("SWARM COMMAND: LAND TRIGGERED", MavlinkService.ToastLevel.Info, "🛬");
    }
}