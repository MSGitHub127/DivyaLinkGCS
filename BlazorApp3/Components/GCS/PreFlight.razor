@page "/preflight"
@inject MavlinkService Drone
@implements IDisposable

<div class="preflight-view-container">
    <div class="hud-wrapper">
        <Hud />
    </div>

    <div class="checklist-section">
        <div class="header-strip">
            <span class="icon">🛡️</span> PRE-ARM SAFETY CHECKS
        </div>

        <div class="check-list-scroll">
            @* GPS CHECK *@
            <div class="check-item @(Drone.State.SatCount >= 8 ? "pass" : "fail")">
                <div class="status-indicator"></div>
                <div class="check-details">
                    <span class="check-label">GPS SATELLITES</span>
                    <span class="check-value">@Drone.State.SatCount Sats (Min 8)</span>
                </div>
            </div>

            @* BATTERY CHECK *@
            <div class="check-item @(Drone.State.BatteryPercent > 20 ? "pass" : "fail")">
                <div class="status-indicator"></div>
                <div class="check-details">
                    <span class="check-label">BATTERY CAPACITY</span>
                    <span class="check-value">@Drone.State.BatteryPercent% (@Drone.State.Voltage.ToString("0.0")V)</span>
                </div>
            </div>

            @* FLIGHT MODE CHECK *@
            <div class="check-item @(Drone.State.FlightMode != "Unknown" ? "pass" : "fail")">
                <div class="status-indicator"></div>
                <div class="check-details">
                    <span class="check-label">FLIGHT MODE VALID</span>
                    <span class="check-value">@Drone.State.FlightMode</span>
                </div>
            </div>

            @* LINK QUALITY (Simulated logic based on heartbeat) *@
            <div class="check-item @(IsLinkHealthy() ? "pass" : "fail")">
                <div class="status-indicator"></div>
                <div class="check-details">
                    <span class="check-label">GCS TELEMETRY LINK</span>
                    <span class="check-value">@(IsLinkHealthy() ? "STABLE" : "LOST HEARTBEAT")</span>
                </div>
            </div>
        </div>

        @if (Drone.State.SatCount < 8 && Drone.State.FlightMode == "LOITER")
        {
            <div class="warning-box">
                ⚠️ GPS WEAK: Switch to STABILIZE mode for indoor testing.
            </div>
        }
    </div>
</div>

<style>
    :root {
        --gcs-bg: #0d1117;
        --gcs-card: #161b22;
        --gcs-border: #30363d;
        --gcs-cyan: #58a6ff;
        --gcs-amber: #d29922;
        --gcs-text: #c9d1d9;
        --gcs-green: #2ea043;
        --gcs-red: #f85149;
    }

    /* STANDARDIZED CONTAINER ALIGNED WITH OTHER TABS */
    .preflight-view-container {
        display: flex;
        flex-direction: column;
        height: 100%;
        gap: 16px;
        padding: 20px;
        background: transparent;
        width: 100%;
        max-width: 500px;
        margin: 0 auto;
        overflow: hidden;
        color: var(--gcs-text);
    }

    /* STANDARDIZED HUD WRAPPER */
    .hud-wrapper {
        height: 300px;
        width: 100%;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.4);
        border: 1px solid var(--gcs-border);
        flex-shrink: 0;
        background: #000;
    }

    /* CHECKLIST CARD MODULE */
    .checklist-section {
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        gap: 15px;
        min-height: 0;
        background: rgba(18, 20, 28, 0.6);
        border: 1px solid var(--gcs-border);
        border-radius: 8px;
        padding: 16px;
        backdrop-filter: blur(4px);
    }

    .header-strip {
        padding-bottom: 12px;
        border-bottom: 1px solid var(--gcs-border);
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 900;
        font-size: 0.85rem;
        text-transform: uppercase;
        color: white;
        letter-spacing: 1.5px;
    }

    /* CUSTOM SCROLL AREA */
    .check-list-scroll {
        flex-grow: 1;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding-right: 5px;
    }

    .check-list-scroll::-webkit-scrollbar {
            width: 4px;
        }

    .check-list-scroll::-webkit-scrollbar-thumb {
            background: var(--gcs-border);
            border-radius: 10px;
        }

    /* CYBERPUNK CHECKLIST ITEMS */
    .check-item {
        background: #010409;
        border: 1px solid var(--gcs-border);
        border-radius: 6px;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        gap: 15px;
        transition: all 0.2s ease;
    }

    .check-item:hover {
            transform: translateX(2px);
            border-color: #555;
        }

    .check-item.pass {
            border-left: 4px solid var(--gcs-green);
        }

    .check-item.fail {
            border-left: 4px solid var(--gcs-red);
            background: rgba(248, 81, 73, 0.05); /* Slight red tint for failures */
        }

    /* NEON INDICATOR LIGHTS */
    .status-indicator {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .pass .status-indicator {
        background: #3fb950;
        box-shadow: 0 0 10px #3fb950;
    }

    .fail .status-indicator {
        background: var(--gcs-red);
        box-shadow: 0 0 10px var(--gcs-red);
    }

    /* TEXT FORMATTING */
    .check-details {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .check-label {
        font-size: 0.6rem;
        color: #8b949e;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .check-value {
        font-size: 0.9rem;
        font-family: monospace;
        font-weight: bold;
    }

    .fail .check-value {
        color: var(--gcs-red);
    }

    .pass .check-value {
        color: #3fb950;
    }

    /* WARNING BANNER */
    .warning-box {
        background: rgba(210, 153, 34, 0.1);
        border: 1px solid var(--gcs-amber);
        color: var(--gcs-amber);
        padding: 12px;
        border-radius: 6px;
        font-size: 0.7rem;
        font-weight: 800;
        text-align: center;
        margin-top: 5px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }
</style>

@code {
    protected override void OnInitialized() => Drone.OnTelemetryUpdated += RefreshUi;
    private void RefreshUi() => InvokeAsync(StateHasChanged);
    public void Dispose() => Drone.OnTelemetryUpdated -= RefreshUi;
    private bool IsLinkHealthy() => (DateTime.Now - Drone.LastPacketTime).TotalSeconds < 3;
}