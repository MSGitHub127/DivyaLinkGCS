@page "/preflight"
@inject MavlinkService Drone
@implements IDisposable

<div class="flex flex-col h-full gap-[16px] p-[20px] bg-transparent w-full max-w-[500px] mx-auto overflow-hidden text-[#c9d1d9]">

    <div class="h-[300px] w-full rounded-[8px] overflow-hidden shadow-[0_4px_20px_rgba(0,0,0,0.4)] border border-[#30363d] shrink-0 bg-black">
        <Hud />
    </div>

    <div class="flex flex-col flex-1 gap-[15px] min-h-0 bg-[rgba(18,20,28,0.6)] border border-[#30363d] rounded-[8px] p-[16px] backdrop-blur-[4px]">
        <div class="pb-[12px] border-b border-[#30363d] flex items-center gap-[10px] font-black text-[0.85rem] uppercase text-white tracking-[1.5px] shrink-0">
            <span class="text-[1rem]">🛡️</span> PRE-ARM SAFETY CHECKS
        </div>

        <div class="flex-1 overflow-y-auto flex flex-col gap-[10px] pr-[5px] [&::-webkit-scrollbar]:w-[4px] [&::-webkit-scrollbar-thumb]:bg-[#30363d] [&::-webkit-scrollbar-thumb]:rounded-[10px]">

            @* GPS CHECK *@
            @{
                var gpsPass = Drone.State.SatCount >= 8;
            }
            <div class="group bg-[#010409] border border-[#30363d] rounded-[6px] p-[12px_16px] flex items-center gap-[15px] transition-all duration-200 hover:translate-x-[2px] hover:border-[#555] @(gpsPass ? "border-l-[4px] !border-l-[#3fb950]" : "border-l-[4px] !border-l-[#f85149] bg-[rgba(248,81,73,0.05)]")">
                <div class="w-[10px] h-[10px] rounded-full shrink-0 @(gpsPass ? "bg-[#3fb950] shadow-[0_0_10px_#3fb950]" : "bg-[#f85149] shadow-[0_0_10px_#f85149]")"></div>
                <div class="flex flex-col gap-[4px]">
                    <span class="text-[0.6rem] text-[#8b949e] font-extrabold uppercase tracking-[0.5px]">GPS SATELLITES</span>
                    <span class="text-[0.9rem] font-mono font-bold @(gpsPass ? "text-[#3fb950]" : "text-[#f85149]")">@Drone.State.SatCount Sats (Min 8)</span>
                </div>
            </div>

            @* BATTERY CHECK *@
            @{
                var battPass = Drone.State.BatteryPercent > 20;
            }
            <div class="group bg-[#010409] border border-[#30363d] rounded-[6px] p-[12px_16px] flex items-center gap-[15px] transition-all duration-200 hover:translate-x-[2px] hover:border-[#555] @(battPass ? "border-l-[4px] !border-l-[#3fb950]" : "border-l-[4px] !border-l-[#f85149] bg-[rgba(248,81,73,0.05)]")">
                <div class="w-[10px] h-[10px] rounded-full shrink-0 @(battPass ? "bg-[#3fb950] shadow-[0_0_10px_#3fb950]" : "bg-[#f85149] shadow-[0_0_10px_#f85149]")"></div>
                <div class="flex flex-col gap-[4px]">
                    <span class="text-[0.6rem] text-[#8b949e] font-extrabold uppercase tracking-[0.5px]">BATTERY CAPACITY</span>
                    <span class="text-[0.9rem] font-mono font-bold @(battPass ? "text-[#3fb950]" : "text-[#f85149]")">@Drone.State.BatteryPercent% (@Drone.State.Voltage.ToString("0.0")V)</span>
                </div>
            </div>

            @* FLIGHT MODE CHECK *@
            @{
                var modePass = Drone.State.FlightMode != "Unknown";
            }
            <div class="group bg-[#010409] border border-[#30363d] rounded-[6px] p-[12px_16px] flex items-center gap-[15px] transition-all duration-200 hover:translate-x-[2px] hover:border-[#555] @(modePass ? "border-l-[4px] !border-l-[#3fb950]" : "border-l-[4px] !border-l-[#f85149] bg-[rgba(248,81,73,0.05)]")">
                <div class="w-[10px] h-[10px] rounded-full shrink-0 @(modePass ? "bg-[#3fb950] shadow-[0_0_10px_#3fb950]" : "bg-[#f85149] shadow-[0_0_10px_#f85149]")"></div>
                <div class="flex flex-col gap-[4px]">
                    <span class="text-[0.6rem] text-[#8b949e] font-extrabold uppercase tracking-[0.5px]">FLIGHT MODE VALID</span>
                    <span class="text-[0.9rem] font-mono font-bold @(modePass ? "text-[#3fb950]" : "text-[#f85149]")">@Drone.State.FlightMode</span>
                </div>
            </div>

            @* LINK QUALITY *@
            @{
                var linkPass = IsLinkHealthy();
            }
            <div class="group bg-[#010409] border border-[#30363d] rounded-[6px] p-[12px_16px] flex items-center gap-[15px] transition-all duration-200 hover:translate-x-[2px] hover:border-[#555] @(linkPass ? "border-l-[4px] !border-l-[#3fb950]" : "border-l-[4px] !border-l-[#f85149] bg-[rgba(248,81,73,0.05)]")">
                <div class="w-[10px] h-[10px] rounded-full shrink-0 @(linkPass ? "bg-[#3fb950] shadow-[0_0_10px_#3fb950]" : "bg-[#f85149] shadow-[0_0_10px_#f85149]")"></div>
                <div class="flex flex-col gap-[4px]">
                    <span class="text-[0.6rem] text-[#8b949e] font-extrabold uppercase tracking-[0.5px]">
                        @(Drone.IsWireless ? "RADIO TELEMETRY LINK" : "USB DIRECT CONNECTION")
                    </span>
                    <span class="text-[0.9rem] font-mono font-bold @(linkPass ? "text-[#3fb950]" : "text-[#f85149]")">
                        @(linkPass ? "STABLE (HEARTBEAT OK)" : "LINK LOST")
                    </span>
                </div>
            </div>
        </div>

        @if (Drone.State.SatCount < 8 && Drone.State.FlightMode == "LOITER")
        {
            <div class="bg-[rgba(210,153,34,0.1)] border border-[#d29922] text-[#d29922] p-[12px] rounded-[6px] text-[0.7rem] font-extrabold text-center mt-[5px] flex items-center justify-center gap-[8px]">
                ⚠️ GPS WEAK: Switch to STABILIZE mode for indoor testing.
            </div>
        }
    </div>
</div>

@code {
    protected override void OnInitialized() => Drone.OnTelemetryUpdated += RefreshUi;

    private DateTime _lastUiUpdate = DateTime.MinValue;
    private void RefreshUi()
    {
        var now = DateTime.UtcNow;
        // Throttle UI updates to 10Hz (100ms) to prevent render storms
        if ((now - _lastUiUpdate).TotalMilliseconds < 100) return;
        _lastUiUpdate = now;

        InvokeAsync(StateHasChanged);
    }

    public void Dispose() => Drone.OnTelemetryUpdated -= RefreshUi;
    private bool IsLinkHealthy() => (DateTime.UtcNow - Drone.LastPacketTime).TotalSeconds < 3;
}