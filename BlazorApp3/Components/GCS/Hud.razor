@inject MavlinkService Drone
@implements IDisposable

<div class="hud-component-container">
    <div class="hud-frame">

        <div class="horizon-layer"
             style="transform: rotate(@(-Drone.State.Roll)deg) translateY(@(Drone.State.Pitch * 4)px);">
            <div class="sky"></div>
            <div class="ground"></div>
            <div class="pitch-ladder">
                <div class="line pos-20"></div>
                <div class="line pos-10"></div>
                <div class="line zero"></div>
                <div class="line neg-10"></div>
                <div class="line neg-20"></div>
            </div>
        </div>

        <div class="crosshair-svg">
            <svg viewBox="0 0 100 100" width="60" height="60">
                <path d="M 10 50 L 35 50 L 50 65 L 65 50 L 90 50"
                      stroke="yellow" stroke-width="3" fill="none"
                      filter="drop-shadow(0px 0px 2px rgba(0,0,0,0.8))" />
                <circle cx="50" cy="50" r="2" fill="yellow" />
            </svg>
        </div>

        <div class="hud-top-bar">
            <div class="heading-box">
                <span class="heading-val">@Drone.State.Yaw.ToString("0")°</span>
                <span class="heading-label">@GetCardinal(Drone.State.Yaw)</span>
            </div>
        </div>

        <div class="hud-tape left-tape">
            <div class="tape-label">SPD m/s</div>
            <div class="tape-window">
                @Drone.State.GroundSpeed.ToString("0.0")
            </div>
        </div>

        <div class="hud-tape right-tape">
            <div class="tape-label">ALT m</div>
            <div class="tape-window">
                @Drone.State.Altitude.ToString("0.0")
            </div>
        </div>

        <div class="hud-container">
            <div class='rc-indicator-wrapper' title='@(Drone.State.IsRcConnected ? "RC Connected" : "RC Disconnected")'>
                <svg class='rc-icon @(Drone.State.IsRcConnected ? "rc-on" : "rc-off")'
                     xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
                    <path d="m 26,25 c -9.94,0 -18,10.06 -18,20 0,9.94 2.06,30 12,30
                             5.32,0 16.11,-12.33 19.41,-16 l 21.19,0
                             c 3.3,3.67 14.08,16 19.41,16 9.94,0 12,-20.06 12,-30
                             0,-9.94 -8.06,-20 -18,-20 -5.32,0 -10.11,0.33 -13.41,4
                             l -21.19,0 C 36.11,25.33 31.32,25 26,25 z
                             m 48,9 c 1.66,0 3,1.34 3,3 0,1.66 -1.34,3 -3,3
                             -1.66,0 -3,-1.34 -3,-3 0,-1.66 1.34,-3 3,-3 z
                             m -48.22,1.03 a 2,2 0 0 1 1.78,2.03 l 0,3.97 3.97,0
                             a 2,2 0 0 1 0,4 l -3.97,0 0,3.97 a 2,2 0 0 1 -4,0
                             l 0,-3.97 -3.97,0 a 2,2 0 1 1 0,-4 l 3.97,0 0,-3.97
                             a 2,2 0 0 1 2.22,-2.03 z
                             M 68,40 c 1.66,0 3,1.34 3,3 0,1.66 -1.34,3 -3,3
                             -1.66,0 -3,-1.34 -3,-3 0,-1.66 1.34,-3 3,-3 z
                             m 12,0 c 1.66,0 3,1.34 3,3 0,1.66 -1.34,3 -3,3
                             -1.66,0 -3,-1.34 -3,-3 0,-1.66 1.34,-3 3,-3 z
                             m -6,6 c 1.66,0 3,1.34 3,3 0,1.66 -1.34,3 -3,3
                             -1.66,0 -3,-1.34 -3,-3 0,-1.66 1.34,-3 3,-3 z" />
                </svg>
            </div>
        </div>

        <div class="hud-bottom-panel">
            <div class="status-msg @(Drone.State.IsArmed ? "armed" : "disarmed")">
                @(Drone.State.IsArmed ? "ARMED" : "DISARMED")
            </div>

            <div class="info-row">
                <div class="info-item">
                    <span class="icon">🔋</span> @Drone.State.BatteryPercent%
                </div>
                <div class="info-item">
                    <span class="icon">📡</span> @Drone.State.SatCount
                </div>
                <div class="info-item">
                    <span class="icon">⚡</span> @Drone.State.Voltage.ToString("0.0")V
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* COMPONENT WRAPPER */
    .hud-component-container {
        width: 100%;
        height: 100%;
        display: flex;
        justify-content: center;
    }

    .hud-frame {
        position: relative;
        width: 100%;
        height: 100%; /* Fills the parent container */
        min-height: 280px; /* Minimum height safety */
        background: #000;
        border-radius: 12px;
        overflow: hidden;
        border: 2px solid #333;
        box-shadow: inset 0 0 20px rgba(0,0,0,0.5);
        font-family: 'Consolas', 'Courier New', monospace;
        color: white;
    }

    /* HORIZON */
    .horizon-layer {
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        transition: transform 0.1s linear; /* Smooth 60fps feel */
        z-index: 1;
    }

    .sky {
        height: 50%;
        background: linear-gradient(to bottom, #3a86ff 0%, #87ceeb 100%);
        border-bottom: 2px solid white;
    }

    .ground {
        height: 50%;
        background: linear-gradient(to bottom, #8b4513 0%, #cd853f 100%);
    }

    /* PITCH LADDER */
    .pitch-ladder {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    .line {
        width: 100px;
        height: 1px;
        background: rgba(255,255,255,0.7);
        position: absolute;
    }

    .pos-20 {
        top: 30%;
        width: 60px;
    }

    .pos-10 {
        top: 40%;
        width: 80px;
    }

    .zero {
        top: 50%;
        width: 120px;
        height: 2px;
        background: #00f2ff;
        box-shadow: 0 0 5px #00f2ff;
    }

    .neg-10 {
        top: 60%;
        width: 80px;
        border-top: 1px dashed white;
        background: transparent;
    }

    .neg-20 {
        top: 70%;
        width: 60px;
        border-top: 1px dashed white;
        background: transparent;
    }

    /* CROSSHAIR */
    .crosshair-svg {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 5;
    }

    /* TAPES */
    .hud-tape {
        position: absolute;
        top: 20px;
        bottom: 60px;
        width: 60px;
        background: rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(2px);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255,255,255,0.2);
        z-index: 10;
    }

    .left-tape {
        left: 0;
        border-right: none;
        border-radius: 0 8px 8px 0;
    }

    .right-tape {
        right: 0;
        border-left: none;
        border-radius: 8px 0 0 8px;
    }

    .tape-label {
        font-size: 0.7rem;
        color: #aaa;
        margin-bottom: 5px;
    }

    .tape-window {
        font-size: 1.4rem;
        font-weight: bold;
        color: white;
        text-shadow: 0 0 5px black;
    }

    /* TOP BAR */
    .hud-top-bar {
        position: absolute;
        top: 10px;
        left: 0;
        width: 100%;
        display: flex;
        justify-content: center;
        z-index: 10;
    }

    .heading-box {
        background: rgba(0,0,0,0.6);
        padding: 5px 15px;
        border-radius: 20px;
        border: 1px solid #555;
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .heading-val {
        font-weight: bold;
        color: #00f2ff;
    }

    /* BOTTOM PANEL */
    .hud-bottom-panel {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        background: rgba(0,0,0,0.85);
        padding: 8px;
        z-index: 20;
        display: flex;
        flex-direction: column;
        gap: 5px;
        border-top: 1px solid #444;
    }

    .status-msg {
        text-align: center;
        font-weight: 900;
        letter-spacing: 2px;
        font-size: 1rem;
    }

        .status-msg.disarmed {
            color: #ff3a3a;
            text-shadow: 0 0 10px #ff3a3a;
        }

        .status-msg.armed {
            color: #00ff00;
            text-shadow: 0 0 10px #00ff00;
        }

    .info-row {
        display: flex;
        justify-content: space-around;
        font-size: 0.9rem;
        color: #ddd;
    }

    .info-item {
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .rc-indicator-wrapper {
        position: absolute;
        top: 5px;
        right: 5px;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(13, 17, 23, 0.7);
        padding: 6px;
        border-radius: 8px;
        border: 1px solid #30363d;
        backdrop-filter: blur(4px);
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
    }

    .rc-icon {
        width: 30px;
        height: 30px;
        transition: fill 0.4s ease, filter 0.4s ease;
    }

        /* RC connected — green fill with glow */
        .rc-icon.rc-on {
            fill: #8abe4e;
            filter: drop-shadow(0 0 5px rgba(138, 190, 78, 0.7));
        }

        /* RC disconnected — grey, no glow */
        .rc-icon.rc-off {
            fill: #4a4a4a;
            filter: none;
            opacity: 0.75;
        }
</style>

@code {
    private PeriodicTimer _timer;
    private CancellationTokenSource _cts = new();

    protected override void OnInitialized()
    {
        // Smooth 60FPS update for Horizon
        _timer = new PeriodicTimer(TimeSpan.FromMilliseconds(50));
        _ = RunTimer();
    }

    private async Task RunTimer()
    {
        while (await _timer.WaitForNextTickAsync(_cts.Token))
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _timer?.Dispose();
    }

    private string GetCardinal(double heading)
    {
        string[] cardinals = { "N", "NE", "E", "SE", "S", "SW", "W", "NW", "N" };
        return cardinals[(int)Math.Round(((double)heading % 360) / 45)];
    }
}