@page "/actions"
@inject MavlinkService Drone
@implements IDisposable

<div class="actions-view-container">
    <div class="hud-wrapper">
        <Hud />
    </div>

    <div class="actions-content">
        <div class="header-strip">
            <span class="icon">🕹️</span> MISSION CONTROL
        </div>

        <div class="command-scroll-area">

            <div class="arm-action-area">
                <button class="clean-arm-btn @(Drone.State.IsArmed ? "state-armed" : "state-disarmed")" @onclick="HandleArmClick">
                    <div class="icon-box">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 2L3 7V11C3 16.55 6.84 21.74 12 23C17.16 21.74 21 16.55 21 11V7L12 2Z" />
                            <path d="M12 7V15M9 11H15" stroke-linecap="round" />
                        </svg>
                    </div>
                    <span class="btn-label">@(Drone.State.IsArmed ? "DISARM SYSTEM" : "ARM SYSTEM")</span>
                </button>
            </div>

            <div class="action-card">
                <div class="card-header">
                    <span class="card-icon">🚀</span>
                    <span class="card-title">Precision Takeoff</span>
                </div>
                <div class="input-container">
                    <label>TARGET ALTITUDE (METERS)</label>
                    <div class="input-group">
                        <input type="number" @bind="TakeoffAlt" step="1.0" min="1" class="cmd-input" />
                        <button class="btn btn-green @(CanTakeoff ? "" : "disabled")" @onclick="HandleTakeoff">
                            @(Drone.State.IsArmed ? "EXECUTE TAKEOFF" : "ARM REQUIRED")
                        </button>
                    </div>
                </div>
                <p class="card-hint">Drone will rise to @TakeoffAlt m and hover.</p>
            </div>

            <div class="action-card">
                <div class="card-header">
                    <span class="card-icon">🏠</span>
                    <span class="card-title">Safe Return to Home</span>
                </div>
                <div class="input-container">
                    <label>CLEARANCE ALTITUDE (METERS)</label>
                    <div class="input-group">
                        <input type="number" @bind="RtlAlt" step="1.0" min="5" class="cmd-input" />
                        <button class="btn btn-blue" @onclick="HandleRTL">EXECUTE RTL</button>
                    </div>
                </div>
                <p class="card-hint">Drone climbs to @RtlAlt m before traveling to launch point.</p>
            </div>

            <div class="emergency-section">
                <div class="card-title" style="color: var(--gcs-red); margin-bottom: 10px;">⚠️ CRITICAL OVERRIDES</div>
                <div class="emergency-grid">
                    <button class="btn btn-red" @onclick='() => Drone.SetFlightMode("LAND")'>LAND NOW</button>
                    <button class="btn btn-orange" @onclick="HandleEmergencyDisarm">EMERGENCY DISARM</button>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    :root {
        --gcs-bg: #0d1117;
        --gcs-card: #161b22;
        --gcs-border: #30363d;
        --gcs-cyan: #58a6ff;
        --gcs-amber: #d29922;
        --gcs-text: #c9d1d9;
        --gcs-green: #2ea043;
        --gcs-red: #f85149;
    }

    .actions-view-container {
        display: flex;
        flex-direction: column;
        height: 100%;
        gap: 16px;
        padding: 20px;
        background: transparent;
        width: 100%;
        max-width: 500px;
        margin: 0 auto;
        overflow: hidden;
        color: var(--gcs-text);
    }

    .hud-wrapper {
        height: 300px;
        width: 100%;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid var(--gcs-border);
        box-shadow: 0 4px 20px rgba(0,0,0,0.4);
        flex-shrink: 0;
        background: #000;
    }

    .actions-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 12px;
        min-height: 0;
        background: rgba(18, 20, 28, 0.6);
        border: 1px solid var(--gcs-border);
        border-radius: 8px;
        padding: 16px;
        backdrop-filter: blur(4px);
    }

    .header-strip {
        padding-bottom: 12px;
        border-bottom: 1px solid var(--gcs-border);
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 900;
        font-size: 0.85rem;
        text-transform: uppercase;
        color: white;
        letter-spacing: 1.5px;
    }

    .command-scroll-area {
        flex: 1;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 15px;
        padding-right: 5px;
    }

    .action-card {
        background: #010409;
        border: 1px solid var(--gcs-border);
        border-radius: 8px;
        padding: 16px;
        transition: border-color 0.2s;
    }

    .action-card:hover {
            border-color: var(--gcs-cyan);
        }

    .card-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 12px;
    }

    .card-title {
        font-size: 0.9rem;
        font-weight: bold;
        color: white;
    }

    .card-icon {
        font-size: 1.2rem;
    }

    .input-container {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .input-container label {
            font-size: 0.6rem;
            color: #8b949e;
            font-weight: 800;
            text-transform: uppercase;
        }

    .input-group {
        display: flex;
        gap: 10px;
    }

    .cmd-input {
        width: 80px;
        background: #010409;
        border: 1px solid var(--gcs-border);
        color: var(--gcs-cyan);
        padding: 8px;
        border-radius: 4px;
        font-family: monospace;
        font-weight: bold;
        font-size: 1.1rem;
        text-align: center;
        outline: none;
    }

    .cmd-input:focus {
            border-color: var(--gcs-cyan);
        }

    .btn {
        flex: 1;
        border: none;
        border-radius: 4px;
        color: white;
        font-weight: 900;
        cursor: pointer;
        text-transform: uppercase;
        font-size: 0.75rem;
        transition: filter 0.2s;
    }

    .btn:hover {
            filter: brightness(1.2);
        }

    .btn.disabled {
            opacity: 0.2;
            cursor: not-allowed;
        }

    .btn-green {
        background: var(--gcs-green);
        border: 1px solid #3fb950;
    }

    .btn-blue {
        background: var(--gcs-cyan);
        color: #000;
    }

    .btn-red {
        background: var(--gcs-red);
    }

    .btn-orange {
        background: var(--gcs-amber);
    }

    .card-hint {
        font-size: 0.65rem;
        color: #8b949e;
        margin-top: 8px;
        font-style: italic;
    }

    .emergency-section {
        margin-top: 10px;
        padding-top: 15px;
        border-top: 1px dashed var(--gcs-border);
    }

    .emergency-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .emergency-grid .btn {
            height: 45px;
        }

    /* Custom Scrollbar */
    .command-scroll-area::-webkit-scrollbar {
        width: 4px;
    }

    .command-scroll-area::-webkit-scrollbar-thumb {
        background: var(--gcs-border);
        border-radius: 10px;
    }

    .arm-action-area {
        width: 100%;
        margin-top: 5px;
    }

    .clean-arm-btn {
        width: 100%;
        height: 50px;
        border: none;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        cursor: pointer;
        transition: all 0.2s ease;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-size: 0.9rem;
        color: white;
    }

    .state-armed {
        background: linear-gradient(90deg, #3a0d0d 0%, var(--gcs-red) 100%);
        box-shadow: 0 4px 15px rgba(248, 81, 73, 0.2);
    }

    .state-disarmed {
        background: linear-gradient(90deg, #0d3a1a 0%, var(--gcs-green) 100%);
        box-shadow: 0 4px 15px rgba(46, 160, 67, 0.2);
        color: #fff;
    }

    .clean-arm-btn:hover {
        filter: brightness(1.1);
        transform: translateY(-1px);
    }

    .icon-box svg {
        width: 20px;
        height: 20px;
    }
</style>

@code {
    private float TakeoffAlt = 10.0f;
    private float RtlAlt = 30.0f;
    private bool CanTakeoff => Drone.State.IsArmed;

    private void HandleArmClick() => Drone.SendArmRequest(!Drone.State.IsArmed);

    protected override void OnInitialized()
    {
        Drone.OnTelemetryUpdated += RefreshUi;
    }

    private void RefreshUi() => InvokeAsync(StateHasChanged);

    private void HandleTakeoff()
    {
        if (!CanTakeoff) return;

        // 1. Drones usually need to be in GUIDED mode to accept software takeoff commands
        Drone.SetFlightMode("GUIDED");

        // 2. MAV_CMD_NAV_TAKEOFF (Enum 22). Param 7 is altitude in meters.
        Drone.SendCommand(MAVLink.MAV_CMD.TAKEOFF, 0, 0, 0, 0, 0, 0, TakeoffAlt);

        Console.WriteLine($"Command Sent: Takeoff to {TakeoffAlt}m");
    }

    private void HandleRTL()
    {
        // Set RTL_ALT parameter (ArduPilot reads this in Centimeters, not Meters!)
        Drone.SendParameter("RTL_ALT", RtlAlt * 100.0f);

        // Trigger RTL Mode
        Drone.SetFlightMode("RTL");
        Console.WriteLine($"Command Sent: RTL with target clearance of {RtlAlt}m");
    }

    private void HandleEmergencyDisarm()
    {
        // Second parameter 21196 is the "Force" magic number for ArduPilot disarm
        Drone.SendArmRequest(false, true);
    }

    public void Dispose()
    {
        Drone.OnTelemetryUpdated -= RefreshUi;
    }
}