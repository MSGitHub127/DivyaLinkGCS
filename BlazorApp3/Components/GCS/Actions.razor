@page "/actions"
@inject MavlinkService Drone
@implements IDisposable

<div class="flex flex-col h-full gap-[10px] pt-[20px] px-[20px] pb-[5px] bg-transparent w-full max-w-[500px] mx-auto overflow-hidden text-[#c9d1d9]">
    <div class="h-[300px] w-full rounded-[8px] overflow-hidden border border-[#30363d] shadow-[0_4px_20px_rgba(0,0,0,0.4)] shrink-0 bg-black">
        <Hud />
    </div>

    <div class="flex-1 flex flex-col gap-[8px] min-h-0 bg-[rgba(18,20,28,0.6)] border border-[#30363d] rounded-[8px] py-[10px] px-[14px] backdrop-blur-[4px]">
        <div class="pb-[8px] border-b border-[#30363d] flex items-center gap-[10px] font-black text-[0.78rem] uppercase text-white tracking-[1.5px] shrink-0">
            <span class="text-[1rem]">🕹️</span> MISSION CONTROL
        </div>

        <div class="flex-1 flex flex-col gap-[10px] overflow-hidden min-h-0">

            @* ── ARM / DISARM ── *@
            <div class="w-full shrink-0">
                <button class="w-full h-[46px] border-none rounded-[6px] flex items-center justify-center gap-[12px] cursor-pointer transition-all duration-200 font-bold tracking-[1px] uppercase text-[0.8rem] text-white hover:brightness-110 hover:-translate-y-[1px] @(Drone.State.IsArmed ? "bg-gradient-to-r from-[#3a0d0d] to-[#f85149] shadow-[0_4px_15px_rgba(248,81,73,0.2)]" : "bg-gradient-to-r from-[#0d3a1a] to-[#2ea043] shadow-[0_4px_15px_rgba(46,160,67,0.2)]")" @onclick="HandleArmClick">
                    <div class="[&>svg]:w-[18px] [&>svg]:h-[18px]">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 2L3 7V11C3 16.55 6.84 21.74 12 23C17.16 21.74 21 16.55 21 11V7L12 2Z" />
                            <path d="M12 7V15M9 11H15" stroke-linecap="round" />
                        </svg>
                    </div>
                    <span>@(Drone.State.IsArmed ? "DISARM SYSTEM" : "ARM SYSTEM")</span>
                </button>
            </div>

            @* ── Precision Takeoff ── *@
            <div class="flex items-center justify-between gap-[10px] bg-[#010409] border border-[#30363d] rounded-[8px] py-[8px] px-[14px] shrink-0 transition-colors duration-200 hover:border-[#444]">
                <div class="flex items-center gap-[10px] flex-1 min-w-0">
                    <div class="flex flex-col gap-[2px] min-w-0">
                        <span class="text-[0.76rem] font-bold text-white whitespace-nowrap">Precision Takeoff</span>
                    </div>
                </div>
                <div class="flex items-center gap-[6px] shrink-0">
                    <div class="flex items-center justify-between w-[85px] bg-[#0a0b0e] border border-[#30363d] rounded-[4px] py-[4px] px-[6px]">
                        <input type="number" @bind="TakeoffAlt" step="1" min="1" class="w-[46px] bg-transparent border-none text-[#58a6ff] font-mono font-bold text-[0.88rem] text-right outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none" />
                        <span class="text-[0.55rem] text-[#555] font-semibold whitespace-nowrap">m</span>
                    </div>
                    <button class="border-none rounded-[4px] text-white font-black cursor-pointer uppercase text-[0.65rem] transition-all duration-200 py-[6px] px-[10px] w-[60px] flex justify-center items-center whitespace-nowrap hover:brightness-120 disabled:opacity-25 disabled:cursor-not-allowed bg-[#2ea043] @(CanTakeoff ? "" : "opacity-25 cursor-not-allowed")" @onclick="HandleTakeoff">
                        @(Drone.State.IsArmed ? "GO" : "ARM")
                    </button>
                </div>
            </div>

            @* ── Return to Home ── *@
            <div class="flex items-center justify-between gap-[10px] bg-[#010409] border border-[#30363d] rounded-[8px] py-[8px] px-[14px] shrink-0 transition-colors duration-200 hover:border-[#444]">
                <div class="flex items-center gap-[10px] flex-1 min-w-0">
                    <div class="flex flex-col gap-[2px] min-w-0">
                        <span class="text-[0.76rem] font-bold text-white whitespace-nowrap">Return to Home</span>
                    </div>
                </div>
                <div class="flex items-center gap-[6px] shrink-0">
                    <div class="flex items-center justify-between w-[85px] bg-[#0a0b0e] border border-[#30363d] rounded-[4px] py-[4px] px-[6px]">
                        <input type="number" @bind="RtlAlt" step="1" min="5" class="w-[46px] bg-transparent border-none text-[#58a6ff] font-mono font-bold text-[0.88rem] text-right outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none" />
                        <span class="text-[0.55rem] text-[#555] font-semibold whitespace-nowrap">m</span>
                    </div>
                    <button class="border-none rounded-[4px] !text-black font-black cursor-pointer uppercase text-[0.65rem] transition-all duration-200 py-[6px] px-[10px] w-[60px] flex justify-center items-center whitespace-nowrap hover:brightness-120 bg-[#58a6ff]" @onclick="HandleRTL">RTL</button>
                </div>
            </div>

            @* ── Precision Landing ── *@
            <div class="flex items-center justify-between gap-[10px] bg-[#010409] border border-[#30363d] rounded-[8px] py-[8px] px-[14px] shrink-0 transition-colors duration-200 hover:border-[#444]">
                <div class="flex items-center gap-[10px] flex-1 min-w-0">
                    <div class="flex flex-col gap-[2px] min-w-0">
                        <span class="text-[0.76rem] font-bold text-white whitespace-nowrap">Precision Landing</span>
                    </div>
                </div>
                <div class="flex items-center gap-[6px] shrink-0">
                    <div class="flex items-center justify-between w-[85px] bg-[#0a0b0e] border border-[#30363d] rounded-[4px] py-[4px] px-[6px]">
                        <input type="number" @bind="LandSpeed" step="1" min="10" max="200" class="w-[46px] bg-transparent border-none text-[#58a6ff] font-mono font-bold text-[0.88rem] text-right outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none" />
                        <span class="text-[0.55rem] text-[#555] font-semibold whitespace-nowrap">cm/s</span>
                    </div>
                    <button class="border-none rounded-[4px] text-white font-black cursor-pointer uppercase text-[0.65rem] transition-all duration-200 py-[6px] px-[10px] w-[60px] flex justify-center items-center whitespace-nowrap hover:brightness-120 disabled:opacity-25 disabled:cursor-not-allowed bg-[#f85149] @(Drone.IsConnected ? "" : "opacity-25 cursor-not-allowed")" @onclick="HandleLand">LAND</button>
                </div>
            </div>

            @* ── Emergency ── *@
            <div class="pt-[8px] border-t border-dashed border-[#30363d] shrink-0 mt-auto">
                <div class="text-[0.58rem] font-extrabold text-[#f85149] uppercase tracking-[0.5px] mb-[6px]">⚠️ CRITICAL OVERRIDES</div>
                <button class="w-full h-[36px] border-none rounded-[4px] text-white font-black cursor-pointer uppercase text-[0.7rem] transition-all duration-200 hover:brightness-120 bg-[#d29922]" @onclick="HandleEmergencyDisarm">EMERGENCY DISARM</button>
            </div>

        </div>
    </div>
</div>

@code {
    private float TakeoffAlt = 10.0f;
    private float RtlAlt = 30.0f;
    private float LandSpeed = 50.0f;
    private bool CanTakeoff => Drone.State.IsArmed;

    private void HandleArmClick() => Drone.SendArmRequest(!Drone.State.IsArmed);

    protected override void OnInitialized()
    {
        Drone.OnTelemetryUpdated += RefreshUi;
    }

    private void RefreshUi() => InvokeAsync(StateHasChanged);

    private void HandleTakeoff()
    {
        if (!CanTakeoff) return;
        Drone.SetFlightMode("GUIDED");
        Drone.SendCommand(MAVLink.MAV_CMD.TAKEOFF, 0, 0, 0, 0, 0, 0, TakeoffAlt);
        Console.WriteLine($"Command Sent: Takeoff to {TakeoffAlt}m");
    }

    private void HandleRTL()
    {
        Drone.SendParameter("RTL_ALT", RtlAlt * 100.0f);
        Drone.SetFlightMode("RTL");
        Console.WriteLine($"Command Sent: RTL with target clearance of {RtlAlt}m");
    }

    private void HandleLand()
    {
        if (!Drone.IsConnected) return;
        Drone.SendParameter("LAND_SPEED", LandSpeed);
        Drone.SetFlightMode("LAND");
        Console.WriteLine($"Land command sent — descent speed: {LandSpeed} cm/s");
    }

    private void HandleEmergencyDisarm()
    {
        Drone.SendArmRequest(false, true);
    }

    public void Dispose()
    {
        Drone.OnTelemetryUpdated -= RefreshUi;
    }
}