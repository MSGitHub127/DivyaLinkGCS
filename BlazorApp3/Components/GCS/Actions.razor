@page "/actions"
@inject MavlinkService Drone
@implements IDisposable

<div class="actions-view-container">
    <div class="hud-wrapper">
        <Hud />
    </div>

    <div class="actions-content">
        <div class="header-strip">
            <span class="icon">🕹️</span> MISSION CONTROL
        </div>

        <div class="command-scroll-area">

            <div class="action-card">
                <div class="card-header">
                    <span class="card-icon">🚀</span>
                    <span class="card-title">Precision Takeoff</span>
                </div>
                <div class="input-container">
                    <label>TARGET ALTITUDE (METERS)</label>
                    <div class="input-group">
                        <input type="number" @bind="TakeoffAlt" step="0.5" min="1" class="cmd-input" />
                        <button class="btn btn-green @(CanTakeoff ? "" : "disabled")"
                                @onclick="HandleTakeoff">
                            @(Drone.State.IsArmed ? "EXECUTE TAKEOFF" : "ARM REQUIRED")
                        </button>
                    </div>
                </div>
                <p class="card-hint">Drone will rise to @TakeoffAlt m and hover.</p>
            </div>

            <div class="action-card">
                <div class="card-header">
                    <span class="card-icon">🏠</span>
                    <span class="card-title">Safe Return to Home</span>
                </div>
                <div class="input-container">
                    <label>CLEARANCE ALTITUDE (METERS)</label>
                    <div class="input-group">
                        <input type="number" @bind="RtlAlt" step="1.0" min="5" class="cmd-input" />
                        <button class="btn btn-blue" @onclick="HandleRTL">EXECUTE RTL</button>
                    </div>
                </div>
                <p class="card-hint">Drone climbs to @RtlAlt m before traveling to launch point.</p>
            </div>

            <div class="emergency-section">
                <div class="card-title" style="color: #ff3a3a; margin-bottom: 10px;">⚠️ CRITICAL OVERRIDES</div>
                <div class="emergency-grid">
                    <button class="btn btn-red" @onclick='() => Drone.SetFlightMode("LAND")'>LAND NOW</button>
                    <button class="btn btn-orange" @onclick="HandleEmergencyDisarm">EMERGENCY DISARM</button>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .actions-view-container {
        display: flex;
        flex-direction: column;
        height: 100%;
        gap: 16px;
        padding: 20px;
        background: #0b0c10;
        width: 100%;
        max-width: 500px;
        margin: 0 auto;
        overflow: hidden;
    }

    .hud-wrapper {
        height: 300px;
        width: 100%;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #242731;
        flex-shrink: 0;
        background: #000;
    }

    .actions-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 12px;
        min-height: 0;
    }

    .header-strip {
        background: rgba(18, 20, 28, 0.8);
        border: 1px solid rgba(0, 242, 255, 0.2);
        padding: 10px;
        border-radius: 6px;
        color: #00f2ff;
        font-weight: 800;
        text-align: center;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .command-scroll-area {
        flex: 1;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 15px;
        padding-right: 5px;
    }

    .action-card {
        background: #12141a;
        border: 1px solid #242731;
        border-radius: 8px;
        padding: 16px;
        transition: border-color 0.2s;
    }

    .action-card:hover {
        border-color: #2b58ff;
    }

    .card-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 12px;
    }

    .card-title {
        font-size: 0.9rem;
        font-weight: bold;
        color: white;
    }

    .card-icon {
        font-size: 1.2rem;
    }

    .input-container {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .input-container label {
        font-size: 0.6rem;
        color: #888;
        font-weight: 800;
    }

    .input-group {
        display: flex;
        gap: 10px;
    }

    .cmd-input {
        width: 80px;
        background: #08090b;
        border: 1px solid #333;
        color: #00f2ff;
        padding: 8px;
        border-radius: 4px;
        font-family: 'Consolas', monospace;
        font-size: 1.1rem;
        text-align: center;
    }

    .btn {
        flex: 1;
        border: none;
        border-radius: 4px;
        color: white;
        font-weight: 900;
        cursor: pointer;
        text-transform: uppercase;
        font-size: 0.75rem;
        transition: opacity 0.2s;
    }

    .btn:hover {
            filter: brightness(1.2);
        }

    .btn.disabled {
            opacity: 0.2;
            cursor: not-allowed;
        }

    .btn-green {
        background: #238636;
    }

    .btn-blue {
        background: #2b58ff;
    }

    .btn-red {
        background: #ff3a3a;
    }

    .btn-orange {
        background: #ff9800;
    }

    .card-hint {
        font-size: 0.65rem;
        color: #555;
        margin-top: 8px;
        font-style: italic;
    }

    .emergency-section {
        margin-top: 10px;
        padding-top: 15px;
        border-top: 1px dashed #333;
    }

    .emergency-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .emergency-grid .btn {
        height: 45px;
    }

    /* Custom Scrollbar */
    .command-scroll-area::-webkit-scrollbar {
        width: 4px;
    }

    .command-scroll-area::-webkit-scrollbar-thumb {
        background: #333;
        border-radius: 10px;
    }
</style>

@code {
    private float TakeoffAlt = 10.0f;
    private float RtlAlt = 30.0f;
    private bool CanTakeoff => Drone.State.IsArmed;

    protected override void OnInitialized()
    {
        Drone.OnTelemetryUpdated += RefreshUi;
    }

    private void RefreshUi() => InvokeAsync(StateHasChanged);

    private void HandleTakeoff()
    {
        if (!CanTakeoff) return;

        // MAV_CMD_NAV_TAKEOFF
        // p7 is altitude in meters
        Drone.SendCommand(MAVLink.MAV_CMD.TAKEOFF, 0, 0, 0, 0, 0, 0, TakeoffAlt);
        Console.WriteLine($"Command Sent: Takeoff to {TakeoffAlt}m");
    }

    private void HandleRTL()
    {
        // For professional ArduPilot/PX4 setups, we set the RTL_ALT parameter first
        // If your MavlinkService has SendParameter implemented, use it here.
        // For now, we trigger the mode change.
        Drone.SetFlightMode("RTL");
        Console.WriteLine($"Command Sent: RTL with target clearance of {RtlAlt}m");
    }

    private void HandleEmergencyDisarm()
    {
        // Second parameter 21196 is the "Force" magic number for ArduPilot disarm
        Drone.SendArmRequest(false);
    }

    public void Dispose()
    {
        Drone.OnTelemetryUpdated -= RefreshUi;
    }
}