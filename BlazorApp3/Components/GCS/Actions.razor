@page "/actions"
@inject MavlinkService Drone
@implements IDisposable

<div class="actions-view-container">
    <div class="hud-wrapper">
        <Hud />
    </div>

    <div class="actions-content">
        <div class="header-strip">
            <span class="icon">🕹️</span> MISSION CONTROL
        </div>

        <div class="actions-body">

            @* ── ARM / DISARM ── *@
            <div class="arm-action-area">
                <button class="clean-arm-btn @(Drone.State.IsArmed ? "state-armed" : "state-disarmed")" @onclick="HandleArmClick">
                    <div class="icon-box">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 2L3 7V11C3 16.55 6.84 21.74 12 23C17.16 21.74 21 16.55 21 11V7L12 2Z" />
                            <path d="M12 7V15M9 11H15" stroke-linecap="round" />
                        </svg>
                    </div>
                    <span class="btn-label">@(Drone.State.IsArmed ? "DISARM SYSTEM" : "ARM SYSTEM")</span>
                </button>
            </div>

            @* ── Precision Takeoff ── *@
            <div class="action-row">
                <div class="row-left">
                    <div class="row-info">
                        <span class="row-title">Precision Takeoff</span>
                    </div>
                </div>
                <div class="row-right">
                    <div class="inline-input-group">
                        <input type="number" @bind="TakeoffAlt" step="1" min="1" class="inline-input" />
                        <span class="inline-unit">m</span>
                    </div>
                    <button class="row-btn btn-green @(CanTakeoff ? "" : "disabled")" @onclick="HandleTakeoff">
                        @(Drone.State.IsArmed ? "GO" : "ARM")
                    </button>
                </div>
            </div>

            @* ── Return to Home ── *@
            <div class="action-row">
                <div class="row-left">
                    <div class="row-info">
                        <span class="row-title">Return to Home</span>
                    </div>
                </div>
                <div class="row-right">
                    <div class="inline-input-group">
                        <input type="number" @bind="RtlAlt" step="1" min="5" class="inline-input" />
                        <span class="inline-unit">m</span>
                    </div>
                    <button class="row-btn btn-blue" @onclick="HandleRTL">RTL</button>
                </div>
            </div>

            @* ── Precision Landing ── *@
            <div class="action-row">
                <div class="row-left">
                    <div class="row-info">
                        <span class="row-title">Precision Landing</span>
                    </div>
                </div>
                <div class="row-right">
                    <div class="inline-input-group">
                        <input type="number" @bind="LandSpeed" step="1" min="10" max="200" class="inline-input" />
                        <span class="inline-unit">cm/s</span>
                    </div>
                    <button class="row-btn btn-red @(Drone.IsConnected ? "" : "disabled")" @onclick="HandleLand">LAND</button>
                </div>
            </div>

            @* ── Emergency ── *@
            <div class="emergency-section">
                <div class="emergency-label">⚠️ CRITICAL OVERRIDES</div>
                <button class="btn btn-orange emergency-btn" @onclick="HandleEmergencyDisarm">EMERGENCY DISARM</button>
            </div>

        </div>
    </div>
</div>

<style>
    :root {
        --gcs-bg: #0d1117;
        --gcs-card: #161b22;
        --gcs-border: #30363d;
        --gcs-cyan: #58a6ff;
        --gcs-amber: #d29922;
        --gcs-text: #c9d1d9;
        --gcs-green: #2ea043;
        --gcs-red: #f85149;
    }

    .actions-view-container {
        display: flex;
        flex-direction: column;
        height: 100%;
        gap: 10px;
        padding: 20px 20px 5px 20px;
        background: transparent;
        width: 100%;
        max-width: 500px;
        margin: 0 auto;
        overflow: hidden;
        color: var(--gcs-text);
    }

    .hud-wrapper {
        height: 300px;
        width: 100%;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid var(--gcs-border);
        box-shadow: 0 4px 20px rgba(0,0,0,0.4);
        flex-shrink: 0;
        background: #000;
    }

    .actions-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 8px;
        min-height: 0;
        background: rgba(18, 20, 28, 0.6);
        border: 1px solid var(--gcs-border);
        border-radius: 8px;
        padding: 10px 14px;
        backdrop-filter: blur(4px);
    }

    .header-strip {
        padding-bottom: 8px;
        border-bottom: 1px solid var(--gcs-border);
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 900;
        font-size: 0.78rem;
        text-transform: uppercase;
        color: white;
        letter-spacing: 1.5px;
        flex-shrink: 0;
    }

    .actions-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 10px;
        overflow: hidden;
        min-height: 0;
    }

    /* ── ARM button ─────────────────────────────────── */
    .arm-action-area {
        width: 100%;
        flex-shrink: 0;
    }

    .clean-arm-btn {
        width: 100%;
        height: 46px;
        border: none;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        cursor: pointer;
        transition: all 0.2s ease;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-size: 0.8rem;
        color: white;
    }

    .state-armed {
        background: linear-gradient(90deg, #3a0d0d 0%, var(--gcs-red) 100%);
        box-shadow: 0 4px 15px rgba(248, 81, 73, 0.2);
    }

    .state-disarmed {
        background: linear-gradient(90deg, #0d3a1a 0%, var(--gcs-green) 100%);
        box-shadow: 0 4px 15px rgba(46, 160, 67, 0.2);
        color: #fff;
    }

    .clean-arm-btn:hover {
        filter: brightness(1.1);
        transform: translateY(-1px);
    }

    .icon-box svg {
        width: 18px;
        height: 18px;
    }

    /* ── Action rows (no accordion) ─────────────────── */
    .action-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        background: #010409;
        border: 1px solid var(--gcs-border);
        border-radius: 8px;
        padding: 8px 14px;
        flex-shrink: 0;
        transition: border-color 0.2s;
    }

        .action-row:hover {
            border-color: #444;
        }

    .row-left {
        display: flex;
        align-items: center;
        gap: 10px;
        flex: 1;
        min-width: 0;
    }

    .row-icon {
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .row-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
    }

    .row-title {
        font-size: 0.76rem;
        font-weight: 700;
        color: white;
        white-space: nowrap;
    }

    .row-hint {
        font-size: 0.56rem;
        color: #6c757d;
        font-style: italic;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .param-tag {
        font-family: monospace;
        color: var(--gcs-cyan);
        opacity: 0.8;
        font-style: normal;
        font-size: 0.5rem;
    }

    .row-right {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-shrink: 0;
    }

    /* Value input inline */
    .inline-input-group {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 85px;
        background: #0a0b0e;
        border: 1px solid var(--gcs-border);
        border-radius: 4px;
        padding: 4px 6px;
    }

    .inline-input {
        width: 46px;
        background: transparent;
        border: none;
        color: var(--gcs-cyan);
        font-family: monospace;
        font-weight: bold;
        font-size: 0.88rem;
        text-align: right;
        outline: none;
        -moz-appearance: textfield;
    }

        .inline-input::-webkit-outer-spin-button,
        .inline-input::-webkit-inner-spin-button {
            -webkit-appearance: none;
        }

    .inline-unit {
        font-size: 0.55rem;
        color: #555;
        font-weight: 600;
        white-space: nowrap;
    }

    /* Action button */
    .row-btn {
        border: none;
        border-radius: 4px;
        color: white;
        font-weight: 900;
        cursor: pointer;
        text-transform: uppercase;
        font-size: 0.65rem;
        transition: filter 0.2s;
        padding: 6px 10px;
        width: 60px;
        display:flex;
        justify-content: center;
        align-items: center;
        white-space: nowrap;
    }

        .row-btn:hover {
            filter: brightness(1.2);
        }

        .row-btn.disabled {
            opacity: 0.25;
            cursor: not-allowed;
        }

    .btn-green {
        background: var(--gcs-green);
    }

    .btn-blue {
        background: var(--gcs-cyan);
        color: #000;
    }

    .btn-red {
        background: var(--gcs-red);
    }

    /* ── Emergency ──────────────────────────────────── */
    .emergency-section {
        padding-top: 8px;
        border-top: 1px dashed var(--gcs-border);
        flex-shrink: 0;
        margin-top: auto;
    }

    .emergency-label {
        font-size: 0.58rem;
        font-weight: 800;
        color: var(--gcs-red);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 6px;
    }

    .btn {
        border: none;
        border-radius: 4px;
        color: white;
        font-weight: 900;
        cursor: pointer;
        text-transform: uppercase;
        font-size: 0.7rem;
        transition: filter 0.2s;
    }

        .btn:hover {
            filter: brightness(1.2);
        }

    .btn-orange {
        background: var(--gcs-amber);
    }

    .emergency-btn {
        width: 100%;
        height: 36px;
    }
</style>

@code {
    private float TakeoffAlt = 10.0f;
    private float RtlAlt = 30.0f;
    private float LandSpeed = 50.0f;
    private bool CanTakeoff => Drone.State.IsArmed;

    private void HandleArmClick() => Drone.SendArmRequest(!Drone.State.IsArmed);

    protected override void OnInitialized()
    {
        Drone.OnTelemetryUpdated += RefreshUi;
    }

    private void RefreshUi() => InvokeAsync(StateHasChanged);

    private void HandleTakeoff()
    {
        if (!CanTakeoff) return;
        Drone.SetFlightMode("GUIDED");
        Drone.SendCommand(MAVLink.MAV_CMD.TAKEOFF, 0, 0, 0, 0, 0, 0, TakeoffAlt);
        Console.WriteLine($"Command Sent: Takeoff to {TakeoffAlt}m");
    }

    private void HandleRTL()
    {
        Drone.SendParameter("RTL_ALT", RtlAlt * 100.0f);
        Drone.SetFlightMode("RTL");
        Console.WriteLine($"Command Sent: RTL with target clearance of {RtlAlt}m");
    }

    private void HandleLand()
    {
        if (!Drone.IsConnected) return;
        Drone.SendParameter("LAND_SPEED", LandSpeed);
        Drone.SetFlightMode("LAND");
        Console.WriteLine($"Land command sent — descent speed: {LandSpeed} cm/s");
    }

    private void HandleEmergencyDisarm()
    {
        Drone.SendArmRequest(false, true);
    }

    public void Dispose()
    {
        Drone.OnTelemetryUpdated -= RefreshUi;
    }
}
