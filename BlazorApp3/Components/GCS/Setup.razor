@code {
    private string selectedFrameClass = "1";
    // FRAME_CLASS: 1=Quad,2=Hexa,3=Octa,5=Y6,7=Tri
    private string selectedFrameType = "1";
    // FRAME_TYPE:  0=Plus,1=X,2=V,3=H,10=CW-X
    private string currentType = "QUAD";
    private string currentClass = "X-FRAME";
    // Failsafe
    private bool _fsParamsLoaded = false;
    private string rcLossAction = "1";
    private int rcThrValue = 975;
    private string lowBattAction = "2";
    private string gcsLossAction = "0";
    // Battery
    private bool _battParamsLoaded = false;
    private double _battLowVolt = 10.5, _battCrtVolt = 9.6, _battArmVolt = 11.5;
    private int _battLowMah = 0;
    private double _battVoltMult = 10.1, _battAmpPerVlt = 17.0, _battAmpOffset = 0.0;
    private int _battNumCells = 3;
    // ESC calibration wizard state
    private int escCalStep = 0;
    // 0=idle, 1-5=steps, 99=done
    private int escCalMethod = 0;
    // 0=auto, 1=manual passthrough
    private bool isLedEnabled = true;
    private bool IsGyroCalibrating => Drone.LiveGyroStatus == "STARTING..." ||
        Drone.LiveGyroStatus == "CALIBRATING...";
    private bool IsMagCalibrating =>
        Drone.LiveMagStatus == "STARTING..." ||
        Drone.LiveMagStatus == "CALIBRATING..." ||
        (Drone.LiveMagProgress > 0 && Drone.LiveMagProgress < 100);
    // Flight modes — 6 positions (FLTMODE1-6), matches ArduCopter FLTMODE params
    private string[] flightModeSettings = { "STABILIZE", "ALT_HOLD", "LOITER", "RTL", "LOITER", "RTL" };
    private string flightModeChannel = "5";   // FLTMODE_CH parameter
    private string battMonitorType = "4";
    private int battCapacity = 3300;
    // Mission Planner Motor Test Settings
    private int motorTestThrottle = 5;
    private int motorTestDuration = 2;
    private DateTime _lastRcRenderUtc = DateTime.MinValue;
    private ushort[] _localChannels = new ushort[8];
    protected override void OnInitialized()
    {
        Drone.OnTelemetryUpdated += RefreshUi;
        Drone.OnRcChannelsUpdated += HandleRcUpdate;
        Drone.OnFlightModeParams += OnFlightModeParamsReceived;
        Drone.OnFailsafeParams += HandleFailsafeParams;
        Drone.OnBatteryParams += HandleBatteryParams;
    }

    private void HandleRcUpdate(ushort[] channels)
    {
        // Copy channels immediately on the background thread (safe, it's a value copy)
        Array.Copy(channels, _localChannels, 8);
        // Throttle UI to 50Hz (20ms) — matches FC output rate exactly, no extra lag
        var now = DateTime.UtcNow;
        if ((now - _lastRcRenderUtc).TotalMilliseconds < 20) return;
        _lastRcRenderUtc = now;

        InvokeAsync(StateHasChanged);
    }

    private bool _lastLink = false;
    private int _lastFrameClass = -1;
    private int _lastFrameType = -1;
    private DateTime _lastSetupRender = DateTime.MinValue;

    private void RefreshUi()
    {
        bool linkNow = Drone.IsLinkHealthy;
        int frameClass = Drone.State.FrameClass;
        int frameType = Drone.State.FrameType;

        bool linkChanged = linkNow != _lastLink;
        bool frameChanged = frameClass != _lastFrameClass || frameType != _lastFrameType;

        // Sync frame dropdowns only when values actually change — not every tick.
        if (frameChanged)
        {
            if (frameClass > 0) selectedFrameClass = frameClass.ToString();
            if (frameType >= 0) selectedFrameType = frameType.ToString();
            _lastFrameClass = frameClass;
            _lastFrameType = frameType;
        }

        // Reset loaded flags on disconnect so they re-load on next connect.
        if (linkChanged && _lastLink && !linkNow)
        {
            _fsParamsLoaded = false;
            _battParamsLoaded = false;
        }
        _lastLink = linkNow;

        if (!linkChanged && !frameChanged)
        {
            // No meaningful change — skip the Blazor diff entirely.
            // Setup is a config page; it only needs to update when something real changes.
            return;
        }

        InvokeAsync(StateHasChanged);
    }

    // Accelerometer Handlers
    // Accelerometer
    private void StartAccel()
    {
        Drone.LiveAccelProgress = 0;
        Drone.LiveAccelStatus = "WAITING..."; Drone.StartCalibration("ACCEL");
    }
    private void CancelAccel()
    {
        Drone.StartCalibration("CANCEL_ACCEL"); Drone.LiveAccelStatus = "CANCELLED"; Drone.LiveAccelProgress = 0;
    }

    // Gyroscope
    private void StartGyro()
    {
        Drone.LiveGyroProgress = 0; Drone.LiveGyroStatus = "STARTING..."; Drone.StartCalibration("GYRO");
    }
    private void CancelGyro()
    {
        Drone.StartCalibration("CANCEL_GYRO"); Drone.LiveGyroStatus = "CANCELLED"; Drone.LiveGyroProgress = 0;
    }

    // Magnetometer
    private void StartMag()
    {
        Drone.LiveMagProgress = 0; Drone.LiveMagStatus = "STARTING..."; Drone.StartCalibration("MAG");
    }
    private void CancelMag()
    {
        Drone.StartCalibration("CANCEL_MAG"); Drone.LiveMagStatus = "CANCELLED"; Drone.LiveMagProgress = 0;
    }

    private async Task HandleRcClick()
    {
        if (Drone.IsRcCalibrating)
        {
            await Drone.SaveRcCalibrationAsync();
        }
        else
        {
            Drone.StartCalibration("RADIO");
        }
    }

    // Safety clamp: PWM ranges from 800 to 2200. This scales it perfectly to 0-100% for CSS.
    private double CalculatePercent(ushort raw) => Math.Clamp((raw - 800) / 14.0, 0, 100);
    private void ApplyFrame()
    {
        Drone.SetFrameConfig(int.Parse(selectedFrameClass), int.Parse(selectedFrameType));
    }

    // ── Frame diagram helpers ─────────────────────────────────────────────
    private string FrameClassName => int.Parse(selectedFrameClass) switch
    {
        1 => "QUADCOPTER",
        2 => "HEXACOPTER",
        3 => "OCTOCOPTER",
        5 => "Y6",
        7 => "TRICOPTER",
        _ => "CUSTOM"
    };
    private string FrameTypeName => int.Parse(selectedFrameType) switch
    {
        0 => "PLUS (+)",
        1 => "X",
        2 => "V / H-FRAME",
        3 => "H",
        10 => "CW-X",
        _ => "CUSTOM"
    };
    private record MotorPoint(double X, double Y, int Num, bool Cw);
    private List<MotorPoint> MotorPositions
    {
        get
        {
            int fc = int.Parse(selectedFrameClass);
            int ft = int.Parse(selectedFrameType);
            double cx = 100, cy = 100, r = 68;
            // Quad X / CW-X
            if (fc == 1 && ft == 1)
                return new() {
                    new(cx + r*Math.Cos(ToRad(-45)),  cy + r*Math.Sin(ToRad(-45)),  1, false), // FR CCW
                    new(cx + r*Math.Cos(ToRad(-135)), cy + r*Math.Sin(ToRad(-135)), 2,
                    true),  // FL CW
                    new(cx + r*Math.Cos(ToRad(135)),  cy + r*Math.Sin(ToRad(135)),  3, false), // RL CCW
                    new(cx + r*Math.Cos(ToRad(45)),   cy + r*Math.Sin(ToRad(45)),   4, true),  // RR CW
                };
            // Quad Plus
            if (fc == 1 && ft == 0)
                return new() {
                    new(cx,       cy - r, 1, false), // Front CCW
                    new(cx + r,   cy,
                    2, true),  // Right CW
                    new(cx,       cy + r, 3, false), // Back CCW
                    new(cx - r,   cy,     4, true),  // Left CW
                };
            // Hexa X
            if (fc == 2)
            {
                var pts = new List<MotorPoint>();
                bool[] cw = { false, true, false, true, false, true };
                for (int i = 0; i < 6; i++)
                {
                    double a = ToRad(-90 + i * 60);
                    pts.Add(new(cx + r * Math.Cos(a), cy + r * Math.Sin(a), i + 1, cw[i]));
                }
                return pts;
            }
            // Octo X
            if (fc == 3)
            {
                var pts = new List<MotorPoint>();
                bool[] cw = { false, true, false, true, false, true, false, true };
                for (int i = 0; i < 8; i++)
                {
                    double a = ToRad(-90 + i * 45);
                    pts.Add(new(cx + r * Math.Cos(a), cy + r * Math.Sin(a), i + 1, cw[i]));
                }
                return pts;
            }
            // Tricopter
            if (fc == 7)
                return new() {
                    new(cx,                          cy - r,
                    1, false),
                    new(cx + r*Math.Cos(ToRad(210)), cy + r*Math.Sin(ToRad(210)),     2, true),
                    new(cx + r*Math.Cos(ToRad(330)), cy + r*Math.Sin(ToRad(330)),     3, false),
                };
            // Y6 (coaxial hexa, show 3 arms × 2 props)
            if (fc == 5)
            {
                var pts = new List<MotorPoint>();
                for (int i = 0; i < 3; i++)
                {
                    double a = ToRad(-90 + i * 120);
                    double mx = cx + r * Math.Cos(a), my = cy + r * Math.Sin(a);
                    pts.Add(new(mx - 8, my, i * 2 + 1, false));
                    // top CCW
                    pts.Add(new(mx + 8, my, i * 2 + 2, true));
                    // bottom CW
                }
                return pts;
            }
            // Default: quad X
            return new() {
                new(cx + r*Math.Cos(ToRad(-45)),  cy + r*Math.Sin(ToRad(-45)),  1, false),
                new(cx + r*Math.Cos(ToRad(-135)), cy + r*Math.Sin(ToRad(-135)), 2, true),
                new(cx + r*Math.Cos(ToRad(135)),  cy + r*Math.Sin(ToRad(135)),
                3, false),
                new(cx + r*Math.Cos(ToRad(45)),   cy + r*Math.Sin(ToRad(45)),   4, true),
            };
        }
    }
    private static double ToRad(double deg) => deg * Math.PI / 180.0;
    private void SyncFlightModes()
    {
        // Write all 6 FLTMODE params to the flight controller
        for (int i = 0; i < 6; i++)
            Drone.SaveFlightMode(i + 1, flightModeSettings[i]);
        // Write the channel mapping — FLTMODE_CH param (5=CH5 default)
        Drone.SendParameter("FLTMODE_CH", float.Parse(flightModeChannel));
    }

    // ESC calibration wizard
    private void EscCalStart() => escCalStep = 1;
    private void EscCalAbort() { escCalStep = 0; Drone.SendParameter("ESC_CALIBRATION", 0); }
    private void EscCalDone() => escCalStep = 99;
    private void EscCalAutoStep1()
    {
        // Write ESC_CALIBRATION=3 — FC will output full-throttle PWM on next boot
        Drone.SendParameter("ESC_CALIBRATION", 3);
        escCalStep = 2;
    }

    private void EscCalManualStep1()
    {
        // Enable passthrough: ESC_CALIBRATION=1 makes FC relay throttle to ESCs directly
        Drone.SendParameter("ESC_CALIBRATION", 1);
        escCalStep = 2;
    }

    private void EscCalManualStep4()
    {
        // Disable passthrough and clear the cal parameter
        Drone.SendParameter("ESC_CALIBRATION", 0);
        escCalStep = 5;
    }

    private void StopAllMotors()
    {
        // Sends 0% throttle to abort immediately
        for (int i = 1; i <= Drone.State.MotorCount; i++)
        {
            Drone.TestMotor(i, 0, 0);
        }
    }

    private void SaveFailsafes() =>
        Drone.SaveFailsafeParams(int.Parse(rcLossAction), rcThrValue,
            int.Parse(lowBattAction), int.Parse(gcsLossAction));
    private void HandleFailsafeParams(MavlinkService.FailsafeParams p)
    {
        rcLossAction = p.ThrEnable.ToString();
        rcThrValue = p.ThrValue;
        lowBattAction = p.BattEnable.ToString(); gcsLossAction = p.GcsEnable.ToString();
        _fsParamsLoaded = true; InvokeAsync(StateHasChanged);
    }

    private void RefreshFailsafeParams()
    {
        _fsParamsLoaded = false;
        Drone.RequestParamRead("FS_THR_ENABLE");
        Drone.RequestParamRead("FS_THR_VALUE"); Drone.RequestParamRead("FS_BATT_ENABLE");
        Drone.RequestParamRead("FS_GCS_ENABLE");
    }

    // FS_THR_ENABLE: 0=off, 1=RTL, 2=Continue+RTL, 3=Land, 4=SRTL+RTL, 5=SRTL+Land
    private string FsRcLbl(string v) => v switch
    {
        "0" => "OFF",
        "1" => "RTL",
        "2" => "CONT+RTL",
        "3" => "LAND",
        "4" => "SRTL+RTL",
        "5" => "SRTL+LAND",
        _ => v

    };

    // FS_BATT_ENABLE: 0=off, 1=Land, 2=RTL, 3=SRTL+RTL, 4=SRTL+Land, 5=KILL
    private string FsBattLbl(string v) => v switch
    {
        "0" => "OFF",
        "1" => "LAND",
        "2" => "RTL",
        "3" => "SRTL+RTL",
        "4" => "SRTL+LAND",
        "5" => "KILL",
        _ => v
    };
    // FS_GCS_ENABLE: 0=off, 1=RTL, 2=Continue, 3=SRTL+RTL, 4=SRTL+Land
    private string FsGcsLbl(string v) => v switch
    {
        "0" => "OFF",
        "1" => "RTL",
        "2" => "CONT",
        "3" => "SRTL+RTL",
        "4" => "SRTL+LAND",
        _ => v
    };
    private void SaveBatterySettings()
    {
        if (_battCrtVolt > 0 && _battLowVolt > 0 && _battCrtVolt >= _battLowVolt)
        {
            Drone.Toast("Critical must be lower than Low", MavlinkService.ToastLevel.Warning, "⚠️");
            return;
        }
        Drone.SaveBatteryParams(int.Parse(battMonitorType), battCapacity,
            _battLowVolt, _battCrtVolt, _battArmVolt, _battLowMah,
            _battVoltMult, _battAmpPerVlt, _battAmpOffset, _battNumCells);
    }

    private void HandleBatteryParams(MavlinkService.BatteryParams p)
    {
        battMonitorType = p.Monitor.ToString();
        battCapacity = p.Capacity;
        _battLowVolt = p.LowVolt; _battCrtVolt = p.CrtVolt; _battArmVolt = p.ArmVolt;
        _battLowMah = p.LowMah; _battVoltMult = p.VoltMult;
        _battAmpPerVlt = p.AmpPerVlt;
        _battAmpOffset = p.AmpOffset; _battNumCells = p.NumCells;
        _battParamsLoaded = true; InvokeAsync(StateHasChanged);
    }

    private void RefreshBatteryParams()
    {
        _battParamsLoaded = false;
        Drone.RequestParamRead("BATT_MONITOR"); Drone.RequestParamRead("BATT_CAPACITY");
        Drone.RequestParamRead("BATT_LOW_VOLT"); Drone.RequestParamRead("BATT_CRT_VOLT");
        Drone.RequestParamRead("BATT_ARM_VOLT"); Drone.RequestParamRead("BATT_LOW_MAH");
        Drone.RequestParamRead("BATT_VOLT_MULT"); Drone.RequestParamRead("BATT_AMP_PERVLT");
        Drone.RequestParamRead("BATT_AMP_OFFSET"); Drone.RequestParamRead("BATT_NUM_CELLS");
    }

    private double TBW(double v)
    {
        if (_battNumCells <= 0) return 0;
        double f = _battNumCells * 4.2, d = _battNumCells * 3.0;
        return Math.Max(0, Math.Min(100, (v - d) / (f - d) * 100));
    }
    private void BattPreset(string k)
    {
        switch (k)
        {
            case "px":
                _battVoltMult = 10.1; _battAmpPerVlt = 17.0;
                _battAmpOffset = 0; break;
            case "hb": _battVoltMult = 12.02; _battAmpPerVlt = 18.0; _battAmpOffset = 0; break;
            case "mu": _battVoltMult = 10.1; _battAmpPerVlt = 39.877; _battAmpOffset = 0; break;
            case "ap":
                _battVoltMult = 15.7; _battAmpPerVlt = 36.364;
                _battAmpOffset = 0; break;
        }
        InvokeAsync(StateHasChanged);
    }
    private string BVC => Drone.State.Voltage > 0 ?
        (_battCrtVolt > 0 && Drone.State.Voltage <= _battCrtVolt ? "bv-c" : _battLowVolt > 0 && Drone.State.Voltage <= _battLowVolt ? "bv-l" : "bv-ok") : "";
    private string BPC => Drone.State.BatteryPercent switch { <= 10 => "bv-c", <= 25 => "bv-l", _ => "bv-ok" };
    private string BCC
    {
        get
        {
            if (_battNumCells <= 0 || Drone.State.Voltage <= 0) return "";
            double c = Drone.State.Voltage / _battNumCells; return c <= 3.3 ? "bv-c" : c <= 3.6 ? "bv-l" : "bv-ok";
        }
    }

    private void TogglePixhawkLeds(bool enable)
    {
        isLedEnabled = enable;
        // NTF_LED_BRIGHT: 0 = Off, 3 = High
        Drone.SendParameter("NTF_LED_BRIGHT", enable ? 3.0f : 0.0f);
        // Log it to the terminal so the user knows what happened
        Console.WriteLine($"[SETUP] Pixhawk LEDs set to: {(enable ? "HIGH" : "OFF")}");
    }
