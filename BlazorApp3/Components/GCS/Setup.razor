@page "/setup"
@inject MavlinkService Drone
@inject IJSRuntime JS
@implements IDisposable

<div class="gcs-setup-container">
    <div class="hud-wrapper">
        <Hud/>
    </div>

    <div class="setup-list">

        <div class="setup-module">
            <div class="module-header">
                <i class="bi bi-gear-wide-connected"></i>
                <span>FRAME GEOMETRY</span>
                <button class="btn-gcs-primary" @onclick="ApplyFrame">SYNC PARAMS</button>
            </div>
            <div class="module-content">
                <div class="readout-row">
                    <div class="readout"><label>ACTIVE TYPE</label><div class="value">@currentType</div></div>
                    <div class="readout"><label>ACTIVE CLASS</label><div class="value">@currentClass</div></div>
                </div>
                <div class="control-group">
                    <label class="input-label">VEHICLE TYPE</label>
                    <select class="gcs-select" @bind="selectedFrameType">
                        <option value="1">QUADCOPTER</option>
                        <option value="2">HEXACOPTER</option>
                        <option value="3">OCTACOPTER</option>
                    </select>
                    <label class="input-label">FRAME CLASS</label>
                    <select class="gcs-select" @bind="selectedFrameClass">
                        <option value="0">PLUS (+)</option>
                        <option value="1">X-FRAME</option>
                        <option value="2">V-FRAME</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="setup-module">
            <div class="module-header">
                <i class="bi bi-compass"></i>
                <span>SENSORS & IMU</span>
                <div style="margin-left: auto; display: flex; gap: 8px;">
                    <button class="btn-gcs-outline" @onclick="HandleAccelClick">
                        @(Drone.LiveAccelProgress > 0 && Drone.LiveAccelProgress < 100 ? "NEXT (ACCEL)" : "CAL ACCEL")
                    </button>
                    <button class="btn-gcs-outline" @onclick="HandleMagClick">
                        @(Drone.LiveMagStatus == "CALIBRATING..." || Drone.LiveMagStatus == "STARTING..." ? "CANCEL MAG" : "CAL COMPASS")
                    </button>
                </div>
            </div>
            <div class="module-content">
                <div class="dual-status-grid">
                    <div class="status-box-pro @(Drone.LiveAccelProgress > 0 && Drone.LiveAccelProgress < 100 ? "active-cal" : "")">
                        <div class="status-label">ACCELEROMETER</div>
                        <div class="status-value">@Drone.LiveAccelStatus</div>
                        <div class="cal-progress-bg" style="visibility: @(Drone.LiveAccelProgress > 0 ? "visible" : "hidden")">
                            <div class="cal-progress-fill" style="width: @(Drone.LiveAccelProgress)%"></div>
                        </div>
                        @if (Drone.LiveAccelProgress > 0 && Drone.LiveAccelProgress < 100)
                        {
                            <div class="cal-pulse"></div>
                        }
                    </div>

                    <div class="status-box-pro @(Drone.LiveMagStatus == "CALIBRATING..." || Drone.LiveMagStatus == "STARTING..." ? "active-cal" : "")">
                        <div class="status-label">COMPASS (MAG)</div>
                        <div class="status-value">
                            @(Drone.LiveMagStatus == "CALIBRATING..." ? $"{Drone.LiveMagProgress}%" : Drone.LiveMagStatus)
                        </div>

                        <div class="cal-progress-bg" style="visibility: @(Drone.LiveMagStatus == "STARTING..." || Drone.LiveMagStatus == "CALIBRATING..." || Drone.LiveMagProgress > 0 ? "visible" : "hidden")">
                            <div class="cal-progress-fill" style="width: @(Drone.LiveMagProgress)%"></div>
                        </div>

                        @if (Drone.LiveMagStatus == "CALIBRATING..." || Drone.LiveMagStatus == "STARTING...")
                        {
                            <div class="cal-pulse"></div>
                        }
                    </div>
                </div>
                <div class="compass-mini-grid">
                    <div class="axis">ROLL: <span class="val">@Drone.State.Roll.ToString("0.0")°</span></div>
                    <div class="axis">PITCH: <span class="val">@Drone.State.Pitch.ToString("0.0")°</span></div>
                    <div class="axis">YAW: <span class="val">@Drone.State.AttitudeYawDeg.ToString("0.0")°</span></div>
                </div>
            </div>
        </div>

        <div class="setup-module">
            <div class="module-header">
                <i class="bi bi-controller"></i>
                <span>RADIO CHANNELS (RC)</span>
                <button class="btn-gcs-outline" @onclick="HandleRcClick">
                    @(Drone.IsRcCalibrating ? "SAVE RC CAL" : "CALIBRATE RC")
                </button>
            </div>
            <div class="module-content radio-layout">
                @for (int i = 0; i < 4; i++)
                {
                    var chanName = (new[] { "ROLL", "PITCH", "THROTTLE", "YAW" })[i];
                    var rawVal = Drone.State.RawChannels[i];
                    <div class="radio-strip">
                        <span class="label">@chanName</span>
                        <div class="bar-container">
                            <div class="bar-fill" style="width:@(CalculatePercent(rawVal))%"></div>
                            <div class="center-line"></div>
                        </div>
                        <span class="raw-val">@rawVal</span>
                    </div>
                }
            </div>
        </div>

        <div class="setup-module">
            <div class="module-header">
                <i class="bi bi-shield-shaded"></i>
                <span>FLIGHT MODE ASSIGNMENT</span>
                <button class="btn-gcs-primary" @onclick="SyncFlightModes">SAVE MODES</button>
            </div>
            <div class="module-content">
                @for (int i = 0; i < 3; i++)
                {
                    var index = i;
                    <div class="mode-row">
                        <label class="input-label">SWITCH POSITION @(index + 1)</label>
                        <select class="gcs-select" @bind="flightModeSettings[index]">
                            <option value="STABILIZE">STABILIZE</option>
                            <option value="ALT_HOLD">ALT_HOLD</option>
                            <option value="LOITER">LOITER</option>
                            <option value="RTL">RTL</option>
                            <option value="AUTO">AUTO</option>
                        </select>
                    </div>
                }
            </div>
        </div>

        <div class="setup-module border-amber">
            <div class="module-header warning">
                <i class="bi bi-propeller"></i>
                <span>MOTOR TEST (@Drone.State.MotorCount MOTORS DETECTED)</span>
            </div>
            <div class="module-content">
                <div class="mp-top-row">
                    <div class="mp-input-group">
                        <label>THROTTLE %</label>
                        <input type="number" class="mp-input" @bind="motorTestThrottle" min="0" max="100" />
                    </div>
                    <div class="mp-input-group">
                        <label>DURATION (S)</label>
                        <input type="number" class="mp-input" @bind="motorTestDuration" min="1" max="15" />
                    </div>
                    <div class="mp-info-row" style="margin-left: auto;">
                        <span>FRAME: @currentType</span>
                    </div>
                </div>

                <div class="motor-grid">
                    @for (int i = 1; i <= Drone.State.MotorCount; i++)
                    {
                        int motorId = i;
                        <button class="btn-motor" @onclick="() => Drone.TestMotor(motorId, motorTestThrottle, motorTestDuration)">
                            MOTOR @motorId
                        </button>
                    }
                </div>

                <div class="mp-action-row">
                    <button class="btn-mp" @onclick="() => Drone.TestAllMotors((float)motorTestThrottle, (float)motorTestDuration)">TEST ALL MOTORS</button>
                    <button class="btn-mp" @onclick="() => Drone.TestMotorSequence((float)motorTestThrottle, (float)motorTestDuration)">RUN SEQUENCE</button>
                    <button class="btn-mp-stop" @onclick="StopAllMotors">ABORT ALL</button>
                </div>

                <p class="footer-hint">CAUTION: PROPELLERS MUST BE REMOVED BEFORE TESTING</p>
            </div>
        </div>

        <div class="setup-module border-amber">
            <div class="module-header warning">
                <i class="bi bi-lightning-charge"></i>
                <span>ESC THROTTLE CALIBRATION</span>
                <button class="btn-gcs-amber" @onclick="ToggleEscCalMode">ENABLE CAL MODE</button>
            </div>
            <div class="module-content">
                <div class="esc-info-box">
                    <p>1. Enable Cal Mode (Sets parameter to 3).</p>
                    <p>2. Disconnect USB and Battery.</p>
                    <p>3. Reconnect battery to start beep sequence.</p>
                </div>
                <div class="status-box-pro">
                    <div class="status-label">CALIBRATION STATE</div>
                    <div class="status-value">@escCalStatus</div>
                </div>
            </div>
        </div>

        <div class="setup-module border-amber">
            <div class="module-header warning">
                <i class="bi bi-exclamation-triangle"></i>
                <span>SAFETY FAILSAFES</span>
                <button class="btn-gcs-amber" @onclick="SaveFailsafes">SAVE ALL</button>
            </div>
            <div class="module-content">
                <div class="fs-row">
                    <label class="input-label">RC LOSS ACTION</label>
                    <select class="gcs-select-sm" @bind="rcLossAction"><option value="1">RTL</option><option value="2">LAND</option></select>
                </div>
                <div class="fs-row">
                    <label class="input-label">LOW BATT ACTION</label>
                    <select class="gcs-select-sm" @bind="lowBattAction"><option value="1">RTL</option><option value="2">LAND</option></select>
                </div>
            </div>
        </div>

        <div class="setup-module">
            <div class="module-header">
                <i class="bi bi-battery-half"></i>
                <span>BATTERY MONITOR</span>
                <button class="btn-gcs-primary" @onclick="SaveBatterySettings">SAVE PARAMS</button>
            </div>
            <div class="module-content">
                <div class="readout-row">
                    <div class="readout">
                        <label>LIVE VOLTAGE</label>
                        <div class="value">@Drone.State.Voltage.ToString("0.00") V</div>
                    </div>
                    <div class="readout">
                        <label>REMAINING</label>
                        <div class="value">@Drone.State.BatteryPercent%</div>
                    </div>
                </div>

                <div class="control-group">
                    <label class="input-label">MONITOR TYPE</label>
                    <select class="gcs-select" @bind="battMonitorType">
                        <option value="0">0: DISABLED</option>
                        <option value="3">3: ANALOG VOLTAGE ONLY</option>
                        <option value="4">4: ANALOG VOLTAGE AND CURRENT</option>
                        <option value="8">8: UAVCAN DIALOG</option>
                        <option value="9">9: ESC TELEMETRY</option>
                    </select>

                    <label class="input-label" style="margin-top: 10px;">BATTERY CAPACITY (mAh)</label>
                    <input type="number" class="gcs-select" @bind="battCapacity" min="0" step="100" />
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    :root {
        --gcs-bg: #0d1117;
        --gcs-card: #161b22;
        --gcs-border: #30363d;
        --gcs-cyan: #58a6ff;
        --gcs-amber: #d29922;
        --gcs-text: #c9d1d9;
    }

    .gcs-setup-container {
        display: flex;
        flex-direction: column;
        height: 100%;
        gap: 16px; /* Aligned with other tabs */
        padding: 20px;
        background: var(--gcs-bg);
        color: var(--gcs-text);
        width: 100%; /* Aligned with other tabs */
        max-width: 500px; /* Aligned with other tabs */
        margin: 0 auto; /* Aligned with other tabs */
        overflow: hidden;
    }

    .hud-wrapper {
        height: 300px;
        width: 100%;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.4);
        border: 1px solid var(--gcs-border);
        flex-shrink: 0;
        background: #000;
        position: relative; /* Keeps your text overlays perfectly positioned */
    }

    .hud-overlay-text {
        position: absolute;
        top: 15px;
        left: 25px;
        font-size: 0.7rem;
        color: var(--gcs-cyan);
        letter-spacing: 2px;
        font-weight: 800;
    }

    .hud-status-bar {
        position: absolute;
        bottom: 0;
        width: 100%;
        background: rgba(0,0,0,0.8);
        padding: 8px 20px;
        display: flex;
        gap: 25px;
        font-size: 0.65rem;
        font-family: monospace;
        border-top: 1px solid var(--gcs-border);
    }

    .setup-list {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 20px;
        overflow-y: auto;
        padding-right: 5px;
    }

    .setup-list::-webkit-scrollbar {
        width: 6px;
    }

    .setup-list::-webkit-scrollbar-thumb {
        background: var(--gcs-border);
        border-radius: 10px;
    }

    .setup-module {
        background: var(--gcs-card);
        border: 1px solid var(--gcs-border);
        border-radius: 8px;
        display: flex;
        flex-direction: column;
        width: 100%;
        transition: border 0.2s;
    }

    .setup-module:hover {
        border-color: var(--gcs-cyan);
    }

    .border-amber {
        border-left: 4px solid var(--gcs-amber);
    }

    .module-header {
        padding: 12px 16px;
        border-bottom: 1px solid var(--gcs-border);
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 800;
        font-size: 0.75rem;
        text-transform: uppercase;
    }

    .module-content {
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .readout-row {
        display: flex;
        gap: 12px;
    }

    .readout {
        flex: 1;
        background: #010409;
        padding: 10px;
        border-radius: 6px;
        border: 1px solid var(--gcs-border);
    }

    .readout label {
        display: block;
        font-size: 0.55rem;
        color: #8b949e;
        margin-bottom: 4px;
        font-weight: 800;
    }

    .readout .value {
        font-size: 0.8rem;
        font-weight: 800;
        color: var(--gcs-cyan);
    }

    .input-label {
        font-size: 0.6rem;
        font-weight: 800;
        color: #8b949e;
        margin-bottom: -10px;
    }

    .gcs-select, .gcs-select-sm {
        background: #010409;
        color: white;
        border: 1px solid var(--gcs-border);
        border-radius: 4px;
        padding: 8px;
        font-size: 0.75rem;
        width: 100%;
        outline: none;
    }

    .gcs-select-sm {
        width: 100px;
        padding: 4px;
    }

    .status-box-pro {
        background: #010409;
        border: 1px dashed var(--gcs-border);
        padding: 18px;
        text-align: center;
        border-radius: 8px;
        position: relative;
    }

    .status-box-pro.active-cal {
        border-color: var(--gcs-cyan);
        background: rgba(88, 166, 255, 0.05);
    }

    .status-value {
        font-size: 0.85rem;
        font-weight: 800;
        color: var(--gcs-cyan);
    }

    .radio-strip {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .radio-strip .label {
        width: 85px;
        font-size: 0.6rem;
        font-weight: 800;
        color: #8b949e;
    }

    .bar-container {
        flex: 1;
        height: 12px;
        background: #000;
        border-radius: 6px;
        position: relative;
        border: 1px solid var(--gcs-border);
        overflow: hidden;
    }

    .bar-fill {
        height: 100%;
        background: var(--gcs-cyan);
        transition: width 0.1s;
    }

    .center-line {
        position: absolute;
        left: 50%;
        width: 1px;
        height: 100%;
        background: rgba(255,255,255,0.1);
    }

    .raw-val {
        width: 45px;
        font-family: monospace;
        font-size: 0.7rem;
        color: var(--gcs-cyan);
        text-align: right;
    }

    /* MISSION PLANNER MOTOR TEST CSS */
    .mp-top-row {
        display: flex;
        gap: 20px;
        align-items: center;
    }

    .mp-input-group {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .mp-input-group label {
            font-size: 0.65rem;
            color: #8b949e;
            font-weight: 800;
        }

    .mp-input {
        background: #010409;
        color: var(--gcs-cyan);
        border: 1px solid var(--gcs-border);
        width: 50px;
        padding: 4px;
        border-radius: 4px;
        font-family: monospace;
        font-weight: bold;
        text-align: center;
        outline: none;
        transition: border 0.2s;
    }

    .mp-input:focus {
            border-color: var(--gcs-cyan);
        }

    .mp-info-row {
        display: flex;
        gap: 30px;
        font-size: 0.7rem;
        color: var(--gcs-cyan);
        margin: 5px 0 10px 0;
        font-weight: 800;
    }

    .mp-motor-grid {
        display: grid;
        grid-template-columns: 120px 1fr; /* Locks buttons to 120px, text takes the rest */
        gap: 10px 15px;
        align-items: center;
    }

    .mp-label {
        font-size: 0.7rem;
        color: #c9d1d9;
        font-family: monospace;
    }

    .mp-action-row {
        display: flex;
        gap: 10px;
        margin-top: 15px;
        border-top: 1px dashed var(--gcs-border);
        padding-top: 15px;
    }

    .btn-mp {
        background: #21262d;
        border: 1px solid var(--gcs-border);
        color: #c9d1d9;
        padding: 6px 12px;
        font-size: 0.65rem;
        font-weight: 800;
        cursor: pointer;
        border-radius: 4px;
        transition: all 0.2s ease;
        width: 100%;
        text-align: center;
    }

    .btn-mp:hover {
            background: #2ea043; /* Mission Planner Green Accent */
            border-color: #3fb950;
            color: white;
        }

    .btn-mp-stop {
        background: #21262d;
        border: 1px solid var(--gcs-border);
        color: #ff3a3a; /* Danger Red for Stop */
        padding: 6px 12px;
        font-size: 0.65rem;
        font-weight: 800;
        cursor: pointer;
        border-radius: 4px;
        transition: all 0.2s ease;
        width: 100%;
        text-align: center;
    }

    .btn-mp-stop:hover {
            background: rgba(255, 58, 58, 0.15);
            border-color: #ff3a3a;
        }

    .motor-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
    }

    .btn-motor {
        background: #21262d;
        border: 1px solid var(--gcs-border);
        color: #fff;
        padding: 15px;
        border-radius: 6px;
        font-weight: 800;
        cursor: pointer;
        transition: background 0.1s;
    }

    .btn-motor:active {
        background: #238636;
        border-color: #2ea043;
    }

    .warning-banner {
        background: rgba(210, 153, 34, 0.1);
        border: 1px solid var(--gcs-amber);
        color: var(--gcs-amber);
        padding: 10px;
        border-radius: 4px;
        font-size: 0.65rem;
        font-weight: 800;
        text-align: center;
    }

    .footer-hint {
        font-size: 0.55rem;
        text-align: center;
        color: #484f58;
        font-weight: 800;
    }

    .esc-info-box {
        font-size: 0.65rem;
        color: #8b949e;
        line-height: 1.5;
    }

    .btn-gcs-primary {
        background: var(--gcs-cyan);
        border: none;
        padding: 6px 12px;
        border-radius: 4px;
        font-size: 0.65rem;
        font-weight: 800;
        cursor: pointer;
        margin-left: auto;
    }

    .btn-gcs-outline {
        background: transparent;
        border: 1px solid var(--gcs-cyan);
        color: var(--gcs-cyan);
        padding: 5px 12px;
        border-radius: 4px;
        font-size: 0.65rem;
        font-weight: 800;
        cursor: pointer;
    }

    .btn-gcs-amber {
        background: var(--gcs-amber);
        border: none;
        padding: 6px 12px;
        border-radius: 4px;
        font-size: 0.65rem;
        font-weight: 800;
        cursor: pointer;
    }

    .fs-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .cal-pulse {
        position: absolute;
        top: 6px;
        right: 6px;
        width: 6px;
        height: 6px;
        background: #ff4444;
        border-radius: 50%;
        animation: pulse 1s infinite;
    }
    
    @@keyframes pulse {
        0% { opacity: 1; }
        50% { opacity: 0.3; }
        100% { opacity: 1; }
    }

    .compass-mini-grid {
        display: flex;
        justify-content: space-around;
        font-family: monospace;
        font-size: 0.7rem;
    }

    .cal-progress-bg {
        width: 100%;
        height: 4px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 2px;
        margin-top: 8px;
        overflow: hidden;
    }

    .cal-progress-fill {
        height: 100%;
        background: var(--gcs-cyan);
        width: 0%;
        transition: width 0.3s ease-out;
        box-shadow: 0 0 5px var(--gcs-cyan);
    }

    .axis .val {
        color: var(--gcs-cyan);
        font-weight: 800;
    }

    .dual-status-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .motor-grid {
        display: grid;
        /* Automatically fits as many buttons as possible in a row */
        grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
        gap: 10px;
        margin-bottom: 15px;
    }

    .btn-motor {
        background: #161b22;
        border: 1px solid var(--gcs-border);
        color: var(--gcs-cyan);
        padding: 10px;
        border-radius: 4px;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-motor:hover {
            background: var(--gcs-cyan);
            color: #000;
            border-color: #fff;
        }

    .status-box-pro {
        display: flex;
        flex-direction: column;
        align-items: center; /* Horizontal Center */
        justify-content: center; /* Vertical Center */
        position: relative; /* Anchor for the pulse dot */
        min-height: 80px;
        text-align: center;
        border: 1px solid var(--gcs-border);
        border-radius: 8px;
        background: #010409;
    }

    .cal-pulse {
        position: absolute; /* Floats on top, won't push text */
        top: 8px;
        right: 8px;
        width: 8px;
        height: 8px;
        background: #ff3a3a;
        border-radius: 50%;
        box-shadow: 0 0 8px #ff3a3a;
    }

    /* Ensures the Action Row (Test All, Sequence, Stop) sits at the bottom */
    .mp-action-row {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 10px;
        margin-top: 15px;
        border-top: 1px dashed var(--gcs-border);
        padding-top: 15px;
    }

    /* Standardizes the buttons for the action row */
    .btn-mp, .btn-mp-stop {
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.65rem;
        font-weight: 800;
        border-radius: 4px;
        cursor: pointer;
        text-transform: uppercase;
        transition: all 0.2s;
    }

    .btn-mp {
        background: #21262d;
        border: 1px solid var(--gcs-border);
        color: var(--gcs-cyan);
    }

