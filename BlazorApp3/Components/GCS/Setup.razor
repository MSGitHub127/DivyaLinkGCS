@page "/setup"
@inject MavlinkService Drone
@inject IJSRuntime JS
@implements IDisposable

<div class="gcs-setup-container">
    <div class="hud-wrapper">
        <Hud />
    </div>

    <div class="setup-list">

        <div class="setup-module">
            <div class="module-header">
                <i class="bi bi-gear-wide-connected"></i>
                <span>FRAME GEOMETRY</span>
                <button class="btn-gcs-primary" @onclick="ApplyFrame">SYNC PARAMS</button>
            </div>
            <div class="module-content">
                <div class="readout-row">
                    <div class="readout"><label>ACTIVE TYPE</label><div class="value">@currentType</div></div>
                    <div class="readout"><label>ACTIVE CLASS</label><div class="value">@currentClass</div></div>
                </div>
                <div class="control-group">
                    <label class="input-label">VEHICLE TYPE</label>
                    <select class="gcs-select" @bind="selectedFrameType">
                        <option value="1">QUADCOPTER</option>
                        <option value="2">HEXACOPTER</option>
                        <option value="3">OCTACOPTER</option>
                    </select>
                    <label class="input-label">FRAME CLASS</label>
                    <select class="gcs-select" @bind="selectedFrameClass">
                        <option value="0">PLUS (+)</option>
                        <option value="1">X-FRAME</option>
                        <option value="2">V-FRAME</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="setup-module">
            <div class="module-header">
                <i class="bi bi-compass"></i>
                <span>SENSORS & IMU</span>
            </div>
            <div class="module-content">

                <div class="sensor-rows-container">
                    @* ACCELEROMETER ROW WITH WIZARD *@
                    <div class="sensor-row-card accel-card">
                        <div class="sr-main-bar">
                            <div class="sr-info">
                                <span class="sr-title">ACCELEROMETER</span>
                                <span class="sr-status @(IsAccelCalibrating && Drone.LiveAccelStatus != "WAITING..." ? "active-text" : Drone.LiveAccelStatus == "FAILED" || Drone.LiveAccelStatus.Contains("DENIED") || Drone.LiveAccelStatus.Contains("NO RESPONSE") ? "text-danger" : Drone.LiveAccelStatus == "SUCCESS" ? "active-text" : "")">
                                    @Drone.LiveAccelStatus
                                </span>
                            </div>
                            <div class="sr-progress">
                                <div class="cal-progress-bg @(IsAccelCalibrating ? "bg-active" : "")">
                                    @if (Drone.LiveAccelStatus == "COMPUTING...")
                                    {
                                        <div class="cal-progress-indeterminate"></div>
                                    }
                                    else
                                    {
                                        <div class="cal-progress-fill" style="width: @(Drone.LiveAccelProgress)%"></div>
                                    }
                                </div>
                            </div>
                            <div class="sr-actions">
                                @if (Drone.LiveAccelStatus == "COMPUTING...")
                                {
                                    <div class="btn-sensor-working">
                                        <div class="spinner-border-sm"></div>
                                        <span>COMPUTING</span>
                                    </div>
                                }
                                else if (Drone.LiveAccelStatus == "RECORDING...")
                                {
                                    <div class="btn-sensor-working">
                                        <div class="spinner-border-sm"></div>
                                        <span>RECORDING</span>
                                    </div>
                                }
                                else if (Drone.LiveAccelStatus == "WAITING...")
                                {
                                    <div class="btn-sensor-working">
                                        <div class="spinner-border-sm"></div>
                                        <span>WAITING</span>
                                    </div>
                                }
                                else if (IsAccelCalibrating)
                                {
                                    <button class="btn-sensor-action" @onclick="Drone.AckCalibrationStep">NEXT</button>
                                }
                                else
                                {
                                    <button class="btn-sensor-start" @onclick="StartAccel">START</button>
                                }
                                <button class="btn-sensor-cancel" @onclick="CancelAccel">CANCEL</button>
                            </div>
                        </div>

                        @* EXPANDED WIZARD UI (Only shows during active calibration) *@
                        @if (IsAccelCalibrating && Drone.LiveAccelStatus != "WAITING...")
                        {
                            <div class="accel-wizard-panel">
                                <div class="drone-model-container">
                                    <svg class="drone-svg @GetDroneOrientationClass(Drone.LiveAccelStatus)" viewBox="0 0 100 100">
                                        <rect x="44" y="20" width="12" height="60" fill="#30363d" rx="4" />
                                        <path d="M50 20 L40 35 L60 35 Z" fill="#00f2ff" />
                                        <line x1="20" y1="20" x2="80" y2="80" stroke="#30363d" stroke-width="4" />
                                        <line x1="20" y1="80" x2="80" y2="20" stroke="#30363d" stroke-width="4" />
                                        <circle cx="20" cy="20" r="10" fill="#ff3a3a" opacity="0.8" />
                                        <circle cx="80" cy="20" r="10" fill="#ff3a3a" opacity="0.8" />
                                        <circle cx="20" cy="80" r="10" fill="#00f2ff" opacity="0.8" />
                                        <circle cx="80" cy="80" r="10" fill="#00f2ff" opacity="0.8" />
                                    </svg>
                                </div>
                                <div class="wizard-text">
                                    <div class="step-badge">
                                        @(Drone.LiveAccelStatus == "COMPUTING..." ? "COMPUTING" : $"STEP {(Drone.LiveAccelProgress / 16) + 1} OF 6")
                                    </div>
                                    <div class="instruction-title">@GetAccelInstructionTitle(Drone.LiveAccelStatus)</div>
                                    <div class="instruction-desc">@GetAccelInstructionDesc(Drone.LiveAccelStatus)</div>
                                </div>
                            </div>
                        }
                    </div>

                    @* GYROSCOPE ROW WITH WIZARD *@
                    <div class="sensor-row-card accel-card">
                        <div class="sr-main-bar">
                            <div class="sr-info">
                                <span class="sr-title">GYROSCOPE</span>
                                <span class="sr-status @(IsGyroCalibrating ? "active-text" : (Drone.LiveGyroStatus == "FAILED" ? "text-danger" : ""))">
                                    @Drone.LiveGyroStatus
                                </span>
                            </div>

                            <div class="sr-progress">
                                <div class="cal-progress-bg @(IsGyroCalibrating ? "bg-active" : "")">
                                    @if (IsGyroCalibrating)
                                    {
                                        <div class="cal-progress-indeterminate"></div>
                                    }
                                    else
                                    {
                                        <div class="cal-progress-fill" style="width: @(Drone.LiveGyroProgress)%"></div>
                                    }
                                </div>
                            </div>

                            <div class="sr-actions">
                                @if (IsGyroCalibrating)
                                {
                                    <div class="btn-sensor-working">
                                        <div class="spinner-border-sm"></div>
                                        <span>WORKING</span>
                                    </div>
                                }
                                else if (Drone.LiveGyroStatus == "AUTO AT BOOT")
                                {
                                    <button class="btn-sensor-start" style="opacity: 0.5; cursor: not-allowed;" disabled>AUTOMATIC</button>
                                }
                                else
                                {
                                    <button class="btn-sensor-start" @onclick="StartGyro">
                                        @(Drone.LiveGyroStatus == "FAILED" ? "RETRY" : "START")
                                    </button>
                                }
                                <button class="btn-sensor-cancel" @onclick="CancelGyro" title="Force Abort">CANCEL</button>
                            </div>
                        </div>

                        @* EXPANDED WIZARD UI (Only shows during active calibration) *@
                        @if (IsGyroCalibrating)
                        {
                            <div class="accel-wizard-panel">
                                <div class="drone-model-container gyro-container">
                                    <svg class="gyro-svg" viewBox="0 0 100 100">
                                        <ellipse cx="50" cy="50" rx="40" ry="15" fill="none" stroke="var(--gcs-amber)" stroke-width="3" class="ring-x" />
                                        <ellipse cx="50" cy="50" rx="15" ry="40" fill="none" stroke="var(--gcs-cyan)" stroke-width="3" class="ring-y" />
                                        <circle cx="50" cy="50" r="6" fill="#fff" class="pulse-dot-fast" />
                                    </svg>
                                </div>
                                <div class="wizard-text">
                                    <div class="step-badge" style="background: var(--gcs-amber); color: #000;">HANDS OFF</div>
                                    <div class="instruction-title">Calculating Baseline Offsets</div>
                                    <div class="instruction-desc">The IMU is actively capturing zero-rotation data. Any vibration will corrupt the calibration. Please step away from the bench until complete.</div>
                                </div>
                            </div>
                        }
                    </div>

                    @* COMPASS ROW WITH WIZARD *@
                    <div class="sensor-row-card accel-card">
                        <div class="sr-main-bar">
                            <div class="sr-info">
                                <span class="sr-title">COMPASS (MAG)</span>
                                <span class="sr-status @(IsMagCalibrating ? "active-text" : (Drone.LiveMagStatus.Contains("FAILED") || Drone.LiveMagStatus.Contains("DENIED") ? "text-danger" : ""))">
                                    @Drone.LiveMagStatus
                                </span>
                            </div>
                            <div class="sr-progress">
                                <div class="cal-progress-bg @(IsMagCalibrating ? "bg-active" : "")">
                                    <div class="cal-progress-fill" style="width: @(Drone.LiveMagProgress)%"></div>
                                </div>
                            </div>
                            <div class="sr-actions">
                                @if (IsMagCalibrating)
                                {
                                    <div class="btn-sensor-working">
                                        <div class="spinner-border-sm"></div>
                                        <span>@Drone.LiveMagProgress%</span>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn-sensor-start" @onclick="StartMag">
                                        @(Drone.LiveMagStatus == "FAILED" ? "RETRY" : "START")
                                    </button>
                                }
                                <button class="btn-sensor-cancel" @onclick="CancelMag" title="Force Abort">CANCEL</button>
                            </div>
                        </div>

                        @* EXPANDED WIZARD UI (Only shows during active calibration) *@
                        @if (IsMagCalibrating)
                        {
                            <div class="accel-wizard-panel">
                                <div class="drone-model-container mag-container">
                                    <svg class="mag-svg" viewBox="0 0 100 100">
                                        <circle cx="50" cy="50" r="40" fill="none" stroke="var(--gcs-cyan)" stroke-width="2" stroke-dasharray="4 4" class="spin-z" />
                                        <ellipse cx="50" cy="50" rx="40" ry="15" fill="none" stroke="#ff3a3a" stroke-width="2" class="spin-x" />
                                        <ellipse cx="50" cy="50" rx="15" ry="40" fill="none" stroke="#3fb950" stroke-width="2" class="spin-y" />
                                        <circle cx="50" cy="50" r="5" fill="#fff" />
                                    </svg>
                                </div>
                                <div class="wizard-text">
                                    <div class="step-badge" style="background: var(--gcs-cyan); color: #000;">DANCE REQUIRED</div>
                                    <div class="instruction-title">Rotate on All Axes</div>
                                    <div class="instruction-desc">Pick up the drone and slowly rotate it continuously around its pitch, roll, and yaw axes. Keep rotating until the progress bar reaches 100%.</div>
                                </div>
                            </div>
                        }
                    </div>

                    @* ONBOARD LED ROW *@
                    <div class="sensor-row-card">
                        <div class="sr-info">
                            <span class="sr-title">ONBOARD LEDS</span>
                            <span class="sr-status @(isLedEnabled ? "active-text" : "")">
                                @(isLedEnabled ? "ENABLED" : "VANISHED")
                            </span>
                        </div>
                        <div class="sr-progress">
                            <span style="font-size: 0.65rem; color: #888; margin-top: 5px; display: block;">
                                Mutes the physical Pixhawk RGB status lights while on the bench.
                            </span>
                        </div>
                        <div class="sr-actions">
                            <button class="btn-sensor-action" style="background: #2ea043; color: white;" @onclick="() => TogglePixhawkLeds(true)">ON</button>
                            <button class="btn-sensor-cancel" @onclick="() => TogglePixhawkLeds(false)">OFF</button>
                        </div>
                    </div>

                </div>

            </div>
        </div>

        <div class="setup-module">
            <div class="module-header">
                <i class="bi bi-controller"></i>
                <span>RADIO CHANNELS (RC)</span>
                <button class="btn-gcs-outline" @onclick="HandleRcClick" style="@(Drone.IsRcCalibrating ? "background: var(--gcs-cyan); color: #000;" : "")">
                    @(Drone.IsRcCalibrating ? "SAVE CALIBRATION" : "CALIBRATE RC")
                </button>
            </div>

            <div class="module-content" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">

                @if (Drone.IsRcCalibrating)
                {
                    <div style="grid-column: span 2; background: rgba(210, 153, 34, 0.1); border: 1px solid #d29922; color: #d29922; padding: 10px; border-radius: 4px; font-size: 0.75rem;">
                        <strong>CALIBRATION ACTIVE:</strong> Move all sticks to their maximum limits, center them, then click SAVE.
                    </div>
                }

                @for (int i = 0; i < 8; i++)
                {
                    var chanNames = new[] { "1: ROLL", "2: PITCH", "3: THROTTLE", "4: YAW", "5: MODE 1", "6: MODE 2", "7: AUX 1", "8: AUX 2" };
                    var rawVal = _localChannels[i];

                    <div style="display: flex; flex-direction: column; gap: 4px;">
                        <div style="display: flex; justify-content: space-between; align-items: flex-end;">
                            <span style="font-size: 0.65rem; color: #888; font-weight: bold;">@chanNames[i]</span>
                            <span style="font-family: monospace; font-size: 0.85rem; font-weight: bold; color: @(rawVal == 0 ? "#ff3a3a" : "#00f2ff");">
                                @(rawVal == 0 ? "NO RC DATA" : $"{rawVal} us")
                            </span>
                        </div>

                        <div style="width: 100%; height: 18px; background: #0a0b0d; border: 1px solid #333; border-radius: 4px; position: relative; overflow: hidden;">

                            @if (Drone.IsRcCalibrating && Drone.RcMax[i] > Drone.RcMin[i] && rawVal != 0)
                            {
                                <div style="position: absolute; height: 100%; background: rgba(0, 242, 255, 0.2);
                                                                    left: @(CalculatePercent(Drone.RcMin[i]))%;
                                                                    width: @(CalculatePercent(Drone.RcMax[i]) - CalculatePercent(Drone.RcMin[i]))%;">
                                </div>
                            }

                            <div style="position: absolute; height: 100%;
                                                    background: @(Drone.IsRcCalibrating ? "#ffffff" : "#00f2ff");
                                                    width: @(rawVal == 0 ? 50 : CalculatePercent(rawVal))%;
                                                    opacity: @(rawVal == 0 ? 0.2 : 1.0);
                                                    transition: width 0.1s linear;">
                            </div>

                            <div style="position: absolute; left: 50%; width: 2px; height: 100%; background: rgba(255, 0, 0, 0.6); z-index: 10;"></div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="setup-module">
            <div class="module-header">
                <i class="bi bi-shield-shaded"></i>
                <span>FLIGHT MODE ASSIGNMENT</span>
                <button class="btn-gcs-primary" @onclick="SyncFlightModes">SAVE MODES</button>
            </div>
            <div class="module-content">
                @for (int i = 0; i < 3; i++)
                {
                    var index = i;
                    <div class="mode-row">
                        <label class="input-label">SWITCH POSITION @(index + 1)</label>
                        <select class="gcs-select" @bind="flightModeSettings[index]">
                            <option value="STABILIZE">STABILIZE</option>
                            <option value="ALT_HOLD">ALT_HOLD</option>
                            <option value="LOITER">LOITER</option>
                            <option value="RTL">RTL</option>
                            <option value="AUTO">AUTO</option>
                        </select>
                    </div>
                }
            </div>
        </div>

        <div class="setup-module border-amber">
            <div class="module-header warning">
                <i class="bi bi-propeller"></i>
                <span>MOTOR TEST (@Drone.State.MotorCount MOTORS DETECTED)</span>
            </div>
            <div class="module-content">
                <div class="mp-top-row">
                    <div class="mp-input-group">
                        <label>THROTTLE %</label>
                        <input type="number" class="mp-input" @bind="motorTestThrottle" min="0" max="100" />
                    </div>
                    <div class="mp-input-group">
                        <label>DURATION (S)</label>
                        <input type="number" class="mp-input" @bind="motorTestDuration" min="1" max="15" />
                    </div>
                    <div class="mp-info-row" style="margin-left: auto;">
                        <span>FRAME: @currentType</span>
                    </div>
                </div>

                <div class="motor-grid">
                    @for (int i = 1; i <= Drone.State.MotorCount; i++)
                    {
                        int motorId = i;
                        <button class="btn-motor" @onclick="() => Drone.TestMotor(motorId, motorTestThrottle, motorTestDuration)">
                            MOTOR @motorId
                        </button>
                    }
                </div>

                <div class="mp-action-row">
                    <button class="btn-mp" @onclick="() => Drone.TestAllMotors((float)motorTestThrottle, (float)motorTestDuration)">TEST ALL MOTORS</button>
                    <button class="btn-mp" @onclick="() => Drone.TestMotorSequence((float)motorTestThrottle, (float)motorTestDuration)">RUN SEQUENCE</button>
                    <button class="btn-mp-stop" @onclick="StopAllMotors">ABORT ALL</button>
                </div>

                <p class="footer-hint">CAUTION: PROPELLERS MUST BE REMOVED BEFORE TESTING</p>
            </div>
        </div>

        <div class="setup-module border-amber">
            <div class="module-header warning">
                <i class="bi bi-lightning-charge"></i>
                <span>ESC THROTTLE CALIBRATION</span>
                <button class="btn-gcs-amber" @onclick="ToggleEscCalMode">ENABLE CAL MODE</button>
            </div>
            <div class="module-content">
                <div class="esc-info-box">
                    <p>1. Enable Cal Mode (Sets parameter to 3).</p>
                    <p>2. Disconnect USB and Battery.</p>
                    <p>3. Reconnect battery to start beep sequence.</p>
                </div>
                <div class="status-box-pro">
                    <div class="status-label">CALIBRATION STATE</div>
                    <div class="status-value">@escCalStatus</div>
                </div>
            </div>
        </div>

        <div class="setup-module border-amber">
            <div class="module-header warning">
                <i class="bi bi-exclamation-triangle"></i>
                <span>SAFETY FAILSAFES</span>
                <button class="btn-gcs-amber" @onclick="SaveFailsafes">SAVE ALL</button>
            </div>
            <div class="module-content">
                <div class="fs-row">
                    <label class="input-label">RC LOSS ACTION</label>
                    <select class="gcs-select-sm" @bind="rcLossAction"><option value="1">RTL</option><option value="2">LAND</option></select>
                </div>
                <div class="fs-row">
                    <label class="input-label">LOW BATT ACTION</label>
                    <select class="gcs-select-sm" @bind="lowBattAction"><option value="1">RTL</option><option value="2">LAND</option></select>
                </div>
            </div>
        </div>

        <div class="setup-module">
            <div class="module-header">
                <i class="bi bi-battery-half"></i>
                <span>BATTERY MONITOR</span>
                <button class="btn-gcs-primary" @onclick="SaveBatterySettings">SAVE PARAMS</button>
            </div>
            <div class="module-content">
                <div class="readout-row">
                    <div class="readout">
                        <label>LIVE VOLTAGE</label>
                        <div class="value">@Drone.State.Voltage.ToString("0.00") V</div>
                    </div>
                    <div class="readout">
                        <label>REMAINING</label>
                        <div class="value">@Drone.State.BatteryPercent%</div>
                    </div>
                </div>

                <div class="control-group">
                    <label class="input-label">MONITOR TYPE</label>
                    <select class="gcs-select" @bind="battMonitorType">
                        <option value="0">0: DISABLED</option>
                        <option value="3">3: ANALOG VOLTAGE ONLY</option>
                        <option value="4">4: ANALOG VOLTAGE AND CURRENT</option>
                        <option value="8">8: UAVCAN DIALOG</option>
                        <option value="9">9: ESC TELEMETRY</option>
                    </select>

                    <label class="input-label" style="margin-top: 10px;">BATTERY CAPACITY (mAh)</label>
                    <input type="number" class="gcs-select" @bind="battCapacity" min="0" step="100" />
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    :root {
        --gcs-bg: #0d1117;
        --gcs-card: #161b22;
        --gcs-border: #30363d;
        --gcs-cyan: #58a6ff;
        --gcs-amber: #d29922;
        --gcs-text: #c9d1d9;
    }

    .gcs-setup-container {
        display: flex;
        flex-direction: column;
        height: 100%;
        gap: 16px; /* Aligned with other tabs */
        padding: 20px;
        background: var(--gcs-bg);
        color: var(--gcs-text);
        width: 100%; /* Aligned with other tabs */
        max-width: 500px; /* Aligned with other tabs */
        margin: 0 auto; /* Aligned with other tabs */
        overflow: hidden;
    }

    .hud-wrapper {
        height: 300px;
        width: 100%;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.4);
        border: 1px solid var(--gcs-border);
        flex-shrink: 0;
        background: #000;
        position: relative; /* Keeps your text overlays perfectly positioned */
    }

    .hud-overlay-text {
        position: absolute;
        top: 15px;
        left: 25px;
        font-size: 0.7rem;
        color: var(--gcs-cyan);
        letter-spacing: 2px;
        font-weight: 800;
    }

    .hud-status-bar {
        position: absolute;
        bottom: 0;
        width: 100%;
        background: rgba(0,0,0,0.8);
        padding: 8px 20px;
        display: flex;
        gap: 25px;
        font-size: 0.65rem;
        font-family: monospace;
        border-top: 1px solid var(--gcs-border);
    }

    .setup-list {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 20px;
        overflow-y: auto;
        padding-right: 5px;
    }

        .setup-list::-webkit-scrollbar {
            width: 6px;
        }

        .setup-list::-webkit-scrollbar-thumb {
            background: var(--gcs-border);
            border-radius: 10px;
        }

    .setup-module {
        background: var(--gcs-card);
        border: 1px solid var(--gcs-border);
        border-radius: 8px;
        display: flex;
        flex-direction: column;
        width: 100%;
        transition: border 0.2s;
    }

        .setup-module:hover {
            border-color: var(--gcs-cyan);
        }

    .border-amber {
        border-left: 4px solid var(--gcs-amber);
    }

    .module-header {
        padding: 12px 16px;
        border-bottom: 1px solid var(--gcs-border);
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 800;
        font-size: 0.75rem;
        text-transform: uppercase;
    }

    /* ROW MAJOR SENSOR LAYOUT */
    .sensor-rows-container {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .sensor-row-card {
        background: #010409;
        border: 1px solid var(--gcs-border);
        border-radius: 6px;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        gap: 20px;
        transition: border 0.2s;
    }

        .sensor-row-card:hover {
            border-color: #555;
        }

    .sr-info {
        display: flex;
        flex-direction: column;
        gap: 4px;
        width: 140px; /* Fixed width so all progress bars align vertically */
        flex-shrink: 0;
    }

    .sr-title {
        font-size: 0.65rem;
        font-weight: 800;
        color: #8b949e;
        letter-spacing: 0.5px;
    }

    .sr-status {
        font-size: 0.8rem;
        font-weight: 800;
        color: var(--gcs-text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

        .sr-status.active-text {
