                        <option value="1">Always RTL</option>
                        <option value="2">Continue if Auto, else RTL</option>
                        <option value="3">Always Land</option>
                        <option value="4">SmartRTL, else RTL</option>
                        <option value="5">SmartRTL, else Land</option>
                    </select>
                    <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px]">PWM THRESHOLD <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(FS_THR_VALUE)</span></label>
                    <div class="flex gap-[8px] items-center mt-[6px] mb-[8px]">
                        <input type="number" class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-[88px] outline-none" @bind="rcThrValue" min="900" max="1100" step="5" />
                        <span class="text-[0.67rem] text-[#555]">µs · RC below this = lost · default 975</span>
                    </div>
                    @if (rcThrValue < 925 || rcThrValue > 1025)
                    {
                        <div class="bg-[rgba(240,180,41,0.08)] border border-[rgba(240,180,41,0.3)] rounded-[5px] p-[5px_10px] text-[0.7rem] text-[#f0b429] m-[3px_0_6px]">⚠️ Unusual — standard range is 925–1025 µs</div>
                    }

                    <div class="flex items-center gap-[8px] text-[0.6rem] font-extrabold tracking-[1px] text-[#d29922] mt-[12px] mb-[4px] border-b border-[#1c2128] pb-[3px]">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-battery-warning">
                            <path d="M10 17h.01"/><path d="M10 7v6"/><path d="M14 6h2a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-2"/><path d="M22 14v-4"/><path d="M6 18H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h2"/>
                        </svg> 
                        <span>BATTERY FAILSAFE <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(FS_BATT_ENABLE)</span></span>
                    </div>
                    <div class="text-[0.67rem] text-[#555] mb-[5px] leading-[1.4]">Action when voltage/mAh consumed crosses the threshold set in Battery Monitor.</div>
                    <select class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[8px]" @bind="lowBattAction">
                        <option value="0">Disabled</option>
                        <option value="1">Land immediately</option>
                        <option value="2">RTL</option>
                        <option value="3">SmartRTL, else RTL</option>
                        <option value="4">SmartRTL, else Land</option>
                        <option value="5">Terminate motors ⚠️</option>
                    </select>

                    <div class="flex items-center gap-[8px] text-[0.6rem] font-extrabold tracking-[1px] text-[#d29922] mt-[12px] mb-[4px] border-b border-[#1c2128] pb-[3px]">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-laptop-minimal">
                            <rect width="18" height="12" x="3" y="4" rx="2" ry="2"/><line x1="2" x2="22" y1="20" y2="20"/>
                        </svg> 
                        <span>GCS HEARTBEAT LOSS <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(FS_GCS_ENABLE)</span></span>
                    </div>
                    <div class="text-[0.67rem] text-[#555] mb-[5px] leading-[1.4]">Action when this GCS stops sending heartbeats for &gt;5 seconds (laptop crash, cable disconnect).</div>
                    <select class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[8px]" @bind="gcsLossAction">
                        <option value="0">Disabled</option>
                        <option value="1">RTL</option>
                        <option value="2">Continue mission (if in Auto)</option>
                        <option value="3">SmartRTL, else RTL</option>
                        <option value="4">SmartRTL, else Land</option>
                    </select>
                </div>
            }
        </div>

        @* ── BATTERY MONITOR MODULE ── *@
        <div class="bg-[#161b22] border border-[#30363d] rounded-[8px] flex flex-col w-full transition-colors duration-200 min-w-0 hover:border-[#58a6ff] @(expandedModules["Battery"] ? (AnyModuleExpanded ? "flex-1 flex-col min-h-0 col-auto" : "col-span-full") : (AnyModuleExpanded ? "hidden" : "flex-col"))">
            <div class="p-[14px_16px] flex items-center gap-[8px] font-bold text-[0.95rem] uppercase cursor-pointer select-none transition-all duration-200 min-h-[58px] hover:bg-[rgba(255,255,255,0.03)] @(expandedModules["Battery"] ? "border-b border-[#30363d] rounded-t-[8px]" : "rounded-[8px]")" @onclick='() => ToggleModule("Battery")'>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-battery-medium-icon lucide-battery-medium"><path d="M10 14v-4"/><path d="M22 14v-4"/><path d="M6 14v-4"/><rect x="2" y="6" width="16" height="12" rx="2"/></svg>
                <span>BATTERY INFO</span>
                <div class="flex-1"></div> @* Standard spacer to push actions to the right *@

        @if (expandedModules["Battery"] && _battParamsLoaded)
        {
            @* Integrated Save Button: Moved from content area *@
            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer hover:brightness-110 transition-all mr-2" 
                    @onclick="SaveBatterySettings" 
                    @onclick:stopPropagation="true"
                    disabled="@(!Drone.IsLinkHealthy)">
                SAVE PARAMS
            </button>
        }
                <i class="bi @(expandedModules["Battery"] ? "bi-chevron-up text-[#58a6ff] rotate-180" : "bi-chevron-down text-[#555]") text-[0.75rem] shrink-0 transition-all duration-200"></i>
            </div>
            @if (expandedModules["Battery"])
            {
                <div class="p-[14px_16px_16px] flex flex-col gap-[12px] @(AnyModuleExpanded ? "flex-1 overflow-y-auto no-scrollbar" : "max-h-[400px] overflow-y-auto no-scrollbar")">
                    @if (Drone.IsLinkHealthy)
                    {
                        <div class="flex gap-[12px] flex-wrap mb-[8px]">
                            <div class="flex-1 bg-[#010409] p-[10px] rounded-[6px] border border-[#30363d]"><label class="block text-[0.55rem] text-[#8b949e] mb-[4px] font-extrabold">VOLTAGE</label><div class="text-[0.8rem] font-extrabold text-[#58a6ff] @BVC">@Drone.State.Voltage.ToString("0.00") V</div></div>
                            <div class="flex-1 bg-[#010409] p-[10px] rounded-[6px] border border-[#30363d]"><label class="block text-[0.55rem] text-[#8b949e] mb-[4px] font-extrabold">CURRENT</label><div class="text-[0.8rem] font-extrabold text-[#58a6ff]">@Drone.State.CurrentDraw.ToString("0.0") A</div></div>
                            <div class="flex-1 bg-[#010409] p-[10px] rounded-[6px] border border-[#30363d]"><label class="block text-[0.55rem] text-[#8b949e] mb-[4px] font-extrabold">REMAINING</label><div class="text-[0.8rem] font-extrabold text-[#58a6ff] @BPC">@Drone.State.BatteryPercent.ToString("0") %</div></div>
                            <div class="flex-1 bg-[#010409] p-[10px] rounded-[6px] border border-[#30363d]"><label class="block text-[0.55rem] text-[#8b949e] mb-[4px] font-extrabold">CELL V</label><div class="text-[0.8rem] font-extrabold text-[#58a6ff] @BCC">@(_battNumCells > 0 && Drone.State.Voltage > 0 ? (Drone.State.Voltage / _battNumCells).ToString("0.000") + " V" : "—")</div></div>
                        </div>
                        <div class="flex items-center gap-[8px] mb-[10px]">
                            <div class="flex-1 h-[6px] bg-[#161b22] rounded-[3px] border border-[#30363d] overflow-hidden">
                                <div class="h-full rounded-[3px] transition-[width] duration-500 @(BPC == "bv-c" ? "bg-[#ff6b6b]" : BPC == "bv-l" ? "bg-[#f0b429]" : "bg-[#3fb950]")" style="width:@Math.Max(0, Math.Min(100, (double)Drone.State.BatteryPercent))%;"></div>
                            </div>
                            <span class="text-[0.67rem] text-[#555]">@Drone.State.BatteryPercent.ToString("0")%</span>
                        </div>
                    }
                    @if (!_battParamsLoaded)
                    {
                        <div class="text-[0.75rem] text-[#555] p-[8px_0] flex items-center">
                            @if (!Drone.IsLinkHealthy)
                            {
                               <div class="flex items-center gap-[8px] text-[0.75rem] text-[#555]">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plug-zap">
                                        <path d="M6.3 20.3a2.4 2.4 0 0 0 3.4 0L12 18l-6-6-2.3 2.3a2.4 2.4 0 0 0 0 3.4Z"/><path d="m2 22 3-3"/><path d="M7.5 13.5 10 11"/><path d="M10.5 16.5 13 14"/><path d="m18 3-4 4h6l-4 4"/>
                                    </svg>
                                    <span>Connect to load</span>
                                </div>
                            }
                            else
                            {
                                <span><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-loader-icon lucide-loader"><path d="M12 2v4"/><path d="m16.2 7.8 2.9-2.9"/><path d="M18 12h4"/><path d="m16.2 16.2 2.9 2.9"/><path d="M12 18v4"/><path d="m4.9 19.1 2.9-2.9"/><path d="M2 12h4"/><path d="m4.9 4.9 2.9 2.9"/></svg> Loading...</span>
                                <button class="bg-[#010409] border border-[#30363d] text-[#8b949e] p-[3px_9px] rounded-[4px] text-[0.62rem] cursor-pointer transition-all hover:border-[#58a6ff] hover:text-[#58a6ff] ml-[8px]" @onclick="RefreshBatteryParams">↺ Re-read</button>
                            }
                        </div>
                    }
                    else
                    {
                        <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px]">MONITOR TYPE <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(BATT_MONITOR)</span></label>
                        <select class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[6px]" @bind="battMonitorType">
                            <option value="0">Disabled</option>
                            <option value="3">Analog Voltage Only</option>
                            <option value="4">Analog Voltage + Current (Pixhawk PM)</option>
                            <option value="7">UAVCAN BatteryInfo</option>
                            <option value="8">BLHeli ESC</option>
                            <option value="9">Sum of all ESCs</option>
                        </select>
                        <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px] mt-[6px]">CELL COUNT <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(BATT_NUM_CELLS)</span></label>
                        <div class="flex gap-[8px] items-center mb-[6px]">
                            <input type="number" class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-[70px] outline-none" @bind="_battNumCells" min="1" max="12" step="1" />
                            @if (_battNumCells > 0)
                            {
                                <span class="text-[0.67rem] text-[#555] font-mono">Full @((_battNumCells * 4.2).ToString("0.0"))V · Low @((_battNumCells * 3.5).ToString("0.0"))V</span>
                            }
                        </div>
                        <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px] mt-[4px]">CAPACITY (mAh) <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(BATT_CAPACITY)</span></label>
                        <input type="number" class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[5px]" @bind="battCapacity" min="100" step="100" />
                        <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px] mt-[5px]">LOW MAH <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(BATT_LOW_MAH)</span> <span class="text-[#555] font-normal">0=off</span></label>
                        <input type="number" class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[5px]" @bind="_battLowMah" min="0" step="100" />

                        <div class="text-[0.6rem] font-extrabold tracking-[1px] text-[#d29922] mt-[8px] mb-[4px] border-b border-[#1c2128] pb-[3px]">⚡ VOLTAGE THRESHOLDS</div>
                        @if (_battNumCells > 0)
                        {
                            <div class="bg-[#010409] border border-[#1c2128] rounded-[5px] p-[8px_10px] mb-[8px] flex flex-col gap-[5px]">
                                @foreach (var (lbl, v, c) in new[] { ("ARM MIN", _battArmVolt, "t-arm"), ("LOW", _battLowVolt, "t-low"), ("CRITICAL", _battCrtVolt, "t-crt") })
                                {
                                    <div class="flex items-center gap-[6px]">
                                        <span class="text-[0.5rem] font-bold text-[#555] w-[52px] text-right shrink-0">@lbl</span>
                                        <span class="text-[0.65rem] font-bold font-mono w-[46px] shrink-0 @c">@v.ToString("0.00")V</span>
                                        <div class="flex-1 h-[5px] bg-[#161b22] rounded-[3px] overflow-hidden"><div class="h-full rounded-[3px] transition-[width] duration-400 @c" style="width:@TBW(v)%;"></div></div>
                                        <span class="text-[0.57rem] font-mono text-[#555] min-w-[64px] text-right shrink-0 @c">@(_battNumCells > 0 && v > 0 ? (v / _battNumCells).ToString("0.00") + "V/c" : "off")</span>
                                    </div>
                                }
                            </div>
                        }
                        <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px]">ARM MIN (V) <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(BATT_ARM_VOLT)</span></label>
                        <input type="number" class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[4px]" @bind="_battArmVolt" min="0" max="60" step="0.1" />
                        <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px] mt-[5px]">LOW VOLTAGE (V) <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(BATT_LOW_VOLT)</span></label>
                        <input type="number" class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[4px]" @bind="_battLowVolt" min="0" max="60" step="0.1" />
                        <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px] mt-[5px]">CRITICAL (V) <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(BATT_CRT_VOLT)</span></label>
                        <input type="number" class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[4px]" @bind="_battCrtVolt" min="0" max="60" step="0.1" />
                        @if (_battCrtVolt > 0 && _battLowVolt > 0 && _battCrtVolt >= _battLowVolt)
                        {
                            <div class="bg-[rgba(240,180,41,0.08)] border border-[rgba(240,180,41,0.3)] rounded-[5px] p-[5px_10px] text-[0.7rem] text-[#f0b429] m-[3px_0_6px]">⚠️ Critical must be lower than Low</div>
                        }

                        <div class="text-[0.6rem] font-extrabold tracking-[1px] text-[#d29922] mt-[8px] mb-[4px] border-b border-[#1c2128] pb-[3px]">🔧 SENSOR CALIBRATION</div>
                        <div class="text-[0.67rem] text-[#555] mb-[5px]">Pixhawk PM: VoltMult=10.1 · A/V=17.0 · Offset=0</div>
                        <div class="flex gap-[5px] flex-wrap mb-[7px]">
                            @foreach (var (lbl, k) in new[] { ("Pixhawk PM", "px"), ("Holybro PM07", "hb"), ("Mauch HS-200", "mu"), ("AttoPilot 180A", "ap") })
                            {
                                <button class="bg-[#010409] border border-[#30363d] text-[#8b949e] p-[3px_9px] rounded-[4px] text-[0.62rem] cursor-pointer transition-all hover:border-[#58a6ff] hover:text-[#58a6ff]" @onclick="() => BattPreset(k)">@lbl</button>
                            }
                        </div>
                        <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px]">VOLT MULT × <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(BATT_VOLT_MULT)</span></label>
                        <input type="number" class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[4px]" @bind="_battVoltMult" min="1" max="30" step="0.01" />
                        <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px] mt-[5px]">AMPS/VOLT <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(BATT_AMP_PERVLT)</span></label>
                        <input type="number" class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[4px]" @bind="_battAmpPerVlt" min="0" max="200" step="0.1" />
                        <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px] mt-[5px]">AMP OFFSET <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(BATT_AMP_OFFSET)</span></label>
                        <input type="number" class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none" @bind="_battAmpOffset" min="-2" max="2" step="0.01" />
                    }
                </div>
            }
        </div>

    </div>
</div> @* End of Battery Module *@

        @* ── 1. DEVELOPER OVERRIDE ZONE (TERMINAL BUTTON) ── *@
        <div class="mt-4 mb-2 px-2 @(AnyModuleExpanded ? "hidden" : "block")">
            <div class="flex items-center gap-3 mb-3">
                <div class="h-[1px] flex-1 bg-gradient-to-r from-transparent via-[#30363d] to-transparent"></div>
                <span class="text-[0.6rem] font-mono text-[#484f58] tracking-[2px] uppercase">Restricted Access</span>
                <div class="h-[1px] flex-1 bg-gradient-to-r from-transparent via-[#30363d] to-transparent"></div>
            </div>

            <button class="w-full bg-[#0d1117] border border-[#21262d] border-dashed hover:border-solid hover:border-[#f0b429] hover:bg-[rgba(240,180,41,0.03)] p-4 rounded-[8px] flex items-center justify-between transition-all duration-300 group cursor-pointer" @onclick="ToggleAdvancedParams">
                <div class="flex items-center gap-4">
                    <div class="relative">
                        <div class="w-2 h-2 rounded-full bg-[#30363d] group-hover:bg-[#f0b429] transition-colors"></div>
                        <div class="absolute inset-0 w-2 h-2 rounded-full bg-[#f0b429] animate-ping opacity-0 group-hover:opacity-40"></div>
                    </div>
                    <div class="flex flex-col text-left">
                        <span class="font-mono text-[0.75rem] text-[#8b949e] group-hover:text-white font-bold tracking-tight">ADVANCED_CONFIG_TERMINAL</span>
                        <span class="text-[0.6rem] text-[#484f58] font-mono group-hover:text-[#6e7681]">RAW_PARAM_TREE // ROOT_UID: @Drone.State.SystemId</span>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <span class="text-[0.6rem] font-mono text-[#30363d] group-hover:text-[#f0b429] opacity-0 group-hover:opacity-100 transition-all">UNLOCKED</span>
                    <i class="bi bi-terminal text-[#30363d] text-[1.2rem] group-hover:text-[#f0b429]"></i>
                </div>
            </button>
        </div>

    @* ── 2. FULL PARAMETER LIST MODAL (TOP-LAYER DIALOG) ── *@
    @if (_showAdvancedParams)
    {
        <dialog id="paramModal" class="bg-[#0a0b0d] text-[#c9d1d9] w-[90vw] max-w-[1400px] h-[90vh] border border-[#30363d] rounded-[12px] p-0 m-auto backdrop:bg-[rgba(0,0,0,0.8)] backdrop:backdrop-blur-sm shadow-[0_0_50px_rgba(0,0,0,0.8)] overflow-hidden">
            <div class="flex flex-col h-full w-full p-[20px]">
                @* Header *@
                <div class="flex items-center justify-between mb-[20px] shrink-0">
                    <div class="flex items-center gap-[15px]">
                        @* Notice this button now calls CloseAdvancedParams *@
                        <button class="bg-transparent border-none text-[#8b949e] hover:text-[#f85149] transition-colors cursor-pointer" @onclick="CloseAdvancedParams">
                            <i class="bi bi-x-circle text-[2rem]"></i>
                        </button>
                        <div class="flex flex-col">
                            <span class="text-[1.2rem] font-black text-white tracking-[1px] uppercase">Full Parameter List</span>
                            <span class="text-[0.7rem] text-[#58a6ff] font-bold">@(_filteredParameters.Count()) PARAMETERS LOADED</span>
                        </div>
                    </div>
                    
                    <div class="flex gap-[12px]">
                        <div class="relative w-[300px]">
                            <i class="bi bi-search absolute left-[12px] top-1/2 -translate-y-1/2 text-[#484f58]"></i>
                            <input type="text" class="w-full bg-[#010409] border border-[#30363d] rounded-[6px] pl-[35px] pr-[10px] py-[8px] text-[0.8rem] font-mono outline-none text-white focus:border-[#58a6ff]" placeholder="Search Params..." @bind="_searchQuery" @bind:event="oninput" />
                        </div>
                        <button class="bg-[#21262d] border border-[#30363d] text-white px-[16px] py-[8px] rounded-[6px] text-[0.75rem] font-bold cursor-pointer hover:bg-[#30363d] transition-all" @onclick="RefreshAllParameters">
                            REFRESH ALL
                        </button>
                    </div>
                </div>

                @* Scrollable Table Area *@
                <div class="flex-1 overflow-y-auto border border-[#30363d] rounded-[8px] bg-[#0d1117]">
                    <table class="w-full border-collapse text-left relative">
                    <thead class="sticky top-0 bg-[#161b22] shadow-[0_2px_0_#30363d] text-[0.65rem] text-[#8b949e] uppercase font-black tracking-[1px] z-10">
                        <tr>
                            <th class="p-[12px_16px] w-[18%]">Parameter</th>
                            <th class="p-[12px_16px] w-[14%]">Value</th>
                            <th class="p-[12px_16px] w-[6%]">Units</th>
                            <th class="p-[12px_16px] w-[18%]">Options / Range</th>
                            <th class="p-[12px_16px] w-[34%]">Description</th>
                            <th class="p-[12px_16px] w-[10%] text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[#21262d] font-mono text-[0.8rem] text-[#c9d1d9]">
                        @if (_isDownloading)
                        {
                            <tr>
                                <td colspan="6" class="p-[40px] text-center">
                                    <div class="flex flex-col items-center gap-[10px]">
                                        <div class="spinner-border-sm w-[20px] h-[20px]"></div>
                                        <span class="text-[#58a6ff] font-bold">DOWNLOADING: @_downloadProgress%</span>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var param in _filteredParameters)
                            {
                                <tr class="hover:bg-[rgba(255,255,255,0.02)] transition-colors">

                                    @* PARAMETER NAME *@
                                    <td class="p-[10px_16px]">
                                        <span class="font-bold text-[#58a6ff]">@param.Id</span>
                                        @if (!string.IsNullOrEmpty(param.DisplayName))
                                        {
                                            <div class="text-[0.6rem] text-[#8b949e] mt-[2px]">@param.DisplayName</div>
                                        }
                                        @if (param.IsDirty)
                                        {
                                            <span class="ml-[4px] text-[0.6rem] text-[#f0b429] bg-[rgba(240,180,41,0.1)] p-[2px_4px] rounded-[3px]">*MODIFIED</span>
                                        }
                                    </td>

                                    @* VALUE — dropdown for enums, number input for everything else *@
                                    <td class="p-[10px_16px]">
                                        @if (param.AllowedValues != null && param.AllowedValues.Count > 0)
                                        {
                                            <select class="bg-[#010409] border border-[#30363d] rounded-[4px] p-[6px_8px] w-[140px] text-[#3fb950] font-mono outline-none focus:border-[#58a6ff]"
                                                    value="@((int)param.Value)"
                                                    @onchange="@(e => param.Value = float.TryParse(e.Value?.ToString(), out var v) ? v : 0f)">
                                                @foreach (var kv in param.AllowedValues.OrderBy(x => x.Key))
                                                {
                                                    <option value="@kv.Key">@kv.Key: @kv.Value</option>
                                                }
                                            </select>
                                        }
                                        else
                                        {
                                            <input type="number" step="any"
                                                   class="bg-[#010409] border border-[#30363d] rounded-[4px] p-[6px_8px] w-[120px] text-[#3fb950] font-mono outline-none focus:border-[#58a6ff]"
                                                   @bind="param.Value" />
                                        }
                                    </td>

                                    @* UNITS *@
                                    <td class="p-[10px_16px] text-[#8b949e] text-[0.7rem]">
                                        @(string.IsNullOrEmpty(param.Units) ? "-" : param.Units)
                                    </td>

                                    @* OPTIONS / RANGE *@
                                    <td class="p-[10px_16px] text-[#8b949e] text-[0.65rem] leading-[1.5]">
                                        @if (param.AllowedValues != null && param.AllowedValues.Count > 0)
                                        {
                                            @foreach (var kv in param.AllowedValues.OrderBy(x => x.Key))
                                            {
                                                <div>@kv.Key: @kv.Value</div>
                                            }
                                        }
                                        else if (param.RangeMin.HasValue && param.RangeMax.HasValue)
                                        {
                                            <span>@param.RangeMin – @param.RangeMax</span>
                                            @if (param.Increment.HasValue)
                                            {
                                                <span class="text-[#58a6ff] ml-[4px]">(±@param.Increment)</span>
                                            }
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>

                                    @* DESCRIPTION *@
                                    <td class="p-[10px_16px] text-[#8b949e] text-[0.7rem] leading-[1.4]">
                                        @if (string.IsNullOrEmpty(param.Description))
                                        {
                                            <span class="text-[#444d56] italic">
                                                @(Drone.ParameterManager != null
                                                    ? "(No description — " + Drone.ParameterManager.MetadataStatus + ")"
                                                    : "(No description available)")
                                            </span>
                                        }
                                        else
                                        {
                                            @param.Description
                                        }
                                    </td>

                                    @* ACTION *@
                                    <td class="p-[10px_16px] text-right">
                                        <button class="bg-[rgba(248,81,73,0.1)] border border-[#f85149] text-[#f85149] hover:bg-[#f85149] hover:text-white px-[12px] py-[6px] rounded-[4px] text-[0.7rem] font-bold cursor-pointer transition-colors"
                                                @onclick="() => WriteParameter(param)">
                                            WRITE
                                        </button>
                                    </td>

                                </tr>
                            }
                        }
                    </tbody>
                </table>
                </div>
            </div>
        </dialog>
    }
    

