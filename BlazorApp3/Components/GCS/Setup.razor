    private Dictionary<string, bool> expandedModules = new()
    {
        { "Frame", false },
        { "Sensors", false },
        { "RC", false },
        { "FlightModes", false },

        { "MotorTest", false },
        { "ESC", false },
        { "Failsafe", false },
        { "Battery", false }
    };

    private bool AnyModuleExpanded => expandedModules.Values.Any(v => v);
    private void ToggleModule(string moduleName)
    {
        bool wasOpen = expandedModules[moduleName];
        // Close all modules first
        foreach (var key in expandedModules.Keys.ToList())
            expandedModules[key] = false;
        // Open clicked one only if it was closed
        if (!wasOpen)
            expandedModules[moduleName] = true;
    }
