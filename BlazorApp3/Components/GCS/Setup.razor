    /* GYRO UX IMPROVEMENTS */

    /* Indeterminate Progress Bar (Barber Pole Effect) */
    .cal-progress-indeterminate {
        height: 100%;
        width: 100%;
        background: repeating-linear-gradient( 45deg, var(--gcs-cyan) 0px, var(--gcs-cyan) 10px, rgba(0, 242, 255, 0.4) 10px, rgba(0, 242, 255, 0.4) 20px );
        background-size: 28px 28px;
