        animation: wobbleY 2.5s ease-in-out infinite alternate;
    }

    .pulse-dot-fast {
        animation: pulseFast 0.8s infinite alternate;
    }

    @@keyframes wobbleX {
        0% {
            transform: rotateX(0deg) rotateZ(0deg);
        }

        100% {
            transform: rotateX(40deg) rotateZ(15deg);
        }
    }

    @@keyframes wobbleY {
        0% {
