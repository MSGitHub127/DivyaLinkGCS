        }
                <i class="bi @(expandedModules["Failsafe"] ? "bi-chevron-up text-[#58a6ff] rotate-180" : "bi-chevron-down text-[#555]") text-[0.75rem] shrink-0 transition-all duration-200"></i>
            </div>
            @if (expandedModules["Failsafe"])
            {
                <div class="p-[14px_16px_16px] flex flex-col gap-[12px] @(AnyModuleExpanded ? "flex-1 overflow-y-auto no-scrollbar" : "max-h-[400px] overflow-y-auto no-scrollbar")">
                    @* STATUS TAGS: Moved from bottom to "below the block" (Top of Content) *@
            <div class="flex gap-[6px] flex-wrap mb-[8px] pb-[10px] border-b border-[#1c2128]">
                <div class="text-[0.58rem] font-extrabold tracking-[0.5px] p-[3px_8px] rounded-[4px] border @(int.Parse(rcLossAction) > 0 ? "bg-[rgba(46,160,67,0.12)] border-[#2ea043] text-[#3fb950]" : "bg-[rgba(60,60,60,0.15)] border-[#444] text-[#666]")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-gamepad2-icon lucide-gamepad-2"><line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15.01" y1="12" y2="12"/><line x1="18" x2="18.01" y1="10" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/></svg> RC: @FsRcLbl(rcLossAction)
                </div>
                <div class="text-[0.58rem] font-extrabold tracking-[0.5px] p-[3px_8px] rounded-[4px] border @(int.Parse(lowBattAction) > 0 ? "bg-[rgba(46,160,67,0.12)] border-[#2ea043] text-[#3fb950]" : "bg-[rgba(60,60,60,0.15)] border-[#444] text-[#666]")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-battery-warning-icon lucide-battery-warning"><path d="M10 17h.01"/><path d="M10 7v6"/><path d="M14 6h2a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-2"/><path d="M22 14v-4"/><path d="M6 18H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h2"/></svg> BATT: @FsBattLbl(lowBattAction)
                </div>
                <div class="text-[0.58rem] font-extrabold tracking-[0.5px] p-[3px_8px] rounded-[4px] border @(int.Parse(gcsLossAction) > 0 ? "bg-[rgba(46,160,67,0.12)] border-[#2ea043] text-[#3fb950]" : "bg-[rgba(60,60,60,0.15)] border-[#444] text-[#666]")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-laptop-minimal-icon lucide-laptop-minimal"><rect width="18" height="12" x="3" y="4" rx="2" ry="2"/><line x1="2" x2="22" y1="20" y2="20"/></svg> GCS: @FsGcsLbl(gcsLossAction)
                </div>
            </div>
                    @if (!_fsParamsLoaded && Drone.IsLinkHealthy)
                    {
                        <div class="text-[0.75rem] text-[#555] p-[8px_0] flex items-center mb-[8px]">
                            <span><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-loader-icon lucide-loader"><path d="M12 2v4"/><path d="m16.2 7.8 2.9-2.9"/><path d="M18 12h4"/><path d="m16.2 16.2 2.9 2.9"/><path d="M12 18v4"/><path d="m4.9 19.1 2.9-2.9"/><path d="M2 12h4"/><path d="m4.9 4.9 2.9 2.9"/></svg> Reading from FC...</span>
                            <button class="bg-[#010409] border border-[#30363d] text-[#8b949e] p-[3px_9px] rounded-[4px] text-[0.62rem] cursor-pointer transition-all hover:border-[#58a6ff] hover:text-[#58a6ff] ml-[8px]" @onclick="RefreshFailsafeParams">↺ Re-read</button>
                        </div>
                    }
                    else if (!_fsParamsLoaded)
                    {
                        <div class="text-[0.75rem] text-[#555] p-[8px_0] flex items-center mb-[8px]">
                            <span class="text-[#555]">⚠️ Not connected — showing defaults. Connect to read actual FC values.</span>
                        </div>
                    }

                    <div class="flex items-center gap-[8px] text-[0.6rem] font-extrabold tracking-[1px] text-[#d29922] mt-[8px] mb-[4px] border-b border-[#1c2128] pb-[3px]">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-gamepad-2">
                            <line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15.01" y1="12" y2="12"/><line x1="18" x2="18.01" y1="10" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/>
                        </svg> 
                        <span>RC SIGNAL LOSS <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(FS_THR_ENABLE)</span></span>
                    </div>
                    <div class="text-[0.67rem] text-[#555] mb-[5px] leading-[1.4]">Action when RC transmitter signal is lost for &gt;1 second.</div>
                    <select class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[8px]" @bind="rcLossAction">
