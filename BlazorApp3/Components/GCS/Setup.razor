    public void Dispose()
    {
        Drone.OnTelemetryUpdated -= RefreshUi;
        Drone.OnRcChannelsUpdated -= HandleRcUpdate;
        Drone.OnFlightModeParams -= OnFlightModeParamsReceived;
        Drone.OnFailsafeParams -= HandleFailsafeParams;
        Drone.OnBatteryParams -= HandleBatteryParams;
        Vehicle.OnProfileChanged -= HandleVehicleProfileChanged;

        if (Drone.ParameterManager != null)
        {
            Drone.ParameterManager.OnProgressChanged -= OnProgress;
            Drone.ParameterManager.OnDownloadComplete -= OnComplete;
            Drone.ParameterManager.OnWriteConfirmed -= OnConfirmed;
            Drone.ParameterManager.OnWriteFailed -= OnFailed;
        }
    }

    private void HandleVehicleProfileChanged(VehicleProfile newProfile)
    {
        try
        {
            _ = InvokeAsync(() =>
            {
                string safeDefault = newProfile == VehicleProfile.ArduRover
                    ? "MANUAL"
                    : "STABILIZE";
                for (int i = 1; i <= 6; i++)
                    SetFlightModeField(i, safeDefault);
                StateHasChanged();
            });
        }
        catch (ObjectDisposedException) { }
    }






    // ── Helper: set flight mode field by index ────────────────────────────────
    // ADD this or integrate with your existing flight mode field assignment pattern.
    private void SetFlightModeField(int index, string mode)
    {
        // Map index → your existing _flightMode1.._flightMode6 fields
        switch (index)
        {
            case 1: _flightMode1 = mode; break;
            case 2: _flightMode2 = mode; break;
            case 3: _flightMode3 = mode; break;
            case 4: _flightMode4 = mode; break;
            case 5: _flightMode5 = mode; break;
            case 6: _flightMode6 = mode; break;
        }
    }

    // Called when MavlinkService has read all FLTMODE params from the FC
    private void OnFlightModeParamsReceived(string[] modes, string channel)
    {

        flightModeSettings = modes;
        flightModeChannel = channel;
        InvokeAsync(StateHasChanged);
    }

    private Dictionary<string, bool> expandedModules = new()
    {
        { "Frame", false },
        { "Sensors", false },
        { "RC", false },
        { "FlightModes", false },
        { "MotorTest", false },
        { "ESC", false },
        { "Failsafe", false },
        { "Battery", false }
    };

    private bool AnyModuleExpanded => expandedModules.Values.Any(v => v);
    private void ToggleModule(string moduleName)
    {
        bool wasOpen = expandedModules[moduleName];
        // Close all modules first
        foreach (var key in expandedModules.Keys.ToList())
            expandedModules[key] = false;
        // Open clicked one only if it was closed
        if (!wasOpen)
            expandedModules[moduleName] = true;
    }

    // ── ADVANCED PARAMETERS (DEVELOPER TERMINAL) LOGIC ──
    private bool _showAdvancedParams = false;
    private string _searchQuery = "";
    private int _downloadProgress = 0;
    private bool _isDownloading = false;

    private IEnumerable<ParameterEntry> _filteredParameters => string.IsNullOrWhiteSpace(_searchQuery)
        ? (Drone.ParameterManager?.GetSortedList() ?? Array.Empty<ParameterEntry>())
        : (Drone.ParameterManager?.GetSortedList().Where(p => p.Id.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)) ?? Array.Empty<ParameterEntry>());

    private async Task ToggleAdvancedParams()
    {
        _showAdvancedParams = true;
        StateHasChanged(); // Force Blazor to render the <dialog> HTML first
        
        await Task.Delay(50); // Tiny delay to ensure the DOM is ready
        
        // Trigger the native HTML5 top-layer API
        await JS.InvokeVoidAsync("eval", "document.getElementById('paramModal').showModal()");
        
        if (Drone.ParameterManager != null && Drone.ParameterManager.State == DownloadState.Idle)
        {
            _ = RefreshAllParameters();
        }
    }

    private async Task CloseAdvancedParams()
    {
        // Tell the browser to close the top-layer dialog
        await JS.InvokeVoidAsync("eval", "document.getElementById('paramModal').close()");
        
        await Task.Delay(50);
        _showAdvancedParams = false;
        StateHasChanged();
    }

    private async Task RefreshAllParameters()
    {
        if (Drone.ParameterManager == null) return;
        
        _isDownloading = true;
        _downloadProgress = 0;
        StateHasChanged();
        
        await Drone.ParameterManager.RequestAllParametersAsync(); 
    }

    private async Task WriteParameter(ParameterEntry param)
    {
        if (Drone.ParameterManager == null) return;
        Drone.Toast($"Writing {param.Id}...", MavlinkService.ToastLevel.Info, "⏳");
        
        try
        {
            await Drone.ParameterManager.WriteParameterAsync(param.Id, param.Value);
        }
        catch (Exception) { /* Handled by OnFailed event */ }
    }

    private void OnProgress(DownloadProgressArgs args)
    {
        _ = InvokeAsync(() => {
            _downloadProgress = (int)args.Percent;
            StateHasChanged(); 
        });
    }

    private void OnComplete(IReadOnlyDictionary<string, ParameterEntry> dict)
    {
        _ = InvokeAsync(() => {
            _isDownloading = false;
            Drone.Toast($"Parameter Tree Loaded ({dict.Count} params)", MavlinkService.ToastLevel.Success, "✅");
            StateHasChanged();
        });
    }

    private void OnConfirmed(WriteResultArgs args)
    {
        _ = InvokeAsync(() => {
            Drone.Toast($"{args.ParamId} saved: {args.ConfirmedValue}", MavlinkService.ToastLevel.Success, "💾");
            StateHasChanged();
        });
    }

    private void OnFailed(WriteResultArgs args)
    {
        _ = InvokeAsync(() => {
            Drone.Toast($"Failed to save {args.ParamId}", MavlinkService.ToastLevel.Error, "❌");
            StateHasChanged();
        });
    }
