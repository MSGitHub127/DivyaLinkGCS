@code {
    private string selectedFrameType = "1";
    private string selectedFrameClass = "1";
    private string currentType = "QUAD";
    private string currentClass = "X-FRAME";
    private string rcLossAction = "1";
    private string lowBattAction = "1";
    private string escCalStatus = "IDLE";
    private string[] flightModeSettings = { "STABILIZE", "LOITER", "RTL" };
    // Battery Monitor Settings
    private string battMonitorType = "4"; // Default to Voltage & Current
    private int battCapacity = 3300;      // Default to a standard 3300mAh lipo
    // Mission Planner Motor Test Settings
    private int motorTestThrottle = 5;
    private int motorTestDuration = 2;

    protected override void OnInitialized()
    {
        // Only refresh the UI on telemetry updates. No more string parsing needed!
        Drone.OnTelemetryUpdated += RefreshUi;
    }

    private void RefreshUi() => InvokeAsync(StateHasChanged);

    private void HandleAccelClick()
    {
        if (Drone.LiveAccelProgress > 0 && Drone.LiveAccelProgress < 100)
        {
            Drone.AckCalibrationStep();
        }
        else
        {
            Drone.LiveAccelProgress = 0;
            Drone.LiveAccelStatus = "WAITING...";
            Drone.StartCalibration("ACCEL");
        }
    }

    private void HandleMagClick()
    {
        if (Drone.LiveMagStatus == "CALIBRATING..." || Drone.LiveMagStatus == "STARTING...")
        {
            Drone.LiveMagStatus = "CANCELLED";
            Drone.LiveMagProgress = 0;
            Drone.StartCalibration("CANCEL_MAG");
        }
        else
        {
            Drone.LiveMagProgress = 0;
            Drone.LiveMagStatus = "STARTING...";
            Drone.StartCalibration("MAG");
        }
    }

    private void HandleRcClick()
    {
        if (Drone.IsRcCalibrating) Drone.SaveRcCalibration();
        else Drone.StartCalibration("RADIO");
    }

    private async Task ApplyFrame()
    {
        Drone.SetFrameConfig(int.Parse(selectedFrameType), int.Parse(selectedFrameClass));
        currentType = selectedFrameType switch { "1" => "QUAD", "2" => "HEXA", "3" => "OCTA", _ => "CUSTOM" };
        currentClass = selectedFrameClass switch { "0" => "PLUS (+)", "1" => "X-FRAME", _ => "CUSTOM" };
        await Task.CompletedTask;
    }

    private void SyncFlightModes()
    {
        for (int i = 0; i < flightModeSettings.Length; i++)
        {
            Drone.SaveFlightMode(i + 1, flightModeSettings[i]);
        }
    }

    private void ToggleEscCalMode()
    {
        Drone.SetEscCalibrationMode();
        escCalStatus = "REBOOT REQUIRED";
    }

    private void StopAllMotors()
    {
        // Sends 0% throttle to abort immediately
        for (int i = 1; i <= Drone.State.MotorCount; i++)
        {
            Drone.TestMotor(i, 0, 0);
        }
    }

    private void SaveFailsafes()
    {
        Drone.SendParameter("FS_THR_ENABLE", float.Parse(rcLossAction));
        Drone.SendParameter("FS_BATT_ENABLE", float.Parse(lowBattAction));
    }

    private double CalculatePercent(ushort raw) => Math.Clamp((raw - 1000) / 10.0, 0, 100);

    private void SaveBatterySettings()
    {
        // 1. Send the monitor type (enables the physical pins on the flight controller)
        Drone.SendParameter("BATT_MONITOR", float.Parse(battMonitorType));

        // 2. Send the total capacity (allows the drone to calculate accurate remaining %)
        Drone.SendParameter("BATT_CAPACITY", battCapacity);

        // Optional: Force a UI refresh to show immediate changes if needed
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Drone.OnTelemetryUpdated -= RefreshUi;
    }
}