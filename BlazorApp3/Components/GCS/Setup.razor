@page "/setup"
@inject MavlinkService Drone
@inject IJSRuntime JS
@implements IDisposable

<div class="gcs-setup-container">
    <div class="hud-wrapper">
        <Hud/>
    </div>

    <div class="setup-list">

        <div class="setup-module">
            <div class="module-header">
                <i class="bi bi-gear-wide-connected"></i>
                <span>FRAME GEOMETRY</span>
                <button class="btn-gcs-primary" @onclick="ApplyFrame">SYNC PARAMS</button>
            </div>
            <div class="module-content">
                <div class="readout-row">
                    <div class="readout"><label>ACTIVE TYPE</label><div class="value">@currentType</div></div>
                    <div class="readout"><label>ACTIVE CLASS</label><div class="value">@currentClass</div></div>
                </div>
                <div class="control-group">
                    <label class="input-label">VEHICLE TYPE</label>
                    <select class="gcs-select" @bind="selectedFrameType">
                        <option value="1">QUADCOPTER</option>
                        <option value="2">HEXACOPTER</option>
                        <option value="3">OCTACOPTER</option>
                    </select>
                    <label class="input-label">FRAME CLASS</label>
                    <select class="gcs-select" @bind="selectedFrameClass">
                        <option value="0">PLUS (+)</option>
                        <option value="1">X-FRAME</option>
                        <option value="2">V-FRAME</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="setup-module">
            <div class="module-header">
                <i class="bi bi-compass"></i>
                <span>SENSORS & IMU</span>
                <button class="btn-gcs-outline" @onclick="HandleAccelClick">
                    @(isAccelCalibrating ? "NEXT STEP" : "START CALIBRATION")
                </button>
            </div>
            <div class="module-content">
                <div class="status-box-pro @(isAccelCalibrating ? "active-cal" : "")">
                    <div class="status-label">@(isAccelCalibrating ? "ACTION REQUIRED" : "SYSTEM STANDBY")</div>
                    <div class="status-value">@lastAccelMsg</div>
                    @if (isAccelCalibrating)
                    {
                        <div class="cal-pulse"></div>
                    }
                </div>
                <div class="compass-mini-grid">
                    <div class="axis">ROLL: <span class="val">@Drone.State.Roll.ToString("0.0")°</span></div>
                    <div class="axis">PITCH: <span class="val">@Drone.State.Pitch.ToString("0.0")°</span></div>
                    <div class="axis">YAW: <span class="val">@Drone.State.AttitudeYawDeg.ToString("0.0")°</span></div>
                </div>
            </div>
        </div>

        <div class="setup-module">
            <div class="module-header">
                <i class="bi bi-controller"></i>
                <span>RADIO CHANNELS (RC)</span>
                <button class="btn-gcs-outline" @onclick="HandleRcClick">
                    @(Drone.IsRcCalibrating ? "SAVE RC CAL" : "CALIBRATE RC")
                </button>
            </div>
            <div class="module-content radio-layout">
                @for (int i = 0; i < 4; i++)
                {
                    var chanName = (new[] { "ROLL", "PITCH", "THROTTLE", "YAW" })[i];
                    var rawVal = Drone.State.RawChannels[i];
                    <div class="radio-strip">
                        <span class="label">@chanName</span>
                        <div class="bar-container">
                            <div class="bar-fill" style="width:@(CalculatePercent(rawVal))%"></div>
                            <div class="center-line"></div>
                        </div>
                        <span class="raw-val">@rawVal</span>
                    </div>
                }
            </div>
        </div>

        <div class="setup-module">
            <div class="module-header">
                <i class="bi bi-shield-shaded"></i>
                <span>FLIGHT MODE ASSIGNMENT</span>
                <button class="btn-gcs-primary" @onclick="SyncFlightModes">SAVE MODES</button>
            </div>
            <div class="module-content">
                @for (int i = 0; i < 3; i++)
                {
                    var index = i;
                    <div class="mode-row">
                        <label class="input-label">SWITCH POSITION @(index + 1)</label>
                        <select class="gcs-select" @bind="flightModeSettings[index]">
                            <option value="STABILIZE">STABILIZE</option>
                            <option value="ALT_HOLD">ALT_HOLD</option>
                            <option value="LOITER">LOITER</option>
                            <option value="RTL">RTL</option>
                            <option value="AUTO">AUTO</option>
                        </select>
                    </div>
                }
            </div>
        </div>

        <div class="setup-module border-amber">
            <div class="module-header warning">
                <i class="bi bi-propeller"></i>
                <span>MOTOR TEST</span>
            </div>
            <div class="module-content">

                <div class="mp-top-row">
                    <div class="mp-input-group">
                        <label>Throttle %</label>
                        <input type="number" class="mp-input" @bind="motorTestThrottle" min="0" max="100" />
                    </div>
                    <div class="mp-input-group">
                        <label>Duration (s)</label>
                        <input type="number" class="mp-input" @bind="motorTestDuration" min="1" max="15" />
                    </div>
                </div>

                <div class="mp-info-row">
                    <span>Class: @currentType</span>
                    <span>Type: @currentClass</span>
                </div>

                <div class="mp-motor-grid">
                    <button class="btn-mp" @onclick="() => RunMotorTest(1)">Test motor A</button>
                    <span class="mp-label">Motor Number: 1, CCW</span>

                    <button class="btn-mp" @onclick="() => RunMotorTest(4)">Test motor B</button>
                    <span class="mp-label">Motor Number: 4, CW</span>

                    <button class="btn-mp" @onclick="() => RunMotorTest(2)">Test motor C</button>
                    <span class="mp-label">Motor Number: 2, CW</span>

                    <button class="btn-mp" @onclick="() => RunMotorTest(3)">Test motor D</button>
                    <span class="mp-label">Motor Number: 3, CCW</span>
                </div>


                <div class="mp-action-row">
                    <button class="btn-mp" @onclick="TestAllMotors">Test All</button>
                    <button class="btn-mp-stop" @onclick="StopAllMotors">Stop All</button>
                    <button class="btn-mp" @onclick="TestSequence">Sequence</button>
                </div>

            </div>
        </div>

        <div class="setup-module border-amber">
            <div class="module-header warning">
                <i class="bi bi-lightning-charge"></i>
                <span>ESC THROTTLE CALIBRATION</span>
                <button class="btn-gcs-amber" @onclick="ToggleEscCalMode">ENABLE CAL MODE</button>
            </div>
            <div class="module-content">
                <div class="esc-info-box">
                    <p>1. Enable Cal Mode (Sets parameter to 3).</p>
                    <p>2. Disconnect USB and Battery.</p>
                    <p>3. Reconnect battery to start beep sequence.</p>
                </div>
                <div class="status-box-pro">
                    <div class="status-label">CALIBRATION STATE</div>
                    <div class="status-value">@escCalStatus</div>
                </div>
            </div>
        </div>

        <div class="setup-module border-amber">
            <div class="module-header warning">
                <i class="bi bi-exclamation-triangle"></i>
                <span>SAFETY FAILSAFES</span>
                <button class="btn-gcs-amber" @onclick="SaveFailsafes">SAVE ALL</button>
            </div>
            <div class="module-content">
                <div class="fs-row">
                    <label class="input-label">RC LOSS ACTION</label>
                    <select class="gcs-select-sm" @bind="rcLossAction"><option value="1">RTL</option><option value="2">LAND</option></select>
                </div>
                <div class="fs-row">
                    <label class="input-label">LOW BATT ACTION</label>
                    <select class="gcs-select-sm" @bind="lowBattAction"><option value="1">RTL</option><option value="2">LAND</option></select>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    :root {
        --gcs-bg: #0d1117;
        --gcs-card: #161b22;
        --gcs-border: #30363d;
        --gcs-cyan: #58a6ff;
        --gcs-amber: #d29922;
        --gcs-text: #c9d1d9;
    }

    .gcs-setup-container {
        display: flex;
        flex-direction: column;
        height: 100%;
        gap: 16px; /* Aligned with other tabs */
        padding: 20px;
        background: var(--gcs-bg);
        color: var(--gcs-text);
        width: 100%; /* Aligned with other tabs */
        max-width: 500px; /* Aligned with other tabs */
        margin: 0 auto; /* Aligned with other tabs */
        overflow: hidden;
    }

    .hud-wrapper {
        height: 300px;
        width: 100%;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.4);
        border: 1px solid var(--gcs-border);
        flex-shrink: 0;
        background: #000;
        position: relative; /* Keeps your text overlays perfectly positioned */
    }

    .hud-overlay-text {
        position: absolute;
        top: 15px;
        left: 25px;
        font-size: 0.7rem;
        color: var(--gcs-cyan);
        letter-spacing: 2px;
        font-weight: 800;
    }

    .hud-status-bar {
        position: absolute;
        bottom: 0;
        width: 100%;
        background: rgba(0,0,0,0.8);
        padding: 8px 20px;
        display: flex;
        gap: 25px;
        font-size: 0.65rem;
        font-family: monospace;
        border-top: 1px solid var(--gcs-border);
    }

    .setup-list {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 20px;
        overflow-y: auto;
        padding-right: 5px;
    }

    .setup-list::-webkit-scrollbar {
        width: 6px;
    }

    .setup-list::-webkit-scrollbar-thumb {
        background: var(--gcs-border);
        border-radius: 10px;
    }

    .setup-module {
        background: var(--gcs-card);
        border: 1px solid var(--gcs-border);
        border-radius: 8px;
        display: flex;
        flex-direction: column;
        width: 100%;
        transition: border 0.2s;
    }

    .setup-module:hover {
        border-color: var(--gcs-cyan);
    }

    .border-amber {
        border-left: 4px solid var(--gcs-amber);
    }

    .module-header {
        padding: 12px 16px;
        border-bottom: 1px solid var(--gcs-border);
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 800;
        font-size: 0.75rem;
        text-transform: uppercase;
    }

    .module-content {
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .readout-row {
        display: flex;
        gap: 12px;
    }

    .readout {
        flex: 1;
        background: #010409;
        padding: 10px;
        border-radius: 6px;
        border: 1px solid var(--gcs-border);
    }

    .readout label {
        display: block;
        font-size: 0.55rem;
        color: #8b949e;
        margin-bottom: 4px;
        font-weight: 800;
    }

    .readout .value {
        font-size: 0.8rem;
        font-weight: 800;
        color: var(--gcs-cyan);
    }

    .input-label {
        font-size: 0.6rem;
        font-weight: 800;
        color: #8b949e;
        margin-bottom: -10px;
    }

    .gcs-select, .gcs-select-sm {
        background: #010409;
        color: white;
        border: 1px solid var(--gcs-border);
        border-radius: 4px;
        padding: 8px;
        font-size: 0.75rem;
        width: 100%;
        outline: none;
    }

    .gcs-select-sm {
        width: 100px;
        padding: 4px;
    }

    .status-box-pro {
        background: #010409;
        border: 1px dashed var(--gcs-border);
        padding: 18px;
        text-align: center;
        border-radius: 8px;
        position: relative;
    }

    .status-box-pro.active-cal {
        border-color: var(--gcs-cyan);
        background: rgba(88, 166, 255, 0.05);
    }

    .status-value {
        font-size: 0.85rem;
        font-weight: 800;
        color: var(--gcs-cyan);
    }

    .radio-strip {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .radio-strip .label {
        width: 85px;
        font-size: 0.6rem;
        font-weight: 800;
        color: #8b949e;
    }

    .bar-container {
        flex: 1;
        height: 12px;
        background: #000;
        border-radius: 6px;
        position: relative;
        border: 1px solid var(--gcs-border);
        overflow: hidden;
    }

    .bar-fill {
        height: 100%;
        background: var(--gcs-cyan);
        transition: width 0.1s;
    }

    .center-line {
        position: absolute;
        left: 50%;
        width: 1px;
        height: 100%;
        background: rgba(255,255,255,0.1);
    }

    .raw-val {
        width: 45px;
        font-family: monospace;
        font-size: 0.7rem;
        color: var(--gcs-cyan);
        text-align: right;
    }

    /* MISSION PLANNER MOTOR TEST CSS */
    .mp-top-row {
        display: flex;
        gap: 20px;
        align-items: center;
    }

    .mp-input-group {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .mp-input-group label {
            font-size: 0.65rem;
            color: #8b949e;
            font-weight: 800;
        }

    .mp-input {
        background: #010409;
        color: var(--gcs-cyan);
        border: 1px solid var(--gcs-border);
        width: 50px;
        padding: 4px;
        border-radius: 4px;
        font-family: monospace;
        font-weight: bold;
        text-align: center;
        outline: none;
        transition: border 0.2s;
    }

    .mp-input:focus {
            border-color: var(--gcs-cyan);
        }

    .mp-info-row {
        display: flex;
        gap: 30px;
        font-size: 0.7rem;
        color: var(--gcs-cyan);
        margin: 5px 0 10px 0;
        font-weight: 800;
    }

    .mp-motor-grid {
        display: grid;
        grid-template-columns: 120px 1fr; /* Locks buttons to 120px, text takes the rest */
        gap: 10px 15px;
        align-items: center;
    }

    .mp-label {
        font-size: 0.7rem;
        color: #c9d1d9;
        font-family: monospace;
    }

    .mp-action-row {
        display: flex;
        gap: 10px;
        margin-top: 15px;
        border-top: 1px dashed var(--gcs-border);
        padding-top: 15px;
    }

    .btn-mp {
        background: #21262d;
        border: 1px solid var(--gcs-border);
        color: #c9d1d9;
        padding: 6px 12px;
        font-size: 0.65rem;
        font-weight: 800;
        cursor: pointer;
        border-radius: 4px;
        transition: all 0.2s ease;
        width: 100%;
        text-align: center;
    }

    .btn-mp:hover {
            background: #2ea043; /* Mission Planner Green Accent */
            border-color: #3fb950;
            color: white;
        }

    .btn-mp-stop {
        background: #21262d;
        border: 1px solid var(--gcs-border);
        color: #ff3a3a; /* Danger Red for Stop */
        padding: 6px 12px;
        font-size: 0.65rem;
        font-weight: 800;
        cursor: pointer;
        border-radius: 4px;
        transition: all 0.2s ease;
        width: 100%;
        text-align: center;
    }

    .btn-mp-stop:hover {
            background: rgba(255, 58, 58, 0.15);
            border-color: #ff3a3a;
        }

    .motor-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
    }

    .btn-motor {
        background: #21262d;
        border: 1px solid var(--gcs-border);
        color: #fff;
        padding: 15px;
        border-radius: 6px;
        font-weight: 800;
        cursor: pointer;
        transition: background 0.1s;
    }

    .btn-motor:active {
        background: #238636;
        border-color: #2ea043;
    }

    .warning-banner {
        background: rgba(210, 153, 34, 0.1);
        border: 1px solid var(--gcs-amber);
        color: var(--gcs-amber);
        padding: 10px;
        border-radius: 4px;
        font-size: 0.65rem;
        font-weight: 800;
        text-align: center;
    }

    .footer-hint {
        font-size: 0.55rem;
        text-align: center;
        color: #484f58;
        font-weight: 800;
    }

    .esc-info-box {
        font-size: 0.65rem;
        color: #8b949e;
        line-height: 1.5;
    }

    .btn-gcs-primary {
        background: var(--gcs-cyan);
        border: none;
        padding: 6px 12px;
        border-radius: 4px;
        font-size: 0.65rem;
        font-weight: 800;
        cursor: pointer;
        margin-left: auto;
    }

    .btn-gcs-outline {
        background: transparent;
        border: 1px solid var(--gcs-cyan);
        color: var(--gcs-cyan);
        padding: 5px 12px;
        border-radius: 4px;
        font-size: 0.65rem;
        font-weight: 800;
        cursor: pointer;
    }

    .btn-gcs-amber {
        background: var(--gcs-amber);
        border: none;
        padding: 6px 12px;
        border-radius: 4px;
        font-size: 0.65rem;
        font-weight: 800;
        cursor: pointer;
    }

    .fs-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .cal-pulse {
        position: absolute;
        top: 6px;
        right: 6px;
        width: 6px;
        height: 6px;
        background: #ff4444;
        border-radius: 50%;
        animation: pulse 1s infinite;
    }
    
    @@keyframes pulse {
        0% { opacity: 1; }
        50% { opacity: 0.3; }
        100% { opacity: 1; }
    }

    .compass-mini-grid {
        display: flex;
        justify-content: space-around;
        font-family: monospace;
        font-size: 0.7rem;
    }

    .axis .val {
        color: var(--gcs-cyan);
        font-weight: 800;
    }
</style>

@code {
    private string selectedFrameType = "1";
    private string selectedFrameClass = "1";
    private string currentType = "QUAD";
    private string currentClass = "X-FRAME";
    private string rcLossAction = "1";
    private string lowBattAction = "1";
    private string escCalStatus = "IDLE";
    private string[] flightModeSettings = { "STABILIZE", "LOITER", "RTL" };
    private string lastAccelMsg = "SYSTEM STANDBY";
    private bool isAccelCalibrating = false;

    // Mission Planner Motor Test Settings
    private int motorTestThrottle = 5;
    private int motorTestDuration = 2;

    protected override void OnInitialized()
    {
        Drone.OnTelemetryUpdated += RefreshUi;
        Drone.OnMessageReceived += HandleMavlinkMessage;
    }

    private void RefreshUi() => InvokeAsync(StateHasChanged);

    private void HandleMavlinkMessage()
    {
        var msg = Drone.StatusMessages.FirstOrDefault();
        if (string.IsNullOrEmpty(msg)) return;

        if (msg.Contains("Place vehicle", StringComparison.OrdinalIgnoreCase))
        {
            lastAccelMsg = msg.ToUpper();
            isAccelCalibrating = true;
        }
        else if (msg.Contains("Successful", StringComparison.OrdinalIgnoreCase))
        {
            lastAccelMsg = "SUCCESS";
            isAccelCalibrating = false;
        }
        else if (msg.Contains("Failed", StringComparison.OrdinalIgnoreCase))
        {
            lastAccelMsg = "FAILED";
            isAccelCalibrating = false;
        }
        InvokeAsync(StateHasChanged);
    }

    private void HandleAccelClick()
    {
        if (isAccelCalibrating)
        {
            Drone.AckCalibrationStep();
        }
        else
        {
            isAccelCalibrating = true;
            lastAccelMsg = "WAITING...";
            Drone.StartCalibration("ACCEL");
        }
    }

    private void HandleRcClick()
    {
        if (Drone.IsRcCalibrating)
        {
            Drone.SaveRcCalibration();
        }
        else
        {
            Drone.StartCalibration("RADIO");
        }
    }

    private async Task ApplyFrame()
    {
        Drone.SetFrameConfig(int.Parse(selectedFrameType), int.Parse(selectedFrameClass));
        currentType = selectedFrameType switch { "1" => "QUAD", "2" => "HEXA", "3" => "OCTA", _ => "CUSTOM" };
        currentClass = selectedFrameClass switch { "0" => "PLUS (+)", "1" => "X-FRAME", _ => "CUSTOM" };
        await Task.CompletedTask;
    }

    private void SyncFlightModes()
    {
        for (int i = 0; i < flightModeSettings.Length; i++)
        {
            Drone.SaveFlightMode(i + 1, flightModeSettings[i]);
        }
    }

    private void ToggleEscCalMode()
    {
        Drone.SetEscCalibrationMode();
        escCalStatus = "REBOOT REQUIRED";
    }

    // --- MISSION PLANNER MOTOR TEST LOGIC ---
    private void RunMotorTest(int motorId) 
    {
        Drone.TestMotor(motorId, motorTestThrottle, motorTestDuration);
    }

    private void TestAllMotors() 
    {
        // Cycles through all 4 motors simultaneously 
        for (int i = 1; i <= 4; i++) 
        {
            Drone.TestMotor(i, motorTestThrottle, motorTestDuration);
        }
    }

    private void StopAllMotors() 
    {
        // Sends 0% throttle to abort immediately
        for (int i = 1; i <= 4; i++) 
        {
            Drone.TestMotor(i, 0, 0);
        }
    }

    private async Task TestSequence() 
    {
        // Tests in standard ArduPilot Quad X Order (A->B->C->D)
        int[] sequence = { 1, 4, 2, 3 }; 
        foreach(var motorId in sequence)
        {
            RunMotorTest(motorId);
            // Waits for the current motor to finish its duration + a small 500ms gap before starting the next
            await Task.Delay((motorTestDuration * 1000) + 500); 
        }
    }

    private void SaveFailsafes()
    {
        Drone.SendParameter("FS_THR_ENABLE", float.Parse(rcLossAction));
        Drone.SendParameter("FS_BATT_ENABLE", float.Parse(lowBattAction));
    }

    private double CalculatePercent(ushort raw) => Math.Clamp((raw - 1000) / 10.0, 0, 100);

    public void Dispose()
    {
        Drone.OnTelemetryUpdated -= RefreshUi;
        Drone.OnMessageReceived -= HandleMavlinkMessage;
    }
}