@page "/setup"
@inject MavlinkService Drone
@inject IJSRuntime JS
@using BlazorApp3.Models
@using BlazorApp3.Services
@implements IDisposable
@inject VehicleProfileService Vehicle 
@inject NtripService Ntrip 
@using BlazorApp3.Components.UI
@using BlazorApp3.Components.Shared
@using BlazorApp3.Components.Tuning
@inject BlazorApp3.Services.RtkBaseStationService RtkEngine
@inject OverlayService Overlay


<div class="flex flex-col h-[100dvh] overflow-hidden p-[20px] bg-transparent text-[#c9d1d9] w-full max-w-[500px] mx-auto gap-[16px] relative">

    <div class="flex-1 min-h-0 overflow-y-auto no-scrollbar relative overflow-hidden @(AnyModuleExpanded ? "flex flex-col gap-[8px] pb-0" : "grid grid-cols-2 auto-rows-max content-start gap-[10px] pb-[40px]")">

        @* ── FRAME MODULE ── *@
        <div class="bg-[#161b22] border border-[#30363d] rounded-[8px] flex flex-col w-full transition-colors duration-200 min-w-0 hover:border-[#58a6ff] @(expandedModules["Frame"] ? (AnyModuleExpanded ? "flex-1 flex-col min-h-0 col-auto" : "col-span-full") : (AnyModuleExpanded ? "hidden" : "flex-col"))">
            <div class="p-[14px_16px] flex items-center gap-[8px] font-bold text-[0.95rem] uppercase cursor-pointer select-none transition-all duration-200 min-h-[58px] hover:bg-[rgba(255,255,255,0.03)] @(expandedModules["Frame"] ? "border-b border-[#30363d] rounded-t-[8px]" : "rounded-[8px]")" @onclick='() => ToggleModule("Frame")'>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 @(expandedModules["Frame"] ? "text-[#58a6ff]" : "text-[#8b949e]")">
                    <path d="M19.5 7a24 24 0 0 1 0 10"/><path d="M4.5 7a24 24 0 0 0 0 10"/><path d="M7 19.5a24 24 0 0 0 10 0"/><path d="M7 4.5a24 24 0 0 1 10 0"/><rect x="17" y="17" width="5" height="5" rx="1"/><rect x="17" y="2" width="5" height="5" rx="1"/><rect x="2" y="17" width="5" height="5" rx="1"/><rect x="2" y="2" width="5" height="5" rx="1"/>
                </svg>
                <span>FRAME GEOMETRY</span>
                <div class="flex-1"></div>
                @if (expandedModules["Frame"])
                {
                    <button class="bg-[#58a6ff] border-none p-[6px_12px] rounded-[4px] text-[0.8rem] font-extrabold cursor-pointer text-black transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed mr-2"
                            disabled="@(!Drone.IsLinkHealthy)"
                            @onclick="ApplyFrame"
                            @onclick:stopPropagation="true"> @* CRITICAL: Prevents closing the module when clicking button *@
                        APPLY & REBOOT
                    </button>
        }
                <i class="bi @(expandedModules["Frame"] ? "bi-chevron-up text-[#58a6ff] rotate-180" : "bi-chevron-down text-[#555]") text-[0.75rem] shrink-0 transition-all duration-200"></i>
            </div>
            @if (expandedModules["Frame"])
            {
                <div class="p-[14px_16px_16px] flex flex-col gap-[0px] @(AnyModuleExpanded ? "flex-1 overflow-y-auto no-scrollbar" : "max-h-[400px] overflow-y-auto no-scrollbar")">

                    <div class="flex gap-[10px] mb-[10px]">
                        <div class="flex-1 bg-[#010409] p-[10px] rounded-[6px] border border-[#30363d]">
                            <label class="block text-[0.75rem] text-[#8b949e] mb-[4px] font-bold">ACTIVE VEHICLE</label>
                            <div class="text-[0.8rem] font-bold text-[#58a6ff]">@FrameClassName</div>
                        </div>
                        <div class="flex-1 bg-[#010409] p-[10px] rounded-[6px] border border-[#30363d]">
                            <label class="block text-[0.75rem] text-[#8b949e] mb-[4px] font-bold">ACTIVE LAYOUT</label>
                            <div class="text-[0.8rem] font-bold text-[#58a6ff]">@FrameTypeName</div>
                        </div>
                        <div class="flex-1 bg-[#010409] p-[10px] rounded-[6px] border border-[#30363d]">
                            <label class="block text-[0.75rem] text-[#8b949e] mb-[4px] font-bold">MOTORS</label>
                            <div class="text-[0.8rem] font-bold text-[#58a6ff]">@Drone.State.MotorCount</div>
                        </div>
                    </div>

                    <div class="flex flex-col items-center gap-[10px] bg-[#010409] border border-[#1c2128] rounded-[8px] p-[14px_10px_10px] mb-[12px]">
                        <svg viewBox="0 0 200 200" class="w-[260px] h-[260px] overflow-visible" xmlns="http://www.w3.org/2000/svg">
    @foreach (var m in MotorPositions)
    {
        @* Motor Arms *@
        <line x1="100" y1="100" x2="@m.X.ToString("0.0")" y2="@m.Y.ToString("0.0")" stroke="#30363d" stroke-width="5" stroke-linecap="round" />
        
        @* Motor Housing *@
        <circle cx="@m.X.ToString("0.0")" cy="@m.Y.ToString("0.0")" r="18" 
                fill="@(m.Cw ? "#1a2a1a" : "#1a1a2a")" 
                stroke="@(m.Cw ? "#3fb950" : "#58a6ff")" 
                stroke-width="2.5" />
        
        @if (m.Cw)
        {
            <path d="M @((m.X - 14).ToString("0.0")),@(m.Y.ToString("0.0")) a 14 14 0 1 1 10 10" fill="none" stroke="#3fb950" stroke-width="2" stroke-linecap="round" />
            <polygon points="@((m.X - 4).ToString("0.0")),@((m.Y + 11).ToString("0.0")) @((m.X + 4).ToString("0.0")),@((m.Y + 16).ToString("0.0")) @((m.X - 1).ToString("0.0")),@((m.Y + 18).ToString("0.0"))" fill="#3fb950" />
        }
        else
        {
            <path d="M @((m.X + 14).ToString("0.0")),@(m.Y.ToString("0.0")) a 14 14 0 1 0 -10 10" fill="none" stroke="#58a6ff" stroke-width="2" stroke-linecap="round" />
            <polygon points="@((m.X + 4).ToString("0.0")),@((m.Y + 11).ToString("0.0")) @((m.X - 4).ToString("0.0")),@((m.Y + 16).ToString("0.0")) @((m.X + 1).ToString("0.0")),@((m.Y + 18).ToString("0.0"))" fill="#58a6ff" />
        }
        
        @* Native SVG Text: Replaces MarkupString to avoid RZ9980 errors *@
        @((MarkupString)$"<text x=\"{m.X:0.0}\" y=\"{m.Y + 1:0.0}\" text-anchor=\"middle\" dominant-baseline=\"middle\" fill=\"white\" style=\"font-size:12px; font-weight:900; font-family:monospace;\">{m.Num}</text>")
    }

    @* Central Flight Controller Block *@
    <circle cx="100" cy="100" r="13" fill="#161b22" stroke="#30363d" stroke-width="3" />
    @((MarkupString)"<text x=\"100\" y=\"100\" text-anchor=\"middle\" dominant-baseline=\"middle\" fill=\"#58a6ff\" style=\"font-size:10px; font-weight:900; font-family:monospace;\">FC</text>")
    
    @* Directional Heading Indicator *@
    <polygon points="100,10 110,26 90,26" fill="#f0b429" opacity="0.9" />
    @((MarkupString)"<text x=\"100\" y=\"5\" text-anchor=\"middle\" fill=\"#f0b429\" style=\"font-size:9px; font-weight:900; font-family:monospace;\">FWD</text>")
</svg>

                        <div class="flex gap-[16px] flex-wrap justify-center">
                            <div class="flex items-center gap-[5px] text-[0.62rem] text-[#8b949e]">
                                <span class="w-[9px] h-[9px] rounded-full shrink-0 bg-[#3fb950]"></span><span>CW (clockwise)</span>
                            </div>
                            <div class="flex items-center gap-[5px] text-[0.62rem] text-[#8b949e]">
                                <span class="w-[9px] h-[9px] rounded-full shrink-0 bg-[#58a6ff]"></span><span>CCW (counter-clockwise)</span>
                            </div>
                            <div class="flex items-center gap-[5px] text-[0.62rem] text-[#8b949e]">
                                <span class="w-[9px] h-[9px] rounded-full shrink-0 bg-[#f0b429]"></span><span>Forward</span>
                            </div>
                        </div>
                    </div>

                    <label class="block text-[0.6rem] font-extrabold text-[#8b949e] mb-[4px] mt-[8px]">VEHICLE TYPE (FRAME_CLASS)</label>
                    <select class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[6px]" @bind="selectedFrameClass">
                        <option value="1">Quadcopter (4 motors)</option>
                        <option value="2">Hexacopter (6 motors)</option>
                        <option value="3">Octocopter (8 motors)</option>
                        <option value="5">Y6 (6 motors coaxial)</option>
                        <option value="7">Tricopter (3 motors)</option>
                    </select>

                    <label class="block text-[0.6rem] font-extrabold text-[#8b949e] mb-[4px] mt-[6px]">MOTOR LAYOUT (FRAME_TYPE)</label>
                    <select class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[10px]" @bind="selectedFrameType">
                        <option value="0">Plus (+)</option>
                        <option value="1">X</option>
                        <option value="2">V (H-Frame)</option>
                        <option value="3">H</option>
                        <option value="10">CW X (reversed CW/CCW)</option>
                    </select>

                    <div class="bg-[rgba(240,180,41,0.06)] border border-[rgba(240,180,41,0.2)] rounded-[5px] p-[8px_12px] text-[0.72rem] text-[#8b949e] leading-[1.5]">
                        <strong>⚠️ Reboot required.</strong> Frame changes take effect after power cycle. Motor numbering and rotation directions follow ArduPilot standard shown above. Verify prop directions match diagram before first flight.
                    </div>
                </div>
            }
        </div>

        @* ── SENSORS MODULE ── *@
        <div class="bg-[#161b22] border border-[#30363d] rounded-[8px] flex flex-col w-full transition-colors duration-200 min-w-0 hover:border-[#58a6ff] @(expandedModules["Sensors"] ? (AnyModuleExpanded ? "flex-1 flex-col min-h-0 col-auto" : "col-span-full") : (AnyModuleExpanded ? "hidden" : "flex-col"))">
            <div class="p-[14px_16px] flex items-center gap-[8px] font-bold text-[0.95rem] uppercase cursor-pointer select-none transition-all duration-200 min-h-[58px] hover:bg-[rgba(255,255,255,0.03)] @(expandedModules["Sensors"] ? "border-b border-[#30363d] rounded-t-[8px]" : "rounded-[8px]")" @onclick='() => ToggleModule("Sensors")'>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 @(expandedModules["Sensors"] ? "text-[#58a6ff]" : "text-[#8b949e]")">
                    <path d="M15.6 2.7a10 10 0 1 0 5.7 5.7"/><circle cx="12" cy="12" r="2"/><path d="M13.4 10.6 19 5"/>
                </svg>
                <span>SENSORS & IMU</span>
                <div class="flex-1"></div>
                <i class="bi @(expandedModules["Sensors"] ? "bi-chevron-up text-[#58a6ff] rotate-180" : "bi-chevron-down text-[#555]") text-[0.75rem] shrink-0 transition-all duration-200"></i>
            </div>
            @if (expandedModules["Sensors"])
            {
                <div class="p-[14px_16px_16px] flex flex-col gap-[12px] @(AnyModuleExpanded ? "flex-1 overflow-y-auto no-scrollbar" : "max-h-[400px] overflow-y-auto no-scrollbar")">
                    <div class="flex flex-col gap-[12px]">

                        @* ACCELEROMETER ROW *@
                        <div class="bg-[#010409] border border-[#30363d] rounded-[6px] p-[12px_16px] flex flex-col items-stretch transition-colors duration-200 hover:border-[#555] overflow-hidden">
                            <div class="flex items-center gap-[20px] w-full">
                                <div class="flex flex-col gap-[4px] w-[140px] shrink-0">
                                    <span class="text-[0.65rem] font-extrabold text-[#8b949e] tracking-[0.5px]">ACCELEROMETER</span>
                                    <span class="text-[0.8rem] font-extrabold whitespace-nowrap overflow-hidden text-ellipsis @(IsAccelCalibrating && Drone.LiveAccelStatus != "WAITING..." ? "text-[#58a6ff]" : Drone.LiveAccelStatus == "FAILED" || (Drone.LiveAccelStatus?.Contains("DENIED") ?? false) || (Drone.LiveAccelStatus?.Contains("NO RESPONSE") ?? false) ? "text-[#f85149]" : Drone.LiveAccelStatus == "SUCCESS" ? "text-[#58a6ff]" : "text-[#c9d1d9]")">
                                        @Drone.LiveAccelStatus
                                    </span>
                                </div>
                                <div class="flex-1 min-w-[50px]">
                                    <div class="h-[8px] bg-[rgba(255,255,255,0.05)] border border-[rgba(255,255,255,0.1)] rounded-[2px] overflow-hidden @(IsAccelCalibrating ? "bg-active" : "")">
                                        @if (Drone.LiveAccelStatus == "COMPUTING...")
                                        {
                                            <div class="cal-progress-indeterminate"></div>
                                        }
                                        else
                                        {
                                            <div class="h-full bg-[#58a6ff] shadow-[0_0_5px_#58a6ff] transition-[width] duration-300 ease-out" style="width: @(Drone.LiveAccelProgress)%"></div>
                                        }
                                    </div>
                                </div>
                                <div class="flex justify-end gap-[8px] shrink-0 w-[140px] [&>button]:flex-1 [&>button]:h-[32px] [&>button]:m-0">
                                    @if (Drone.LiveAccelStatus == "COMPUTING...")
                                    {
                                        <div class="flex-1 flex items-center justify-center gap-[6px] bg-transparent text-[#58a6ff] text-[0.65rem] font-black border border-dashed border-[#58a6ff] rounded-[4px] h-[32px] cursor-not-allowed"><div class="spinner-border-sm"></div><span>COMPUTING</span></div>
                                    }
                                    else if (Drone.LiveAccelStatus == "RECORDING...")
                                    {
                                        <div class="flex-1 flex items-center justify-center gap-[6px] bg-transparent text-[#58a6ff] text-[0.65rem] font-black border border-dashed border-[#58a6ff] rounded-[4px] h-[32px] cursor-not-allowed"><div class="spinner-border-sm"></div><span>RECORDING</span></div>
                                    }
                                    else if (Drone.LiveAccelStatus == "WAITING...")
                                    {
                                        <div class="flex-1 flex items-center justify-center gap-[6px] bg-transparent text-[#58a6ff] text-[0.65rem] font-black border border-dashed border-[#58a6ff] rounded-[4px] h-[32px] cursor-not-allowed"><div class="spinner-border-sm"></div><span>WAITING</span></div>
                                    }
                                    else if (IsAccelCalibrating)
                                    {
                                        <button class="bg-[#58a6ff] text-black border-none rounded-[4px] text-[0.65rem] font-black cursor-pointer" @onclick="Drone.AckCalibrationStep">NEXT</button>
                                    }
                                    else
                                    {
                                        <button class="bg-[#21262d] text-[#58a6ff] border border-[#30363d] rounded-[4px] text-[0.65rem] font-black cursor-pointer hover:bg-[#58a6ff] hover:text-black transition-colors" @onclick="StartAccel">START</button>
                                    }
                                    <button class="bg-[rgba(255,58,58,0.1)] text-[#ff3a3a] border border-[#ff3a3a] rounded-[4px] text-[0.65rem] font-black cursor-pointer hover:bg-[#ff3a3a] hover:text-white transition-colors" @onclick="CancelAccel">CANCEL</button>
                                </div>
                            </div>
                            @if (IsAccelCalibrating && Drone.LiveAccelStatus != "WAITING...")
                            {
                                <div class="flex items-center gap-[20px] mt-[15px] pt-[15px] border-t border-dashed border-[#30363d] animate-[slideDown_0.3s_cubic-bezier(0.175,0.885,0.32,1.275)]">
                                    <div class="w-[80px] h-[80px] bg-[rgba(0,242,255,0.05)] border border-[rgba(0,242,255,0.3)] rounded-[8px] flex items-center justify-center shrink-0">
                                        <svg class="w-[60px] h-[60px] transition-transform duration-600 ease-[cubic-bezier(0.4,0,0.2,1)] @GetDroneOrientationClass(Drone.LiveAccelStatus)" viewBox="0 0 100 100">
                                            <rect x="44" y="20" width="12" height="60" fill="#30363d" rx="4" />
                                            <path d="M50 20 L40 35 L60 35 Z" fill="#00f2ff" />
                                            <line x1="20" y1="20" x2="80" y2="80" stroke="#30363d" stroke-width="4" />
                                            <line x1="20" y1="80" x2="80" y2="20" stroke="#30363d" stroke-width="4" />
                                            <circle cx="20" cy="20" r="10" fill="#ff3a3a" opacity="0.8" />
                                            <circle cx="80" cy="20" r="10" fill="#ff3a3a" opacity="0.8" />
                                            <circle cx="20" cy="80" r="10" fill="#00f2ff" opacity="0.8" />
                                            <circle cx="80" cy="80" r="10" fill="#00f2ff" opacity="0.8" />
                                        </svg>
                                    </div>
                                    <div class="flex flex-col gap-[6px]">
                                        <div class="text-[0.55rem] bg-[#58a6ff] text-black p-[2px_6px] rounded-[4px] font-black self-start tracking-[1px]">
                                            @(Drone.LiveAccelStatus == "COMPUTING..." ? "COMPUTING" : $"STEP {(Drone.LiveAccelProgress / 16) + 1} OF 6")
                                        </div>
                                        <div class="text-[0.95rem] font-black text-white">@GetAccelInstructionTitle(Drone.LiveAccelStatus)</div>
                                        <div class="text-[0.75rem] text-[#8b949e] leading-[1.4]">@GetAccelInstructionDesc(Drone.LiveAccelStatus)</div>
                                    </div>
                                </div>
                            }
                        </div>

                        @* GYRO ROW *@
                        <div class="bg-[#010409] border border-[#30363d] rounded-[6px] p-[12px_16px] flex flex-col items-stretch transition-colors duration-200 hover:border-[#555] overflow-hidden">
                            <div class="flex items-center gap-[20px] w-full">
                                <div class="flex flex-col gap-[4px] w-[140px] shrink-0">
                                    <span class="text-[0.65rem] font-extrabold text-[#8b949e] tracking-[0.5px]">GYROSCOPE</span>
                                    <span class="text-[0.8rem] font-extrabold whitespace-nowrap overflow-hidden text-ellipsis @(IsGyroCalibrating ? "text-[#58a6ff]" : (Drone.LiveGyroStatus == "FAILED" ? "text-[#f85149]" : "text-[#c9d1d9]"))">
                                        @Drone.LiveGyroStatus
                                    </span>
                                </div>
                                <div class="flex-1 min-w-[50px]">
                                    <div class="h-[8px] bg-[rgba(255,255,255,0.05)] border border-[rgba(255,255,255,0.1)] rounded-[2px] mt-2 overflow-hidden @(IsGyroCalibrating ? "bg-active" : "")">
                                        @if (IsGyroCalibrating)
                                        {
                                            <div class="cal-progress-indeterminate"></div>
                                        }
                                        else
                                        {

                                            <div class="h-full bg-[#58a6ff] shadow-[0_0_5px_#58a6ff] transition-[width] duration-300 ease-out" style="width: @(Drone.LiveGyroProgress)%"></div>
                                        }
                                    </div>
                                </div>
                                <div class="flex justify-end gap-[8px] shrink-0 w-[140px] [&>button]:flex-1 [&>button]:h-[32px] [&>button]:m-0">
                                    @if (IsGyroCalibrating)
                                    {
                                        <div class="flex-1 flex items-center justify-center gap-[6px] bg-transparent text-[#58a6ff] text-[0.65rem] font-black border border-dashed border-[#58a6ff] rounded-[4px] h-[32px] cursor-not-allowed"><div class="spinner-border-sm"></div><span>WORKING</span></div>
                                    }
                                    else if (Drone.LiveGyroStatus == "AUTO AT BOOT")
                                    {
                                        <button class="bg-[#21262d] text-[#58a6ff] border border-[#30363d] rounded-[4px] text-[0.65rem] font-black opacity-50 cursor-not-allowed" disabled>AUTOMATIC</button>
                                    }
                                    else
                                    {
                                        <button class="bg-[#21262d] text-[#58a6ff] border border-[#30363d] rounded-[4px] text-[0.65rem] font-black cursor-pointer hover:bg-[#58a6ff] hover:text-black transition-colors" @onclick="StartGyro">
                                            @(Drone.LiveGyroStatus == "FAILED" ? "RETRY" : "START")
                                        </button>
                                    }
                                    <button class="bg-[rgba(255,58,58,0.1)] text-[#ff3a3a] border border-[#ff3a3a] rounded-[4px] text-[0.65rem] font-black cursor-pointer hover:bg-[#ff3a3a] hover:text-white transition-colors" @onclick="CancelGyro" title="Force Abort">CANCEL</button>
                                </div>
                            </div>
                            @if (IsGyroCalibrating)
                            {
                                <div class="flex items-center gap-[20px] mt-[15px] pt-[15px] border-t border-dashed border-[#30363d] animate-[slideDown_0.3s_cubic-bezier(0.175,0.885,0.32,1.275)]">
                                    <div class="w-[80px] h-[80px] bg-[rgba(0,242,255,0.05)] border border-[#58a6ff] rounded-[8px] flex items-center justify-center shrink-0">
                                        <svg class="w-[60px] h-[60px]" viewBox="0 0 100 100">
                                            <ellipse cx="50" cy="50" rx="40" ry="15" fill="none" stroke="#58a6ff" stroke-width="3" class="ring-x" />
                                            <ellipse cx="50" cy="50" rx="15" ry="40" fill="none" stroke="#58a6ff" stroke-width="3" class="ring-y" />
                                            <circle cx="50" cy="50" r="6" fill="#fff" class="pulse-dot-fast" />
                                        </svg>
                                    </div>
                                    <div class="flex flex-col gap-[6px]">
                                        <div class="text-[0.55rem] bg-[#58a6ff] text-black p-[2px_6px] rounded-[4px] font-black self-start tracking-[1px]">HANDS OFF</div>
                                        <div class="text-[0.95rem] font-black text-white">Calculating Baseline Offsets</div>
                                        <div class="text-[0.75rem] text-[#8b949e] leading-[1.4]">The IMU is actively capturing zero-rotation data. Any vibration will corrupt the calibration. Please step away from the bench until complete.</div>
                                    </div>
                                </div>
                            }
                        </div>

                        @* COMPASS ROW *@
                        <div class="bg-[#010409] border border-[#30363d] rounded-[6px] p-[12px_16px] flex flex-col items-stretch transition-colors duration-200 hover:border-[#555] overflow-hidden">
                            <div class="flex items-center gap-[20px] w-full">
                                <div class="flex flex-col gap-[4px] w-[140px] shrink-0">
                                    <span class="text-[0.65rem] font-extrabold text-[#8b949e] tracking-[0.5px]">COMPASS (MAG)</span>
                                    <span class="text-[0.8rem] font-extrabold whitespace-nowrap overflow-hidden text-ellipsis @(IsMagCalibrating ? "text-[#58a6ff]" : ((Drone.LiveMagStatus?.Contains("FAILED") ?? false) || (Drone.LiveMagStatus?.Contains("DENIED") ?? false) ? "text-[#f85149]" : "text-[#c9d1d9]"))">
                                        @Drone.LiveMagStatus
                                    </span>
                                </div>
                                <div class="flex-1 min-w-[50px]">
                                    <div class="h-[8px] bg-[rgba(255,255,255,0.05)] border border-[rgba(255,255,255,0.1)] rounded-[2px] mt-2 overflow-hidden @(IsMagCalibrating ? "bg-active" : "")">
                                        <div class="h-full bg-[#58a6ff] shadow-[0_0_5px_#58a6ff] transition-[width] duration-300 ease-out" style="width: @(Drone.LiveMagProgress)%"></div>
                                    </div>
                                </div>
                                <div class="flex justify-end gap-[8px] shrink-0 w-[140px] [&>button]:flex-1 [&>button]:h-[32px] [&>button]:m-0">
                                    @if (IsMagCalibrating)
                                    {
                                        <div class="flex-1 flex items-center justify-center gap-[6px] bg-transparent text-[#58a6ff] text-[0.65rem] font-black border border-dashed border-[#58a6ff] rounded-[4px] h-[32px] cursor-not-allowed"><div class="spinner-border-sm"></div><span>@Drone.LiveMagProgress%</span></div>
                                    }
                                    else
                                    {
                                        <button class="bg-[#21262d] text-[#58a6ff] border border-[#30363d] rounded-[4px] text-[0.65rem] font-black cursor-pointer hover:bg-[#58a6ff] hover:text-black transition-colors" @onclick="StartMag">
                                            @(Drone.LiveMagStatus == "FAILED" ? "RETRY" : "START")
                                        </button>
                                    }
                                    <button class="bg-[rgba(255,58,58,0.1)] text-[#ff3a3a] border border-[#ff3a3a] rounded-[4px] text-[0.65rem] font-black cursor-pointer hover:bg-[#ff3a3a] hover:text-white transition-colors" @onclick="CancelMag" title="Force Abort">CANCEL</button>
                                </div>
                            </div>
                            @if (IsMagCalibrating)
                            {
                                <div class="flex items-center gap-[20px] mt-[15px] pt-[15px] border-t border-dashed border-[#30363d] animate-[slideDown_0.3s_cubic-bezier(0.175,0.885,0.32,1.275)]">
                                    <div class="w-[80px] h-[80px] bg-[rgba(0,242,255,0.05)] border border-[#58a6ff] rounded-[8px] flex items-center justify-center shrink-0">
                                        <svg class="w-[60px] h-[60px] [perspective:1000px]" viewBox="0 0 100 100">
                                            <circle cx="50" cy="50" r="40" fill="none" stroke="#58a6ff" stroke-width="2" stroke-dasharray="4 4" class="spin-z" />
                                            <ellipse cx="50" cy="50" rx="40" ry="15" fill="none" stroke="#ff3a3a" stroke-width="2" class="spin-x" />
                                            <ellipse cx="50" cy="50" rx="15" ry="40" fill="none" stroke="#3fb950" stroke-width="2" class="spin-y" />
                                            <circle cx="50" cy="50" r="5" fill="#fff" />
                                        </svg>
                                    </div>
                                    <div class="flex flex-col gap-[6px]">
                                        <div class="text-[0.55rem] bg-[#58a6ff] text-black p-[2px_6px] rounded-[4px] font-black self-start tracking-[1px]">DANCE REQUIRED</div>
                                        <div class="text-[0.95rem] font-black text-white">Rotate on All Axes</div>
                                        <div class="text-[0.75rem] text-[#8b949e] leading-[1.4]">Pick up the drone and slowly rotate it continuously around its pitch, roll, and yaw axes. Keep rotating until the progress bar reaches 100%.</div>
                                    </div>
                                </div>
                            }
                        </div>

                        @* ONBOARD LED ROW *@
                        @*<div class="bg-[#010409] border border-[#30363d] rounded-[6px] p-[12px_16px] flex items-center gap-[20px] transition-colors duration-200 hover:border-[#555]">
                            <div class="flex flex-col gap-[4px] w-[140px] shrink-0">
                                <span class="text-[0.65rem] font-extrabold text-[#8b949e] tracking-[0.5px]">ONBOARD LEDS</span>
                                <span class="text-[0.8rem] font-extrabold whitespace-nowrap overflow-hidden text-ellipsis @(isLedEnabled ? "text-[#58a6ff]" : "text-[#c9d1d9]")">
                                    @(isLedEnabled ? "ENABLED" : "VANISHED")
                                </span>
                            </div>
                            <div class="flex-1 min-w-[50px]">
                                <span class="text-[0.65rem] text-[#888] mt-[5px] block">Mutes the physical Pixhawk RGB status lights while on the bench.</span>
                            </div>
                            <div class="flex justify-end gap-[8px] shrink-0 w-[140px] [&>button]:flex-1 [&>button]:h-[32px] [&>button]:m-0">
                                <button class="bg-[#2ea043] text-white border-none rounded-[4px] text-[0.65rem] font-black cursor-pointer" @onclick="() => TogglePixhawkLeds(true)">ON</button>
                                <button class="bg-[rgba(255,58,58,0.1)] text-[#ff3a3a] border border-[#ff3a3a] rounded-[4px] text-[0.65rem] font-black cursor-pointer hover:bg-[#ff3a3a] hover:text-white transition-colors" @onclick="() => TogglePixhawkLeds(false)">OFF</button>
                            </div>
                        </div>*@

                    </div>
                </div>
            }
        </div>

        @* ── RC MODULE ── *@
        <div class="bg-[#161b22] border border-[#30363d] rounded-[8px] flex flex-col w-full transition-colors duration-200 min-w-0 hover:border-[#58a6ff] @(expandedModules["RC"] ? (AnyModuleExpanded ? "flex-1 flex-col min-h-0 col-auto" : "col-span-full") : (AnyModuleExpanded ? "hidden" : "flex-col"))">
            <div class="p-[14px_16px] flex items-center gap-[8px] font-bold text-[0.95rem] uppercase cursor-pointer select-none transition-all duration-200 min-h-[58px] hover:bg-[rgba(255,255,255,0.03)] @(expandedModules["RC"] ? "border-b border-[#30363d] rounded-t-[8px]" : "rounded-[8px]")" @onclick='() => ToggleModule("RC")'>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 @(expandedModules["RC"] ? "text-[#58a6ff]" : "text-[#8b949e]")">
                    <path d="M2 10v3"/><path d="M6 6v11"/><path d="M10 3v18"/><path d="M14 8v7"/><path d="M18 5v13"/><path d="M22 10v3"/>
                </svg>
                <span>RADIO CHANNELS</span>
                <div class="flex-1"></div>
                @if (expandedModules["RC"])
                {
                    <button class="bg-transparent border border-[#58a6ff] text-[#58a6ff] p-[5px_12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer hover:bg-[#58a6ff] hover:text-black transition-colors mr-2"
                            style="@(Drone.IsRcCalibrating ? "background: #58a6ff; color: #000;" : "")"
                            @onclick="HandleRcClick"
                            @onclick:stopPropagation="true">
                        @(Drone.IsRcCalibrating ? "SAVE CALIBRATION" : "CALIBRATE RC")
                    </button>
        }
                <i class="bi @(expandedModules["RC"] ? "bi-chevron-up text-[#58a6ff] rotate-180" : "bi-chevron-down text-[#555]") text-[0.75rem] shrink-0 transition-all duration-200"></i>
            </div>
            @if (expandedModules["RC"])
            {
                <div class="p-[14px_16px_16px] grid grid-cols-2 gap-[15px] @(AnyModuleExpanded ? "flex-1 overflow-y-auto no-scrollbar block" : "max-h-[400px] overflow-y-auto no-scrollbar")">

                    @if (Drone.IsRcCalibrating)
                    {
                        <div class="col-span-2 bg-[rgba(210,153,34,0.1)] border border-[#d29922] text-[#d29922] p-[10px] rounded-[4px] text-[0.75rem]">
                            <strong>CALIBRATION ACTIVE:</strong> Move all sticks to their maximum limits, center them, then click SAVE.
                        </div>
                    }

                    @for (int i = 0; i < 8; i++)
                    {
                        var chanNames = new[] { "1: ROLL", "2: PITCH", "3: THROTTLE", "4: YAW", "5: MODE 1", "6: MODE 2", "7: AUX 1", "8: AUX 2" };
                        var rawVal = _localChannels[i];

                        <div class="flex flex-col gap-[4px]">
                            <div class="flex justify-between items-end">
                                <span class="text-[0.65rem] text-[#888] font-bold">@chanNames[i]</span>
                                <span class="font-mono text-[0.85rem] font-bold @(rawVal == 0 ? "text-[#ff3a3a]" : "text-[#00f2ff]")">
                                    @(rawVal == 0 ? "NO RC DATA" : $"{rawVal} us")
                                </span>
                            </div>
                            <div class="w-full h-[18px] bg-[#0a0b0d] border border-[#333] rounded-[4px] relative overflow-hidden">
                                @if (Drone.IsRcCalibrating && Drone.RcMax[i] > Drone.RcMin[i] && rawVal != 0)
                                {
                                    <div class="absolute h-full bg-[rgba(0,242,255,0.2)]" style="left: @(CalculatePercent(Drone.RcMin[i]))%; width: @(CalculatePercent(Drone.RcMax[i]) - CalculatePercent(Drone.RcMin[i]))%;"></div>
                                }
                                <div class="absolute h-full transition-[width] duration-100 ease-linear" style="background: @(Drone.IsRcCalibrating ? "#ffffff" : "#00f2ff"); width: @(rawVal == 0 ? 50 : CalculatePercent(rawVal))%; opacity: @(rawVal == 0 ? 0.2 : 1.0);"></div>
                                <div class="absolute left-1/2 w-[2px] h-full bg-[rgba(255,0,0,0.6)] z-10"></div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        @* ── FLIGHT MODES MODULE ── *@
        <div class="bg-[#161b22] border border-[#30363d] rounded-[8px] flex flex-col w-full transition-colors duration-200 min-w-0 hover:border-[#58a6ff] @(expandedModules["FlightModes"] ? (AnyModuleExpanded ? "flex-1 flex-col min-h-0 col-auto" : "col-span-full") : (AnyModuleExpanded ? "hidden" : "flex-col"))">
            <div class="p-[14px_16px] flex items-center gap-[8px] font-bold text-[0.95rem] uppercase cursor-pointer select-none transition-all duration-200 min-h-[58px] hover:bg-[rgba(255,255,255,0.03)] @(expandedModules["FlightModes"] ? "border-b border-[#30363d] rounded-t-[8px]" : "rounded-[8px]")" @onclick='() => ToggleModule("FlightModes")'>
                <i class="bi bi-toggles"></i>
                <span>FLIGHT MODES</span>
                @if (expandedModules["FlightModes"])
                {
                    @* Middle Section: Active Mode Display *@
                    <div class="flex-1 flex justify-center">
                        <div class="flex items-center gap-[6px] bg-[rgba(0,212,255,0.08)] border border-[rgba(0,212,255,0.3)] rounded-[4px] p-[3px_10px]">
                            <span class="text-[0.55rem] text-[#8b949e] tracking-[1px]">ACTIVE</span>
                            <span class="text-[0.7rem] font-extrabold text-[#00d4ff] tracking-[1px]">@Drone.State.FlightMode</span>
                        </div>
                    </div>

                    @* Rightmost Section: Write Button *@
                    <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer hover:brightness-110 transition-all mr-2" 
                            @onclick="SyncFlightModes" 
                            @onclick:stopPropagation="true">
                        WRITE TO FC
                    </button>
                }
                else
                {
                    <div class="flex-1"></div>
                }
                <i class="bi @(expandedModules["FlightModes"] ? "bi-chevron-up text-[#58a6ff] rotate-180" : "bi-chevron-down text-[#555]") text-[0.75rem] shrink-0 transition-all duration-200"></i>
            </div>
            @if (expandedModules["FlightModes"])
            {
                <div class="p-[14px_16px_16px] flex flex-col gap-[12px] @(AnyModuleExpanded ? "flex-1 overflow-y-auto no-scrollbar" : "max-h-[400px] overflow-y-auto no-scrollbar")">

                    <div class="flex items-center gap-[10px] mb-[14px] p-[8px_12px] bg-[rgba(255,255,255,0.03)] border border-[#30363d] rounded-[6px]">
                        <span class="text-[0.6rem] font-bold text-[#8b949e] tracking-[1px] whitespace-nowrap">MODE CHANNEL</span>
                        <select class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[4px] text-[0.75rem] w-[100px] outline-none" @bind="flightModeChannel">
                            <option value="5">CH 5</option>
                            <option value="6">CH 6</option>
                            <option value="7">CH 7</option>
                            <option value="8">CH 8</option>
                        </select>
                        <span class="text-[0.58rem] text-[#8b949e] ml-auto">RC channel that controls mode switching</span>
                    </div>

                    <div class="grid grid-cols-2 gap-[8px]">
                        @for (int i = 0; i < 6; i++)
                        {
                            var idx = i;
                            bool isActive = (flightModeSettings[idx] == Drone.State.FlightMode);
                            <div class="bg-[#010409] border rounded-[6px] p-[10px_12px] flex flex-col gap-[6px] transition-colors duration-200 hover:border-[#555] @(isActive ? "border-[#00d4ff] bg-[rgba(0,212,255,0.04)]" : "border-[#30363d]")">
                                <div class="flex items-center justify-between">
                                    <span class="text-[0.58rem] font-bold text-[#8b949e] tracking-[1.5px]">MODE @(idx + 1)</span>
                                    @if (isActive)
                                    {
                                        <span class="text-[0.52rem] font-extrabold text-[#00d4ff] tracking-[1px] animate-[pip-pulse_1.5s_ease-in-out_infinite]">● ACTIVE</span>
                                    }
                                </div>
                                <select class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[5px_8px] text-[0.68rem] w-full outline-none" @bind="flightModeSettings[idx]">
                                    @foreach (var mode in Vehicle.GetAvailableModes())
                                    {
                                        <option value="@mode">@mode</option>
                                    }
                                </select>
                                <div class="text-[0.56rem] text-[#8b949e] leading-[1.3] min-h-[24px]">@GetFlightModeDesc(flightModeSettings[idx])</div>
                            </div>
                        }
                    </div>

                    <div class="mt-[10px] p-[8px_12px] bg-[rgba(255,255,255,0.02)] border border-[#30363d] rounded-[5px] text-[0.58rem] text-[#8b949e] flex items-center gap-[7px]">
                        <i class="bi bi-info-circle"></i>
                        Modes 1–6 map to RC switch positions. Mode 1 = lowest PWM, Mode 6 = highest.
                    </div>
                </div>
            }
        </div>


@* ── TUNING button ────────────────────────────────────────────────── *@
<div class="bg-[#161b22] border @(Overlay.ShowTuning ? "border-[#f0b429]" : "border-[#30363d]")
            rounded-[8px] flex flex-col w-full transition-colors duration-200
            min-w-0 hover:border-[#f0b429] cursor-pointer
            @(AnyModuleExpanded ? "hidden" : "")"
     @onclick="Overlay.OpenTuning">
    <div class="p-[14px_16px] flex items-center gap-[8px]
                font-bold text-[0.95rem] uppercase min-h-[58px]
                hover:bg-[rgba(255,255,255,0.03)]
                @(Overlay.ShowTuning ? "text-[#f0b429]" : "text-white")">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
             viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
             class="shrink-0">
            <path d="M12 20h9"/>
            <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/>
        </svg>
        <span>Tuning</span>
        <div class="flex-1"></div>
        @* Vehicle badge *@
        <span class="text-[0.55rem] font-bold uppercase tracking-widest
                     px-[6px] py-[1px] rounded-full border
                     @(Vehicle.IsRover
                         ? "bg-[#3fb950]/10 text-[#3fb950] border-[#3fb950]/30"
                         : "bg-[#58a6ff]/10 text-[#58a6ff] border-[#58a6ff]/30")">
            @Vehicle.ActiveProfileDisplayName
        </span>
    </div>
</div>

@* ── RTK / NTRIP button ──────────────────────────────────────────── *@
<div class="bg-[#161b22] border @(Overlay.ShowRtk ? "border-[#3fb950]" : "border-[#30363d]")
            rounded-[8px] flex flex-col w-full transition-colors duration-200
            min-w-0 hover:border-[#3fb950] cursor-pointer
            @(AnyModuleExpanded ? "hidden" : "")"
     @onclick="Overlay.OpenRtk">
    <div class="p-[14px_16px] flex items-center gap-[8px]
                font-bold text-[0.95rem] uppercase min-h-[58px]
                hover:bg-[rgba(255,255,255,0.03)]
                @(Overlay.ShowRtk ? "text-[#3fb950]" : "text-white")">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
             viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
             class="shrink-0">
            <path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/>
            <path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5"/>
            <circle cx="12" cy="12" r="2"/>
            <path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.5"/>
            <path d="M19.1 4.9C23 8.8 23 15.1 19.1 19"/>
        </svg>
        <span>RTK / NTRIP</span>
        <div class="flex-1"></div>
        @* Status badge *@
        <span class="text-[0.55rem] font-bold uppercase tracking-widest
                     px-[6px] py-[1px] rounded-full border
                     @(Ntrip.IsConnected
                         ? "bg-[#3fb950]/10 text-[#3fb950] border-[#3fb950]/30"
                         : "bg-[#21262d] text-[#484f58] border-[#30363d]")">
            @(Ntrip.IsConnected ? "Active" : "Idle")
        </span>
    </div>
</div>
        @* ── MOTOR TEST MODULE ── *@
        <div class="bg-[#161b22] border border-[#30363d] rounded-[8px] flex flex-col w-full transition-colors duration-200 min-w-0 hover:border-[#58a6ff] @(expandedModules["MotorTest"] ? (AnyModuleExpanded ? "flex-1 flex-col min-h-0 col-auto" : "col-span-full") : (AnyModuleExpanded ? "hidden" : "flex-col"))">
            <div class="p-[14px_16px] flex items-center gap-[8px] font-bold text-[0.95rem] uppercase cursor-pointer select-none transition-all duration-200 min-h-[58px] hover:bg-[rgba(255,255,255,0.03)] @(expandedModules["MotorTest"] ? "border-b border-[#30363d] rounded-t-[8px]" : "rounded-[8px]")" @onclick='() => ToggleModule("MotorTest")'>
                <i class="bi bi-cpu"></i>
                <span>MOTOR TEST </span>
                <div class="flex-1"></div>
                <i class="bi @(expandedModules["MotorTest"] ? "bi-chevron-up text-[#58a6ff] rotate-180" : "bi-chevron-down text-[#555]") text-[0.75rem] shrink-0 transition-all duration-200"></i>
            </div>
            @if (expandedModules["MotorTest"])
            {
                <div class="p-[14px_16px_16px] flex flex-col gap-[12px] @(AnyModuleExpanded ? "flex-1 overflow-y-auto no-scrollbar" : "max-h-[400px] overflow-y-auto no-scrollbar")">
                    <div class="flex gap-[20px] items-center">
                        <div class="flex items-center gap-[8px]">
                            <label class="text-[0.65rem] text-[#8b949e] font-extrabold">THROTTLE %</label>
                            <input type="number" class="bg-[#010409] text-[#58a6ff] border border-[#30363d] w-[50px] p-[4px] rounded-[4px] font-mono font-bold text-center outline-none transition-colors duration-200 focus:border-[#58a6ff]" @bind="motorTestThrottle" min="0" max="100" />
                        </div>
                        <div class="flex items-center gap-[8px]">
                            <label class="text-[0.65rem] text-[#8b949e] font-extrabold">DURATION (S)</label>
                            <input type="number" class="bg-[#010409] text-[#58a6ff] border border-[#30363d] w-[50px] p-[4px] rounded-[4px] font-mono font-bold text-center outline-none transition-colors duration-200 focus:border-[#58a6ff]" @bind="motorTestDuration" min="1" max="15" />
                        </div>
                        <div class="flex gap-[30px] text-[0.7rem] text-[#58a6ff] m-[5px_0_10px_0] font-extrabold ml-auto">
                            <span>FRAME: @currentType</span>
                        </div>
                    </div>

                    <div class="grid grid-cols-[repeat(auto-fill,minmax(80px,1fr))] gap-[10px] mb-[15px]">
                        @for (int i = 1; i <= Drone.State.MotorCount; i++)
                        {
                            int motorId = i;
                            <button class="bg-[#161b22] border border-[#30363d] text-[#58a6ff] p-[10px] rounded-[4px] font-bold cursor-pointer transition-all duration-200 hover:bg-[#58a6ff] hover:text-black hover:border-white active:bg-[#238636] active:border-[#2ea043]" @onclick="() => Drone.TestMotor(motorId, motorTestThrottle, motorTestDuration)">
                                MOTOR @motorId
                            </button>
                        }
                    </div>

                    <div class="grid grid-cols-3 gap-[10px] mt-[15px] border-t border-dashed border-[#30363d] pt-[15px]">
                        <button class="h-[32px] flex items-center justify-center text-[0.65rem] font-extrabold rounded-[4px] cursor-pointer uppercase transition-all duration-200 bg-[#21262d] border border-[#30363d] text-[#58a6ff] hover:bg-[#58a6ff] hover:text-black text-center" @onclick="() => Drone.TestAllMotors((float)motorTestThrottle, (float)motorTestDuration)">TEST ALL MOTORS</button>
                        <button class="h-[32px] flex items-center justify-center text-[0.65rem] font-extrabold rounded-[4px] cursor-pointer uppercase transition-all duration-200 bg-[#21262d] border border-[#30363d] text-[#58a6ff] hover:bg-[#58a6ff] hover:text-black text-center" @onclick="() => Drone.TestMotorSequence((float)motorTestThrottle, (float)motorTestDuration)">RUN SEQUENCE</button>
                        <button class="h-[32px] flex items-center justify-center text-[0.65rem] font-extrabold rounded-[4px] cursor-pointer uppercase transition-all duration-200 bg-[rgba(255,58,58,0.1)] border border-[#ff3a3a] text-[#ff3a3a] hover:bg-[#ff3a3a] hover:text-white text-center" @onclick="StopAllMotors">ABORT ALL</button>
                    </div>

                    <p class="text-[0.55rem] text-center text-[#8b949e] mt-[10px] font-bold">CAUTION: PROPELLERS MUST BE REMOVED BEFORE TESTING</p>
                </div>
            }
        </div>

        @* ── ESC CALIBRATION MODULE ── *@
        <div class="bg-[#161b22] border border-[#30363d] rounded-[8px] flex flex-col w-full transition-colors duration-200 min-w-0 hover:border-[#58a6ff] @(expandedModules["ESC"] ? (AnyModuleExpanded ? "flex-1 flex-col min-h-0 col-auto" : "col-span-full") : (AnyModuleExpanded ? "hidden" : "flex-col"))">
            <div class="p-[14px_16px] flex items-center gap-[8px] font-bold text-[0.95rem] uppercase cursor-pointer select-none transition-all duration-200 min-h-[58px] hover:bg-[rgba(255,255,255,0.03)] @(expandedModules["ESC"] ? "border-b border-[#30363d] rounded-t-[8px]" : "rounded-[8px]")" @onclick='() => ToggleModule("ESC")'>
                <i class="bi bi-lightning-charge"></i>
                <span>ESC CALIBRATION</span>
                <div class="flex-1 flex justify-center">
                @if (expandedModules["ESC"] && escCalStep > 0 && escCalStep < 99)
            {
                <div class="text-[0.6rem] bg-[rgba(88,166,255,0.15)] text-[#58a6ff] p-[3px_10px] rounded-full border border-[rgba(88,166,255,0.3)] tracking-[1px] animate-pulse">
                    STEP @escCalStep OF @(escCalMethod == 0 ? 4 : 5)
                </div>
            }
                </div>

        @if (expandedModules["ESC"])
        {
            <div class="flex items-center gap-[8px] mr-2" @onclick:stopPropagation="true">
                @if (escCalStep == 0)
                {
                    <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer hover:brightness-110 transition-all" @onclick="EscCalStart">BEGIN</button>
                }
                else if (escCalStep < 5)
                {
                    <button class="bg-[rgba(255,58,58,0.1)] border border-[#ff3a3a] text-[#ff3a3a] py-[5px] px-[12px] text-[0.65rem] font-bold rounded-[4px] cursor-pointer hover:bg-[#ff3a3a] hover:text-white transition-all" @onclick="EscCalAbort">ABORT</button>
                }
            </div>
        }
                <i class="bi @(expandedModules["ESC"] ? "bi-chevron-up text-[#58a6ff] rotate-180" : "bi-chevron-down text-[#555]") text-[0.75rem] shrink-0 transition-all duration-200"></i>
            </div>
            @if (expandedModules["ESC"])
            {
                <div class="p-[14px_16px_16px] flex flex-col gap-[12px] @(AnyModuleExpanded ? "flex-1 overflow-y-auto no-scrollbar" : "max-h-[400px] overflow-y-auto no-scrollbar")">

                    @if (escCalStep == 0)
                    {
                        <div class="mb-[14px]">
                            <div class="text-[0.6rem] font-bold text-[#8b949e] tracking-[1.5px] mb-[8px]">CALIBRATION METHOD</div>
                            <div class="flex flex-col gap-[8px]">
                                <div class="bg-[#010409] border rounded-[6px] p-[10px_14px] cursor-pointer transition-all duration-200 @(escCalMethod == 0 ? "border-[#58a6ff] bg-[rgba(0,242,255,0.06)]" : "border-[#30363d] hover:border-[#555]")" @onclick="() => escCalMethod = 0">
                                    <div class="text-[0.68rem] font-extrabold text-[#c9d1d9] tracking-[0.5px] mb-[4px] flex items-center gap-[6px]">
                                        <i class="bi bi-magic"></i> AUTO (RECOMMENDED)
                                    </div>
                                    <div class="text-[0.6rem] text-[#8b949e] leading-[1.4]">FC sends full-throttle signal on next boot. Connect battery to start ESC calibration sequence automatically. Works with most ESCs.</div>
                                </div>
                                <div class="bg-[#010409] border rounded-[6px] p-[10px_14px] cursor-pointer transition-all duration-200 @(escCalMethod == 1 ? "border-[#58a6ff] bg-[rgba(0,242,255,0.06)]" : "border-[#30363d] hover:border-[#555]")" @onclick="() => escCalMethod = 1">
                                    <div class="text-[0.68rem] font-extrabold text-[#c9d1d9] tracking-[0.5px] mb-[4px] flex items-center gap-[6px]">
                                        <i class="bi bi-sliders"></i> MANUAL (PASSTHROUGH)
                                    </div>
                                    <div class="text-[0.6rem] text-[#8b949e] leading-[1.4]">FC passes RC throttle directly to ESCs. Move your TX throttle stick from max to min during calibration. Use if Auto method fails.</div>
                                </div>
                            </div>
                        </div>
                        <div class="bg-[rgba(255,165,0,0.05)] border border-[rgba(230,168,23,0.3)] rounded-[6px] p-[10px_14px] mt-[10px]">
                            <div class="text-[0.62rem] font-bold text-[#58a6ff] tracking-[1px] mb-[6px] flex items-center gap-[6px]"><i class="bi bi-exclamation-triangle-fill text-[#58a6ff]"></i> BEFORE YOU BEGIN</div>
                            <ul class="m-0 pl-[16px] text-[0.6rem] text-[#c9d1d9] leading-[1.8]">
                                <li>Remove all propellers</li>
                                <li>Vehicle must be DISARMED</li>
                                <li>Connect USB but NOT battery</li>
                                @if (escCalMethod == 1)
                                {
                                    <li>TX throttle stick at maximum position</li>
                                    <li>Verify RC calibration is complete</li>
                                }
                            </ul>
                        </div>
                    }

                    @if (escCalStep > 0)
                    {
                        <div class="flex flex-col gap-[16px]">
                            <div class="flex items-center justify-center gap-0 p-[4px_0]">
                                @{
                                    int totalSteps = escCalMethod == 0 ? 4 : 5;
                                }
                                @for (int st = 1; st <= totalSteps; st++)
                                {
                                    var stepNum = st;
                                    <div class="w-[28px] h-[28px] rounded-full flex items-center justify-center text-[0.62rem] font-extrabold border-[2px] bg-[#161b22] shrink-0 transition-all duration-300 z-10 @(escCalStep == stepNum ? "border-[#58a6ff] bg-[rgba(0,242,255,0.15)] text-[#58a6ff] shadow-[0_0_10px_rgba(0,242,255,0.3)]" : escCalStep > stepNum ? "border-[#58a6ff] bg-[rgba(0,212,255,0.15)] text-[#58a6ff]" : "border-[#30363d] text-[#8b949e] opacity-40")">
                                        @if (escCalStep > stepNum)
                                        {
                                            <i class="bi bi-check-lg"></i>
                                        }
                                        else
                                        {

                                            @stepNum
                                        }
                                    </div>
                                    @if (stepNum < totalSteps)
