    public void Dispose()
    {
        Drone.OnTelemetryUpdated -= RefreshUi;
        Drone.OnRcChannelsUpdated -= HandleRcUpdate;
        Drone.OnFlightModeParams -= OnFlightModeParamsReceived;
        Drone.OnFailsafeParams -= HandleFailsafeParams;
        Drone.OnBatteryParams -= HandleBatteryParams;
    }

    // Called when MavlinkService has read all FLTMODE params from the FC
    private void OnFlightModeParamsReceived(string[] modes, string channel)
    {

        flightModeSettings = modes;
        flightModeChannel = channel;
        InvokeAsync(StateHasChanged);
    }

