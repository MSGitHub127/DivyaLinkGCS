                                    @switch (escCalStep)
                                    {
                                        case 1:
                                            <div class="text-[2rem] leading-none text-[#58a6ff]"><i class="bi bi-lightning-charge-fill"></i></div>
                                            <div class="text-[0.75rem] font-extrabold tracking-[1.5px] text-[#c9d1d9]">WRITE CALIBRATION FLAG</div>
                                            <div class="text-[0.65rem] text-[#8b949e] leading-[1.5] max-w-[340px] [&>code]:bg-[rgba(255,255,255,0.07)] [&>code]:rounded-[3px] [&>code]:p-[1px_5px] [&>code]:text-[0.62rem] [&>code]:text-[#58a6ff]">Sending <code>ESC_CALIBRATION = 3</code> to flight controller. On next boot, the FC will output full-throttle PWM to all ESCs.</div>
                                            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed" @onclick="EscCalAutoStep1">WRITE PARAMETER →</button>
                                            break;
                                        case 2:
                                            <div class="text-[2rem] leading-none text-[#58a6ff]"><i class="bi bi-plug-fill"></i></div>
