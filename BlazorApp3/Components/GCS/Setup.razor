                                            <div class="text-[0.65rem] text-[#8b949e] leading-[1.5] max-w-[340px]">Parameter written. Now <strong>disconnect USB cable</strong> and <strong>disconnect the battery</strong> completely. Wait 5 seconds for capacitors to discharge.</div>
                                            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed ml-auto" @onclick="() => escCalStep = 3">I'VE DISCONNECTED →</button>
                                            break;
                                        case 3:
                                            <div class="text-[2rem] leading-none text-[#58a6ff]"><i class="bi bi-battery-charging"></i></div>
                                            <div class="text-[0.75rem] font-extrabold tracking-[1.5px] text-[#c9d1d9]">CONNECT BATTERY</div>
                                            <div class="text-[0.65rem] text-[#8b949e] leading-[1.5] max-w-[340px]">Connect the <strong>battery only</strong> (not USB yet). ESCs will beep to confirm they received the full-throttle signal. Wait for beeps to complete.</div>
                                            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed ml-auto" @onclick="() => escCalStep = 4">ESCs BEEPED →</button>
                                            break;
                                        case 4:
                                            <div class="text-[2rem] leading-none text-[#3fb950]"><i class="bi bi-check-circle-fill"></i></div>
                                            <div class="text-[0.75rem] font-extrabold tracking-[1.5px] text-[#c9d1d9]">CALIBRATION COMPLETE</div>
                                            <div class="text-[0.65rem] text-[#8b949e] leading-[1.5] max-w-[340px] [&>code]:bg-[rgba(255,255,255,0.07)] [&>code]:rounded-[3px] [&>code]:p-[1px_5px] [&>code]:text-[0.62rem] [&>code]:text-[#58a6ff]">ESC endpoints have been set. Reconnect USB. The <code>ESC_CALIBRATION</code> parameter automatically resets to 0 after a successful calibration.</div>
                                            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed ml-auto" @onclick="EscCalDone">FINISH</button>
                                            break;
                                    }
                                }
                                else
                                {
                                    @switch (escCalStep)
                                    {
                                        case 1:
                                            <div class="text-[2rem] leading-none text-[#58a6ff]"><i class="bi bi-arrow-up-circle-fill"></i></div>
                                            <div class="text-[0.75rem] font-extrabold tracking-[1.5px] text-[#c9d1d9]">THROTTLE TO MAXIMUM</div>
                                            <div class="text-[0.65rem] text-[#8b949e] leading-[1.5] max-w-[340px]">Move your transmitter <strong>throttle stick to full maximum</strong>. Keep it there until instructed.</div>
                                            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed" @onclick="EscCalManualStep1">THROTTLE IS MAX →</button>
                                            break;
                                        case 2:
                                            <div class="text-[2rem] leading-none text-[#58a6ff]"><i class="bi bi-plug-fill"></i></div>
                                            <div class="text-[0.75rem] font-extrabold tracking-[1.5px] text-[#c9d1d9]">ENABLE PASSTHROUGH</div>
                                            <div class="text-[0.65rem] text-[#8b949e] leading-[1.5] max-w-[340px]">Passthrough mode active — FC is now relaying RC throttle directly to all ESCs. <strong>Connect the battery now.</strong> ESCs will beep acknowledging full throttle.</div>
                                            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed ml-auto" @onclick="() => escCalStep = 3">ESCs BEEPED →</button>
                                            break;
                                        case 3:
                                            <div class="text-[2rem] leading-none text-[#58a6ff]"><i class="bi bi-arrow-down-circle-fill"></i></div>
                                            <div class="text-[0.75rem] font-extrabold tracking-[1.5px] text-[#c9d1d9]">THROTTLE TO MINIMUM</div>
                                            <div class="text-[0.65rem] text-[#8b949e] leading-[1.5] max-w-[340px]">Move your transmitter <strong>throttle stick to full minimum (zero)</strong>. ESCs will beep again to confirm the low endpoint is set.</div>
                                            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed ml-auto" @onclick="() => escCalStep = 4">ESCs BEEPED →</button>
                                            break;
                                        case 4:
                                            <div class="text-[2rem] leading-none text-[#58a6ff]"><i class="bi bi-power"></i></div>
                                            <div class="text-[0.75rem] font-extrabold tracking-[1.5px] text-[#c9d1d9]">DISABLE PASSTHROUGH</div>
                                            <div class="text-[0.65rem] text-[#8b949e] leading-[1.5] max-w-[340px]">Disabling passthrough mode. Disconnect battery and wait 5 seconds before reconnecting.</div>
                                            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed" @onclick="EscCalManualStep4">DISABLE PASSTHROUGH →</button>
                                            break;
                                        case 5:
                                            <div class="text-[2rem] leading-none text-[#3fb950]"><i class="bi bi-check-circle-fill"></i></div>
                                            <div class="text-[0.75rem] font-extrabold tracking-[1.5px] text-[#c9d1d9]">CALIBRATION COMPLETE</div>
                                            <div class="text-[0.65rem] text-[#8b949e] leading-[1.5] max-w-[340px]">All ESC endpoints have been set. Your ESCs are now calibrated to your transmitter's throttle range.</div>
                                            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed ml-auto" @onclick="EscCalDone">FINISH</button>
                                            break;
                                    }
                                }
                            </div>
                        </div>
                    }

                    @if (escCalStep == 99)
                    {
                        <div class="flex items-center justify-center gap-[10px] p-[14px] bg-[rgba(63,185,80,0.08)] border border-[rgba(63,185,80,0.4)] rounded-[6px] text-[0.65rem] font-bold text-[#3fb950] tracking-[0.5px]">
                            <i class="bi bi-check-circle-fill"></i>
                            ESC CALIBRATION COMPLETE — All endpoints saved
                            <button class="bg-transparent border-none text-[#58a6ff] text-[0.62rem] cursor-pointer underline p-0 font-inherit" @onclick="() => escCalStep = 0">Recalibrate</button>
                        </div>
                    }
                </div>
            }
        </div>

        @* ── FAILSAFES MODULE ── *@
        <div class="bg-[#161b22] border border-[#30363d] rounded-[8px] flex flex-col w-full transition-colors duration-200 min-w-0 hover:border-[#58a6ff] @(expandedModules["Failsafe"] ? (AnyModuleExpanded ? "flex-1 flex-col min-h-0 col-auto" : "col-span-full") : (AnyModuleExpanded ? "hidden" : "flex-col"))">
            <div class="p-[14px_16px] flex items-center gap-[8px] font-bold text-[0.95rem] uppercase cursor-pointer select-none transition-all duration-200 min-h-[58px] hover:bg-[rgba(255,255,255,0.03)] @(expandedModules["Failsafe"] ? "border-b border-[#30363d] rounded-t-[8px]" : "rounded-[8px]")" @onclick='() => ToggleModule("Failsafe")'>
                <i class="bi bi-exclamation-triangle"></i>
                <span>SAFETY FAILSAFES</span>
                <div class="flex-1"></div> @* Standard spacer logic for right-aligned button *@

        @if (expandedModules["Failsafe"])
        {
            @* Integrated Save Button: Merged into the header *@
            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer hover:brightness-110 transition-all mr-2" 
