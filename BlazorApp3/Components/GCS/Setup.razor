@page "/setup"
@inject MavlinkService Drone
@inject IJSRuntime JS
@implements IDisposable

<div class="flex flex-col h-full gap-[16px] p-[20px] bg-transparent text-[#c9d1d9] w-full max-w-[500px] mx-auto overflow-hidden @(AnyModuleExpanded ? "gap-[16px]" : "")">
    <div class="h-[300px] w-full rounded-[8px] overflow-hidden shadow-[0_4px_20px_rgba(0,0,0,0.4)] border border-[#333] shrink-0 transition-[height] duration-250 ease-in-out">
        <Hud />
    </div>

    <div class="@(AnyModuleExpanded ? "flex flex-col gap-0 overflow-hidden" : "grid grid-cols-2 auto-rows-min gap-[10px] items-start overflow-hidden min-h-0") flex-1">

        @* ── FRAME MODULE ── *@
        <div class="bg-[#161b22] border border-[#30363d] rounded-[8px] flex flex-col w-full transition-colors duration-200 min-w-0 hover:border-[#58a6ff] @(expandedModules["Frame"] ? (AnyModuleExpanded ? "flex-1 flex-col min-h-0 col-auto" : "col-span-full") : (AnyModuleExpanded ? "hidden" : "flex-col"))">
            <div class="p-[14px_16px] flex items-center gap-[8px] font-extrabold text-[0.7rem] uppercase cursor-pointer select-none transition-all duration-200 min-h-[58px] hover:bg-[rgba(255,255,255,0.03)] @(expandedModules["Frame"] ? "border-b border-[#30363d] rounded-t-[8px]" : "rounded-[8px]")" @onclick='() => ToggleModule("Frame")'>
                <i class="bi bi-gear-wide-connected"></i>
                <span>FRAME GEOMETRY</span>
                <div class="flex-1"></div>
                <i class="bi @(expandedModules["Frame"] ? "bi-chevron-up text-[#58a6ff] rotate-180" : "bi-chevron-down text-[#555]") text-[0.75rem] shrink-0 transition-all duration-200"></i>
            </div>
            @if (expandedModules["Frame"])
            {
                <div class="p-[14px_16px_16px] flex flex-col gap-[12px] @(AnyModuleExpanded ? "flex-1 overflow-y-auto no-scrollbar" : "max-h-[400px] overflow-y-auto no-scrollbar")">
                    <div class="flex items-center justify-between gap-[10px] p-[8px_12px] bg-[rgba(0,242,255,0.04)] border border-[rgba(0,242,255,0.15)] rounded-[6px] mb-[4px]">
                        <button class="bg-[#58a6ff] border-none p-[6px_12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer ml-auto text-black transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed disabled:filter-none"
                                disabled="@(!Drone.IsLinkHealthy)"
                                @onclick="ApplyFrame">
                            APPLY & REBOOT
                        </button>
                    </div>

                    <div class="flex gap-[12px] mb-[10px]">
                        <div class="flex-1 bg-[#010409] p-[10px] rounded-[6px] border border-[#30363d]">
                            <label class="block text-[0.55rem] text-[#8b949e] mb-[4px] font-extrabold">ACTIVE VEHICLE</label>
                            <div class="text-[0.8rem] font-extrabold text-[#58a6ff]">@FrameClassName</div>
                        </div>
                        <div class="flex-1 bg-[#010409] p-[10px] rounded-[6px] border border-[#30363d]">
                            <label class="block text-[0.55rem] text-[#8b949e] mb-[4px] font-extrabold">ACTIVE LAYOUT</label>
                            <div class="text-[0.8rem] font-extrabold text-[#58a6ff]">@FrameTypeName</div>
                        </div>
                        <div class="flex-1 bg-[#010409] p-[10px] rounded-[6px] border border-[#30363d]">
                            <label class="block text-[0.55rem] text-[#8b949e] mb-[4px] font-extrabold">MOTORS</label>
                            <div class="text-[0.8rem] font-extrabold text-[#58a6ff]">@Drone.State.MotorCount</div>
                        </div>
                    </div>

                    <div class="flex flex-col items-center gap-[10px] bg-[#010409] border border-[#1c2128] rounded-[8px] p-[14px_10px_10px] mb-[12px]">
                        <svg viewBox="0 0 200 200" class="w-[180px] h-[180px] overflow-visible" xmlns="http://www.w3.org/2000/svg">
                            @foreach (var m in MotorPositions)
                            {
                                <line x1="100" y1="100" x2="@m.X.ToString("0.0")" y2="@m.Y.ToString("0.0")" stroke="#30363d" stroke-width="4" stroke-linecap="round" />
                                <circle cx="@m.X.ToString("0.0")" cy="@m.Y.ToString("0.0")" r="14" fill="@(m.Cw ? "#1a2a1a" : "#1a1a2a")" stroke="@(m.Cw ? "#3fb950" : "#58a6ff")" stroke-width="2" />
                                @if (m.Cw)
                                {
                                    <path d="M @((m.X - 11).ToString("0.0")),@(m.Y.ToString("0.0")) a 11 11 0 1 1 8 8" fill="none" stroke="#3fb950" stroke-width="1.5" stroke-linecap="round" />
                                    <polygon points="@((m.X - 3).ToString("0.0")),@((m.Y + 8).ToString("0.0")) @((m.X + 3).ToString("0.0")),@((m.Y + 12).ToString("0.0")) @((m.X - 1).ToString("0.0")),@((m.Y + 14).ToString("0.0"))" fill="#3fb950" />
                                }
                                else
                                {
                                    <path d="M @((m.X + 11).ToString("0.0")),@(m.Y.ToString("0.0")) a 11 11 0 1 0 -8 8" fill="none" stroke="#58a6ff" stroke-width="1.5" stroke-linecap="round" />
                                    <polygon points="@((m.X + 3).ToString("0.0")),@((m.Y + 8).ToString("0.0")) @((m.X - 3).ToString("0.0")),@((m.Y + 12).ToString("0.0")) @((m.X + 1).ToString("0.0")),@((m.Y + 14).ToString("0.0"))" fill="#58a6ff" />
                                }
                                @((MarkupString)$"<text x='{m.X:0.0}' y='{m.Y + 1:0.0}' style='text-anchor:middle;dominant-baseline:middle;fill:white;font-size:8px;font-weight:bold;font-family:monospace;'>{m.Num}</text>")
                            }
                            <circle cx="100" cy="100" r="10" fill="#161b22" stroke="#30363d" stroke-width="2" />
                            @((MarkupString)"<text x='100' y='100' style='text-anchor:middle;dominant-baseline:middle;fill:#58a6ff;font-size:7px;font-weight:bold;font-family:monospace;'>FC</text>")
                            <polygon points="100,18 106,30 94,30" fill="#f0b429" opacity="0.8" />
                            @((MarkupString)"<text x='100' y='13' style='text-anchor:middle;fill:#f0b429;font-size:7px;font-family:monospace;opacity:0.8;'>FWD</text>")
                        </svg>

                        <div class="flex gap-[16px] flex-wrap justify-center">
                            <div class="flex items-center gap-[5px] text-[0.62rem] text-[#8b949e]">
                                <span class="w-[9px] h-[9px] rounded-full shrink-0 bg-[#3fb950]"></span><span>CW (clockwise)</span>
                            </div>
                            <div class="flex items-center gap-[5px] text-[0.62rem] text-[#8b949e]">
                                <span class="w-[9px] h-[9px] rounded-full shrink-0 bg-[#58a6ff]"></span><span>CCW (counter-clockwise)</span>
                            </div>
                            <div class="flex items-center gap-[5px] text-[0.62rem] text-[#8b949e]">
                                <span class="w-[9px] h-[9px] rounded-full shrink-0 bg-[#f0b429]"></span><span>Forward</span>
                            </div>
                        </div>
                    </div>

                    <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px] mt-[8px]">VEHICLE TYPE (FRAME_CLASS)</label>
                    <select class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[6px]" @bind="selectedFrameClass">
                        <option value="1">Quadcopter (4 motors)</option>
                        <option value="2">Hexacopter (6 motors)</option>
                        <option value="3">Octocopter (8 motors)</option>
                        <option value="5">Y6 (6 motors coaxial)</option>
                        <option value="7">Tricopter (3 motors)</option>
                    </select>

                    <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px] mt-[6px]">MOTOR LAYOUT (FRAME_TYPE)</label>
                    <select class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[10px]" @bind="selectedFrameType">
                        <option value="0">Plus (+)</option>
                        <option value="1">X</option>
                        <option value="2">V (H-Frame)</option>
                        <option value="3">H</option>
                        <option value="10">CW X (reversed CW/CCW)</option>
                    </select>

                    <div class="bg-[rgba(240,180,41,0.06)] border border-[rgba(240,180,41,0.2)] rounded-[5px] p-[8px_12px] text-[0.72rem] text-[#8b949e] leading-[1.5]">
                        <strong>⚠️ Reboot required.</strong> Frame changes take effect after power cycle. Motor numbering and rotation directions follow ArduPilot standard shown above. Verify prop directions match diagram before first flight.
                    </div>
                </div>
            }
        </div>

        @* ── SENSORS MODULE ── *@
        <div class="bg-[#161b22] border border-[#30363d] rounded-[8px] flex flex-col w-full transition-colors duration-200 min-w-0 hover:border-[#58a6ff] @(expandedModules["Sensors"] ? (AnyModuleExpanded ? "flex-1 flex-col min-h-0 col-auto" : "col-span-full") : (AnyModuleExpanded ? "hidden" : "flex-col"))">
            <div class="p-[14px_16px] flex items-center gap-[8px] font-extrabold text-[0.7rem] uppercase cursor-pointer select-none transition-all duration-200 min-h-[58px] hover:bg-[rgba(255,255,255,0.03)] @(expandedModules["Sensors"] ? "border-b border-[#30363d] rounded-t-[8px]" : "rounded-[8px]")" @onclick='() => ToggleModule("Sensors")'>
                <i class="bi bi-compass"></i>
                <span>SENSORS & IMU</span>
                <div class="flex-1"></div>
                <i class="bi @(expandedModules["Sensors"] ? "bi-chevron-up text-[#58a6ff] rotate-180" : "bi-chevron-down text-[#555]") text-[0.75rem] shrink-0 transition-all duration-200"></i>
            </div>
            @if (expandedModules["Sensors"])
            {
                <div class="p-[14px_16px_16px] flex flex-col gap-[12px] @(AnyModuleExpanded ? "flex-1 overflow-y-auto no-scrollbar" : "max-h-[400px] overflow-y-auto no-scrollbar")">
                    <div class="flex flex-col gap-[12px]">

                        @* ACCELEROMETER ROW *@
                        <div class="bg-[#010409] border border-[#30363d] rounded-[6px] p-[12px_16px] flex flex-col items-stretch transition-colors duration-200 hover:border-[#555] overflow-hidden">
                            <div class="flex items-center gap-[20px] w-full">
                                <div class="flex flex-col gap-[4px] w-[140px] shrink-0">
                                    <span class="text-[0.65rem] font-extrabold text-[#8b949e] tracking-[0.5px]">ACCELEROMETER</span>
                                    <span class="text-[0.8rem] font-extrabold whitespace-nowrap overflow-hidden text-ellipsis @(IsAccelCalibrating && Drone.LiveAccelStatus != "WAITING..." ? "text-[#58a6ff]" : Drone.LiveAccelStatus == "FAILED" || Drone.LiveAccelStatus.Contains("DENIED") || Drone.LiveAccelStatus.Contains("NO RESPONSE") ? "text-[#f85149]" : Drone.LiveAccelStatus == "SUCCESS" ? "text-[#58a6ff]" : "text-[#c9d1d9]")">
                                        @Drone.LiveAccelStatus
                                    </span>
                                </div>
                                <div class="flex-1 min-w-[50px]">
                                    <div class="h-[8px] bg-[rgba(255,255,255,0.05)] border border-[rgba(255,255,255,0.1)] rounded-[2px] overflow-hidden @(IsAccelCalibrating ? "bg-active" : "")">
                                        @if (Drone.LiveAccelStatus == "COMPUTING...")
                                        {
                                            <div class="cal-progress-indeterminate"></div>
                                        }
                                        else
                                        {
                                            <div class="h-full bg-[#58a6ff] shadow-[0_0_5px_#58a6ff] transition-[width] duration-300 ease-out" style="width: @(Drone.LiveAccelProgress)%"></div>
                                        }
                                    </div>
                                </div>
                                <div class="flex justify-end gap-[8px] shrink-0 w-[140px] [&>button]:flex-1 [&>button]:h-[32px] [&>button]:m-0">
                                    @if (Drone.LiveAccelStatus == "COMPUTING...")
                                    {
                                        <div class="flex-1 flex items-center justify-center gap-[6px] bg-transparent text-[#58a6ff] text-[0.65rem] font-black border border-dashed border-[#58a6ff] rounded-[4px] h-[32px] cursor-not-allowed"><div class="spinner-border-sm"></div><span>COMPUTING</span></div>
                                    }
                                    else if (Drone.LiveAccelStatus == "RECORDING...")
                                    {
                                        <div class="flex-1 flex items-center justify-center gap-[6px] bg-transparent text-[#58a6ff] text-[0.65rem] font-black border border-dashed border-[#58a6ff] rounded-[4px] h-[32px] cursor-not-allowed"><div class="spinner-border-sm"></div><span>RECORDING</span></div>
                                    }
                                    else if (Drone.LiveAccelStatus == "WAITING...")
                                    {
                                        <div class="flex-1 flex items-center justify-center gap-[6px] bg-transparent text-[#58a6ff] text-[0.65rem] font-black border border-dashed border-[#58a6ff] rounded-[4px] h-[32px] cursor-not-allowed"><div class="spinner-border-sm"></div><span>WAITING</span></div>
                                    }
                                    else if (IsAccelCalibrating)
                                    {
                                        <button class="bg-[#58a6ff] text-black border-none rounded-[4px] text-[0.65rem] font-black cursor-pointer" @onclick="Drone.AckCalibrationStep">NEXT</button>
                                    }
                                    else
                                    {
                                        <button class="bg-[#21262d] text-[#58a6ff] border border-[#30363d] rounded-[4px] text-[0.65rem] font-black cursor-pointer hover:bg-[#58a6ff] hover:text-black transition-colors" @onclick="StartAccel">START</button>
                                    }
                                    <button class="bg-[rgba(255,58,58,0.1)] text-[#ff3a3a] border border-[#ff3a3a] rounded-[4px] text-[0.65rem] font-black cursor-pointer hover:bg-[#ff3a3a] hover:text-white transition-colors" @onclick="CancelAccel">CANCEL</button>
                                </div>
                            </div>
                            @if (IsAccelCalibrating && Drone.LiveAccelStatus != "WAITING...")
                            {
                                <div class="flex items-center gap-[20px] mt-[15px] pt-[15px] border-t border-dashed border-[#30363d] animate-[slideDown_0.3s_cubic-bezier(0.175,0.885,0.32,1.275)]">
                                    <div class="w-[80px] h-[80px] bg-[rgba(0,242,255,0.05)] border border-[rgba(0,242,255,0.3)] rounded-[8px] flex items-center justify-center shrink-0">
                                        <svg class="w-[60px] h-[60px] transition-transform duration-600 ease-[cubic-bezier(0.4,0,0.2,1)] @GetDroneOrientationClass(Drone.LiveAccelStatus)" viewBox="0 0 100 100">
                                            <rect x="44" y="20" width="12" height="60" fill="#30363d" rx="4" />
                                            <path d="M50 20 L40 35 L60 35 Z" fill="#00f2ff" />
                                            <line x1="20" y1="20" x2="80" y2="80" stroke="#30363d" stroke-width="4" />
                                            <line x1="20" y1="80" x2="80" y2="20" stroke="#30363d" stroke-width="4" />
                                            <circle cx="20" cy="20" r="10" fill="#ff3a3a" opacity="0.8" />
                                            <circle cx="80" cy="20" r="10" fill="#ff3a3a" opacity="0.8" />
                                            <circle cx="20" cy="80" r="10" fill="#00f2ff" opacity="0.8" />
                                            <circle cx="80" cy="80" r="10" fill="#00f2ff" opacity="0.8" />
                                        </svg>
                                    </div>
                                    <div class="flex flex-col gap-[6px]">
                                        <div class="text-[0.55rem] bg-[#58a6ff] text-black p-[2px_6px] rounded-[4px] font-black self-start tracking-[1px]">
                                            @(Drone.LiveAccelStatus == "COMPUTING..." ? "COMPUTING" : $"STEP {(Drone.LiveAccelProgress / 16) + 1} OF 6")
                                        </div>
                                        <div class="text-[0.95rem] font-black text-white">@GetAccelInstructionTitle(Drone.LiveAccelStatus)</div>
                                        <div class="text-[0.75rem] text-[#8b949e] leading-[1.4]">@GetAccelInstructionDesc(Drone.LiveAccelStatus)</div>
                                    </div>
                                </div>
                            }
                        </div>

                        @* GYRO ROW *@
                        <div class="bg-[#010409] border border-[#30363d] rounded-[6px] p-[12px_16px] flex flex-col items-stretch transition-colors duration-200 hover:border-[#555] overflow-hidden">
                            <div class="flex items-center gap-[20px] w-full">
                                <div class="flex flex-col gap-[4px] w-[140px] shrink-0">
                                    <span class="text-[0.65rem] font-extrabold text-[#8b949e] tracking-[0.5px]">GYROSCOPE</span>
                                    <span class="text-[0.8rem] font-extrabold whitespace-nowrap overflow-hidden text-ellipsis @(IsGyroCalibrating ? "text-[#58a6ff]" : (Drone.LiveGyroStatus == "FAILED" ? "text-[#f85149]" : "text-[#c9d1d9]"))">
                                        @Drone.LiveGyroStatus
                                    </span>
                                </div>
                                <div class="flex-1 min-w-[50px]">
                                    <div class="h-[8px] bg-[rgba(255,255,255,0.05)] border border-[rgba(255,255,255,0.1)] rounded-[2px] mt-2 overflow-hidden @(IsGyroCalibrating ? "bg-active" : "")">
                                        @if (IsGyroCalibrating)
                                        {
                                            <div class="cal-progress-indeterminate"></div>
                                        }
                                        else
                                        {

                                            <div class="h-full bg-[#58a6ff] shadow-[0_0_5px_#58a6ff] transition-[width] duration-300 ease-out" style="width: @(Drone.LiveGyroProgress)%"></div>
                                        }
                                    </div>
                                </div>
                                <div class="flex justify-end gap-[8px] shrink-0 w-[140px] [&>button]:flex-1 [&>button]:h-[32px] [&>button]:m-0">
                                    @if (IsGyroCalibrating)
                                    {
                                        <div class="flex-1 flex items-center justify-center gap-[6px] bg-transparent text-[#58a6ff] text-[0.65rem] font-black border border-dashed border-[#58a6ff] rounded-[4px] h-[32px] cursor-not-allowed"><div class="spinner-border-sm"></div><span>WORKING</span></div>
                                    }
                                    else if (Drone.LiveGyroStatus == "AUTO AT BOOT")
                                    {
                                        <button class="bg-[#21262d] text-[#58a6ff] border border-[#30363d] rounded-[4px] text-[0.65rem] font-black opacity-50 cursor-not-allowed" disabled>AUTOMATIC</button>
                                    }
                                    else
                                    {
                                        <button class="bg-[#21262d] text-[#58a6ff] border border-[#30363d] rounded-[4px] text-[0.65rem] font-black cursor-pointer hover:bg-[#58a6ff] hover:text-black transition-colors" @onclick="StartGyro">
                                            @(Drone.LiveGyroStatus == "FAILED" ? "RETRY" : "START")
                                        </button>
                                    }
                                    <button class="bg-[rgba(255,58,58,0.1)] text-[#ff3a3a] border border-[#ff3a3a] rounded-[4px] text-[0.65rem] font-black cursor-pointer hover:bg-[#ff3a3a] hover:text-white transition-colors" @onclick="CancelGyro" title="Force Abort">CANCEL</button>
                                </div>
                            </div>
                            @if (IsGyroCalibrating)
                            {
                                <div class="flex items-center gap-[20px] mt-[15px] pt-[15px] border-t border-dashed border-[#30363d] animate-[slideDown_0.3s_cubic-bezier(0.175,0.885,0.32,1.275)]">
                                    <div class="w-[80px] h-[80px] bg-[rgba(0,242,255,0.05)] border border-[#58a6ff] rounded-[8px] flex items-center justify-center shrink-0">
                                        <svg class="w-[60px] h-[60px]" viewBox="0 0 100 100">
                                            <ellipse cx="50" cy="50" rx="40" ry="15" fill="none" stroke="#58a6ff" stroke-width="3" class="ring-x" />
                                            <ellipse cx="50" cy="50" rx="15" ry="40" fill="none" stroke="#58a6ff" stroke-width="3" class="ring-y" />
                                            <circle cx="50" cy="50" r="6" fill="#fff" class="pulse-dot-fast" />
                                        </svg>
                                    </div>
                                    <div class="flex flex-col gap-[6px]">
                                        <div class="text-[0.55rem] bg-[#58a6ff] text-black p-[2px_6px] rounded-[4px] font-black self-start tracking-[1px]">HANDS OFF</div>
                                        <div class="text-[0.95rem] font-black text-white">Calculating Baseline Offsets</div>
                                        <div class="text-[0.75rem] text-[#8b949e] leading-[1.4]">The IMU is actively capturing zero-rotation data. Any vibration will corrupt the calibration. Please step away from the bench until complete.</div>
                                    </div>
                                </div>
                            }
                        </div>

                        @* COMPASS ROW *@
                        <div class="bg-[#010409] border border-[#30363d] rounded-[6px] p-[12px_16px] flex flex-col items-stretch transition-colors duration-200 hover:border-[#555] overflow-hidden">
                            <div class="flex items-center gap-[20px] w-full">
                                <div class="flex flex-col gap-[4px] w-[140px] shrink-0">
                                    <span class="text-[0.65rem] font-extrabold text-[#8b949e] tracking-[0.5px]">COMPASS (MAG)</span>
                                    <span class="text-[0.8rem] font-extrabold whitespace-nowrap overflow-hidden text-ellipsis @(IsMagCalibrating ? "text-[#58a6ff]" : (Drone.LiveMagStatus.Contains("FAILED") || Drone.LiveMagStatus.Contains("DENIED") ? "text-[#f85149]" : "text-[#c9d1d9]"))">
                                        @Drone.LiveMagStatus
                                    </span>
                                </div>
                                <div class="flex-1 min-w-[50px]">
                                    <div class="h-[8px] bg-[rgba(255,255,255,0.05)] border border-[rgba(255,255,255,0.1)] rounded-[2px] mt-2 overflow-hidden @(IsMagCalibrating ? "bg-active" : "")">
                                        <div class="h-full bg-[#58a6ff] shadow-[0_0_5px_#58a6ff] transition-[width] duration-300 ease-out" style="width: @(Drone.LiveMagProgress)%"></div>
                                    </div>
                                </div>
                                <div class="flex justify-end gap-[8px] shrink-0 w-[140px] [&>button]:flex-1 [&>button]:h-[32px] [&>button]:m-0">
                                    @if (IsMagCalibrating)
                                    {
                                        <div class="flex-1 flex items-center justify-center gap-[6px] bg-transparent text-[#58a6ff] text-[0.65rem] font-black border border-dashed border-[#58a6ff] rounded-[4px] h-[32px] cursor-not-allowed"><div class="spinner-border-sm"></div><span>@Drone.LiveMagProgress%</span></div>
                                    }
                                    else
                                    {
                                        <button class="bg-[#21262d] text-[#58a6ff] border border-[#30363d] rounded-[4px] text-[0.65rem] font-black cursor-pointer hover:bg-[#58a6ff] hover:text-black transition-colors" @onclick="StartMag">
                                            @(Drone.LiveMagStatus == "FAILED" ? "RETRY" : "START")
                                        </button>
                                    }
                                    <button class="bg-[rgba(255,58,58,0.1)] text-[#ff3a3a] border border-[#ff3a3a] rounded-[4px] text-[0.65rem] font-black cursor-pointer hover:bg-[#ff3a3a] hover:text-white transition-colors" @onclick="CancelMag" title="Force Abort">CANCEL</button>
                                </div>
                            </div>
                            @if (IsMagCalibrating)
                            {
                                <div class="flex items-center gap-[20px] mt-[15px] pt-[15px] border-t border-dashed border-[#30363d] animate-[slideDown_0.3s_cubic-bezier(0.175,0.885,0.32,1.275)]">
                                    <div class="w-[80px] h-[80px] bg-[rgba(0,242,255,0.05)] border border-[#58a6ff] rounded-[8px] flex items-center justify-center shrink-0">
                                        <svg class="w-[60px] h-[60px] [perspective:1000px]" viewBox="0 0 100 100">
                                            <circle cx="50" cy="50" r="40" fill="none" stroke="#58a6ff" stroke-width="2" stroke-dasharray="4 4" class="spin-z" />
                                            <ellipse cx="50" cy="50" rx="40" ry="15" fill="none" stroke="#ff3a3a" stroke-width="2" class="spin-x" />
                                            <ellipse cx="50" cy="50" rx="15" ry="40" fill="none" stroke="#3fb950" stroke-width="2" class="spin-y" />
                                            <circle cx="50" cy="50" r="5" fill="#fff" />
                                        </svg>
                                    </div>
                                    <div class="flex flex-col gap-[6px]">
                                        <div class="text-[0.55rem] bg-[#58a6ff] text-black p-[2px_6px] rounded-[4px] font-black self-start tracking-[1px]">DANCE REQUIRED</div>
                                        <div class="text-[0.95rem] font-black text-white">Rotate on All Axes</div>
                                        <div class="text-[0.75rem] text-[#8b949e] leading-[1.4]">Pick up the drone and slowly rotate it continuously around its pitch, roll, and yaw axes. Keep rotating until the progress bar reaches 100%.</div>
                                    </div>
                                </div>
                            }
                        </div>

                        @* ONBOARD LED ROW *@
                        <div class="bg-[#010409] border border-[#30363d] rounded-[6px] p-[12px_16px] flex items-center gap-[20px] transition-colors duration-200 hover:border-[#555]">
                            <div class="flex flex-col gap-[4px] w-[140px] shrink-0">
                                <span class="text-[0.65rem] font-extrabold text-[#8b949e] tracking-[0.5px]">ONBOARD LEDS</span>
                                <span class="text-[0.8rem] font-extrabold whitespace-nowrap overflow-hidden text-ellipsis @(isLedEnabled ? "text-[#58a6ff]" : "text-[#c9d1d9]")">
                                    @(isLedEnabled ? "ENABLED" : "VANISHED")
                                </span>
                            </div>
                            <div class="flex-1 min-w-[50px]">
                                <span class="text-[0.65rem] text-[#888] mt-[5px] block">Mutes the physical Pixhawk RGB status lights while on the bench.</span>
                            </div>
                            <div class="flex justify-end gap-[8px] shrink-0 w-[140px] [&>button]:flex-1 [&>button]:h-[32px] [&>button]:m-0">
                                <button class="bg-[#2ea043] text-white border-none rounded-[4px] text-[0.65rem] font-black cursor-pointer" @onclick="() => TogglePixhawkLeds(true)">ON</button>
                                <button class="bg-[rgba(255,58,58,0.1)] text-[#ff3a3a] border border-[#ff3a3a] rounded-[4px] text-[0.65rem] font-black cursor-pointer hover:bg-[#ff3a3a] hover:text-white transition-colors" @onclick="() => TogglePixhawkLeds(false)">OFF</button>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>

        @* ── RC MODULE ── *@
        <div class="bg-[#161b22] border border-[#30363d] rounded-[8px] flex flex-col w-full transition-colors duration-200 min-w-0 hover:border-[#58a6ff] @(expandedModules["RC"] ? (AnyModuleExpanded ? "flex-1 flex-col min-h-0 col-auto" : "col-span-full") : (AnyModuleExpanded ? "hidden" : "flex-col"))">
            <div class="p-[14px_16px] flex items-center gap-[8px] font-extrabold text-[0.7rem] uppercase cursor-pointer select-none transition-all duration-200 min-h-[58px] hover:bg-[rgba(255,255,255,0.03)] @(expandedModules["RC"] ? "border-b border-[#30363d] rounded-t-[8px]" : "rounded-[8px]")" @onclick='() => ToggleModule("RC")'>
                <i class="bi bi-controller"></i>
                <span>RADIO CHANNELS (RC)</span>
                <div class="flex-1"></div>
                <i class="bi @(expandedModules["RC"] ? "bi-chevron-up text-[#58a6ff] rotate-180" : "bi-chevron-down text-[#555]") text-[0.75rem] shrink-0 transition-all duration-200"></i>
            </div>
            @if (expandedModules["RC"])
            {
                <div class="p-[14px_16px_16px] grid grid-cols-2 gap-[15px] @(AnyModuleExpanded ? "flex-1 overflow-y-auto no-scrollbar block" : "max-h-[400px] overflow-y-auto no-scrollbar")">
                    <div class="col-span-2 flex items-center justify-between gap-[10px] p-[8px_12px] bg-[rgba(0,242,255,0.04)] border border-[rgba(0,242,255,0.15)] rounded-[6px] mb-[4px]">
                        <button class="bg-transparent border border-[#58a6ff] text-[#58a6ff] p-[5px_12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer ml-auto hover:bg-[#58a6ff] hover:text-black transition-colors"
                                style="@(Drone.IsRcCalibrating ? "background: #58a6ff; color: #000;" : "")"
                                @onclick="HandleRcClick">
                            @(Drone.IsRcCalibrating ? "SAVE CALIBRATION" : "CALIBRATE RC")
                        </button>
                    </div>

                    @if (Drone.IsRcCalibrating)
                    {
                        <div class="col-span-2 bg-[rgba(210,153,34,0.1)] border border-[#d29922] text-[#d29922] p-[10px] rounded-[4px] text-[0.75rem]">
                            <strong>CALIBRATION ACTIVE:</strong> Move all sticks to their maximum limits, center them, then click SAVE.
                        </div>
                    }

                    @for (int i = 0; i < 8; i++)
                    {
                        var chanNames = new[] { "1: ROLL", "2: PITCH", "3: THROTTLE", "4: YAW", "5: MODE 1", "6: MODE 2", "7: AUX 1", "8: AUX 2" };
                        var rawVal = _localChannels[i];

                        <div class="flex flex-col gap-[4px]">
                            <div class="flex justify-between items-end">
                                <span class="text-[0.65rem] text-[#888] font-bold">@chanNames[i]</span>
                                <span class="font-mono text-[0.85rem] font-bold @(rawVal == 0 ? "text-[#ff3a3a]" : "text-[#00f2ff]")">
                                    @(rawVal == 0 ? "NO RC DATA" : $"{rawVal} us")
                                </span>
                            </div>
                            <div class="w-full h-[18px] bg-[#0a0b0d] border border-[#333] rounded-[4px] relative overflow-hidden">
                                @if (Drone.IsRcCalibrating && Drone.RcMax[i] > Drone.RcMin[i] && rawVal != 0)
                                {
                                    <div class="absolute h-full bg-[rgba(0,242,255,0.2)]" style="left: @(CalculatePercent(Drone.RcMin[i]))%; width: @(CalculatePercent(Drone.RcMax[i]) - CalculatePercent(Drone.RcMin[i]))%;"></div>
                                }
                                <div class="absolute h-full transition-[width] duration-100 ease-linear" style="background: @(Drone.IsRcCalibrating ? "#ffffff" : "#00f2ff"); width: @(rawVal == 0 ? 50 : CalculatePercent(rawVal))%; opacity: @(rawVal == 0 ? 0.2 : 1.0);"></div>
                                <div class="absolute left-1/2 w-[2px] h-full bg-[rgba(255,0,0,0.6)] z-10"></div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        @* ── FLIGHT MODES MODULE ── *@
        <div class="bg-[#161b22] border border-[#30363d] rounded-[8px] flex flex-col w-full transition-colors duration-200 min-w-0 hover:border-[#58a6ff] @(expandedModules["FlightModes"] ? (AnyModuleExpanded ? "flex-1 flex-col min-h-0 col-auto" : "col-span-full") : (AnyModuleExpanded ? "hidden" : "flex-col"))">
            <div class="p-[14px_16px] flex items-center gap-[8px] font-extrabold text-[0.7rem] uppercase cursor-pointer select-none transition-all duration-200 min-h-[58px] hover:bg-[rgba(255,255,255,0.03)] @(expandedModules["FlightModes"] ? "border-b border-[#30363d] rounded-t-[8px]" : "rounded-[8px]")" @onclick='() => ToggleModule("FlightModes")'>
                <i class="bi bi-toggles"></i>
                <span>FLIGHT MODES</span>
                <div class="flex-1"></div>
                <i class="bi @(expandedModules["FlightModes"] ? "bi-chevron-up text-[#58a6ff] rotate-180" : "bi-chevron-down text-[#555]") text-[0.75rem] shrink-0 transition-all duration-200"></i>
            </div>
            @if (expandedModules["FlightModes"])
            {
                <div class="p-[14px_16px_16px] flex flex-col gap-[12px] @(AnyModuleExpanded ? "flex-1 overflow-y-auto no-scrollbar" : "max-h-[400px] overflow-y-auto no-scrollbar")">
                    <div class="flex items-center justify-between gap-[10px] p-[8px_12px] bg-[rgba(0,242,255,0.04)] border border-[rgba(0,242,255,0.15)] rounded-[6px] mb-[4px]">
                        <div class="flex items-center gap-[6px] bg-[rgba(0,212,255,0.08)] border border-[rgba(0,212,255,0.3)] rounded-[4px] p-[3px_10px]">
                            <span class="text-[0.55rem] text-[#8b949e] tracking-[1px]">ACTIVE</span>
                            <span class="text-[0.7rem] font-extrabold text-[#00d4ff] tracking-[1px]">@Drone.State.FlightMode</span>
                        </div>
                        <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer ml-auto hover:brightness-110 transition-all" @onclick="SyncFlightModes">WRITE TO FC</button>
                    </div>

                    <div class="flex items-center gap-[10px] mb-[14px] p-[8px_12px] bg-[rgba(255,255,255,0.03)] border border-[#30363d] rounded-[6px]">
                        <span class="text-[0.6rem] font-bold text-[#8b949e] tracking-[1px] whitespace-nowrap">MODE CHANNEL</span>
                        <select class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[4px] text-[0.75rem] w-[100px] outline-none" @bind="flightModeChannel">
                            <option value="5">CH 5</option>
                            <option value="6">CH 6</option>
                            <option value="7">CH 7</option>
                            <option value="8">CH 8</option>
                        </select>
                        <span class="text-[0.58rem] text-[#8b949e] ml-auto">RC channel that controls mode switching</span>
                    </div>

                    <div class="grid grid-cols-2 gap-[8px]">
                        @for (int i = 0; i < 6; i++)
                        {
                            var idx = i;
                            bool isActive = (flightModeSettings[idx] == Drone.State.FlightMode);
                            <div class="bg-[#010409] border rounded-[6px] p-[10px_12px] flex flex-col gap-[6px] transition-colors duration-200 hover:border-[#555] @(isActive ? "border-[#00d4ff] bg-[rgba(0,212,255,0.04)]" : "border-[#30363d]")">
                                <div class="flex items-center justify-between">
                                    <span class="text-[0.58rem] font-bold text-[#8b949e] tracking-[1.5px]">MODE @(idx + 1)</span>
                                    @if (isActive)
                                    {
                                        <span class="text-[0.52rem] font-extrabold text-[#00d4ff] tracking-[1px] animate-[pip-pulse_1.5s_ease-in-out_infinite]">● ACTIVE</span>
                                    }
                                </div>
                                <select class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[5px_8px] text-[0.68rem] w-full outline-none" @bind="flightModeSettings[idx]">
                                    <option value="STABILIZE">STABILIZE</option>
                                    <option value="ACRO">ACRO</option>
                                    <option value="ALT_HOLD">ALT HOLD</option>
                                    <option value="AUTO">AUTO</option>
                                    <option value="GUIDED">GUIDED</option>
                                    <option value="LOITER">LOITER</option>
                                    <option value="RTL">RTL</option>
                                    <option value="CIRCLE">CIRCLE</option>
                                    <option value="LAND">LAND</option>
                                    <option value="DRIFT">DRIFT</option>
                                    <option value="SPORT">SPORT</option>
                                    <option value="FLIP">FLIP</option>
                                    <option value="AUTOTUNE">AUTOTUNE</option>
                                    <option value="POSHOLD">POS HOLD</option>
                                    <option value="BRAKE">BRAKE</option>
                                    <option value="THROW">THROW</option>
                                    <option value="SMART_RTL">SMART RTL</option>
                                    <option value="FLOWHOLD">FLOW HOLD</option>
                                    <option value="FOLLOW">FOLLOW</option>
                                    <option value="ZIGZAG">ZIGZAG</option>
                                    <option value="SYSTEMID">SYSTEM ID</option>
                                    <option value="AUTOROTATE">AUTOROTATE</option>
                                    <option value="AUTO_RTL">AUTO RTL</option>
                                    <option value="TURTLE">TURTLE</option>
                                </select>
                                <div class="text-[0.56rem] text-[#8b949e] leading-[1.3] min-h-[24px]">@GetFlightModeDesc(flightModeSettings[idx])</div>
                            </div>
                        }
                    </div>

                    <div class="mt-[10px] p-[8px_12px] bg-[rgba(255,255,255,0.02)] border border-[#30363d] rounded-[5px] text-[0.58rem] text-[#8b949e] flex items-center gap-[7px]">
                        <i class="bi bi-info-circle"></i>
                        Modes 1–6 map to RC switch positions. Mode 1 = lowest PWM, Mode 6 = highest.
                    </div>
                </div>
            }
        </div>

        @* ── MOTOR TEST MODULE ── *@
        <div class="bg-[#161b22] border border-[#30363d] rounded-[8px] flex flex-col w-full transition-colors duration-200 min-w-0 hover:border-[#58a6ff] @(expandedModules["MotorTest"] ? (AnyModuleExpanded ? "flex-1 flex-col min-h-0 col-auto" : "col-span-full") : (AnyModuleExpanded ? "hidden" : "flex-col"))">
            <div class="p-[14px_16px] flex items-center gap-[8px] font-extrabold text-[0.7rem] uppercase cursor-pointer select-none transition-all duration-200 min-h-[58px] hover:bg-[rgba(255,255,255,0.03)] @(expandedModules["MotorTest"] ? "border-b border-[#30363d] rounded-t-[8px]" : "rounded-[8px]")" @onclick='() => ToggleModule("MotorTest")'>
                <i class="bi bi-cpu"></i>
                <span>MOTOR TEST (@Drone.State.MotorCount MOTORS DETECTED)</span>
                <div class="flex-1"></div>
                <i class="bi @(expandedModules["MotorTest"] ? "bi-chevron-up text-[#58a6ff] rotate-180" : "bi-chevron-down text-[#555]") text-[0.75rem] shrink-0 transition-all duration-200"></i>
            </div>
            @if (expandedModules["MotorTest"])
            {
                <div class="p-[14px_16px_16px] flex flex-col gap-[12px] @(AnyModuleExpanded ? "flex-1 overflow-y-auto no-scrollbar" : "max-h-[400px] overflow-y-auto no-scrollbar")">
                    <div class="flex gap-[20px] items-center">
                        <div class="flex items-center gap-[8px]">
                            <label class="text-[0.65rem] text-[#8b949e] font-extrabold">THROTTLE %</label>
                            <input type="number" class="bg-[#010409] text-[#58a6ff] border border-[#30363d] w-[50px] p-[4px] rounded-[4px] font-mono font-bold text-center outline-none transition-colors duration-200 focus:border-[#58a6ff]" @bind="motorTestThrottle" min="0" max="100" />
                        </div>
                        <div class="flex items-center gap-[8px]">
                            <label class="text-[0.65rem] text-[#8b949e] font-extrabold">DURATION (S)</label>
                            <input type="number" class="bg-[#010409] text-[#58a6ff] border border-[#30363d] w-[50px] p-[4px] rounded-[4px] font-mono font-bold text-center outline-none transition-colors duration-200 focus:border-[#58a6ff]" @bind="motorTestDuration" min="1" max="15" />
                        </div>
                        <div class="flex gap-[30px] text-[0.7rem] text-[#58a6ff] m-[5px_0_10px_0] font-extrabold ml-auto">
                            <span>FRAME: @currentType</span>
                        </div>
                    </div>

                    <div class="grid grid-cols-[repeat(auto-fill,minmax(80px,1fr))] gap-[10px] mb-[15px]">
                        @for (int i = 1; i <= Drone.State.MotorCount; i++)
                        {
                            int motorId = i;
                            <button class="bg-[#161b22] border border-[#30363d] text-[#58a6ff] p-[10px] rounded-[4px] font-bold cursor-pointer transition-all duration-200 hover:bg-[#58a6ff] hover:text-black hover:border-white active:bg-[#238636] active:border-[#2ea043]" @onclick="() => Drone.TestMotor(motorId, motorTestThrottle, motorTestDuration)">
                                MOTOR @motorId
                            </button>
                        }
                    </div>

                    <div class="grid grid-cols-3 gap-[10px] mt-[15px] border-t border-dashed border-[#30363d] pt-[15px]">
                        <button class="h-[32px] flex items-center justify-center text-[0.65rem] font-extrabold rounded-[4px] cursor-pointer uppercase transition-all duration-200 bg-[#21262d] border border-[#30363d] text-[#58a6ff] hover:bg-[#58a6ff] hover:text-black text-center" @onclick="() => Drone.TestAllMotors((float)motorTestThrottle, (float)motorTestDuration)">TEST ALL MOTORS</button>
                        <button class="h-[32px] flex items-center justify-center text-[0.65rem] font-extrabold rounded-[4px] cursor-pointer uppercase transition-all duration-200 bg-[#21262d] border border-[#30363d] text-[#58a6ff] hover:bg-[#58a6ff] hover:text-black text-center" @onclick="() => Drone.TestMotorSequence((float)motorTestThrottle, (float)motorTestDuration)">RUN SEQUENCE</button>
                        <button class="h-[32px] flex items-center justify-center text-[0.65rem] font-extrabold rounded-[4px] cursor-pointer uppercase transition-all duration-200 bg-[rgba(255,58,58,0.1)] border border-[#ff3a3a] text-[#ff3a3a] hover:bg-[#ff3a3a] hover:text-white text-center" @onclick="StopAllMotors">ABORT ALL</button>
                    </div>

                    <p class="text-[0.55rem] text-center text-[#8b949e] mt-[10px] font-bold">CAUTION: PROPELLERS MUST BE REMOVED BEFORE TESTING</p>
                </div>
            }
        </div>

        @* ── ESC CALIBRATION MODULE ── *@
        <div class="bg-[#161b22] border border-[#30363d] rounded-[8px] flex flex-col w-full transition-colors duration-200 min-w-0 hover:border-[#58a6ff] @(expandedModules["ESC"] ? (AnyModuleExpanded ? "flex-1 flex-col min-h-0 col-auto" : "col-span-full") : (AnyModuleExpanded ? "hidden" : "flex-col"))">
            <div class="p-[14px_16px] flex items-center gap-[8px] font-extrabold text-[0.7rem] uppercase cursor-pointer select-none transition-all duration-200 min-h-[58px] hover:bg-[rgba(255,255,255,0.03)] @(expandedModules["ESC"] ? "border-b border-[#30363d] rounded-t-[8px]" : "rounded-[8px]")" @onclick='() => ToggleModule("ESC")'>
                <i class="bi bi-lightning-charge"></i>
                <span>ESC CALIBRATION</span>
                <div class="flex-1"></div>
                <i class="bi @(expandedModules["ESC"] ? "bi-chevron-up text-[#58a6ff] rotate-180" : "bi-chevron-down text-[#555]") text-[0.75rem] shrink-0 transition-all duration-200"></i>
            </div>
            @if (expandedModules["ESC"])
            {
                <div class="p-[14px_16px_16px] flex flex-col gap-[12px] @(AnyModuleExpanded ? "flex-1 overflow-y-auto no-scrollbar" : "max-h-[400px] overflow-y-auto no-scrollbar")">
                    @if (escCalStep == 0)
                    {
                        <div class="flex items-center justify-between gap-[10px] p-[8px_12px] bg-[rgba(0,242,255,0.04)] border border-[rgba(0,242,255,0.15)] rounded-[6px] mb-[4px]">
                            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed ml-auto" @onclick="EscCalStart">BEGIN CALIBRATION</button>
                        </div>
                    }
                    else if (escCalStep < 5)
                    {
                        <div class="flex items-center justify-between gap-[10px] p-[8px_12px] bg-[rgba(0,242,255,0.04)] border border-[rgba(0,242,255,0.15)] rounded-[6px] mb-[4px]">
                            <button class="bg-[rgba(255,58,58,0.1)] border border-[#ff3a3a] text-[#ff3a3a] p-[5px_14px] text-[0.65rem] font-bold rounded-[4px] cursor-pointer tracking-[1px] transition-all duration-150 hover:bg-[#ff3a3a] hover:text-white" @onclick="EscCalAbort">ABORT</button>
                        </div>
                    }

                    @if (escCalStep == 0)
                    {
                        <div class="mb-[14px]">
                            <div class="text-[0.6rem] font-bold text-[#8b949e] tracking-[1.5px] mb-[8px]">CALIBRATION METHOD</div>
                            <div class="flex flex-col gap-[8px]">
                                <div class="bg-[#010409] border rounded-[6px] p-[10px_14px] cursor-pointer transition-all duration-200 @(escCalMethod == 0 ? "border-[#58a6ff] bg-[rgba(0,242,255,0.06)]" : "border-[#30363d] hover:border-[#555]")" @onclick="() => escCalMethod = 0">
                                    <div class="text-[0.68rem] font-extrabold text-[#c9d1d9] tracking-[0.5px] mb-[4px] flex items-center gap-[6px]">
                                        <i class="bi bi-magic"></i> AUTO (RECOMMENDED)
                                    </div>
                                    <div class="text-[0.6rem] text-[#8b949e] leading-[1.4]">FC sends full-throttle signal on next boot. Connect battery to start ESC calibration sequence automatically. Works with most ESCs.</div>
                                </div>
                                <div class="bg-[#010409] border rounded-[6px] p-[10px_14px] cursor-pointer transition-all duration-200 @(escCalMethod == 1 ? "border-[#58a6ff] bg-[rgba(0,242,255,0.06)]" : "border-[#30363d] hover:border-[#555]")" @onclick="() => escCalMethod = 1">
                                    <div class="text-[0.68rem] font-extrabold text-[#c9d1d9] tracking-[0.5px] mb-[4px] flex items-center gap-[6px]">
                                        <i class="bi bi-sliders"></i> MANUAL (PASSTHROUGH)
                                    </div>
                                    <div class="text-[0.6rem] text-[#8b949e] leading-[1.4]">FC passes RC throttle directly to ESCs. Move your TX throttle stick from max to min during calibration. Use if Auto method fails.</div>
                                </div>
                            </div>
                        </div>
                        <div class="bg-[rgba(255,165,0,0.05)] border border-[rgba(230,168,23,0.3)] rounded-[6px] p-[10px_14px] mt-[10px]">
                            <div class="text-[0.62rem] font-bold text-[#58a6ff] tracking-[1px] mb-[6px] flex items-center gap-[6px]"><i class="bi bi-exclamation-triangle-fill text-[#58a6ff]"></i> BEFORE YOU BEGIN</div>
                            <ul class="m-0 pl-[16px] text-[0.6rem] text-[#c9d1d9] leading-[1.8]">
                                <li>Remove all propellers</li>
                                <li>Vehicle must be DISARMED</li>
                                <li>Connect USB but NOT battery</li>
                                @if (escCalMethod == 1)
                                {
                                    <li>TX throttle stick at maximum position</li>
                                    <li>Verify RC calibration is complete</li>
                                }
                            </ul>
                        </div>
                    }

                    @if (escCalStep > 0)
                    {
                        <div class="flex flex-col gap-[16px]">
                            <div class="flex items-center justify-center gap-0 p-[4px_0]">
                                @{
                                    int totalSteps = escCalMethod == 0 ? 4 : 5;
                                }
                                @for (int st = 1; st <= totalSteps; st++)
                                {
                                    var stepNum = st;
                                    <div class="w-[28px] h-[28px] rounded-full flex items-center justify-center text-[0.62rem] font-extrabold border-[2px] bg-[#161b22] shrink-0 transition-all duration-300 z-10 @(escCalStep == stepNum ? "border-[#58a6ff] bg-[rgba(0,242,255,0.15)] text-[#58a6ff] shadow-[0_0_10px_rgba(0,242,255,0.3)]" : escCalStep > stepNum ? "border-[#58a6ff] bg-[rgba(0,212,255,0.15)] text-[#58a6ff]" : "border-[#30363d] text-[#8b949e] opacity-40")">
                                        @if (escCalStep > stepNum)
                                        {
                                            <i class="bi bi-check-lg"></i>
                                        }
                                        else
                                        {

                                            @stepNum
                                        }
                                    </div>
                                    @if (stepNum < totalSteps)
                                    {
                                        <div class="flex-1 h-[2px] bg-[#30363d] transition-colors duration-300 @(escCalStep > stepNum ? "!bg-[#58a6ff]" : "")"></div>
                                    }
                                }
                            </div>

                            <div class="bg-[#010409] border border-[#30363d] rounded-[8px] p-[20px] flex flex-col items-center gap-[10px] text-center">
                                @if (escCalMethod == 0)
                                {
                                    @switch (escCalStep)
                                    {
                                        case 1:
                                            <div class="text-[2rem] leading-none text-[#58a6ff]"><i class="bi bi-lightning-charge-fill"></i></div>
                                            <div class="text-[0.75rem] font-extrabold tracking-[1.5px] text-[#c9d1d9]">WRITE CALIBRATION FLAG</div>
                                            <div class="text-[0.65rem] text-[#8b949e] leading-[1.5] max-w-[340px] [&>code]:bg-[rgba(255,255,255,0.07)] [&>code]:rounded-[3px] [&>code]:p-[1px_5px] [&>code]:text-[0.62rem] [&>code]:text-[#58a6ff]">Sending <code>ESC_CALIBRATION = 3</code> to flight controller. On next boot, the FC will output full-throttle PWM to all ESCs.</div>
                                            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed" @onclick="EscCalAutoStep1">WRITE PARAMETER →</button>
                                            break;
                                        case 2:
                                            <div class="text-[2rem] leading-none text-[#58a6ff]"><i class="bi bi-plug-fill"></i></div>
                                            <div class="text-[0.75rem] font-extrabold tracking-[1.5px] text-[#c9d1d9]">DISCONNECT POWER</div>
                                            <div class="text-[0.65rem] text-[#8b949e] leading-[1.5] max-w-[340px]">Parameter written. Now <strong>disconnect USB cable</strong> and <strong>disconnect the battery</strong> completely. Wait 5 seconds for capacitors to discharge.</div>
                                            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed ml-auto" @onclick="() => escCalStep = 3">I'VE DISCONNECTED →</button>
                                            break;
                                        case 3:
                                            <div class="text-[2rem] leading-none text-[#58a6ff]"><i class="bi bi-battery-charging"></i></div>
                                            <div class="text-[0.75rem] font-extrabold tracking-[1.5px] text-[#c9d1d9]">CONNECT BATTERY</div>
                                            <div class="text-[0.65rem] text-[#8b949e] leading-[1.5] max-w-[340px]">Connect the <strong>battery only</strong> (not USB yet). ESCs will beep to confirm they received the full-throttle signal. Wait for beeps to complete.</div>
                                            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed ml-auto" @onclick="() => escCalStep = 4">ESCs BEEPED →</button>
                                            break;
                                        case 4:
                                            <div class="text-[2rem] leading-none text-[#3fb950]"><i class="bi bi-check-circle-fill"></i></div>
                                            <div class="text-[0.75rem] font-extrabold tracking-[1.5px] text-[#c9d1d9]">CALIBRATION COMPLETE</div>
                                            <div class="text-[0.65rem] text-[#8b949e] leading-[1.5] max-w-[340px] [&>code]:bg-[rgba(255,255,255,0.07)] [&>code]:rounded-[3px] [&>code]:p-[1px_5px] [&>code]:text-[0.62rem] [&>code]:text-[#58a6ff]">ESC endpoints have been set. Reconnect USB. The <code>ESC_CALIBRATION</code> parameter automatically resets to 0 after a successful calibration.</div>
                                            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed ml-auto" @onclick="EscCalDone">FINISH</button>
                                            break;
                                    }
                                }
                                else
                                {
                                    @switch (escCalStep)
                                    {
                                        case 1:
                                            <div class="text-[2rem] leading-none text-[#58a6ff]"><i class="bi bi-arrow-up-circle-fill"></i></div>
                                            <div class="text-[0.75rem] font-extrabold tracking-[1.5px] text-[#c9d1d9]">THROTTLE TO MAXIMUM</div>
                                            <div class="text-[0.65rem] text-[#8b949e] leading-[1.5] max-w-[340px]">Move your transmitter <strong>throttle stick to full maximum</strong>. Keep it there until instructed.</div>
                                            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed" @onclick="EscCalManualStep1">THROTTLE IS MAX →</button>
                                            break;
                                        case 2:
                                            <div class="text-[2rem] leading-none text-[#58a6ff]"><i class="bi bi-plug-fill"></i></div>
                                            <div class="text-[0.75rem] font-extrabold tracking-[1.5px] text-[#c9d1d9]">ENABLE PASSTHROUGH</div>
                                            <div class="text-[0.65rem] text-[#8b949e] leading-[1.5] max-w-[340px]">Passthrough mode active — FC is now relaying RC throttle directly to all ESCs. <strong>Connect the battery now.</strong> ESCs will beep acknowledging full throttle.</div>
                                            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed ml-auto" @onclick="() => escCalStep = 3">ESCs BEEPED →</button>
                                            break;
                                        case 3:
                                            <div class="text-[2rem] leading-none text-[#58a6ff]"><i class="bi bi-arrow-down-circle-fill"></i></div>
                                            <div class="text-[0.75rem] font-extrabold tracking-[1.5px] text-[#c9d1d9]">THROTTLE TO MINIMUM</div>
                                            <div class="text-[0.65rem] text-[#8b949e] leading-[1.5] max-w-[340px]">Move your transmitter <strong>throttle stick to full minimum (zero)</strong>. ESCs will beep again to confirm the low endpoint is set.</div>
                                            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed ml-auto" @onclick="() => escCalStep = 4">ESCs BEEPED →</button>
                                            break;
                                        case 4:
                                            <div class="text-[2rem] leading-none text-[#58a6ff]"><i class="bi bi-power"></i></div>
                                            <div class="text-[0.75rem] font-extrabold tracking-[1.5px] text-[#c9d1d9]">DISABLE PASSTHROUGH</div>
                                            <div class="text-[0.65rem] text-[#8b949e] leading-[1.5] max-w-[340px]">Disabling passthrough mode. Disconnect battery and wait 5 seconds before reconnecting.</div>
                                            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed" @onclick="EscCalManualStep4">DISABLE PASSTHROUGH →</button>
                                            break;
                                        case 5:
                                            <div class="text-[2rem] leading-none text-[#3fb950]"><i class="bi bi-check-circle-fill"></i></div>
                                            <div class="text-[0.75rem] font-extrabold tracking-[1.5px] text-[#c9d1d9]">CALIBRATION COMPLETE</div>
                                            <div class="text-[0.65rem] text-[#8b949e] leading-[1.5] max-w-[340px]">All ESC endpoints have been set. Your ESCs are now calibrated to your transmitter's throttle range.</div>
                                            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed ml-auto" @onclick="EscCalDone">FINISH</button>
                                            break;
                                    }
                                }
                            </div>
                        </div>
                    }

                    @if (escCalStep == 99)
                    {
                        <div class="flex items-center justify-center gap-[10px] p-[14px] bg-[rgba(63,185,80,0.08)] border border-[rgba(63,185,80,0.4)] rounded-[6px] text-[0.65rem] font-bold text-[#3fb950] tracking-[0.5px]">
                            <i class="bi bi-check-circle-fill"></i>
                            ESC CALIBRATION COMPLETE — All endpoints saved
                            <button class="bg-transparent border-none text-[#58a6ff] text-[0.62rem] cursor-pointer underline p-0 font-inherit" @onclick="() => escCalStep = 0">Recalibrate</button>
                        </div>
                    }
                </div>
            }
        </div>

        @* ── FAILSAFES MODULE ── *@
        <div class="bg-[#161b22] border border-[#30363d] rounded-[8px] flex flex-col w-full transition-colors duration-200 min-w-0 hover:border-[#58a6ff] @(expandedModules["Failsafe"] ? (AnyModuleExpanded ? "flex-1 flex-col min-h-0 col-auto" : "col-span-full") : (AnyModuleExpanded ? "hidden" : "flex-col"))">
            <div class="p-[14px_16px] flex items-center gap-[8px] font-extrabold text-[0.7rem] uppercase cursor-pointer select-none transition-all duration-200 min-h-[58px] hover:bg-[rgba(255,255,255,0.03)] @(expandedModules["Failsafe"] ? "border-b border-[#30363d] rounded-t-[8px]" : "rounded-[8px]")" @onclick='() => ToggleModule("Failsafe")'>
                <i class="bi bi-exclamation-triangle"></i>
                <span>SAFETY FAILSAFES</span>
                <div class="flex-1"></div>
                <i class="bi @(expandedModules["Failsafe"] ? "bi-chevron-up text-[#58a6ff] rotate-180" : "bi-chevron-down text-[#555]") text-[0.75rem] shrink-0 transition-all duration-200"></i>
            </div>
            @if (expandedModules["Failsafe"])
            {
                <div class="p-[14px_16px_16px] flex flex-col gap-[12px] @(AnyModuleExpanded ? "flex-1 overflow-y-auto no-scrollbar" : "max-h-[400px] overflow-y-auto no-scrollbar")">
                    <div class="flex items-center justify-between gap-[10px] p-[8px_12px] bg-[rgba(0,242,255,0.04)] border border-[rgba(0,242,255,0.15)] rounded-[6px] mb-[4px]">
                        <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer transition-all hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed" @onclick="SaveFailsafes" disabled="@(!Drone.IsLinkHealthy)">SAVE ALL</button>
                    </div>
                    @if (!_fsParamsLoaded && Drone.IsLinkHealthy)
                    {
                        <div class="text-[0.75rem] text-[#555] p-[8px_0] flex items-center mb-[8px]">
                            <span>⏳ Reading from FC...</span>
                            <button class="bg-[#010409] border border-[#30363d] text-[#8b949e] p-[3px_9px] rounded-[4px] text-[0.62rem] cursor-pointer transition-all hover:border-[#58a6ff] hover:text-[#58a6ff] ml-[8px]" @onclick="RefreshFailsafeParams">↺ Re-read</button>
                        </div>
                    }
                    else if (!_fsParamsLoaded)
                    {
                        <div class="text-[0.75rem] text-[#555] p-[8px_0] flex items-center mb-[8px]">
                            <span class="text-[#555]">⚠️ Not connected — showing defaults. Connect to read actual FC values.</span>
                        </div>
                    }

                    <div class="text-[0.6rem] font-extrabold tracking-[1px] text-[#d29922] mt-[8px] mb-[4px] border-b border-[#1c2128] pb-[3px]">📡 RC SIGNAL LOSS <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(FS_THR_ENABLE)</span></div>
                    <div class="text-[0.67rem] text-[#555] mb-[5px] leading-[1.4]">Action when RC transmitter signal is lost for &gt;1 second.</div>
                    <select class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[8px]" @bind="rcLossAction">
                        <option value="0">Disabled (not recommended)</option>
                        <option value="1">Always RTL</option>
                        <option value="2">Continue if Auto, else RTL</option>
                        <option value="3">Always Land</option>
                        <option value="4">SmartRTL, else RTL</option>
                        <option value="5">SmartRTL, else Land</option>
                    </select>
                    <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px]">PWM THRESHOLD <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(FS_THR_VALUE)</span></label>
                    <div class="flex gap-[8px] items-center mt-[6px] mb-[8px]">
                        <input type="number" class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-[88px] outline-none" @bind="rcThrValue" min="900" max="1100" step="5" />
                        <span class="text-[0.67rem] text-[#555]">µs · RC below this = lost · default 975</span>
                    </div>
                    @if (rcThrValue < 925 || rcThrValue > 1025)
                    {
                        <div class="bg-[rgba(240,180,41,0.08)] border border-[rgba(240,180,41,0.3)] rounded-[5px] p-[5px_10px] text-[0.7rem] text-[#f0b429] m-[3px_0_6px]">⚠️ Unusual — standard range is 925–1025 µs</div>
                    }

                    <div class="text-[0.6rem] font-extrabold tracking-[1px] text-[#d29922] mt-[12px] mb-[4px] border-b border-[#1c2128] pb-[3px]">🔋 BATTERY FAILSAFE <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(FS_BATT_ENABLE)</span></div>
                    <div class="text-[0.67rem] text-[#555] mb-[5px] leading-[1.4]">Action when voltage/mAh consumed crosses the threshold set in Battery Monitor.</div>
                    <select class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[8px]" @bind="lowBattAction">
                        <option value="0">Disabled</option>
                        <option value="1">Land immediately</option>
                        <option value="2">RTL</option>
                        <option value="3">SmartRTL, else RTL</option>
                        <option value="4">SmartRTL, else Land</option>
                        <option value="5">Terminate motors ⚠️</option>
                    </select>

                    <div class="text-[0.6rem] font-extrabold tracking-[1px] text-[#d29922] mt-[12px] mb-[4px] border-b border-[#1c2128] pb-[3px]">🖥️ GCS HEARTBEAT LOSS <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(FS_GCS_ENABLE)</span></div>
                    <div class="text-[0.67rem] text-[#555] mb-[5px] leading-[1.4]">Action when this GCS stops sending heartbeats for &gt;5 seconds (laptop crash, cable disconnect).</div>
                    <select class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[8px]" @bind="gcsLossAction">
                        <option value="0">Disabled</option>
                        <option value="1">RTL</option>
                        <option value="2">Continue mission (if in Auto)</option>
                        <option value="3">SmartRTL, else RTL</option>
                        <option value="4">SmartRTL, else Land</option>
                    </select>

                    <div class="flex gap-[5px] flex-wrap mt-[8px] pt-[8px] border-t border-[#1c2128]">
                        <div class="text-[0.58rem] font-extrabold letter-spacing-[0.5px] p-[3px_7px] rounded-[4px] border @(int.Parse(rcLossAction) > 0 ? "bg-[rgba(46,160,67,0.12)] border-[#2ea043] text-[#3fb950]" : "bg-[rgba(60,60,60,0.15)] border-[#444] text-[#666]")">📡 RC: @FsRcLbl(rcLossAction)</div>
                        <div class="text-[0.58rem] font-extrabold letter-spacing-[0.5px] p-[3px_7px] rounded-[4px] border @(int.Parse(lowBattAction) > 0 ? "bg-[rgba(46,160,67,0.12)] border-[#2ea043] text-[#3fb950]" : "bg-[rgba(60,60,60,0.15)] border-[#444] text-[#666]")">🔋 BATT: @FsBattLbl(lowBattAction)</div>
                        <div class="text-[0.58rem] font-extrabold letter-spacing-[0.5px] p-[3px_7px] rounded-[4px] border @(int.Parse(gcsLossAction) > 0 ? "bg-[rgba(46,160,67,0.12)] border-[#2ea043] text-[#3fb950]" : "bg-[rgba(60,60,60,0.15)] border-[#444] text-[#666]")">🖥️ GCS: @FsGcsLbl(gcsLossAction)</div>
                    </div>
                </div>
            }
        </div>

        @* ── BATTERY MONITOR MODULE ── *@
        <div class="bg-[#161b22] border border-[#30363d] rounded-[8px] flex flex-col w-full transition-colors duration-200 min-w-0 hover:border-[#58a6ff] @(expandedModules["Battery"] ? (AnyModuleExpanded ? "flex-1 flex-col min-h-0 col-auto" : "col-span-full") : (AnyModuleExpanded ? "hidden" : "flex-col"))">
            <div class="p-[14px_16px] flex items-center gap-[8px] font-extrabold text-[0.7rem] uppercase cursor-pointer select-none transition-all duration-200 min-h-[58px] hover:bg-[rgba(255,255,255,0.03)] @(expandedModules["Battery"] ? "border-b border-[#30363d] rounded-t-[8px]" : "rounded-[8px]")" @onclick='() => ToggleModule("Battery")'>
                <i class="bi bi-battery-half"></i>
                <span>BATTERY MONITOR</span>
                <div class="flex-1"></div>
                <i class="bi @(expandedModules["Battery"] ? "bi-chevron-up text-[#58a6ff] rotate-180" : "bi-chevron-down text-[#555]") text-[0.75rem] shrink-0 transition-all duration-200"></i>
            </div>
            @if (expandedModules["Battery"])
            {
                <div class="p-[14px_16px_16px] flex flex-col gap-[12px] @(AnyModuleExpanded ? "flex-1 overflow-y-auto no-scrollbar" : "max-h-[400px] overflow-y-auto no-scrollbar")">
                    @if (_battParamsLoaded)
                    {
                        <div class="flex items-center justify-between gap-[10px] p-[8px_12px] bg-[rgba(0,242,255,0.04)] border border-[rgba(0,242,255,0.15)] rounded-[6px] mb-[4px]">
                            <button class="bg-[#58a6ff] text-black border-none py-[6px] px-[12px] rounded-[4px] text-[0.65rem] font-extrabold cursor-pointer ml-auto hover:brightness-110 disabled:opacity-35 disabled:cursor-not-allowed" @onclick="SaveBatterySettings">SAVE PARAMS</button>
                        </div>
                    }
                    @if (Drone.IsLinkHealthy)
                    {
                        <div class="flex gap-[12px] flex-wrap mb-[8px]">
                            <div class="flex-1 bg-[#010409] p-[10px] rounded-[6px] border border-[#30363d]"><label class="block text-[0.55rem] text-[#8b949e] mb-[4px] font-extrabold">VOLTAGE</label><div class="text-[0.8rem] font-extrabold text-[#58a6ff] @BVC">@Drone.State.Voltage.ToString("0.00") V</div></div>
                            <div class="flex-1 bg-[#010409] p-[10px] rounded-[6px] border border-[#30363d]"><label class="block text-[0.55rem] text-[#8b949e] mb-[4px] font-extrabold">CURRENT</label><div class="text-[0.8rem] font-extrabold text-[#58a6ff]">@Drone.State.CurrentDraw.ToString("0.0") A</div></div>
                            <div class="flex-1 bg-[#010409] p-[10px] rounded-[6px] border border-[#30363d]"><label class="block text-[0.55rem] text-[#8b949e] mb-[4px] font-extrabold">REMAINING</label><div class="text-[0.8rem] font-extrabold text-[#58a6ff] @BPC">@Drone.State.BatteryPercent.ToString("0") %</div></div>
                            <div class="flex-1 bg-[#010409] p-[10px] rounded-[6px] border border-[#30363d]"><label class="block text-[0.55rem] text-[#8b949e] mb-[4px] font-extrabold">CELL V</label><div class="text-[0.8rem] font-extrabold text-[#58a6ff] @BCC">@(_battNumCells > 0 && Drone.State.Voltage > 0 ? (Drone.State.Voltage / _battNumCells).ToString("0.000") + " V" : "—")</div></div>
                        </div>
                        <div class="flex items-center gap-[8px] mb-[10px]">
                            <div class="flex-1 h-[6px] bg-[#161b22] rounded-[3px] border border-[#30363d] overflow-hidden">
                                <div class="h-full rounded-[3px] transition-[width] duration-500 @(BPC == "bv-c" ? "bg-[#ff6b6b]" : BPC == "bv-l" ? "bg-[#f0b429]" : "bg-[#3fb950]")" style="width:@Math.Max(0, Math.Min(100, (double)Drone.State.BatteryPercent))%;"></div>
                            </div>
                            <span class="text-[0.67rem] text-[#555]">@Drone.State.BatteryPercent.ToString("0")%</span>
                        </div>
                    }
                    @if (!_battParamsLoaded)
                    {
                        <div class="text-[0.75rem] text-[#555] p-[8px_0] flex items-center">
                            @if (!Drone.IsLinkHealthy)
                            {
                                <span>🔌 Connect to load</span>
                            }
                            else
                            {
                                <span>⏳ Loading...</span>
                                <button class="bg-[#010409] border border-[#30363d] text-[#8b949e] p-[3px_9px] rounded-[4px] text-[0.62rem] cursor-pointer transition-all hover:border-[#58a6ff] hover:text-[#58a6ff] ml-[8px]" @onclick="RefreshBatteryParams">↺ Re-read</button>
                            }
                        </div>
                    }
                    else
                    {
                        <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px]">MONITOR TYPE <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(BATT_MONITOR)</span></label>
                        <select class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[6px]" @bind="battMonitorType">
                            <option value="0">Disabled</option>
                            <option value="3">Analog Voltage Only</option>
                            <option value="4">Analog Voltage + Current (Pixhawk PM)</option>
                            <option value="7">UAVCAN BatteryInfo</option>
                            <option value="8">BLHeli ESC</option>
                            <option value="9">Sum of all ESCs</option>
                        </select>
                        <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px] mt-[6px]">CELL COUNT <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(BATT_NUM_CELLS)</span></label>
                        <div class="flex gap-[8px] items-center mb-[6px]">
                            <input type="number" class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-[70px] outline-none" @bind="_battNumCells" min="1" max="12" step="1" />
                            @if (_battNumCells > 0)
                            {
                                <span class="text-[0.67rem] text-[#555] font-mono">Full @((_battNumCells * 4.2).ToString("0.0"))V · Low @((_battNumCells * 3.5).ToString("0.0"))V</span>
                            }
                        </div>
                        <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px] mt-[4px]">CAPACITY (mAh) <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(BATT_CAPACITY)</span></label>
                        <input type="number" class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[5px]" @bind="battCapacity" min="100" step="100" />
                        <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px] mt-[5px]">LOW MAH <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(BATT_LOW_MAH)</span> <span class="text-[#555] font-normal">0=off</span></label>
                        <input type="number" class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[5px]" @bind="_battLowMah" min="0" step="100" />

                        <div class="text-[0.6rem] font-extrabold tracking-[1px] text-[#d29922] mt-[8px] mb-[4px] border-b border-[#1c2128] pb-[3px]">⚡ VOLTAGE THRESHOLDS</div>
                        @if (_battNumCells > 0)
                        {
                            <div class="bg-[#010409] border border-[#1c2128] rounded-[5px] p-[8px_10px] mb-[8px] flex flex-col gap-[5px]">
                                @foreach (var (lbl, v, c) in new[] { ("ARM MIN", _battArmVolt, "t-arm"), ("LOW", _battLowVolt, "t-low"), ("CRITICAL", _battCrtVolt, "t-crt") })
                                {
                                    <div class="flex items-center gap-[6px]">
                                        <span class="text-[0.5rem] font-bold text-[#555] w-[52px] text-right shrink-0">@lbl</span>
                                        <span class="text-[0.65rem] font-bold font-mono w-[46px] shrink-0 @c">@v.ToString("0.00")V</span>
                                        <div class="flex-1 h-[5px] bg-[#161b22] rounded-[3px] overflow-hidden"><div class="h-full rounded-[3px] transition-[width] duration-400 @c" style="width:@TBW(v)%;"></div></div>
                                        <span class="text-[0.57rem] font-mono text-[#555] min-w-[64px] text-right shrink-0 @c">@(_battNumCells > 0 && v > 0 ? (v / _battNumCells).ToString("0.00") + "V/c" : "off")</span>
                                    </div>
                                }
                            </div>
                        }
                        <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px]">ARM MIN (V) <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(BATT_ARM_VOLT)</span></label>
                        <input type="number" class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[4px]" @bind="_battArmVolt" min="0" max="60" step="0.1" />
                        <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px] mt-[5px]">LOW VOLTAGE (V) <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(BATT_LOW_VOLT)</span></label>
                        <input type="number" class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[4px]" @bind="_battLowVolt" min="0" max="60" step="0.1" />
                        <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px] mt-[5px]">CRITICAL (V) <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(BATT_CRT_VOLT)</span></label>
                        <input type="number" class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[4px]" @bind="_battCrtVolt" min="0" max="60" step="0.1" />
                        @if (_battCrtVolt > 0 && _battLowVolt > 0 && _battCrtVolt >= _battLowVolt)
                        {
                            <div class="bg-[rgba(240,180,41,0.08)] border border-[rgba(240,180,41,0.3)] rounded-[5px] p-[5px_10px] text-[0.7rem] text-[#f0b429] m-[3px_0_6px]">⚠️ Critical must be lower than Low</div>
                        }

                        <div class="text-[0.6rem] font-extrabold tracking-[1px] text-[#d29922] mt-[8px] mb-[4px] border-b border-[#1c2128] pb-[3px]">🔧 SENSOR CALIBRATION</div>
                        <div class="text-[0.67rem] text-[#555] mb-[5px]">Pixhawk PM: VoltMult=10.1 · A/V=17.0 · Offset=0</div>
                        <div class="flex gap-[5px] flex-wrap mb-[7px]">
                            @foreach (var (lbl, k) in new[] { ("Pixhawk PM", "px"), ("Holybro PM07", "hb"), ("Mauch HS-200", "mu"), ("AttoPilot 180A", "ap") })
                            {
                                <button class="bg-[#010409] border border-[#30363d] text-[#8b949e] p-[3px_9px] rounded-[4px] text-[0.62rem] cursor-pointer transition-all hover:border-[#58a6ff] hover:text-[#58a6ff]" @onclick="() => BattPreset(k)">@lbl</button>
                            }
                        </div>
                        <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px]">VOLT MULT × <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(BATT_VOLT_MULT)</span></label>
                        <input type="number" class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[4px]" @bind="_battVoltMult" min="1" max="30" step="0.01" />
                        <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px] mt-[5px]">AMPS/VOLT <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(BATT_AMP_PERVLT)</span></label>
                        <input type="number" class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none mb-[4px]" @bind="_battAmpPerVlt" min="0" max="200" step="0.1" />
                        <label class="text-[0.6rem] font-extrabold text-[#8b949e] mb-[-10px] mt-[5px]">AMP OFFSET <span class="text-[#555] text-[0.55rem] font-normal font-mono ml-[4px]">(BATT_AMP_OFFSET)</span></label>
                        <input type="number" class="bg-[#010409] text-white border border-[#30363d] rounded-[4px] p-[8px] text-[0.75rem] w-full outline-none" @bind="_battAmpOffset" min="-2" max="2" step="0.01" />
                    }
                </div>
            }
        </div>

    </div>
</div>

