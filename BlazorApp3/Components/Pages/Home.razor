@page "/"
@inject IJSRuntime JS
@inject MavlinkService Drone

<div class="map-wrapper">
    <div id="map-element"></div>

    @* Right Side Telemetry Overlay as seen in image *@
    <div class="side-telemetry">
        <div class="stat-box @(Drone.State.BatteryPercent < 20 ? "low-bat" : "")">
            <div class="icon">@(Drone.State.BatteryPercent > 50 ? "🔋" : "🪫")</div>
            <div class="data">
                <div class="label">Battery</div>
                <div class="val">@Drone.State.BatteryPercent%</div>
            </div>
        </div>

        <div class="stat-box">
            <div class="icon">🚀</div>
            <div class="data">
                <div class="label">Ground Speed</div>
                <div class="val">@Drone.State.GroundSpeed.ToString("0.0") <small>m/s</small></div>
            </div>
        </div>

        <div class="stat-box">
            <div class="icon">🏔️</div>
            <div class="data">
                <div class="label">Altitude</div>
                <div class="val">@Drone.State.Altitude.ToString("0") <small>m</small></div>
            </div>
        </div>
    </div>
</div>

<style>
    .map-wrapper {
        width: 100%;
        height: 100%;
        position: relative;
    }

    #map-element {
        width: 100%;
        height: calc(100vh - 150px); /* Explicit height is MANDATORY */
        min-height: 400px;
        background-color: #0a0b0d;
    }

    .side-telemetry {
        position: absolute;
        top: 120px;
        right: 20px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        z-index: 5;
    }

    .stat-box {
        background: rgba(13, 14, 16, 0.9);
        border: 1px solid #242731;
        border-radius: 8px;
        padding: 10px 15px;
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 140px;
    }

        .stat-box .icon {
            font-size: 1.2rem;
        }

        .stat-box .label {
            font-size: 0.6rem;
            color: #888;
            text-transform: uppercase;
        }

        .stat-box .val {
            font-size: 0.9rem;
            font-weight: bold;
            color: var(--cyan);
        }
</style>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Call the JavaScript function we wrote in App.razor
                // Passing the Drone's current Lat/Lng to center the map
                await JS.InvokeVoidAsync("initMap", Drone.State.Latitude, Drone.State.Longitude);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Map Error: {ex.Message}");
            }
        }
    }
}