@page "/"
@inject IJSRuntime JS
@inject MavlinkService Drone
@inject IConfiguration Config
@implements IDisposable

@* 1. The Dynamic Map Container *@
<div class="@GetMapClasses()" @onclick="HandleMapClick">
    <div id="map-element" class="w-full h-full bg-[#0a0b0d]"></div>
</div>

@* Only keep the Coordinate Log and Fullscreen toggle *@
<div id="map-coord-log" class="fixed bottom-[30px] left-[12px] z-[10] bg-[rgba(10,11,13,0.85)] backdrop-blur-md border border-[#30363d] rounded-[5px] px-[10px] py-[5px] text-[0.62rem] font-mono text-[#00f2ff] pointer-events-none leading-[1.6]">
    LAT: —<br>LNG: —
</div>

<button class="fixed top-[72px] left-[12px] z-[10] w-[34px] h-[34px] pointer-events-auto bg-[rgba(10,11,13,0.85)] backdrop-blur-md border rounded-[6px] text-[0.95rem] cursor-pointer flex items-center justify-center transition-all duration-150 hover:bg-[#161b22] hover:text-[#00f2ff] hover:border-[#58a6ff] @(_mapExpanded ? "border-[#f0b429] text-[#f0b429]" : "border-[#30363d] text-[#58a6ff]")"
        @onclick="ToggleExpand">
    <i class="bi @(_mapExpanded ? "bi-fullscreen-exit" : "bi-fullscreen")"></i>
</button>

@* Right Side Telemetry Overlay (Transparent Clean Glass) *@
<div class="fixed top-[calc(var(--header-height)+12px)] right-[16px] flex flex-col gap-[10px] z-[10] pointer-events-none">
    @{
        // High transparency (0.3 opacity) with a subtle blur and a faint white edge
        var statBoxBase = "pointer-events-auto bg-[rgba(10,11,13,0.3)] border border-[rgba(255,255,255,0.15)] rounded-[12px] px-[14px] py-[10px] flex items-center gap-[12px] w-[170px] backdrop-blur-sm shadow-lg transition-all duration-300";

        // Drop-shadows added to the text so it pops against the transparent background
        var statLabel = "text-[0.55rem] text-[#a1aab5] uppercase tracking-[1px] font-bold whitespace-nowrap mb-[2px] drop-shadow-md";
        var statVal = "text-[0.9rem] font-black text-white whitespace-nowrap drop-shadow-md";
        var statSmall = "text-[0.65rem] text-[#00f2ff] font-bold ml-[3px] drop-shadow-md";
    }

    @* Battery Stat Box *@
    <div class="@statBoxBase">
        <div class="text-[1.2rem] shrink-0 drop-shadow-lg">@(Drone.State.BatteryPercent > 20 ? "🔋" : "🪫")</div>
        <div class="flex flex-col min-w-0">
            <div class="@statLabel">Battery</div>
            <div class="@statVal @(Drone.State.BatteryPercent < 20 ? "!text-[#ff3a3a]" : "")">
                @Drone.State.BatteryPercent% <small class="@statSmall">@Drone.State.Voltage.ToString("0.0")V</small>
            </div>
        </div>
    </div>

    @* Ground Speed Stat Box *@
    <div class="@statBoxBase">
        <div class="text-[1.2rem] shrink-0 drop-shadow-lg">🚀</div>
        <div class="flex flex-col min-w-0">
            <div class="@statLabel">Ground Speed</div>
            <div class="@statVal">@Drone.State.GroundSpeed.ToString("0.0") <small class="@statSmall">m/s</small></div>
        </div>
    </div>

    @* Altitude Stat Box *@
    <div class="@statBoxBase">
        <div class="text-[1.2rem] shrink-0 drop-shadow-lg">🏔️</div>
        <div class="flex flex-col min-w-0">
            <div class="@statLabel">Altitude (AGL)</div>
            <div class="@statVal">@Drone.State.Altitude.ToString("0") <small class="@statSmall">m</small></div>
        </div>
    </div>
</div>

@* Floating Camera Overlay - Stable HLS *@
@if (_videoEnabled)
{
    <div class="@GetVideoClasses()" @onclick="HandleVideoClick">
        @* <video id="hls-video" *@
        <video id="webrtc-video"
               autoplay
               muted
               playsinline
               class="w-full h-full object-cover"
               style="background: #000;">
        </video>

        @* NEW: "No Signal" Placeholder for Development *@
        @if (_videoStatus != "Connected")
        {
            <div class="absolute inset-0 flex flex-col items-center justify-center bg-[#0a0b0d] z-[10]">
                <i class="bi bi-camera-video-off text-[#30363d] text-4xl mb-2"></i>
                <span class="text-[#555] font-mono text-sm tracking-widest font-bold">STANDBY</span>
            </div>
        }

        @* Connection Status Badge *@
        <div class="absolute top-[8px] left-[8px] flex items-center gap-2 bg-black/70 px-3 py-1 rounded text-white text-[0.65rem] font-bold z-[60]">
            <span class="w-2 h-2 rounded-full @(_videoStatus == "Connected" ? "bg-green-500 animate-pulse" : "bg-yellow-500")"></span>
            @_videoStatus
        </div>

        @* Expand/Collapse Icon *@
        <div class="absolute top-[8px] right-[8px] text-white bg-black/60 hover:bg-black p-2 rounded cursor-pointer z-[60] transition-colors">
            <i class="bi @(_videoExpanded ? "bi-fullscreen-exit" : "bi-fullscreen") text-lg"></i>
        </div>
    </div>
}
@code {
    private bool _mapInitialized = false;
    private bool _jumpedToDrone = false;
    private bool _mapExpanded = false;
    private bool _videoEnabled = false;
    private bool _videoExpanded = false;
    private string _videoStatus = "Disconnected";
    private bool _trailEnabled = true;
    public static event Action<string>? VideoStatusUpdated;

    private DateTime _lastJsUpdateUtc = DateTime.MinValue;
    private readonly TimeSpan _jsMinPeriod = TimeSpan.FromMilliseconds(200);

    protected override void OnInitialized()
    {
        Drone.OnTelemetryUpdated += HandleTelemetryUpdated;
        VideoStatusUpdated += HandleVideoStatusUpdate;
        _videoEnabled = Config.GetValue<bool>("VideoStreaming:Enabled", true);
    }

    private void HandleVideoStatusUpdate(string status)
    {
        _videoStatus = status;
        _ = InvokeAsync(StateHasChanged); // Force the UI to redraw!
    }

    [JSInvokable]
    public static Task OnVideoStatusChanged(string status)
    {
        Console.WriteLine($"[VIDEO] Status changed: {status}");
        VideoStatusUpdated?.Invoke(status); // Tell the UI about the change
        return Task.CompletedTask;
    }

    private DateTime _lastHomeRender = DateTime.MinValue;

    private void HandleTelemetryUpdated()
    {
        _ = InvokeAsync(async () =>
        {
            await TryJumpOrUpdateAsync();

            // Stat boxes (battery, speed, altitude) shown over the map only
            // need ~5 Hz. The JS map position update already has its own
            // 200 ms guard in TryJumpOrUpdateAsync — this guard covers the
            // Blazor diff cost of re-rendering the overlay divs.
            var now = DateTime.UtcNow;
            if ((now - _lastHomeRender).TotalMilliseconds < 200) return;
            _lastHomeRender = now;
            StateHasChanged();
        });
    }

    private static bool HasValidGps(double lat, double lon)
    {
        if (double.IsNaN(lat) || double.IsNaN(lon)) return false;
        if (Math.Abs(lat) < 0.000001 && Math.Abs(lon) < 0.000001) return false;
        if (lat < -90 || lat > 90) return false;
        if (lon < -180 || lon > 180) return false;
        return true;
    }

    private async Task TryJumpOrUpdateAsync()
    {
        if (!_mapInitialized) return;
        var lat = Drone.State.Latitude;
        var lon = Drone.State.Longitude;
        var heading = Drone.State.Yaw;

        if (!HasValidGps(lat, lon)) return;

        var now = DateTime.UtcNow;
        if (now - _lastJsUpdateUtc < _jsMinPeriod) return;
        _lastJsUpdateUtc = now;

        var extra = new
        {
            alt = (double)Drone.State.Altitude,
            spd = (double)Drone.State.GroundSpeed,
            bat = (int)Drone.State.BatteryPercent,
            hdop = Drone.State.SatCount > 0 ? Math.Max(0.5, 5.0 - Drone.State.SatCount * 0.3) : 5.0
        };

        try
        {
            if (!_jumpedToDrone)
            {
                await JS.InvokeVoidAsync("jumpToDrone", lat, lon, heading, extra);
                _jumpedToDrone = true;
                return;
            }
            await JS.InvokeVoidAsync("updateMapPos", lat, lon, heading, extra);
        }
        catch (Exception ex) { Console.WriteLine($"Map Error: {ex.Message}"); }
    }

    // Add these methods to handle the layout swapping
    private void ToggleVideoExpand()
    {
        _videoExpanded = !_videoExpanded;
        StateHasChanged();

        // CRITICAL: Leaflet maps "break" if their container changes size dynamically.
        // We call the animateMapResize JS function you already have in App.razor to fix it!
        _ = JS.InvokeVoidAsync("animateMapResize");
    }

    private string GetMapClasses()
    {
        if (_videoExpanded)
        {
            // Map becomes the small floating box
            return $"fixed {GetVideoPosition()} z-[50] w-[320px] aspect-video bg-[#0a0b0d] border border-[#30363d] rounded-[8px] overflow-hidden shadow-2xl pointer-events-auto transition-all duration-300 cursor-pointer";
        }

        // Map is full screen
        return "fixed inset-0 w-full h-screen bg-[#0a0b0d] z-[0] pointer-events-auto transition-all duration-300";
    }

    private string GetVideoClasses()
    {
        if (_videoExpanded)
        {
            // Video becomes full screen (z-[0] means it goes behind the telemetry HUD)
            return "fixed inset-0 w-full h-screen bg-black z-[0] pointer-events-auto transition-all duration-300";
        }

        // Video is the small floating box
        return $"fixed {GetVideoPosition()} z-[50] w-[320px] aspect-video bg-black border {GetVideoBorderColor()} rounded-[8px] overflow-hidden shadow-2xl pointer-events-auto transition-all duration-300 cursor-pointer hover:border-[#58a6ff]";
    }

    private async Task ToggleExpand()
    {
        _mapExpanded = !_mapExpanded;
        // This fires the Javascript in App.razor to hide/show the sidebars and drawers!
        try { await JS.InvokeVoidAsync(_mapExpanded ? "expandMap" : "collapseMap"); } catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await JS.InvokeVoidAsync("initMap", 0.0, 0.0);
        _mapInitialized = true;
        await Task.Delay(300); // Give Blazor a split second to apply the CSS
        await JS.InvokeVoidAsync("eval", "if (window._gcsMap) window._gcsMap.invalidateSize();");

        // if (_videoEnabled)
        // {
        //     string hlsUrl = Config["VideoStreaming:HLSUrl"] ?? "http:127.0.0.1:8888/live/index.m3u8";
        //     Console.WriteLine($"[HLS] Starting stable stream: {hlsUrl}");

        //     _videoStatus = "Connecting";
        //     StateHasChanged();

        //     await Task.Delay(500);
        //     await JS.InvokeVoidAsync("initHLSStream", hlsUrl);
        // }
        if (_videoEnabled)
        {
            // WebRTC uses port 8889 and requires the /whep endpoint for the handshake
            string webrtcUrl = Config["VideoStreaming:WebRTCUrl"] ?? "http://127.0.0.1:8889/live/whep";
            Console.WriteLine($"[WebRTC] Starting low-latency stream: {webrtcUrl}");

            _videoStatus = "Connecting";
            StateHasChanged();

            await Task.Delay(500);
            await JS.InvokeVoidAsync("initWebRTCStream", webrtcUrl);
        }
    }

    public void Dispose()
    {
        Drone.OnTelemetryUpdated -= HandleTelemetryUpdated;
        VideoStatusUpdated -= HandleVideoStatusUpdate; // Clean up memory
    }

    private string GetVideoPosition()
    {
        string pos = Config["VideoStreaming:VideoPosition"] ?? "bottom-right";
        return pos.ToLower() switch
        {
            "bottom-right" => "bottom-[25px] right-[12px]",
            "bottom-left" => "bottom-[25px] left-[12px]",
            "top-right" => "top-[72px] right-[12px]",
            "top-left" => "top-[72px] left-[12px]",
            _ => "bottom-[25px] right-[12px]"
        };
    }

    private string GetVideoBorderColor()
    {
        return _videoStatus switch
        {
            "Connected" => "border-[#2ea043]",
            "Connecting" => "border-[#58a6ff]",
            "Standby" => "border-[#f0b429]", // Yellow border for dev mode
            "Error" => "border-[#ff3a3a]",
            _ => "border-[#30363d]"
        };
    }

    private void HandleMapClick()
    {
        // Only swap if the map is currently shrunk to the mini-player
        if (_videoExpanded)
        {
            ToggleVideoExpand();
        }
    }

    private void HandleVideoClick()
    {
        // Only swap if the video is currently shrunk to the mini-player
        if (!_videoExpanded)
        {
            ToggleVideoExpand();
        }
    }
}