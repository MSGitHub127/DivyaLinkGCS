@page "/map"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject MavlinkService Drone
@implements IDisposable

<div class="map-wrapper">
    <div id="map-element" style="height: 100%; width: 100%;"></div>

    <div class="map-overlay">
        <div class="stat">LAT: @Drone.State.Latitude.ToString("F7")</div>
        <div class="stat">LON: @Drone.State.Longitude.ToString("F7")</div>
        <div class="stat">HDG: @Drone.State.Yaw.ToString("0")°</div>
    </div>
</div>

<style>
    .map-wrapper {
        height: calc(100vh - 60px);
        width: 100%;
        position: relative;
    }

    .map-overlay {
        position: absolute;
        top: 120px;
        left: 20px;
        background: rgba(13, 14, 16, 0.85);
        padding: 15px;
        border-radius: 8px;
        border: 1px solid #2a2d35;
        color: #00f2ff;
        font-family: monospace;
        pointer-events: none;
    }

    .stat {
        margin-bottom: 5px;
        font-size: 0.9rem;
    }
</style>

@code {
    private System.Threading.Timer? _mapTimer;
    private bool _jumpedToDrone = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // India at start
            await JS.InvokeVoidAsync("initMap", 0.0, 0.0);

            _mapTimer = new System.Threading.Timer(async _ =>
            {
                await InvokeAsync(async () =>
                {
                    await TryJumpOrUpdateAsync();
                    StateHasChanged();
                });
            }, null, 0, 200);
        }
    }

    private static bool HasValidGps(double lat, double lon)
    {
        if (double.IsNaN(lat) || double.IsNaN(lon)) return false;
        if (Math.Abs(lat) < 0.000001 && Math.Abs(lon) < 0.000001) return false;
        if (lat < -90 || lat > 90) return false;
        if (lon < -180 || lon > 180) return false;
        return true;
    }

    private async Task TryJumpOrUpdateAsync()
    {
        var lat = Drone.State.Latitude;
        var lon = Drone.State.Longitude;

        Console.WriteLine($"[MAP] lat={lat:F7} lon={lon:F7} jumped={_jumpedToDrone}");

        if (!HasValidGps(lat, lon))
            return;

        // JUMP immediately the moment GPS becomes valid
        if (!_jumpedToDrone)
        {
            await JS.InvokeVoidAsync("jumpToDrone", lat, lon);
            _jumpedToDrone = true;
            return;
        }

        // then follow normally
        await JS.InvokeVoidAsync("updateMapPos", lat, lon);
    }

    public void Dispose() => _mapTimer?.Dispose();
}

