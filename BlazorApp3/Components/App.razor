<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="BlazorApp3.styles.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        html, body {
            background-color: #0a0b0d; 
            overscroll-behavior-y: none; 
        }
        :root {
            --header-height: 55px;
        }

        @@media (min-width: 768px) {
            :root {
                --header-height: 60px;
            }
        }

        /* 1. Default: Sit perfectly in the top right for smaller maps (like FlightPlan) */
        .leaflet-top.leaflet-right {
            top: 10px !important;
            right: 10px !important;
        }

        /* 2. Override: Only push down when the map is full-screen and sitting behind the main header */
        .fixed.inset-0 .leaflet-top.leaflet-right {
            top: calc(var(--header-height) + 10px) !important;
        }

        /* 1. Hide scrollbar for IE, Edge, and Firefox */
        .leaflet-control-layers-list {
            -ms-overflow-style: none !important;
            scrollbar-width: none !important;
        }

            /* 2. Hide scrollbar for Chrome, Safari, and newer Edge */
            .leaflet-control-layers-list::-webkit-scrollbar {
                display: none !important;
            }

        .leaflet-container {
            background: #0a0b0d;
        }

        .leaflet-control-attribution {
            background: rgba(10,11,13,.85) !important;
            color: #555 !important;
            font-size: .55rem !important;
        }

            .leaflet-control-attribution a {
                color: #58a6ff !important;
            }

        .leaflet-control-layers {
            background: rgba(10,11,13,.92) !important;
            border: 1px solid #30363d !important;
            border-radius: 6px !important;
        }

            .leaflet-control-layers label {
                color: #c9d1d9 !important;
                font-size: .78rem !important;
            }

        .leaflet-control-zoom a {
            background: rgba(10,11,13,.92) !important;
            border-color: #30363d !important;
            color: #58a6ff !important;
        }

            .leaflet-control-zoom a:hover {
                background: #161b22 !important;
                color: #00f2ff !important;
            }

        .leaflet-bottom.leaflet-right .leaflet-control-scale {
            margin-right: 54px;
            margin-bottom: 4px;
        }

        /* Position the layer control in the vertical center of the left side */
        .leaflet-left.leaflet-top {
            top: 50% !important;
            left: !important;
            transform: translateY(-50%);
            margin-top: 0 !important;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .leaflet-control-zoom {
            display: none;
        }

        .leaflet-control-attribution {
            background: rgba(10,11,13,.82) !important;
            color: #444 !important;
            font-size: .52rem !important;
            padding: 1px 6px !important;
            border-radius: 4px 0 0 0 !important;
        }

        .drone-tooltip {
            background: rgba(10,11,14,0.92) !important;
            border: 1px solid #30363d !important;
            border-radius: 6px !important;
            box-shadow: 0 4px 16px rgba(0,0,0,0.6) !important;
            padding: 8px 10px !important;
        }

        .leaflet-tile {
            image-rendering: -webkit-optimize-contrast;
            image-rendering: pixelated;
            image-rendering: crisp-edges;
        }

        #map-coord-log {
            position: absolute;
            bottom: 25px;
            left: 12px;
            z-index: 1000;
            background: rgba(10,11,13,.88);
            border: 1px solid #30363d;
            border-radius: 5px;
            padding: 5px 10px;
            font-size: .62rem;
            font-family: monospace;
            color: #00f2ff;
            pointer-events: none;
            min-width: 180px;
            line-height: 1.6;
        }
    </style>
    <HeadOutlet />
</head>
<body>
    <Routes @rendermode="InteractiveServer" />

    <script src="_framework/blazor.web.js"></script>
    <script>
        window.setToastUplift = function (heightPx) {
            document.documentElement.style.setProperty('--toast-pip-uplift', heightPx + 'px');
        };
    </script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
    <script src="js/airspace.js"></script>

    <script>
        // Minimal, robust Leaflet engine for the GCS map.
        window._gcsMap = null;
        window._gcsMarker = null;
        window._missionMarkers = [];
        window._missionPath = null;
        window._trailPoints = [];
        window._trailLine = null;
        window._trailEnabled = true;
        window._accuracyCircle = null;
        window._MAX_TRAIL_PTS = 400;
        window._pc = null;

        function _validGps(lat, lng) {
            return typeof lat === 'number' && typeof lng === 'number'
                   && !Number.isNaN(lat) && !Number.isNaN(lng)
                   && (Math.abs(lat) > 0.000001 || Math.abs(lng) > 0.000001);
        }

        function _updateCoordLog(lat, lng) {
            const el = document.getElementById('map-coord-log');
            if (el) el.innerHTML = `LAT <b style="color:#fff">${lat.toFixed(7)}</b><br>LNG <b style="color:#fff">${lng.toFixed(7)}</b>`;
        }

        function _droneIcon(yawDeg) {
            const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 36 36">
                <g transform="rotate(${yawDeg},18,18)">
                    <polygon points="18,4 28,30 18,24 8,30"
                             fill="#00f2ff" stroke="#0a0b0d" stroke-width="1.5"
                             stroke-linejoin="round"/>
                </g></svg>`;
            return L.divIcon({ html: svg, className: '', iconSize: [36, 36], iconAnchor: [18, 18] });
        }

        function _createBingLayer(imagerySet, opts) {
            const layer = L.tileLayer('', opts);
            layer.getTileUrl = function (coords) {
                let quad = '';
                for (let i = coords.z; i > 0; i--) {
                    let digit = 0;
                    const mask = 1 << (i - 1);
                    if ((coords.x & mask) !== 0) digit++;
                    if ((coords.y & mask) !== 0) digit += 2;
                    quad += digit;
                }
                return `https://ecn.t${Math.floor(Math.random() * 4)}.tiles.virtualearth.net/tiles/${imagerySet}${quad}.jpeg?g=1`;
            };
            return layer;
        }

        window.initMap = (lat, lng) => {
            const el = document.getElementById('map-element');
            if (!el) return;

            if (window._gcsMap) { window._gcsMap.invalidateSize(); return; }

            const isGpsValid = _validGps(lat, lng);
            const startLatLng = isGpsValid ? [lat, lng] : [20.5937, 78.9629];
            const startZoom = isGpsValid ? 19 : 5;

            window._gcsMap = L.map(el, {
                center: startLatLng, 
                zoom: startZoom,
                minZoom: 3,        
                maxZoom: 22, 
                zoomControl: true, 
                attributionControl: true, 
                tap: false,
                worldCopyJump: true
            });

            window.airspace.attachMoveListener();

            const southWest = L.latLng(-85.05, -999999); 
            const northEast = L.latLng(85.05, 999999);   
            const bounds = L.latLngBounds(southWest, northEast);
            
            window._gcsMap.setMaxBounds(bounds);

            if (window.ResizeObserver) {
                new ResizeObserver(() => { if (window._gcsMap) window._gcsMap.invalidateSize(); }).observe(el);
            }

            const BLANK = 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7';
            
            const tileOpts = (maxNative, extra) => Object.assign({
                maxNativeZoom: maxNative,
                maxZoom: 22,
                minZoom: 3,         
                keepBuffer: 6,
                updateWhenIdle: false,
                updateWhenZooming: false,
                errorTileUrl: BLANK,
                crossOrigin: true
            }, extra || {});

            const googleSat = L.tileLayer('https://mt{s}.google.com/vt/lyrs=s&x={x}&y={y}&z={z}', tileOpts(20, { subdomains: '0123', attribution: 'Map data &copy; Google' }));
            const googleHybrid = L.tileLayer('https://mt{s}.google.com/vt/lyrs=y&x={x}&y={y}&z={z}', tileOpts(20, { subdomains: '0123', attribution: 'Map data &copy; Google' }));
            const bingSat = _createBingLayer('a', tileOpts(19, { attribution: 'Map data &copy; Microsoft Bing' }));
            const esriClarity = L.tileLayer('https://clarity.maptiles.arcgis.com/arcgis/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', tileOpts(19, { attribution: 'Tiles &copy; Esri' }));
            const esriHybrid = L.layerGroup([L.tileLayer('https://clarity.maptiles.arcgis.com/arcgis/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', tileOpts(19, { attribution: 'Tiles &copy; Esri' })), L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/Reference/World_Boundaries_and_Places/MapServer/tile/{z}/{y}/{x}', tileOpts(19, { opacity: 0.85 }))]);
            const osm = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', tileOpts(19, { subdomains: 'abc', attribution: '&copy; <a href="https://openstreetmap.org">OpenStreetMap</a>' }));
            const esriTopo = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer/tile/{z}/{y}/{x}', tileOpts(19, { attribution: 'Tiles &copy; Esri' }));

            googleSat.addTo(window._gcsMap);
            L.control.layers({
                '🛰️ Google Satellite': googleSat,
                '🛰️ Google Hybrid': googleHybrid,
                '🛰️ Bing Satellite': bingSat,
                '🛰️ Esri Clarity': esriClarity,
                '🛰️ Esri Hybrid': esriHybrid,
                '🗺️ Street (OSM)': osm,
                '🏔️ Terrain (Esri)': esriTopo
            }, {}, { position: 'topleft', collapsed: true }).addTo(window._gcsMap);

            try {
                window._gcsMap.on('click', function (e) {
                    if (typeof DotNet !== 'undefined') {
                        DotNet.invokeMethodAsync('BlazorApp3', 'AddWaypointFromMap', e.latlng.lat, e.latlng.lng)
                            .catch(err => console.error('AddWaypointFromMap invoke failed', err));
                    }
                });
            } catch (ex) {
                console.warn('Failed to attach map click handler', ex);
            }
        }; // <-- MAKE SURE THIS CLOSING BRACKET AND SEMICOLON ARE HERE
        window.preserveMap = () => { /* Leaflet: no-op */ };

        function _droneTooltip(lat, lng, yaw, alt, spd, bat) {
            return `<div style="font-family:monospace;font-size:0.65rem;line-height:1.6;color:#c9d1d9;min-width:130px;">
                <div style="font-weight:900;color:#00f2ff;letter-spacing:1px;margin-bottom:3px;">DRONE</div>
                <div>HDG <b style="color:#fff">${yaw.toFixed(0)}°</b></div>
                <div>ALT <b style="color:#fff">${alt.toFixed(1)} m</b></div>
                <div>SPD <b style="color:#fff">${spd.toFixed(1)} m/s</b></div>
                <div>BAT <b style="color:${bat < 20 ? '#ff6b6b' : '#3fb950'}">${bat}%</b></div>
                <div style="color:#555;font-size:0.55rem;margin-top:2px;">${lat.toFixed(7)}, ${lng.toFixed(7)}</div>
            </div>`;
        }

        function _updateAccuracyRing(lat, lng, hdop) {
            if (!window._gcsMap) return;
            const radius = Math.max(1, (hdop || 1) * 3);
            if (!window._accuracyCircle) {
                window._accuracyCircle = L.circle([lat, lng], { radius, color: '#00f2ff', fillColor: '#00f2ff', fillOpacity: 0.06, weight: 1, opacity: 0.35, interactive: false }).addTo(window._gcsMap);
            } else {
                window._accuracyCircle.setLatLng([lat, lng]);
                window._accuracyCircle.setRadius(radius);
            }
        }

        // Minimum distance (degrees) before a new trail point is added.
        // ~1.1m at the equator — prevents setLatLngs from rebuilding the
        // polyline SVG on every GPS packet when the drone is stationary.
        const _TRAIL_MIN_DIST_DEG = 0.00001;

        function _appendTrail(lat, lng) {
            if (!window._trailEnabled || !window._gcsMap) return;
            const pts = window._trailPoints;
            if (pts.length > 0) {
                const last = pts[pts.length - 1];
                const dLat = lat - last[0], dLng = lng - last[1];
                // Skip if moved less than ~1m — avoids redundant polyline redraws.
                if (dLat * dLat + dLng * dLng < _TRAIL_MIN_DIST_DEG * _TRAIL_MIN_DIST_DEG) return;
            }
            pts.push([lat, lng]);
            if (pts.length > window._MAX_TRAIL_PTS) pts.shift();
            if (!window._trailLine) {
                window._trailLine = L.polyline(pts, { color: '#f0b429', weight: 2, opacity: 0.7, smoothFactor: 1, interactive: false }).addTo(window._gcsMap);
            } else {
                window._trailLine.setLatLngs(pts);
            }
        }

        function _ensureDroneMarker(lat, lng, yaw, extra) {
            if (!window._gcsMap) return;
            const alt = extra?.alt ?? 0, spd = extra?.spd ?? 0, bat = extra?.bat ?? 0, hdop = extra?.hdop ?? 1;
            if (!window._gcsMarker) {
                window._gcsMarker = L.marker([lat, lng], { icon: _droneIcon(yaw), draggable: true, zIndexOffset: 1000 }).addTo(window._gcsMap);
                window._gcsMarker.bindTooltip(_droneTooltip(lat, lng, yaw, alt, spd, bat), { permanent: false, direction: 'right', className: 'drone-tooltip', offset: [20, 0] });
                window._gcsMarker.on('drag', (e) => { const p = e.target.getLatLng(); _updateCoordLog(p.lat, p.lng, 'DRONE (DRAG)'); });
                window._gcsMarker.on('dragend', (e) => { const p = e.target.getLatLng(); _updateCoordLog(p.lat, p.lng, 'DRONE DROPPED'); });
            } else {
                window._gcsMarker.setLatLng([lat, lng]);
                window._gcsMarker.setIcon(_droneIcon(yaw));
                if (window._gcsMarker.getTooltip()) window._gcsMarker.getTooltip().setContent(_droneTooltip(lat, lng, yaw, alt, spd, bat));
                _updateCoordLog(lat, lng, 'DRONE (LIVE)');
            }
            _appendTrail(lat, lng);
            _updateAccuracyRing(lat, lng, hdop);
        }

        window.jumpToDrone = (lat, lng, yawDeg, extra) => {
            if (!window._gcsMap || !_validGps(lat, lng)) return;
            window._gcsMap.setView([lat, lng], Math.max(window._gcsMap.getZoom(), 19));
            _ensureDroneMarker(lat, lng, yawDeg ?? 0, extra);
        };

        window.recentreToDrone = () => { if (!window._gcsMap || !window._gcsMarker) return; window._gcsMap.panTo(window._gcsMarker.getLatLng()); };

        window.updateMapPos = (lat, lng, yawDeg, extra) => { if (!window._gcsMap || !_validGps(lat, lng)) return; _ensureDroneMarker(lat, lng, yawDeg ?? 0, extra); };

        window.setTrailEnabled = (enabled) => { window._trailEnabled = enabled; if (!enabled && window._trailLine) { window._gcsMap?.removeLayer(window._trailLine); window._trailLine = null; window._trailPoints = []; } };
        window.clearTrail = () => { if (window._trailLine) { window._gcsMap?.removeLayer(window._trailLine); window._trailLine = null; } window._trailPoints = []; };

        window.drawMission = (waypoints) => {
            if (!window._gcsMap) return;
            window._missionMarkers.forEach(m => window._gcsMap.removeLayer(m));
            window._missionMarkers = [];
            if (window._missionPath) { window._gcsMap.removeLayer(window._missionPath); window._missionPath = null; }
            if (!waypoints || !waypoints.length) return;
            const coords = [];
            waypoints.forEach(wp => {
                const lat = wp.lat ?? wp.Lat, lng = wp.lng ?? wp.Lng, idx = wp.index ?? wp.Index;
                const home = wp.IsHome || wp.isHome || idx === 0;
                if (lat === undefined || lng === undefined) return;
                coords.push([lat, lng]);
                const sz = home ? 22 : 18, bg = home ? '#ff9900' : '#00f2ff';
                const icon = L.divIcon({ html: `<div style="width:${sz}px;height:${sz}px;background:${bg};border:2px solid #fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:bold;color:#000;">${home ? 'H' : idx}</div>`, className: '', iconSize: [sz, sz], iconAnchor: [sz / 2, sz / 2] });
                const m = L.marker([lat, lng], { icon, draggable: true }).addTo(window._gcsMap);
                m.bindTooltip(`WP${idx}: ${lat.toFixed(6)}, ${lng.toFixed(6)}`, { direction: 'top' });
                m.on('dragend', e => {
                    const p = e.target.getLatLng();
                    if (typeof DotNet !== 'undefined')
                        DotNet.invokeMethodAsync('BlazorApp3', 'UpdateWaypointPosition', idx, p.lat, p.lng).catch(console.error);
                });
                window._missionMarkers.push(m);
            });
            if (coords.length > 1) window._missionPath = L.polyline(coords, { color: '#2b58ff', weight: 3, opacity: .85 }).addTo(window._gcsMap);
        };

        const animateMapResize = () => {
            let ticks = 0;
            const timer = setInterval(() => { if (window._gcsMap) window._gcsMap.invalidateSize(false); ticks++; if (ticks > 35) clearInterval(timer); }, 10);
        };

        window.expandMap = () => { document.querySelector('.gcs-wrapper')?.classList.add('map-fullscreen'); document.querySelector('.gcs-drawer')?.classList.add('map-fullscreen-drawer'); animateMapResize(); };
        window.collapseMap = () => { document.querySelector('.gcs-wrapper')?.classList.remove('map-fullscreen'); document.querySelector('.gcs-drawer')?.classList.remove('map-fullscreen-drawer'); animateMapResize(); };

        window.scrollToBottom = (elementId) => { const el = document.getElementById(elementId); if (el) el.scrollTo({ top: el.scrollHeight, behavior: 'smooth' }); };
        window.scrollToBottomInstant = (elementId) => { const el = document.getElementById(elementId); if (el) el.scrollTop = el.scrollHeight; };

        window.downloadFile = (fileName, content) => {
            const blob = new Blob([content], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a'); a.href = url; a.download = fileName; a.click();
            URL.revokeObjectURL(url);
        };

        window.triggerFilePicker = (id) => { const el = document.getElementById(id); if (el) el.click(); };

        window.initSkydroidStream = async () => {
            const videoElement = document.getElementById('skydroid-video');
            if (!videoElement) {
                console.error("Video element not found!");
                return;
            }

            const pc = new RTCPeerConnection();

            // Feed the incoming video track directly into the HTML video element
            pc.ontrack = (event) => {
                videoElement.srcObject = event.streams[0];
            };

            pc.addTransceiver('video', { direction: 'recvonly' });

            try {
                const offer = await pc.createOffer();
                await pc.setLocalDescription(offer);

                // Connect to the local MediaMTX server we are about to spin up in C#
                const response = await fetch(webrtcUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/sdp'
                    },
                    body: offer.sdp
                });

                if (!response.ok) throw new Error("MediaMTX server not responding");

                const answer = await response.json();
                await pc.setRemoteDescription(new RTCSessionDescription(answer));

                console.log("Skydroid WebRTC stream established.");
            } catch (err) {
                console.error("Failed to connect to video stream. Is MediaMTX running?", err);
            }
        };

        // ═══════════════════════════════════════════════════════════
        // HLS VIDEO STREAMING WITH AUTOMATIC FALLBACK
        // ═══════════════════════════════════════════════════════════

        window.initHLSStreamWithFallback = async (urls) => {
            console.log('[HLS] Initializing with fallback strategy');
            console.log('[HLS] Will try', urls.length, 'URLs');

            const video = document.getElementById('hls-video');
            if (!video) {
                console.error('[HLS] Video element not found');
                return;
            }

            // Try each URL in sequence until one works
            for (let i = 0; i < urls.length; i++) {
                const url = urls[i];
                console.log(`[HLS] Trying URL ${i + 1}/${urls.length}: ${url}`);

                const success = await tryHLSUrl(url, video);
                if (success) {
                    console.log(`[HLS] ✓ Success with URL: ${url}`);
                    if (typeof DotNet !== 'undefined') {
                        // Ensure 'BlazorApp3' perfectly matches your project's DLL name!
                        DotNet.invokeMethodAsync('BlazorApp3', 'OnVideoStatusChanged', 'Connected')
                            .catch(e => console.log('[HLS] Blazor callback unavailable', e));
                    }
                    return;
                }

                console.log(`[HLS] ✗ Failed, trying next URL...`);
                await new Promise(resolve => setTimeout(resolve, 1000)); // Wait 1s between attempts
            }

            console.error('[HLS] ✗ All URLs failed');
            if (typeof DotNet !== 'undefined') {
                DotNet.invokeMethodAsync('BlazorApp3', 'OnVideoStatusChanged', 'Error')
                    .catch(e => console.log('[HLS] Blazor callback unavailable'));
            }

            // Retry entire sequence after 10 seconds
            console.log('[HLS] Retrying entire sequence in 10 seconds...');
            setTimeout(() => window.initHLSStreamWithFallback(urls), 10000);
        };

        async function tryHLSUrl(hlsUrl, video) {
            return new Promise((resolve) => {
                console.log('[HLS] Attempting URL:', hlsUrl);

                const timeout = setTimeout(() => {
                    console.log('[HLS] Timeout - no response in 10s');
                    cleanup();
                    resolve(false);
                }, 10000);  // Increased timeout

                let resolved = false;
                const cleanup = () => {
                    if (!resolved) {
                        resolved = true;
                        clearTimeout(timeout);
                    }
                };

                // Try native HLS first (Safari)
                if (video.canPlayType('application/vnd.apple.mpegurl')) {
                    console.log('[HLS] Using native HLS');
                    video.src = hlsUrl;
                    video.load();

                    video.onloadedmetadata = () => {
                        console.log('[HLS] ✓ Native metadata loaded');
                        video.play().then(() => {
                            console.log('[HLS] ✓ Native playing');
                            cleanup();
                            resolve(true);
                        });
                    };

                    video.onerror = (e) => {
                        console.error('[HLS] ✗ Native error:', e);
                        cleanup();
                        resolve(false);
                    };

                    return;
                }

                // Use hls.js for Chrome/Firefox
                if (typeof Hls === 'undefined' || !Hls.isSupported()) {
                    console.error('[HLS] hls.js not supported');
                    cleanup();
                    resolve(false);
                    return;
                }

                console.log('[HLS] Using hls.js');

                // Destroy existing instance
                if (window.hls) {
                    console.log('[HLS] Destroying previous instance');
                    window.hls.destroy();
                }

                // Create new HLS instance with FIXED settings for continuous streaming
                window.hls = new Hls({
                    debug: true,
                    autoStartLoad: true,
                    startPosition: -1,

                    // CRITICAL FIX: Proper buffer sizes for continuous streaming
                    backBufferLength: 90,        // Keep 90s of back buffer
                    maxBufferLength: 30,          // Target 30s ahead
                    maxMaxBufferLength: 60,       // Maximum 60s buffer

                    // Low latency mode ENABLED
                    lowLatencyMode: true,

                    // Live sync settings - stay close to live edge
                    liveSyncDurationCount: 3,      // Stay 3 segments from live
                    liveMaxLatencyDurationCount: 10,

                    // Fragment loading
                    maxFragLookUpTolerance: 0.25,
                    enableWorker: true,

                    // CRITICAL: Aggressive loading to prevent stalls
                    progressive: true,

                    // Manifest settings
                    manifestLoadingTimeOut: 10000,
                    manifestLoadingMaxRetry: 3,
                    manifestLoadingRetryDelay: 500,

                    // Fragment settings
                    fragLoadingTimeOut: 20000,
                    fragLoadingMaxRetry: 6,
                    fragLoadingRetryDelay: 500,

                    // Level settings
                    levelLoadingTimeOut: 10000,
                    levelLoadingMaxRetry: 3,
                    levelLoadingRetryDelay: 500
                });

                // Event: Manifest parsed
                window.hls.on(Hls.Events.MANIFEST_PARSED, () => {
                    console.log('[HLS] ✓ Manifest parsed - stream is ready');

                    video.play()
                        .then(() => {
                            console.log('[HLS] ✓✓✓ PLAYING STARTED ✓✓✓');
                            cleanup();
                            resolve(true);
                        })
                        .catch(err => {
                            console.warn('[HLS] Autoplay blocked - user interaction needed:', err);
                            // Still resolve true - user can click to play
                            cleanup();
                            resolve(true);
                        });
                });

                // Event: Level loaded - new playlist
                window.hls.on(Hls.Events.LEVEL_LOADED, (evt, data) => {
                    console.log(`[HLS] Level loaded - ${data.details.fragments.length} fragments available`);
                });

                // Event: Fragment loading (when it starts loading a chunk)
                window.hls.on(Hls.Events.FRAG_LOADING, (evt, data) => {
                    console.log(`[HLS] Loading fragment ${data.frag.sn}`);
                });

                // Event: Fragment loaded (continuous - THIS SHOULD KEEP HAPPENING)
                window.hls.on(Hls.Events.FRAG_LOADED, (evt, data) => {
                    console.log(`[HLS] ✓ Fragment ${data.frag.sn} loaded (${data.frag.duration.toFixed(2)}s)`);
                });

                // Event: Fragment parsed (video decoded)
                window.hls.on(Hls.Events.FRAG_PARSED, (evt, data) => {
                    console.log(`[HLS] ✓ Fragment ${data.frag.sn} parsed and ready to play`);
                });

                // Event: Buffer appending (data going to video buffer)
                window.hls.on(Hls.Events.BUFFER_APPENDING, (evt, data) => {
                    console.log(`[HLS] Appending ${data.type} buffer`);
                });

                // Event: Buffer appended successfully
                window.hls.on(Hls.Events.BUFFER_APPENDED, (evt, data) => {
                    console.log(`[HLS] ✓ Buffer appended - playback should continue`);
                });

                // CRITICAL: Monitor if loading stops
                let lastFragTime = Date.now();
                window.hls.on(Hls.Events.FRAG_LOADED, () => {
                    lastFragTime = Date.now();
                });

                // Check every 5 seconds if we're still loading fragments
                const healthCheck = setInterval(() => {
                    const timeSinceLastFrag = Date.now() - lastFragTime;
                    if (timeSinceLastFrag > 5000 && window.hls) {
                        console.warn(`[HLS] ⚠ No fragments loaded for ${(timeSinceLastFrag/1000).toFixed(1)}s - stream may be stuck`);
                        console.log('[HLS] Attempting recovery...');
                        window.hls.startLoad();
                    }
                }, 5000);

                // Event: Error handling
                window.hls.on(Hls.Events.ERROR, (evt, data) => {
                    console.error('[HLS] Error:', data.type, data.details, data.fatal);

                    if (data.fatal) {
                        switch (data.type) {
                            case Hls.ErrorTypes.NETWORK_ERROR:
                                console.log('[HLS] Network error - retrying...');
                                setTimeout(() => window.hls.startLoad(), 1000);
                                break;

                            case Hls.ErrorTypes.MEDIA_ERROR:
                                console.log('[HLS] Media error - recovering...');
                                window.hls.recoverMediaError();
                                break;

                            default:
                                console.error('[HLS] Fatal error - giving up');
                                window.hls.destroy();
                                cleanup();
                                resolve(false);
                                break;
                        }
                    }
                });

                // Load and attach
                console.log('[HLS] Loading source...');
                window.hls.loadSource(hlsUrl);
                window.hls.attachMedia(video);

                console.log('[HLS] Attached to video element, waiting for manifest...');

                // Add video element event listeners to diagnose freezing
                video.addEventListener('playing', () => {
                    console.log('[VIDEO] ▶ Playing event fired');
                });

                video.addEventListener('waiting', () => {
                    console.warn('[VIDEO] ⏸ Waiting for data (buffering)');
                });

                video.addEventListener('stalled', () => {
                    console.error('[VIDEO] ⚠ STALLED - network issue');
                });

                video.addEventListener('suspend', () => {
                    console.warn('[VIDEO] ⏸ Suspended - paused data loading');
                });

                video.addEventListener('progress', () => {
                    console.log('[VIDEO] Downloading data...');
                });

                video.addEventListener('timeupdate', function logTime() {
                    // Log every 2 seconds to confirm playback is advancing
                    if (this.currentTime % 2 < 0.1) {
                        console.log(`[VIDEO] Playing at ${this.currentTime.toFixed(1)}s`);
                    }
                });
            });
        }

        // Keep old function for compatibility
        window.initHLSStream = async (hlsUrl) => {
            await window.initHLSStreamWithFallback([hlsUrl]);
        };

        // Cleanup on page unload
        window.addEventListener('beforeunload', () => {
            if (window.hls) {
                window.hls.destroy();
            }
        });

        // ═══════════════════════════════════════════════════════════
        // ULTRA-LOW LATENCY WEBRTC (WHEP) STREAMING
        // ═══════════════════════════════════════════════════════════

        window.initWebRTCStream = async (webrtcUrl) => {
            console.log('[WebRTC] Initiating handshake with:', webrtcUrl);

            const video = document.getElementById('webrtc-video');
            if (!video) return;

            // Clean up existing peer connection if reconnecting
            if (window._pc) {
                window._pc.close();
            }

            window._pc = new RTCPeerConnection();

            // Bind the incoming video track directly to the HTML video element
            // Bind the incoming video track directly to the HTML video element
            window._pc.ontrack = (event) => {
                console.log('[WebRTC] ✓ Video track received!');

                // BULLETPROOF FIX: If streams array is empty, wrap the track manually
                if (event.streams && event.streams[0]) {
                    video.srcObject = event.streams[0];
                } else {
                    video.srcObject = new MediaStream([event.track]);
                }

                // Force the browser to play it
                video.play().catch(e => console.warn('[WebRTC] Autoplay blocked:', e));
            };

            // We only want to receive video, not send it
            window._pc.addTransceiver('video', { direction: 'recvonly' });

            try {
                // 1. Browser creates an SDP Offer
                const offer = await window._pc.createOffer();
                await window._pc.setLocalDescription(offer);

                // 2. Send the Offer to MediaMTX
                const response = await fetch(webrtcUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/sdp' },
                    body: offer.sdp
                });

                if (!response.ok) {
                    throw new Error(`MediaMTX Error: ${response.status} ${response.statusText}`);
                }

                // 3. Receive the SDP Answer from MediaMTX and apply it
                const answerSdp = await response.text();
                await window._pc.setRemoteDescription(
                    new RTCSessionDescription({ type: 'answer', sdp: answerSdp })
                );

                console.log("[WebRTC] ✓ Handshake complete. Zero-latency stream live.");

                // Tell Blazor UI to show "Connected"
                if (typeof DotNet !== 'undefined') {
                    DotNet.invokeMethodAsync('BlazorApp3', 'OnVideoStatusChanged', 'Connected')
                        .catch(e => console.warn('Blazor callback failed', e));
                }

            } catch (err) {
                // Fails gracefully so you can develop UI without the camera turned on!
                console.warn("[WebRTC] Camera not detected. Entering Standby mode.");
                if (typeof DotNet !== 'undefined') {
                    DotNet.invokeMethodAsync('BlazorApp3', 'OnVideoStatusChanged', 'Standby')
                    .catch(e => console.warn('Blazor callback failed', e));
                }
            }
        };
        // ═══════════════════════════════════════════════════════════
        // TIME-DELTA SPRING INTERPOLATION ENGINE (Flawless HUD)
        // ═══════════════════════════════════════════════════════════
        window._hudTarget      = { roll: 0, pitch: 0 };
        window._hudCurrent     = { roll: 0, pitch: 0 };
        window._lastFrameTime  = performance.now();

        window.updateHudTarget = (roll, pitch) => {
            window._hudTarget.roll  = roll;
            window._hudTarget.pitch = pitch;
        };

        const animateHud = (currentTime) => {
            // 1. Calculate time delta (capped at 50ms to prevent huge jumps if tab is hidden)
            const dt = Math.min(currentTime - window._lastFrameTime, 50) / 1000;
            window._lastFrameTime = currentTime;

            // 2. THE MISSING SPRING MATH!
            // This smoothly closes the gap between Current and Target at 60fps.
            const k = 8.0; // Higher = snappier, Lower = smoother
            const alpha = 1 - Math.exp(-k * dt);

            window._hudCurrent.roll  += (window._hudTarget.roll  - window._hudCurrent.roll)  * alpha;
            window._hudCurrent.pitch += (window._hudTarget.pitch - window._hudCurrent.pitch) * alpha;

            // 3. Find the active element and apply the CSS transform
            const activeHudEl = document.getElementById('hud-horizon');
            if (activeHudEl) {
                const r = window._hudCurrent.roll;
                const p = window._hudCurrent.pitch;
                // rotate: negative because right-roll tilts horizon LEFT
                // translateY: multiplying by 3 gives excellent visual scaling
                activeHudEl.style.transform = `rotate(${-r}deg) translateY(${p * 3}px)`;
            }

            requestAnimationFrame(animateHud);
        };

        // Start the engine
        requestAnimationFrame(animateHud);
    </script>
</body>
</html>