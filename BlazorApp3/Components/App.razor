@inject IConfiguration Configuration
@{
    var mapsApiKey = Configuration["GoogleMaps:ApiKey"] ?? string.Empty;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="BlazorApp3.styles.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <HeadOutlet />
</head>
<body>
    <Routes @rendermode="InteractiveServer" />

    <script src="_framework/blazor.web.js"></script>
    <script src="https://maps.googleapis.com/maps/api/js?key=@mapsApiKey&loading=async"></script>

    <script>
        window._gcsMap = null;
        window._gcsMarker = null;
        window._missionMarkers = [];
        window._missionPath = null;

        // THE FIX: Persistence logic added to initMap
        window.initMap = (lat, lng) => {
            const el = document.getElementById("map-element");
            if (!el) return;

            // NEW: If map already exists, re-attach it WITHOUT changing zoom or center
            if (window._gcsMap) {
                const mapDiv = window._gcsMap.getDiv();

                // Keep the current view state
                const currentCenter = window._gcsMap.getCenter();
                const currentZoom = window._gcsMap.getZoom();

                mapDiv.style.display = 'block';
                el.appendChild(mapDiv);

                // Force Google Maps to acknowledge the new container size
                google.maps.event.trigger(window._gcsMap, 'resize');

                // Re-lock the position so it doesn't jump
                window._gcsMap.setCenter(currentCenter);
                window._gcsMap.setZoom(currentZoom);
                return;
            }

            if (typeof google === 'undefined' || typeof google.maps === 'undefined') {
                setTimeout(() => window.initMap(lat, lng), 200);
                return;
            }

            const isGpsValid = (Math.abs(lat) > 0.1 && Math.abs(lng) > 0.1);
            const startPos = isGpsValid ? { lat: lat, lng: lng } : { lat: 20.5937, lng: 78.9629 };

            try {
                window._gcsMap = new google.maps.Map(el, {
                    center: startPos,
                    zoom: isGpsValid ? 18 : 5,
                    mapTypeId: "hybrid",
                    disableDefaultUI: true,
                    fullscreenControl: true,
                    zoomControl: true,
                    mapTypeControl: true,
                    mapTypeControlOptions: {
                        style: google.maps.MapTypeControlStyle.HORIZONTAL_BAR,
                        position: google.maps.ControlPosition.TOP_LEFT,
                        mapTypeIds: ["roadmap", "satellite", "hybrid", "terrain"]
                    }
                });

                window._gcsMap.addListener("click", (e) => {
                    if (typeof DotNet !== 'undefined') {
                        DotNet.invokeMethodAsync('BlazorApp3', 'AddWaypointFromMap', e.latLng.lat(), e.latLng.lng())
                              .catch(err => console.error("Interop Error:", err));
                    }
                });
            } catch (error) {
                console.error("Failed to render Google Map:", error);
            }
        };

        // NEW: Function to safely hide the map when you leave the tab
        window.preserveMap = () => {
            if (window._gcsMap) {
                const mapDiv = window._gcsMap.getDiv();
                mapDiv.style.display = 'none';
                document.body.appendChild(mapDiv); // Keep the map object alive in the body
            }
        };

        function _validGps(lat, lng) {
            if (typeof lat !== "number" || typeof lng !== "number") return false;
            if (Number.isNaN(lat) || Number.isNaN(lng)) return false;
            return (Math.abs(lat) > 0.000001 || Math.abs(lng) > 0.000001);
        }

        function _ensureDroneMarker(pos, yaw) {
            if (!window._gcsMap) return;
            if (!window._gcsMarker) {
                window._gcsMarker = new google.maps.Marker({
                    position: pos,
                    map: window._gcsMap,
                    icon: {
                        path: google.maps.SymbolPath.FORWARD_CLOSED_ARROW,
                        scale: 6,
                        fillColor: "#00f2ff",
                        fillOpacity: 1,
                        strokeWeight: 2,
                        rotation: yaw
                    }
                });
            } else {
                window._gcsMarker.setPosition(pos);
                const icon = window._gcsMarker.getIcon();
                icon.rotation = yaw;
                window._gcsMarker.setIcon(icon);
            }
        }

        window.drawMission = (waypoints) => {
            if (!window._gcsMap) return;
            window._missionMarkers.forEach(m => m.setMap(null));
            window._missionMarkers = [];
            if (window._missionPath) {
                window._missionPath.setMap(null);
                window._missionPath = null;
            }

            if (!waypoints || waypoints.length === 0) return;
            const pathCoords = [];

            waypoints.forEach((wp) => {
                const lat = wp.lat !== undefined ? wp.lat : wp.Lat;
                const lng = wp.lng !== undefined ? wp.lng : wp.Lng;
                const index = wp.index !== undefined ? wp.index : wp.Index;

                if (lat === undefined || lng === undefined) return;

                const pos = { lat: lat, lng: lng };
                pathCoords.push(pos);

                const marker = new google.maps.Marker({
                    position: pos,
                    map: window._gcsMap,
                    draggable: true,
                    label: {
                        text: wp.IsHome || wp.isHome ? "H" : index.toString(),
                        color: "black",
                        fontWeight: "bold"
                    },
                    icon: {
                        path: google.maps.SymbolPath.CIRCLE,
                        fillColor: wp.IsHome || wp.isHome ? "#ff9900" : "#00f2ff",
                        fillOpacity: 1,
                        strokeColor: "#ffffff",
                        strokeWeight: 2,
                        scale: wp.IsHome || wp.isHome ? 10 : 8
                    }
                });

                marker.addListener("dragend", (e) => {
                    if (typeof DotNet !== 'undefined') {
                        DotNet.invokeMethodAsync('BlazorApp3', 'UpdateWaypointPosition', index, e.latLng.lat(), e.latLng.lng())
                              .catch(err => console.error("Drag Update Error:", err));
                    }
                });
                window._missionMarkers.push(marker);
            });

            if (pathCoords.length > 1) {
                window._missionPath = new google.maps.Polyline({
                    path: pathCoords,
                    geodesic: true,
                    strokeColor: "#2b58ff",
                    strokeOpacity: 0.8,
                    strokeWeight: 3,
                    map: window._gcsMap
                });
            }
        };

        window.jumpToDrone = (lat, lng, yawDeg) => {
            if (!window._gcsMap) return;
            if (!_validGps(lat, lng)) return;
            const pos = { lat: lat, lng: lng };
            window._gcsMap.setCenter(pos);
            window._gcsMap.setZoom(19);
            _ensureDroneMarker(pos, yawDeg ?? 0);
        };

        window.updateMapPos = (lat, lng, yawDeg) => {
            if (!window._gcsMap || !_validGps(lat, lng)) return;
            const pos = { lat: lat, lng: lng };
            _ensureDroneMarker(pos, yawDeg ?? 0);
        };

        window.downloadFile = (fileName, content) => {
            const blob = new Blob([content], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = fileName;
            a.click();
            URL.revokeObjectURL(url);
        };

        window.triggerFilePicker = (id) => {
            const el = document.getElementById(id);
            if (el) el.click();
        };
    </script>
</body>
</html>