        new() { Name="ATC_STR_RAT_I",    LegacyName="STEER2SRV_I",    Label="I",          Step=0.01f,  Max=5f,   Default=0.2f   },
        new() { Name="ATC_STR_RAT_D",    LegacyName="STEER2SRV_D",    Label="D",          Step=0.001f, Max=1f,   Default=0f     },
        new() { Name="ATC_STR_RAT_IMAX", LegacyName="STEER2SRV_IMAX", Label="IMAX",       Step=0.1f,   Max=10f,  Default=1f     },
        new() { Name="ATC_STR_RAT_FF",                                 Label="FF",         Step=0.01f,  Max=5f,   Default=0.2f   },
        new() { Name="TURN_RADIUS",                                    Label="Turn Radius",Step=0.1f,   Max=20f,  Default=0.9f,  Unit="m" },
    ];

    private static readonly ParameterDefinition[] RoverSpeedPid =
    [
        new() { Name="ATC_SPEED_P",    LegacyName="SPEED2THR_P",    Label="P",        Step=0.01f,  Max=10f,  Default=0.2f   },
        new() { Name="ATC_SPEED_I",    LegacyName="SPEED2THR_I",    Label="I",        Step=0.01f,  Max=10f,  Default=0.2f   },
        new() { Name="ATC_SPEED_D",    LegacyName="SPEED2THR_D",    Label="D",        Step=0.001f, Max=1f,   Default=0f     },
        new() { Name="ATC_SPEED_IMAX", LegacyName="SPEED2THR_IMAX", Label="IMAX",     Step=0.1f,   Max=100f, Default=1f     },
        new() { Name="ATC_ACCEL_MAX",                                Label="Accel Max",Step=0.1f,   Max=20f,  Default=0f,    Unit="m/s²" },
        new() { Name="CRUISE_SPEED",                                 Label="Cruise Spd",Step=0.1f,  Max=50f,  Default=1.5f,  Unit="m/s" },
        new() { Name="CRUISE_THROTTLE",                              Label="Cruise Thr",Step=1f,    Max=100f, Default=50f,   Unit="%" },
        new() { Name="WP_SPEED",                                     Label="WP Speed",  Step=10f,   Max=1000f,Default=200f,  Unit="cm/s" },
    ];

    private static readonly ParameterDefinition[] RoverNavigation =
    [
        new() { Name="WP_RADIUS",    Label="WP Radius",  Step=0.1f,  Max=100f, Default=2f,   Unit="m" },
        new() { Name="WP_OVERSHOOT", Label="WP Overshoot",Step=0.1f, Max=100f, Default=2f,   Unit="m" },
        new() { Name="NAVL1_PERIOD", Label="L1 Period",  Step=1f,    Max=60f,  Default=8f,   Unit="s" },
        new() { Name="NAVL1_DAMPING",Label="L1 Damping", Step=0.05f, Max=1f,   Default=0.75f           },
        new() { Name="ATC_TURN_MAX_G",LegacyName="TURN_MAX_G", Label="Max Turn G", Step=0.05f, Max=2f, Default=0.6f, Unit="G" },
    ];

    private static readonly ParameterDefinition[] RoverThrottleMotors =
    [
        new() { Name="MOT_THR_MIN", LegacyName="THR_MIN", Label="Thr Min", Step=1f, Max=100f, Default=0f,   Unit="%" },
        new() { Name="MOT_THR_MAX", LegacyName="THR_MAX", Label="Thr Max", Step=1f, Max=100f, Default=100f, Unit="%" },
        new() { Name="ATC_BRAKE",   Label="Brake",  ControlType=ParameterControlType.Checkbox, Default=1f },
        new() { Name="MOT_PWM_TYPE",Label="PWM Type",ControlType=ParameterControlType.Select,
                Options=ParamOptions.MotorType, Default=0f },
    ];

    private static readonly ParameterDefinition[] RoverRcOptions =
    [
        new() { Name="RC7_OPTION", LegacyName="CH7_OPTION",  Label="RC7 Opt", ControlType=ParameterControlType.Select, Options=RcRoverOptions, Default=0 },
        new() { Name="RC8_OPTION", LegacyName="CH8_OPTION",  Label="RC8 Opt", ControlType=ParameterControlType.Select, Options=RcRoverOptions, Default=0 },
        new() { Name="RC9_OPTION", LegacyName="CH9_OPTION",  Label="RC9 Opt", ControlType=ParameterControlType.Select, Options=RcRoverOptions, Default=0 },
        new() { Name="RC10_OPTION",LegacyName="CH10_OPTION", Label="RC10 Opt",ControlType=ParameterControlType.Select, Options=RcRoverOptions, Default=0 },
    ];

    // ── COPTER ────────────────────────────────────────────────────────────────

    private static readonly ParameterDefinition[] CopterStabilizeRoll =
    [
        new() { Name="ATC_ANG_RLL_P",   Label="P",        Step=0.01f, Max=20f,     Default=4.5f   },
        new() { Name="ATC_ACCEL_R_MAX", Label="Accel MA", Step=1000f, Max=200000f, Default=110000f },
    ];

    private static readonly ParameterDefinition[] CopterStabilizePitch =
