    private static readonly ParameterDefinition[] CopterRateRoll =
    [
        new() { Name="ATC_RAT_RLL_P",    Label="P",    Step=0.001f, Max=1f,   Default=0.135f },
        new() { Name="ATC_RAT_RLL_I",    Label="I",    Step=0.001f, Max=1f,   Default=0.135f },
        new() { Name="ATC_RAT_RLL_D",    Label="D",    Step=0.0001f,Max=0.1f, Default=0.0036f},
        new() { Name="ATC_RAT_RLL_IMAX", Label="IMAX", Step=0.01f,  Max=1f,   Default=0.5f   },
