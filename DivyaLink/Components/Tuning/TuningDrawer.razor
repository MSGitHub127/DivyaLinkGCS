        {7,"Save Waypoint"},{9,"Camera Trigger"},{11,"Fence"},{16,"Auto"},
        {17,"AutoTune"},{18,"Land"},{21,"Parachute Enable"},{22,"Parachute Release"},
        {24,"Auto Mission Reset"},{28,"Relay 1"},{30,"Lost Copter Sound"},
        {31,"Motor Emergency Stop"},{32,"Motor Interlock"},{33,"Brake"},
        {36,"Arm/Disarm"},{40,"Proximity Avoidance"},{43,"Precision Loiter"},
        {46,"RC Override Enable"},{65,"GPS Disable"},{69,"Compass Learn"},
