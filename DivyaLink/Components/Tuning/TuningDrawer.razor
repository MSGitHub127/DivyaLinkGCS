@* Components/Tuning/TuningDrawer.razor
   Vehicle-adaptive tuning workspace. Placed inside OverlayDrawer.
   Renders ArduRover parameters when Vehicle.IsRover, ArduCopter when IsCopter.
   Lock Pitch/Roll synchronisation implemented per Q2 spec with _syncing guard.
   All writes use ParameterManager.WriteParameterAsync() per Q4.
*@

@using DivyaLink.Models
@using DivyaLink.Services
@inject VehicleProfileService Vehicle
@inject MavlinkService         Drone
@implements IDisposable

@* ══════════════════════════════════════════════════════════════════════════
   TOP TOOLBAR
   ══════════════════════════════════════════════════════════════════════════ *@
<div class="flex items-center gap-[10px] px-[20px] py-[10px]
            border-b border-[#21262d] shrink-0 bg-[#0d1117]">

    @* Vehicle badge *@
    <span class="text-[0.6rem] font-bold uppercase tracking-widest px-[8px] py-[1px]
                 rounded-full border
                 @(Vehicle.IsRover
                     ? "bg-[#3fb950]/10 text-[#3fb950] border-[#3fb950]/30"
                     : "bg-[#58a6ff]/10 text-[#58a6ff] border-[#58a6ff]/30")">
        @Vehicle.ActiveProfileDisplayName
    </span>

    @* Lock Pitch/Roll — copter only *@
    @if (Vehicle.IsCopter)
    {
        <label class="flex items-center gap-[6px] cursor-pointer select-none">
            <input type="checkbox" class="accent-[#58a6ff]"
                   @bind="_lockPitchRoll" />
            <span class="text-[0.72rem] text-[#8b949e]">Lock Pitch and Roll Values</span>
        </label>
    }

    <div class="flex-1"></div>

    @* Dirty count *@
    @if (_dirtyParams.Count > 0)
    {
        <span class="text-[0.65rem] text-[#f0b429]">
            @_dirtyParams.Count unsaved change(s)
        </span>
    }

    @* Discard *@
    <button class="text-[0.72rem] px-[10px] py-[5px] rounded-[5px] border
                   border-[#30363d] text-[#8b949e] hover:border-[#8b949e]
                   hover:text-white bg-transparent cursor-pointer transition-colors"
            @onclick="Discard">
        Discard
    </button>

    @* Refresh *@
    <button class="text-[0.72rem] px-[10px] py-[5px] rounded-[5px] border
                   border-[#30363d] text-[#8b949e] hover:border-[#58a6ff]
                   hover:text-white bg-transparent cursor-pointer transition-colors"
            @onclick="RefreshFromFc">
        <i class="bi bi-arrow-clockwise mr-[4px]"></i>Refresh
    </button>

    @* Write All *@
    <button class="text-[0.72rem] px-[14px] py-[5px] rounded-[5px] font-bold
                   border-none cursor-pointer transition-colors
                   @(_dirtyParams.Count > 0 && !_isWriting
                       ? "bg-[#f0b429] hover:bg-[#e3a11b] text-black"
                       : "bg-[#21262d] text-[#484f58] cursor-not-allowed")"
            disabled="@(_dirtyParams.Count == 0 || _isWriting)"
            @onclick="WriteAllAsync">
        @if (_isWriting)
        {
            <span class="inline-block w-[11px] h-[11px] border-2 border-black/30
                         border-t-black rounded-full animate-spin mr-[5px]"></span>
        }
        Write Params
    </button>
</div>

@* ══════════════════════════════════════════════════════════════════════════
   PARAMETER GRID
   ══════════════════════════════════════════════════════════════════════════ *@
<div class="flex-1 overflow-y-auto no-scrollbar p-[16px]">

    @* ── PARAMETERS NOT DOWNLOADED GATE ──────────────────────────────────── *@
    @if (Drone.ParameterManager == null || Drone.ParameterManager.ReceivedCount == 0)
    {
        <div class="flex flex-col items-center justify-center h-full gap-[12px]">
            <i class="bi bi-sliders2 text-[#30363d] text-[3rem]"></i>
            <div class="text-[0.85rem] text-[#8b949e]">
                Parameters not downloaded yet
            </div>
            <button class="bg-[#238636] hover:bg-[#2ea043] text-white text-[0.75rem]
                           font-semibold px-[16px] py-[8px] rounded-[6px]
                           border-none cursor-pointer transition-colors"
                    @onclick="DownloadParamsAsync">
                Download Parameters
            </button>
        </div>
    }

    @* ────────────────────────────────────────────────────────────────────── *@
    @* ── ROVER LAYOUT ────────────────────────────────────────────────────── *@
    @* ────────────────────────────────────────────────────────────────────── *@
    else if (Vehicle.IsRover)
    {
        @* Row 1: 3 columns *@
        <div class="grid grid-cols-3 gap-[12px] mb-[12px]">
            <TuningGroup Title="STEERING RATE PID"  AccentColor="#58a6ff"
                         Params="RoverSteeringPid"
                         EditedValues="_editedValues" DirtyParams="_dirtyParams"
                         ReadValue="ReadParam" OnParamChanged="OnParamChanged"
                         OnWriteSingle="WriteSingleAsync" />

            <TuningGroup Title="SPEED / THROTTLE PID" AccentColor="#3fb950"
                         Params="RoverSpeedPid"
                         EditedValues="_editedValues" DirtyParams="_dirtyParams"
                         ReadValue="ReadParam" OnParamChanged="OnParamChanged"
                         OnWriteSingle="WriteSingleAsync" />

            <TuningGroup Title="NAVIGATION"         AccentColor="#f0b429"
                         Params="RoverNavigation"
                         EditedValues="_editedValues" DirtyParams="_dirtyParams"
                         ReadValue="ReadParam" OnParamChanged="OnParamChanged"
                         OnWriteSingle="WriteSingleAsync" />
        </div>

        @* Row 2: 2 columns *@
        <div class="grid grid-cols-2 gap-[12px]">
            <TuningGroup Title="THROTTLE &amp; MOTORS"  AccentColor="#ff6b6b"
                         Params="RoverThrottleMotors"
                         EditedValues="_editedValues" DirtyParams="_dirtyParams"
                         ReadValue="ReadParam" OnParamChanged="OnParamChanged"
                         OnWriteSingle="WriteSingleAsync" />

            <TuningGroup Title="RC CHANNEL OPTIONS" AccentColor="#a78bfa"
                         Params="RoverRcOptions"
                         EditedValues="_editedValues" DirtyParams="_dirtyParams"
                         ReadValue="ReadParam" OnParamChanged="OnParamChanged"
                         OnWriteSingle="WriteSingleAsync" />
        </div>
    }

    @* ────────────────────────────────────────────────────────────────────── *@
    @* ── ARDUCOPTER LAYOUT ───────────────────────────────────────────────── *@
    @* ────────────────────────────────────────────────────────────────────── *@
    else
    {
        @* Row 1: Stabilize + Position XY (4 compact cols) *@
        <div class="grid grid-cols-4 gap-[12px] mb-[12px]">
            <TuningGroup Title="STABILIZE ROLL"  AccentColor="#58a6ff"
                         Params="CopterStabilizeRoll"
                         EditedValues="_editedValues" DirtyParams="_dirtyParams"
                         ReadValue="ReadParam" OnParamChanged="OnParamChanged"
                         OnWriteSingle="WriteSingleAsync" />

            <TuningGroup Title="STABILIZE PITCH" AccentColor="#58a6ff"
                         Params="CopterStabilizePitch"
                         EditedValues="_editedValues" DirtyParams="_dirtyParams"
                         ReadValue="ReadParam" OnParamChanged="OnParamChanged"
                         OnWriteSingle="WriteSingleAsync" />

            <TuningGroup Title="STABILIZE YAW"   AccentColor="#58a6ff"
                         Params="CopterStabilizeYaw"
                         EditedValues="_editedValues" DirtyParams="_dirtyParams"
                         ReadValue="ReadParam" OnParamChanged="OnParamChanged"
                         OnWriteSingle="WriteSingleAsync" />

            <TuningGroup Title="POSITION XY"     AccentColor="#3fb950"
                         Params="CopterPositionXy"
                         EditedValues="_editedValues" DirtyParams="_dirtyParams"
                         ReadValue="ReadParam" OnParamChanged="OnParamChanged"
                         OnWriteSingle="WriteSingleAsync" />
        </div>

        @* Row 2: Rate PIDs + Velocity XY (4 cols) *@
        <div class="grid grid-cols-4 gap-[12px] mb-[12px]">
            <TuningGroup Title="RATE ROLL"        AccentColor="#f0b429"
                         Params="CopterRateRoll"
                         EditedValues="_editedValues" DirtyParams="_dirtyParams"
                         ReadValue="ReadParam" OnParamChanged="OnParamChanged"
                         OnWriteSingle="WriteSingleAsync" />

            <TuningGroup Title="RATE PITCH"       AccentColor="#f0b429"
                         Params="CopterRatePitch"
                         EditedValues="_editedValues" DirtyParams="_dirtyParams"
                         ReadValue="ReadParam" OnParamChanged="OnParamChanged"
                         OnWriteSingle="WriteSingleAsync" />

            <TuningGroup Title="RATE YAW"         AccentColor="#f0b429"
                         Params="CopterRateYaw"
                         EditedValues="_editedValues" DirtyParams="_dirtyParams"
                         ReadValue="ReadParam" OnParamChanged="OnParamChanged"
                         OnWriteSingle="WriteSingleAsync" />

            <TuningGroup Title="VELOCITY XY"      AccentColor="#3fb950"
                         Params="CopterVelocityXy"
                         EditedValues="_editedValues" DirtyParams="_dirtyParams"
                         ReadValue="ReadParam" OnParamChanged="OnParamChanged"
                         OnWriteSingle="WriteSingleAsync" />
        </div>

        @* Row 3: Throttle + Altitude/WPNav + Filters (3 cols) *@
        <div class="grid grid-cols-3 gap-[12px] mb-[12px]">
            <div class="flex flex-col gap-[12px]">
                <TuningGroup Title="THROTTLE ACCEL"  AccentColor="#ff6b6b"
                             Params="CopterThrottleAccel"
                             EditedValues="_editedValues" DirtyParams="_dirtyParams"
                             ReadValue="ReadParam" OnParamChanged="OnParamChanged"
                             OnWriteSingle="WriteSingleAsync" />

                <TuningGroup Title="THROTTLE RATE / ALT HOLD" AccentColor="#ff6b6b"
                             Params="CopterThrottleRateAlt"
                             EditedValues="_editedValues" DirtyParams="_dirtyParams"
                             ReadValue="ReadParam" OnParamChanged="OnParamChanged"
                             OnWriteSingle="WriteSingleAsync" />
            </div>

            <TuningGroup Title="WPNAV (cm/s)"       AccentColor="#a78bfa"
                         Params="CopterWpNav"
                         EditedValues="_editedValues" DirtyParams="_dirtyParams"
                         ReadValue="ReadParam" OnParamChanged="OnParamChanged"
                         OnWriteSingle="WriteSingleAsync" />

            <div class="flex flex-col gap-[12px]">
                <TuningGroup Title="BASIC FILTERS"   AccentColor="#00f2ff"
                             Params="CopterBasicFilters"
                             EditedValues="_editedValues" DirtyParams="_dirtyParams"
                             ReadValue="ReadParam" OnParamChanged="OnParamChanged"
                             OnWriteSingle="WriteSingleAsync" />

                <TuningGroup Title="RC CHANNEL OPTIONS" AccentColor="#a78bfa"
                             Params="CopterRcOptions"
                             EditedValues="_editedValues" DirtyParams="_dirtyParams"
                             ReadValue="ReadParam" OnParamChanged="OnParamChanged"
                             OnWriteSingle="WriteSingleAsync" />
            </div>
        </div>

        @* Row 4: Notch filters (2 cols) *@
        <div class="grid grid-cols-2 gap-[12px]">
            <TuningGroup Title="STATIC NOTCH FILTER"   AccentColor="#00f2ff"
                         Params="CopterStaticNotch"
                         EditedValues="_editedValues" DirtyParams="_dirtyParams"
                         ReadValue="ReadParam" OnParamChanged="OnParamChanged"
                         OnWriteSingle="WriteSingleAsync" />

            <TuningGroup Title="HARMONIC NOTCH FILTER" AccentColor="#00f2ff"
                         Params="CopterHarmonicNotch"
                         EditedValues="_editedValues" DirtyParams="_dirtyParams"
                         ReadValue="ReadParam" OnParamChanged="OnParamChanged"
                         OnWriteSingle="WriteSingleAsync" />
        </div>
    }
</div>

@code {
    // ── Local state ────────────────────────────────────────────────────────────
    private readonly Dictionary<string, float> _editedValues  = new();
    private readonly HashSet<string>           _dirtyParams   = new();
    private bool  _lockPitchRoll = false;
    private bool  _syncing       = false;
    private bool  _isWriting     = false;

    // ── Lifecycle ──────────────────────────────────────────────────────────────

    protected override void OnInitialized()
    {
        Vehicle.OnProfileChanged += HandleProfileChanged;
        if (Drone.ParameterManager != null)
        Drone.ParameterManager.OnParameterLiveUpdate += HandleParamLiveUpdate;
    }

    private void HandleParamLiveUpdate(ParameterEntry entry)
    {
        // Only re-render if this param isn't locally edited (don't stomp unsaved changes)
        if (!_dirtyParams.Contains(entry.Id))
            try { _ = InvokeAsync(StateHasChanged); }
            catch (ObjectDisposedException) { }
    }

    public void Dispose()
    {
        Vehicle.OnProfileChanged -= HandleProfileChanged;
        if (Drone.ParameterManager != null)
        Drone.ParameterManager.OnParameterLiveUpdate -= HandleParamLiveUpdate;
    }

    private void HandleProfileChanged(VehicleProfile newProfile)
    {
        // Clear all edits when vehicle type changes — Rover and Copter params differ
        _editedValues.Clear();
        _dirtyParams.Clear();
        _lockPitchRoll = false;
        try { _ = InvokeAsync(StateHasChanged); }
        catch (ObjectDisposedException) { }
    }

    // ── Parameter read ─────────────────────────────────────────────────────────

    private float ReadParam(ParameterDefinition p)
    {
        var pm = Drone.ParameterManager;
        if (pm == null) return p.Default;

        // Check local edited values first
        if (_editedValues.TryGetValue(p.Name, out var ev)) return ev;

        // Try modern name
        var v = pm.GetValue(p.Name);
        if (v.HasValue) return v.Value;

        // Try legacy name
        if (p.LegacyName != null)
        {
            if (_editedValues.TryGetValue(p.LegacyName, out var lev)) return lev;
            v = pm.GetValue(p.LegacyName);
            if (v.HasValue) return v.Value;
        }

        return p.Default;
    }

    // ── Parameter change handler — owns dirty tracking + Lock P/R sync ─────────

    private void OnParamChanged((string Name, float Value) args)
    {
        _editedValues[args.Name] = args.Value;
        _dirtyParams.Add(args.Name);

        // ── Lock Pitch/Roll synchronisation (Q2) ─────────────────────────────
        if (_lockPitchRoll && !_syncing)
        {
            _syncing = true;
            try
            {
                string? mirror = args.Name switch
                {
                    // Roll → Pitch
                    "ATC_RAT_RLL_P"  => "ATC_RAT_PIT_P",
                    "ATC_RAT_RLL_I"  => "ATC_RAT_PIT_I",
                    "ATC_RAT_RLL_D"  => "ATC_RAT_PIT_D",
                    "ATC_RAT_RLL_FF" => "ATC_RAT_PIT_FF",
                    "ATC_RAT_RLL_FLTE" => "ATC_RAT_PIT_FLTE",
                    "ATC_RAT_RLL_FLTD" => "ATC_RAT_PIT_FLTD",
                    "ATC_RAT_RLL_FLTT" => "ATC_RAT_PIT_FLTT",
                    // Pitch → Roll
                    "ATC_RAT_PIT_P"  => "ATC_RAT_RLL_P",
                    "ATC_RAT_PIT_I"  => "ATC_RAT_RLL_I",
                    "ATC_RAT_PIT_D"  => "ATC_RAT_RLL_D",
                    "ATC_RAT_PIT_FF" => "ATC_RAT_RLL_FF",
                    "ATC_RAT_PIT_FLTE" => "ATC_RAT_RLL_FLTE",
                    "ATC_RAT_PIT_FLTD" => "ATC_RAT_RLL_FLTD",
                    "ATC_RAT_PIT_FLTT" => "ATC_RAT_RLL_FLTT",
                    _ => null
                };
                if (mirror != null)
                {
                    _editedValues[mirror] = args.Value;
                    _dirtyParams.Add(mirror);
                }
            }
            finally { _syncing = false; }
        }

        StateHasChanged();
    }

    // ── Write operations ───────────────────────────────────────────────────────

    private async Task WriteAllAsync()
    {
        if (Drone.ParameterManager == null || _dirtyParams.Count == 0) return;
        _isWriting = true;
        StateHasChanged();

        var writes = _dirtyParams.ToList();
        foreach (var name in writes)
        {
            if (!_editedValues.TryGetValue(name, out var val)) continue;
            try
            {
                await Drone.ParameterManager.WriteParameterAsync(name, val);
                _dirtyParams.Remove(name);
            }
            catch (Exception)
            {
                // Keep in dirty set so operator can retry
            }
        }

        _isWriting = false;
        StateHasChanged();
    }

    private async Task WriteSingleAsync((string Name, float Value) args)
    {
        if (Drone.ParameterManager == null) return;
        await Drone.ParameterManager.WriteParameterAsync(args.Name, args.Value);
        _dirtyParams.Remove(args.Name);
        StateHasChanged();
    }

    private void Discard()
    {
        _editedValues.Clear();
        _dirtyParams.Clear();
        StateHasChanged();
    }

    private async Task RefreshFromFc()
    {
        Discard();
        if (Drone.ParameterManager != null)
            await Drone.ParameterManager.RequestAllParametersAsync(
                Vehicle.IsRover
                    ? ArduPilotVehicleType.Rover
                    : ArduPilotVehicleType.ArduCopter);
    }

    private async Task DownloadParamsAsync()
    {
        if (Drone.ParameterManager != null)
            await Drone.ParameterManager.RequestAllParametersAsync(
                Vehicle.IsRover
                    ? ArduPilotVehicleType.Rover
                    : ArduPilotVehicleType.ArduCopter);
    }

    // ══════════════════════════════════════════════════════════════════════════
    // PARAMETER DEFINITIONS
    // ══════════════════════════════════════════════════════════════════════════

    private static readonly Dictionary<int, string> RcCopterOptions = new()
