@page "/messages"
@inject MavlinkService Drone
@inject IJSRuntime JS
@implements IDisposable

<div class="flex flex-col h-full gap-[16px] p-[20px] bg-transparent w-full max-w-[500px] mx-auto overflow-hidden">

    <div class="h-[300px] w-full rounded-[8px] overflow-hidden shadow-[0_4px_20px_rgba(0,0,0,0.4)] border border-[#333] shrink-0 bg-black">
        <Hud />
    </div>

    <div class="flex flex-col flex-1 gap-[10px] min-h-0">
        <div class="bg-[rgba(18,20,28,0.8)] border border-[rgba(0,242,255,0.2)] rounded-[6px] p-[8px] flex items-center justify-center text-[#00f2ff] font-semibold text-[1.1rem] tracking-[1.5px] uppercase backdrop-blur-[4px] shrink-0">
        <span class="flex items-center gap-[10px]">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-monitor-cog">
            <path d="M12 17v4"/><path d="m14.305 7.53.923-.382"/><path d="m15.228 4.852-.923-.383"/><path d="m16.852 3.228-.383-.924"/><path d="m16.852 8.772-.383.923"/><path d="m19.148 3.228.383-.924"/><path d="m19.53 9.696-.382-.924"/><path d="m20.772 4.852.924-.383"/><path d="m20.772 7.148.924.383"/><path d="M22 13v2a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7"/><path d="M8 21h8"/><circle cx="18" cy="6" r="3"/>
        </svg>
        <span>SYSTEM TERMINAL (@Drone.StatusMessages.Count)</span>
    </span>
    </div>

        <div id="terminal-scroll" class="flex-1 bg-[rgba(5,5,10,0.9)] border border-[#222] rounded-[6px] p-[12px] overflow-y-auto font-mono shadow-[inset_0_0_15px_rgba(0,0,0,0.8)]" @ref="_consoleWindow">
            @if (Drone.StatusMessages.Count == 0)
            {
                <div class="flex flex-col items-center justify-center h-full text-[#444] text-[0.8rem]">
                    <span class="w-[8px] h-[8px] bg-[#444] rounded-full mb-[10px] animate-[pulse_1.5s_infinite]"></span>
                    WAITING FOR SYSTEM DATA...
                </div>
            }
            else
            {
                <div class="flex flex-col">
                    @foreach (var msg in Drone.GetSafeStatusMessages())
                    {
                        var isCritical = msg.Contains("Arm");
                        <div class="text-[0.85rem] border-b border-[#111] pb-[4px] mb-[4px] leading-[1.4] @(isCritical ? "text-[#ff3a3a] font-bold" : "text-[#00ff00]")">
                            @msg
                        </div>
                    }
                </div>
            }
        </div>

        <button class="bg-[rgba(255,255,255,0.05)] border border-[#333] text-[#888] p-[8px] rounded-[4px] text-[1rem] cursor-pointer shrink-0 transition-colors hover:bg-[rgba(255,255,255,0.1)] hover:text-white" @onclick="ClearLogs">
            CLEAR SYSTEM LOGS
        </button>
    </div>
</div>

@code {
    private ElementReference _consoleWindow;
    private bool _shouldScroll = false;
    private DateTime _lastScroll = DateTime.MinValue;

    protected override void OnInitialized()
    {
        Drone.OnMessageReceived += RefreshUi;
    }

    private void RefreshUi(string msg)
    {
        _shouldScroll = true;

        // Batch terminal updates to prevent layout thrashing
        if ((DateTime.UtcNow - _lastScroll).TotalMilliseconds > 200)
        {
            _lastScroll = DateTime.UtcNow;
            InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldScroll || firstRender)
        {
            _shouldScroll = false;
            try
            {
                // Instant jump to the very top of the scroll container
                await JS.InvokeVoidAsync("eval",
                    "var el=document.getElementById('terminal-scroll'); if(el) el.scrollTop=0;");
            }
            catch { }
        }
    }

    private void ClearLogs()
    {
        lock (Drone.StatusMessages) { Drone.StatusMessages.Clear(); }
        StateHasChanged();
    }

    public void Dispose() => Drone.OnMessageReceived -= RefreshUi;
}