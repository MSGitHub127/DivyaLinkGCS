@page "/"
@inject IJSRuntime JS
@inject MavlinkService Drone
@inject IConfiguration Config
@implements IAsyncDisposable
@inject DgcaAirspaceService AirspaceSvc

@* ── THE MAP LAYER ──
     Fullscreen state: map shrinks to a mini PiP box in the corner
     All other states:  map fills the entire screen                   *@
<div class="transition-all duration-300 ease-in-out @(_videoState == VideoState.Fullscreen ? "absolute z-[1000] border-2 border-[#58a6ff] rounded-[8px] shadow-[0_10px_40px_rgba(0,0,0,0.5)] overflow-hidden w-[340px] h-[240px] cursor-pointer hover:border-[#00f2ff] group" : "absolute inset-0 z-[0]")"
     style="@(_videoState == VideoState.Fullscreen ? "bottom: 90px; right: 20px;" : "")"
     @onclick="CollapseVideoIfFullscreen">

    <div id="map-element" class="w-full h-full"></div>

    @* 'Click to Swap' hover overlay — only visible during fullscreen video swap *@
    @if (_videoState == VideoState.Fullscreen)
    {
        <div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity z-[2000]">
            <span class="bg-[#0a0b0d]/80 text-white px-3 py-1 rounded-full text-[0.7rem] font-bold border border-[#58a6ff]">SWAP TO MAP</span>
        </div>
    }
</div>

@* Coordinate readout — bottom-left, always visible *@
<div id="map-coord-log" class="fixed bottom-[30px] left-[12px] z-[10] bg-[rgba(10,11,13,0.85)] backdrop-blur-md border border-[#30363d] rounded-[5px] px-[10px] py-[5px] text-[0.62rem] font-mono text-[#00f2ff] pointer-events-none leading-[1.6]">
    LAT: —<br>LNG: —
</div>

@* Map fullscreen toggle button *@
<button class="fixed top-[72px] left-[12px] z-[10] w-[34px] h-[34px] pointer-events-auto bg-[rgba(10,11,13,0.85)] backdrop-blur-md border rounded-[6px] text-[0.95rem] cursor-pointer flex items-center justify-center transition-all duration-150 hover:bg-[#161b22] hover:text-[#00f2ff] hover:border-[#58a6ff] @(_mapExpanded ? "border-[#f0b429] text-[#f0b429]" : "border-[#30363d] text-[#58a6ff]")"
        @onclick="ToggleExpand">
    <i class="bi @(_mapExpanded ? "bi-fullscreen-exit" : "bi-fullscreen")"></i>
</button>

@* ── RIGHT-SIDE TELEMETRY + VIDEO OVERLAY ── *@
<div class="fixed top-[calc(var(--header-height)+12px)] right-[16px] flex flex-col items-end gap-[10px] z-[10] pointer-events-none"">
    @{
        var statBoxBase = "pointer-events-auto bg-[rgba(10,11,13,0.3)] border border-[rgba(255,255,255,0.15)] rounded-[12px] px-[14px] py-[10px] flex items-center gap-[12px] w-[170px] backdrop-blur-sm shadow-lg transition-all duration-300";
        var statLabel   = "text-[0.8rem] text-[#a1aab5] uppercase tracking-[1px] font-bold whitespace-nowrap mb-[2px] drop-shadow-md";
        var statVal     = "text-[1rem] font-semibold text-white whitespace-nowrap drop-shadow-md";
        var statSmall   = "text-[1rem] text-[#00f2ff] font-semibold ml-[3px] drop-shadow-md";
    }

    @* ── BATTERY ── *@
    <div class="@statBoxBase flex items-center gap-[12px] p-[10px_14px] bg-[rgba(0,0,0,0.5)] backdrop-blur-md border border-[rgba(255,255,255,0.1)] rounded-[10px]">
        <div class="text-[1.4rem] shrink-0 drop-shadow-lg @BPC">
            @if (Drone.State.BatteryPercent > 20)
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00FF00" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="16" height="10" x="2" y="7" rx="2" />
                    <line x1="22" x2="22" y1="11" y2="13" />
                    <rect width="@(Drone.State.BatteryPercent * 14 / 100)" height="6" x="3" y="9" fill="#00FF00" opacity="0.9" />
                </svg>
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FF0000" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="animate-pulse">
                    <path d="M10 7v4" /><path d="M10 15h.01" />
                    <rect width="16" height="10" x="2" y="7" rx="2" /><line x1="22" x2="22" y1="11" y2="13" />
                </svg>
            }
        </div>
        <div class="flex flex-col min-w-0 leading-tight">
            <div class="@statLabel uppercase tracking-[1.5px] text-[0.6rem] font-black text-[#8b949e]">BATTERY</div>
            <div class="@statVal font-mono text-[1.1rem] font-black @(Drone.State.BatteryPercent < 20 ? "text-[#ff3a3a]" : "text-white")">
                @Drone.State.BatteryPercent<span class="text-[0.7rem] ml-[1px]">%</span>
                <small class="@statSmall ml-[6px] text-[0.75rem] font-bold text-[#00f2ff] opacity-80">
                    @Drone.State.Voltage.ToString("0.0")V
                </small>
            </div>
        </div>
    </div>

    @* ── GROUND SPEED ── *@
    <div class="@statBoxBase">
        <div class="text-[1.2rem] shrink-0 drop-shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>
                <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09"/>
                <path d="M9 12a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.4 22.4 0 0 1-4 2z"/>
                <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 .05 5 .05"/>
            </svg>
        </div>
        <div class="flex flex-col min-w-0">
            <div class="@statLabel">Ground Speed</div>
            <div class="@statVal">@Drone.State.GroundSpeed.ToString("0.0") <small class="@statSmall">m/s</small></div>
        </div>
    </div>

    @* ── ALTITUDE ── *@
    <div class="@statBoxBase">
        <div class="text-[1.2rem] shrink-0 drop-shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path class="text-[#ffffff]" stroke="currentColor" d="M2 21c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1 .6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 .6 0 1.2.1 1.5.3" />
                <path class="text-[#ffffff]" stroke="currentColor" d="m2 17 5-5 3 3 5-7 3 4" />
                <g class="text-[#ffffff]" stroke="currentColor">
                    <path d="M21 7v10" /><path d="m19 9 2-2 2 2" />
                    <path d="m19 15 2 2 2-2" />
                    <path d="M19 3.5c.5 0 1 .5 2 1.5.8-1 1.5-1.5 2-1.5" />
                </g>
            </svg>
        </div>
        <div class="flex flex-col min-w-0">
            <div class="@statLabel">Altitude (AGL)</div>
            <div class="@statVal">@Drone.State.Altitude.ToString("0") <small class="@statSmall">m</small></div>
        </div>
    </div>

    @* ── VIDEO LAYER ── *@
    @if (_videoEnabled)
    {
        @if (_videoState == VideoState.Standby)
        {
            @* STATE 1 — Collapsed pill button *@
            <div class="fixed z-[1000] pointer-events-auto" style="bottom: 90px; right: 20px;">
                <button class="bg-[#0a0b0d]/90 backdrop-blur-md border border-[#30363d] hover:border-[#f0b429] hover:bg-[#161b22] text-[#8b949e] hover:text-[#f0b429] p-[10px_18px] rounded-[20px] shadow-[0_4px_15px_rgba(0,0,0,0.4)] flex items-center gap-[12px] transition-all duration-300 group animate-[fadeIn_0.2s_ease-out]"
                        @onclick="ToggleVideo">
                    <div class="relative">
                        <i class="bi bi-camera-video text-[1.2rem]"></i>
                        <div class="absolute -top-[2px] -right-[2px] w-[8px] h-[8px] rounded-full @(_videoStatus == "Connected" ? "bg-[#3fb950]" : "bg-[#f0b429]") animate-pulse"></div>
                    </div>
                    <div class="flex flex-col text-left">
                        <span class="text-[0.6rem] font-extrabold tracking-[1px] @(_videoStatus == "Connected" ? "text-[#3fb950]" : "text-[#f0b429]") uppercase leading-none">@_videoStatus</span>
                        <span class="text-[0.75rem] font-bold text-white group-hover:text-white transition-colors mt-[2px] leading-none">Video Feed</span>
                    </div>
                </button>
            </div>
        }
        else
        {
            @* STATE 2 (PiP) and STATE 3 (Fullscreen) — the video player panel
               Fullscreen: fixed inset-0, z-[0] so telemetry HUD sits on top
               PiP:        fixed 340×240 box at bottom-right, z-[1000]          *@
            <div class="pointer-events-auto transition-all duration-300 ease-in-out overflow-hidden flex flex-col @(_videoState == VideoState.Fullscreen ? "fixed inset-0 z-[0] bg-black" : "fixed z-[1000] bg-[#0a0b0d]/95 backdrop-blur-md border border-[#f0b429] rounded-[8px] shadow-[0_10px_40px_rgba(0,0,0,0.5)] w-[340px] h-[240px] animate-[zoomIn_0.2s_ease-out] origin-bottom-right")"
                 style="@(_videoState == VideoState.Fullscreen ? "" : "bottom: 90px; right: 20px;")">

                @* Header bar — floats top-right when fullscreen, docked when PiP *@
                <div class="@(_videoState == VideoState.Fullscreen ? "absolute top-[20px] right-[20px] bg-[#0a0b0d]/80 backdrop-blur-md rounded-[8px] border border-[#30363d] z-[60] shadow-lg" : "bg-[#161b22] border-b border-[#30363d] shrink-0 z-[60]") p-[8px_12px] flex items-center justify-between transition-all">
                    <div class="flex items-center gap-[8px] mr-4">
                        <span class="w-[8px] h-[8px] rounded-full @(_videoStatus == "Connected" ? "bg-[#3fb950] animate-pulse" : "bg-[#f0b429]")"></span>
                        <span class="text-[0.65rem] font-bold @(_videoStatus == "Connected" ? "text-[#3fb950]" : "text-[#f0b429]") tracking-[1.5px] uppercase">@_videoStatus</span>
                    </div>

                    <div class="flex items-center gap-[15px]">
                        @* Swap / fullscreen toggle *@
                        <button class="text-[#8b949e] hover:text-white transition-colors cursor-pointer border-none bg-transparent flex items-center justify-center p-0"
                                @onclick="ToggleVideoExpand" title="Swap Views">
                            <i class="bi @(_videoState == VideoState.Fullscreen ? "bi-fullscreen-exit" : "bi-fullscreen") text-[1.1rem]"></i>
                        </button>

                        @* Minimize — hidden in fullscreen to keep the header clean *@
                        @if (_videoState != VideoState.Fullscreen)
                        {
                            <button class="text-[#8b949e] hover:text-[#f85149] transition-colors cursor-pointer border-none bg-transparent flex items-center justify-center p-0"
                                    @onclick="ToggleVideo" title="Minimize">
                                <i class="bi bi-dash-lg text-[1.3rem]"></i>
                            </button>
                        }
                    </div>
                </div>

                @* WebRTC video feed *@
                <div class="flex-1 relative bg-black flex flex-col items-center justify-center w-full h-full">
                    <video id="webrtc-video" autoplay muted playsinline class="w-full h-full object-cover absolute inset-0"></video>
                    @if (_videoStatus != "Connected")
                    {
                        <div class="absolute inset-0 flex flex-col items-center justify-center bg-[#0a0b0d] z-[10]">
                            <i class="bi bi-camera-video-off text-[#30363d] text-5xl mb-3"></i>
                            <span class="text-[#555] font-mono text-[0.8rem] tracking-[3px] font-bold">STANDBY</span>
                        </div>
                    }
                </div>
            </div>
        }
    }

</div>

@code {
    // ── VIDEO STATE MACHINE ────────────────────────────────────────────────
    // Single enum replaces the two-boolean system (_isVideoExpanded + _videoExpanded).
    // Every transition goes through SetVideoState() — the toast sync is
    // guaranteed by OnAfterRenderAsync and cannot be missed by any code path.

    private enum VideoState { Standby, Pip, Fullscreen }

    private VideoState _videoState = VideoState.Standby;

    // Derived from state — NEVER computed at call sites.
    // PiP player: h-[240px] positioned at bottom: 90px
    //   → top of player = 90 + 240 = 330px from screen bottom
    //   → uplift = 330 + 6px breathing room = 336px
    // Fullscreen / Standby: toasts stay at their default position (0px uplift).
    private int ToastUpliftPx => _videoState switch
    {
        VideoState.Pip        => 200,
        VideoState.Standby    => 0,
        VideoState.Fullscreen => 200,
        _                     => 0
    };

    // Guards OnAfterRenderAsync against redundant JS calls.
    // -1 = never synced this session, so the first render always runs.
    private int _syncedUplift = -1;

    // ── OTHER STATE ───────────────────────────────────────────────────────
    private bool _mapInitialized = false;
    private bool _jumpedToDrone  = false;
    private bool _mapExpanded    = false;
    private bool _videoEnabled   = false;
    private string _videoStatus  = "Disconnected";
    private bool _airspaceLoaded = false;

    public static event Action<string>? VideoStatusUpdated;

    private DateTime _lastJsUpdateUtc = DateTime.MinValue;
    private readonly TimeSpan _jsMinPeriod = TimeSpan.FromMilliseconds(200);

    private DateTime _lastHomeRender = DateTime.MinValue;

    private string BPC => Drone.State.BatteryPercent switch
    {
        <= 10 => "bv-c",
        <= 25 => "bv-l",
        _     => "bv-ok"
    };

    // ── LIFECYCLE ─────────────────────────────────────────────────────────

    protected override void OnInitialized()
    {
        Drone.OnTelemetryUpdated += HandleTelemetryUpdated;
        VideoStatusUpdated       += HandleVideoStatusUpdate;
        _videoEnabled = Config.GetValue<bool>("VideoStreaming:Enabled", true);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // ── First-render: initialise map and video stream ─────────────────
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initMap", 0.0, 0.0);
            _mapInitialized = true;
            await Task.Delay(300);
            await JS.InvokeVoidAsync("eval", "if (window._gcsMap) window._gcsMap.invalidateSize();");

            if (_videoEnabled)
            {
                string webrtcUrl = Config["VideoStreaming:WebRTCUrl"]
                    ?? "http://127.0.0.1:8889/live/whep";
                Console.WriteLine($"[WebRTC] Starting low-latency stream: {webrtcUrl}");

                _videoStatus = "Connecting";
                StateHasChanged();

                await Task.Delay(500);
                await JS.InvokeVoidAsync("initWebRTCStream", webrtcUrl);
            }
        }

        // ── Every render: sync toast position if video state changed ──────
        // This is the SINGLE authoritative call site for setToastUplift.
        // Because it runs after every render, no toggle method can ever
        // leave the toast position in the wrong place.
        int target = ToastUpliftPx;
        if (target != _syncedUplift)
        {
            await JS.InvokeVoidAsync("setToastUplift", target);
            _syncedUplift = target;
        }
    }

    // IAsyncDisposable: resets the toast uplift when the user navigates
    // away from Home.razor while the video is expanded, preventing the
    // CSS variable from staying "stuck" on other pages.
    public async ValueTask DisposeAsync()
    {
        Drone.OnTelemetryUpdated -= HandleTelemetryUpdated;
        VideoStatusUpdated       -= HandleVideoStatusUpdate;

        if (_syncedUplift != 0)
        {
            try { await JS.InvokeVoidAsync("setToastUplift", 0); }
            catch { /* component already torn down — safe to swallow */ }
        }
    }

    private async Task LoadAirspaceOnceAsync(double lat, double lon)
    {
        // Only load once per session — MainLayout.LoadAirspaceForRegion
        // already handles the 5 km re-fetch internally.
        if (_airspaceLoaded) return;
        _airspaceLoaded = true;

        try
        {
            // Fetch GeoJSON from DGCA and push it to the Leaflet layer
            double pad = 0.5;
            string geoJson = await AirspaceSvc.GetAirspaceGeoJsonAsync(
               lat - pad, lon - pad, lat + pad, lon + pad);
            await JS.InvokeVoidAsync("airspace.loadZones", geoJson);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[DGCA] Airspace load failed: {ex.Message}");
        }
    }

    // ── VIDEO STATE TRANSITIONS ───────────────────────────────────────────

    // All transitions funnel through here.
    // StateHasChanged() triggers a re-render → OnAfterRenderAsync → toast sync.
    private Task SetVideoState(VideoState next)
    {
        if (_videoState == next) return Task.CompletedTask;
        _videoState = next;
        StateHasChanged();
        return Task.CompletedTask;
    }

    // Button pill → PiP, or PiP → Button pill
    private Task ToggleVideo()
    {
        return _videoState switch
        {
            VideoState.Standby    => SetVideoState(VideoState.Pip),
            VideoState.Pip        => SetVideoState(VideoState.Standby),
            VideoState.Fullscreen => SetVideoState(VideoState.Pip),  // safety fallback
            _                     => Task.CompletedTask
        };
    }

    // PiP ↔ Fullscreen swap (also resizes the Leaflet map)
    private async Task ToggleVideoExpand()
    {
        var next = _videoState == VideoState.Fullscreen
            ? VideoState.Pip
            : VideoState.Fullscreen;

        await SetVideoState(next);

        // Leaflet breaks silently when its container size changes — invalidate it
        try { await JS.InvokeVoidAsync("animateMapResize"); } catch { }
    }

    // Clicking the mini-map during fullscreen swaps back to PiP
    private Task CollapseVideoIfFullscreen()
    {
        if (_videoState == VideoState.Fullscreen)
            return SetVideoState(VideoState.Pip);
        return Task.CompletedTask;
    }

    // ── MAP STATE ─────────────────────────────────────────────────────────

    private async Task ToggleExpand()
    {
        _mapExpanded = !_mapExpanded;
        try
        {
            await JS.InvokeVoidAsync(_mapExpanded ? "expandMap" : "collapseMap");
        }
        catch { }
    }

    private string GetMapClasses()
    {
        if (_videoState == VideoState.Fullscreen)
        {
            return $"fixed {GetVideoPosition()} z-[70] w-[320px] aspect-video bg-[#0a0b0d] border border-[#30363d] rounded-[8px] overflow-hidden shadow-2xl pointer-events-auto transition-all duration-300 cursor-pointer";
        }
        if (_mapExpanded)
        {
            return "fixed inset-0 w-full h-screen bg-[#0a0b0d] z-[50] pointer-events-auto transition-all duration-300";
        }
        return "absolute inset-0 w-full h-full bg-[#0a0b0d] z-[0] pointer-events-auto transition-all duration-300";
    }

    private string GetVideoClasses()
    {
        if (_videoState == VideoState.Fullscreen)
        {
            return "fixed inset-0 w-full h-screen bg-black z-[0] pointer-events-auto transition-all duration-300";
        }
        return $"relative w-[320px] aspect-video bg-black border {GetVideoBorderColor()} rounded-[8px] overflow-hidden shadow-2xl pointer-events-auto transition-all duration-300 cursor-pointer hover:border-[#58a6ff]";
    }

    // ── TELEMETRY / MAP UPDATES ───────────────────────────────────────────

    private void HandleTelemetryUpdated()
    {
        _ = InvokeAsync(async () =>
        {
            await TryJumpOrUpdateAsync();

            var now = DateTime.UtcNow;
            if ((now - _lastHomeRender).TotalMilliseconds < 250) return;
            _lastHomeRender = now;
            StateHasChanged();
        });
    }

    private static bool HasValidGps(double lat, double lon)
    {
        if (double.IsNaN(lat) || double.IsNaN(lon)) return false;
        if (Math.Abs(lat) < 0.000001 && Math.Abs(lon) < 0.000001) return false;
        if (lat < -90  || lat > 90)   return false;
        if (lon < -180 || lon > 180)  return false;
        return true;
    }

    private async Task TryJumpOrUpdateAsync()
    {
        if (!_mapInitialized) return;
        var lat     = Drone.State.Latitude;
        var lon     = Drone.State.Longitude;
        var heading = Drone.State.Yaw;
        if (!HasValidGps(lat, lon)) return;

        var now = DateTime.UtcNow;
        if (now - _lastJsUpdateUtc < _jsMinPeriod) return;
        _lastJsUpdateUtc = now;

        var extra = new
        {
            alt  = (double)Drone.State.Altitude,
            spd  = (double)Drone.State.GroundSpeed,
            bat  = (int)Drone.State.BatteryPercent,
            hdop = Drone.State.SatCount > 0
                ? Math.Max(0.5, 5.0 - Drone.State.SatCount * 0.3)
                : 5.0
        };

        try
        {
            if (!_jumpedToDrone)
            {
                await JS.InvokeVoidAsync("jumpToDrone", lat, lon, heading, extra);
                _jumpedToDrone = true;
                _ = LoadAirspaceOnceAsync(lat, lon);
                return;
            }
            await JS.InvokeVoidAsync("updateMapPos", lat, lon, heading, extra);
        }
        catch (Exception ex) { Console.WriteLine($"Map Error: {ex.Message}"); }
    }

    // ── VIDEO STATUS (called from JS via JSInvokable) ─────────────────────

    private void HandleVideoStatusUpdate(string status)
    {
        _videoStatus = status;
        _ = InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public static Task OnVideoStatusChanged(string status)
    {
        Console.WriteLine($"[VIDEO] Status changed: {status}");
        VideoStatusUpdated?.Invoke(status);
        return Task.CompletedTask;
    }

    // ── LEGACY CLICK HELPERS (kept for any external references) ──────────
    // Both now delegate through SetVideoState so toast sync is guaranteed.

    private Task HandleMapClick()
    {
        if (_videoState == VideoState.Fullscreen)
            return ToggleVideoExpand();
        return Task.CompletedTask;
    }

    private Task HandleVideoClick()
    {
        if (_videoState != VideoState.Fullscreen)
            return ToggleVideoExpand();
        return Task.CompletedTask;
    }

    // ── HELPERS ───────────────────────────────────────────────────────────

    private string GetVideoPosition()
    {
        string pos = Config["VideoStreaming:VideoPosition"] ?? "bottom-right";
        return pos.ToLower() switch
        {
            "bottom-right" => "bottom-[25px] right-[12px]",
            "bottom-left"  => "bottom-[25px] left-[12px]",
            "top-right"    => "top-[72px] right-[12px]",
            "top-left"     => "top-[72px] left-[12px]",
            _              => "bottom-[25px] right-[12px]"
        };
    }

    private string GetVideoBorderColor()
    {
        return _videoStatus switch
        {
            "Connected"  => "border-[#2ea043]",
            "Connecting" => "border-[#58a6ff]",
            "Standby"    => "border-[#f0b429]",
            "Error"      => "border-[#ff3a3a]",
            _            => "border-[#30363d]"
        };
    }
}
