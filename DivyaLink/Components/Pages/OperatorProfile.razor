@page "/operator-profile"
@inject NavigationManager Navigation
@inject MavlinkService Drone
@inject DivyaLink.Services.LicenseService License
@inject IJSRuntime JS

<div class="h-full w-full bg-[#0a0b0d] text-white p-6 md:p-10 font-sans overflow-y-auto" style="padding-top: 95px !important;">
    <!-- Header -->
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
        <div>
            <button class="mb-3 px-4 py-1.5 rounded-[6px] bg-[#1c1f26] border border-[#30363d] hover:border-[#58a6ff] hover:text-[#58a6ff] text-gray-300 font-bold text-[0.8rem] flex items-center gap-2 cursor-pointer transition-all duration-200"
                    @onclick="GoBack">
                <i class="bi bi-arrow-left text-[1.1rem]"></i> BACK TO DASHBOARD
            </button>
            <h1 class="text-3xl font-black tracking-tight bg-gradient-to-r from-white via-gray-200 to-gray-400 bg-clip-text text-transparent">
                OPERATOR PROFILE & SETTINGS
            </h1>
            <p class="text-gray-400 text-xs mt-1 uppercase tracking-[1px]">Manage pilot credentials, logs, and GCS preferences</p>
        </div>
        <div class="flex items-center gap-3 bg-[#11141c] border border-[#242731] rounded-[10px] p-3 shadow-lg">
            <span class="w-2.5 h-2.5 rounded-full bg-[#00ff00] animate-pulse"></span>
            <span class="text-xs font-bold text-gray-300 tracking-[0.5px]">PILOT STATUS: ACTIVE</span>
        </div>
    </div>

    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Left Side: Profile Summary & Stats -->
        <div class="lg:col-span-1 flex flex-col gap-6">
            <!-- Profile Card -->
            <div class="bg-[#11141c]/80 backdrop-blur-md border border-[#242731] rounded-[12px] p-6 shadow-xl text-center relative overflow-hidden">
                <div class="absolute -top-10 -right-10 w-24 h-24 bg-blue-600/10 rounded-full blur-2xl"></div>
                <div class="absolute -bottom-10 -left-10 w-24 h-24 bg-purple-600/10 rounded-full blur-2xl"></div>

                <div class="w-[80px] h-[80px] rounded-full bg-gradient-to-tr from-[#3a86ff] to-[#7e3ff2] flex items-center justify-center font-black text-2xl text-white shadow-2xl mx-auto mb-4 border-2 border-[#30363d]">
                    FA
                </div>
                <h2 class="text-xl font-black tracking-tight">Faheem</h2>
                <p class="text-[#3fb950] font-bold text-xs uppercase tracking-[0.5px] mt-0.5">Admin Operator</p>
                <p class="text-gray-500 text-[0.7rem] mt-2">Operator ID: VN-OP-2026-081</p>
                
                <div class="border-t border-[#242731] mt-6 pt-4 flex flex-col gap-2">
                    <div class="flex justify-between items-center text-xs">
                        <span class="text-gray-400 font-semibold">License Tier</span>
                        <span class="px-2 py-0.5 rounded bg-blue-500/10 border border-blue-500/30 text-[#3a86ff] font-extrabold text-[0.7rem]">@License.LicenseTier</span>
                    </div>
                    <div class="flex justify-between items-center text-xs">
                        <span class="text-gray-400 font-semibold">Valid For</span>
                        <span class="text-white font-bold">@License.RemainingDaysText</span>
                    </div>
                    <div class="flex justify-between items-center text-xs">
                        <span class="text-gray-400 font-semibold">GCS Region</span>
                        <span class="text-white font-bold">India (DGCA Sky)</span>
                    </div>
                </div>
            </div>

            <!-- Quick Stats -->
            <div class="bg-[#11141c]/80 backdrop-blur-md border border-[#242731] rounded-[12px] p-6 shadow-xl">
                <h3 class="text-sm font-black tracking-wider text-gray-400 uppercase mb-4">Flight Statistics</h3>
                <div class="grid grid-cols-2 gap-4">
                    <div class="bg-[#0b0c10] border border-[#242731] rounded-[8px] p-3 text-center">
                        <div class="text-2xl font-black text-white">142</div>
                        <div class="text-[0.62rem] text-gray-500 font-bold uppercase tracking-[0.5px] mt-1">Total Flights</div>
                    </div>
                    <div class="bg-[#0b0c10] border border-[#242731] rounded-[8px] p-3 text-center">
                        <div class="text-2xl font-black text-white">48.5h</div>
                        <div class="text-[0.62rem] text-gray-500 font-bold uppercase tracking-[0.5px] mt-1">Flight Hours</div>
                    </div>
                    <div class="bg-[#0b0c10] border border-[#242731] rounded-[8px] p-3 text-center">
                        <div class="text-2xl font-black text-white">120m</div>
                        <div class="text-[0.62rem] text-gray-500 font-bold uppercase tracking-[0.5px] mt-1">Max Altitude</div>
                    </div>
                    <div class="bg-[#0b0c10] border border-[#242731] rounded-[8px] p-3 text-center">
                        <div class="text-2xl font-black text-[#3fb950]">100%</div>
                        <div class="text-[0.62rem] text-gray-500 font-bold uppercase tracking-[0.5px] mt-1">Safe Landings</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side: Preferences Forms & Logs -->
        <div class="lg:col-span-2 flex flex-col gap-6">
            <!-- Settings & GCS Preferences Tab -->
            <div class="bg-[#11141c]/80 backdrop-blur-md border border-[#242731] rounded-[12px] p-6 shadow-xl">
                <h3 class="text-base font-black tracking-tight mb-4 flex items-center gap-2">
                    <i class="bi bi-sliders text-[#3a86ff]"></i> GCS PREFERENCES
                </h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-xs font-bold text-gray-400 uppercase tracking-[0.5px] mb-2">Measurement Units</label>
                        <select class="w-full h-[38px] bg-[#08090b] border border-[#242731] text-white px-3 rounded-[6px] text-xs font-semibold outline-none focus:border-[#58a6ff] cursor-pointer"
                                @bind="unitPreference">
                            <option value="Metric">Metric (meters, m/s)</option>
                            <option value="Imperial">Imperial (feet, mph)</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-gray-400 uppercase tracking-[0.5px] mb-2">Telemetry Log Rate</label>
                        <select class="w-full h-[38px] bg-[#08090b] border border-[#242731] text-white px-3 rounded-[6px] text-xs font-semibold outline-none focus:border-[#58a6ff] cursor-pointer"
                                @bind="logRate">
                            <option value="1">1 Hz (Low overhead)</option>
                            <option value="2">2 Hz (Balanced)</option>
                            <option value="5">5 Hz (Detailed)</option>
                            <option value="10">10 Hz (Real-time telemetry)</option>
                        </select>
                    </div>

                    <div class="flex items-center justify-between p-3 bg-[#08090b] border border-[#242731] rounded-[8px]">
                        <div class="flex flex-col">
                            <span class="text-xs font-bold text-gray-300">Voice Alerts & Telemetry Speech</span>
                            <span class="text-[0.65rem] text-gray-500 mt-0.5">Read safety critical alarms aloud</span>
                        </div>
                        <label class="gcs-switch">
                            <input type="checkbox" @bind="voiceAlertsEnabled" />
                            <span class="gcs-switch-slider"></span>
                        </label>
                    </div>

                    <div class="flex items-center justify-between p-3 bg-[#08090b] border border-[#242731] rounded-[8px]">
                        <div class="flex flex-col">
                            <span class="text-xs font-bold text-gray-300">Auto-Save Telemetry Logs</span>
                            <span class="text-[0.65rem] text-gray-500 mt-0.5">Save .tlog files locally after flight</span>
                        </div>
                        <label class="gcs-switch">
                            <input type="checkbox" @bind="autoSaveLogsEnabled" />
                            <span class="gcs-switch-slider"></span>
                        </label>
                    </div>
                </div>

                <div class="mt-6 flex justify-end">
                    <button class="px-5 py-2 rounded-[6px] bg-[#2b58ff] hover:bg-blue-600 text-white text-xs font-bold transition-all duration-200 cursor-pointer shadow-lg hover:shadow-blue-500/10"
                            @onclick="SaveGcsPreferences">
                        SAVE PREFERENCES
                    </button>
                </div>
            </div>

            <!-- Credentials & DGCA Sky Keys -->
            <div class="bg-[#11141c]/80 backdrop-blur-md border border-[#242731] rounded-[12px] p-6 shadow-xl">
                <h3 class="text-base font-black tracking-tight mb-4 flex items-center gap-2">
                    <i class="bi bi-shield-lock text-[#3a86ff]"></i> DGCA DIGITAL SKY API CREDENTIALS
                </h3>

                <div class="flex flex-col gap-4">
                    <div>
                        <label class="block text-xs font-bold text-gray-400 uppercase tracking-[0.5px] mb-2">DGCA Client ID</label>
                        <input class="w-full h-[38px] bg-[#08090b] border border-[#242731] text-white px-3 rounded-[6px] text-xs font-mono outline-none focus:border-[#58a6ff]"
                               @bind="dgcaClientId" placeholder="e.g. dgca_client_faheem_991" />
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-gray-400 uppercase tracking-[0.5px] mb-2">DGCA API Secret Key</label>
                        <div class="relative flex items-center">
                            <input class="w-full h-[38px] bg-[#08090b] border border-[#242731] text-white pl-3 pr-10 rounded-[6px] text-xs font-mono outline-none focus:border-[#58a6ff]"
                                   type="@(showSecret ? "text" : "password")" @bind="dgcaSecretKey" />
                            <button class="absolute right-3 text-gray-400 hover:text-white transition-colors cursor-pointer border-none bg-transparent"
                                    @onclick="ToggleSecretVisibility">
                                <i class="bi @(showSecret ? "bi-eye-slash-fill" : "bi-eye-fill") text-[1.1rem]"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="mt-6 flex justify-end">
                    <button class="px-5 py-2 rounded-[6px] bg-[#2b58ff] hover:bg-blue-600 text-white text-xs font-bold transition-all duration-200 cursor-pointer shadow-lg hover:shadow-blue-500/10"
                            @onclick="SaveDgcaCredentials">
                        UPDATE CREDENTIALS
                    </button>
                </div>
            </div>

            <!-- Recent Flight Logs Table -->
            <div class="bg-[#11141c]/80 backdrop-blur-md border border-[#242731] rounded-[12px] p-6 shadow-xl">
                <h3 class="text-base font-black tracking-tight mb-4 flex items-center gap-2">
                    <i class="bi bi-journal-text text-[#3a86ff]"></i> RECENT PILOT FLIGHT LOGBOOK
                </h3>

                <div class="overflow-x-auto">
                    <table class="w-full text-left text-xs border-collapse">
                        <thead>
                            <tr class="border-b border-[#242731] text-gray-400 uppercase tracking-[0.5px] font-bold">
                                <th class="pb-3 pr-4">Flight Date</th>
                                <th class="pb-3 px-4">UAV Model</th>
                                <th class="pb-3 px-4">Duration</th>
                                <th class="pb-3 px-4">Status</th>
                                <th class="pb-3 pl-4 text-right">Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in flightLogs)
                            {
                                <tr class="border-b border-[#1b1e26] hover:bg-[#161922]/50 transition-colors">
                                    <td class="py-3 pr-4 font-mono font-bold text-gray-300">@log.Date</td>
                                    <td class="py-3 px-4 text-white font-semibold">@log.DroneModel</td>
                                    <td class="py-3 px-4 text-gray-300">@log.Duration</td>
                                    <td class="py-3 px-4">
                                        <span class="px-2 py-0.5 rounded text-[0.62rem] font-bold @(GetStatusClass(log.Status))">
                                            @log.Status.ToUpper()
                                        </span>
                                    </td>
                                    <td class="py-3 pl-4 text-right">
                                        <button class="px-3 py-1 rounded bg-[#1c1f26] border border-[#30363d] hover:border-[#58a6ff] hover:text-[#58a6ff] text-gray-300 text-[0.7rem] font-bold transition-all duration-200 cursor-pointer"
                                                @onclick='() => ViewLogDetails(log.Date)'>
                                            VIEW
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string unitPreference = "Metric";
    private string logRate = "2";
    private bool voiceAlertsEnabled = true;
    private bool autoSaveLogsEnabled = true;

    private string dgcaClientId = "dgca_client_faheem_991";
    private string dgcaSecretKey = "sk_prod_dgca_8829910a9f38e219ba";
    private bool showSecret = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            var savedUnit = await JS.InvokeAsync<string>("localStorage.getItem", "gcs_units");
            if (!string.IsNullOrWhiteSpace(savedUnit)) unitPreference = savedUnit;

            var savedLogRate = await JS.InvokeAsync<string>("localStorage.getItem", "gcs_log_rate");
            if (!string.IsNullOrWhiteSpace(savedLogRate)) logRate = savedLogRate;

            var savedVoice = await JS.InvokeAsync<string>("localStorage.getItem", "gcs_voice_alerts");
            if (bool.TryParse(savedVoice, out bool voice)) voiceAlertsEnabled = voice;

            var savedAutoSave = await JS.InvokeAsync<string>("localStorage.getItem", "gcs_auto_save_logs");
            if (bool.TryParse(savedAutoSave, out bool autoSave)) autoSaveLogsEnabled = autoSave;

            var savedDgcaClientId = await JS.InvokeAsync<string>("localStorage.getItem", "dgca_client_id");
            if (!string.IsNullOrWhiteSpace(savedDgcaClientId)) dgcaClientId = savedDgcaClientId;

            var savedDgcaSecretKey = await JS.InvokeAsync<string>("localStorage.getItem", "dgca_secret_key");
            if (!string.IsNullOrWhiteSpace(savedDgcaSecretKey)) dgcaSecretKey = savedDgcaSecretKey;

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Settings] Failed to load preferences: {ex.Message}");
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/");
    }

    private void ToggleSecretVisibility()
    {
        showSecret = !showSecret;
    }

    private void SaveGcsPreferences()
    {
        _ = Task.Run(async () =>
        {
            try
            {
                await JS.InvokeVoidAsync("localStorage.setItem", "gcs_units", unitPreference);
                await JS.InvokeVoidAsync("localStorage.setItem", "gcs_log_rate", logRate);
                await JS.InvokeVoidAsync("localStorage.setItem", "gcs_voice_alerts", voiceAlertsEnabled.ToString());
                await JS.InvokeVoidAsync("localStorage.setItem", "gcs_auto_save_logs", autoSaveLogsEnabled.ToString());

                await InvokeAsync(() =>
                {
                    Drone.Toast("GCS Preferences saved successfully", MavlinkService.ToastLevel.Success, "⚙️");
                    StateHasChanged();
                });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[Settings] Save preferences error: {ex.Message}");
            }
        });
    }

    private void SaveDgcaCredentials()
    {
        _ = Task.Run(async () =>
        {
            try
            {
                await JS.InvokeVoidAsync("localStorage.setItem", "dgca_client_id", dgcaClientId);
                await JS.InvokeVoidAsync("localStorage.setItem", "dgca_secret_key", dgcaSecretKey);

                await InvokeAsync(() =>
                {
                    Drone.Toast("DGCA Sky Credentials updated & verified", MavlinkService.ToastLevel.Success, "🔐");
                    StateHasChanged();
                });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[Settings] Save credentials error: {ex.Message}");
            }
        });
    }

    private void ViewLogDetails(string date)
    {
        Drone.Toast($"Opening flight logs telemetry for {date}", MavlinkService.ToastLevel.Info, "📊");
    }

    private string GetStatusClass(string status) => status.ToLower() switch
    {
        "completed"   => "bg-[#00ff00]/10 border border-[#00ff00]/30 text-[#3fb950]",
        "auto-landed" => "bg-[rgba(210,153,34,0.12)] border border-[#d29922]/30 text-[#e3a820]",
        "aborted"     => "bg-[#ff3a3a]/10 border border-[#ff3a3a]/30 text-[#ff3a3a]",
        _             => "bg-gray-500/10 border border-gray-500/30 text-gray-400"
    };

    private class FlightLogEntry
    {
        public string Date { get; set; } = "";
        public string DroneModel { get; set; } = "";
        public string Duration { get; set; } = "";
        public string Status { get; set; } = "";
    }

    private List<FlightLogEntry> flightLogs = new()
    {
        new() { Date = "2026-06-03 16:40", DroneModel = "Quad-Vayu-X4", Duration = "22 mins", Status = "Completed" },
        new() { Date = "2026-06-02 11:15", DroneModel = "Hex-Vayu-H6", Duration = "14 mins", Status = "Auto-Landed" },
        new() { Date = "2026-05-28 09:30", DroneModel = "Quad-Vayu-X4", Duration = "3 mins", Status = "Aborted" },
        new() { Date = "2026-05-27 15:20", DroneModel = "Quad-Vayu-X4", Duration = "28 mins", Status = "Completed" }
    };
}
