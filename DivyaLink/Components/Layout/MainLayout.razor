    private async Task RenameRegion(SavedRegion region)
    {
        var newName = await JS.InvokeAsync<string>("prompt", $"Rename offline cache zone '{region.Name}' to:", region.Name);
        if (!string.IsNullOrWhiteSpace(newName) && newName != region.Name)
        {
            if (savedRegions.Any(r => r.Name.Equals(newName, StringComparison.OrdinalIgnoreCase)))
            {
                Drone.Toast($"A region named '{newName}' already exists.", MavlinkService.ToastLevel.Error, "❌");
                return;
            }
            
            var oldName = region.Name;
            region.Name = newName;
            offlineMaps = savedRegions.Select(r => r.Name).ToList();
            
            if (_selectedOfflineMap == oldName)
            {
                _selectedOfflineMap = newName;
                await JS.InvokeVoidAsync("localStorage.setItem", "gcs_offline_map", newName);
            }
            
            var json = System.Text.Json.JsonSerializer.Serialize(savedRegions);
            await JS.InvokeVoidAsync("localStorage.setItem", "gcs_saved_regions", json);
            
            Drone.Toast($"Zone renamed to '{newName}'", MavlinkService.ToastLevel.Success, "✏️");
            StateHasChanged();
        }
    }

    private async Task DeleteRegion(SavedRegion region)
    {
        savedRegions.Remove(region);
        offlineMaps = savedRegions.Select(r => r.Name).ToList();
        
        var json = System.Text.Json.JsonSerializer.Serialize(savedRegions);
        await JS.InvokeVoidAsync("localStorage.setItem", "gcs_saved_regions", json);
        
        if (_selectedOfflineMap == region.Name)
        {
            _selectedOfflineMap = offlineMaps.FirstOrDefault() ?? "";
            await JS.InvokeVoidAsync("localStorage.setItem", "gcs_offline_map", _selectedOfflineMap);
            await JS.InvokeVoidAsync("clearSavedPolygon");
        }
        
        Drone.Toast($"Zone '{region.Name}' deleted.", MavlinkService.ToastLevel.Success, "🗑️");
        StateHasChanged();
    }

    public class SavedRegion
