@inherits LayoutComponentBase
@using DivyaLink.Components.GCS
@inject MavlinkService Drone
@inject IJSRuntime JS
@inject DgcaAirspaceService AirspaceSvc
@implements IDisposable
@using System.IO.Ports
@using System.Linq
@inject VehicleProfileService Vehicle
@inject NavigationManager Navigation
@inject DivyaLink.Services.LicenseService License
@inject DivyaLink.Services.ParameterMetadataService MetadataSvc
@inject DivyaLink.Services.Firmware.FirmwareProfileService FirmwareSvc
@inject DivyaLink.Services.Firmware.Px4ParameterMetadataService Px4MetadataSvc

@* REMOVED 'flex flex-col' so elements can overlap properly to restore frosted glass *@
<div class="gcs-wrapper block h-screen w-full bg-[#0a0b0d] overflow-hidden relative">

    @if (isDrawing)
    {
        <div class="fixed top-[75px] left-1/2 -translate-x-1/2 bg-[#0f1117]/90 backdrop-blur-md border border-[#ff9900] rounded-[8px] p-[10px_20px] shadow-[0_4px_25px_rgba(255,153,0,0.3)] z-[1000] flex items-center gap-4 text-white pointer-events-auto">
            <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full bg-[#ff9900] animate-pulse"></span>
                <span class="text-xs font-black tracking-[1px] uppercase">Drawing Cache Zone</span>
            </div>
            <div class="text-[0.75rem] text-[#8b949e]">Click map to place points (min 3 to save)</div>
            <button class="h-[28px] px-3 bg-[#3fb950] border-none rounded-[4px] text-white text-[0.75rem] font-bold cursor-pointer hover:bg-green-600 transition-colors"
                    @onclick="SaveDrawnRegion" id="floating-btn-save-zone">SAVE ZONE</button>
            <button class="h-[28px] px-3 bg-[#ff4a4a] border-none rounded-[4px] text-white text-[0.75rem] font-bold cursor-pointer hover:bg-red-600 transition-colors"
                    @onclick="CancelDrawingRegion" id="floating-btn-cancel-zone">CANCEL</button>
        </div>
    }

    @* --- HEADER --- *@
    <header class="header fixed top-0 left-0 w-full h-[60px] z-[100] shrink-0 bg-[rgba(18,20,26,0.6)] backdrop-blur-md border-b border-[#242731] flex items-center justify-between px-2 md:px-5 transition-all duration-300">
        @* HEADER CONTENT IS UNCHANGED *@
        <div class="flex items-center gap-2 md:gap-[15px]">
            <div class="hidden sm:flex flex-col justify-center">
                <span class="bg-gradient-to-r from-[#3a86ff] to-[#ff00c8] bg-clip-text text-transparent font-black text-lg md:text-[1.6rem] tracking-[-0.5px] leading-none">DIVYALINK</span>
                <div class="text-[0.7rem] text-[#888] tracking-[1.5px] uppercase mt-[2px] font-bold">BY VAYUNOTICS</div>
            </div>

            <div class="flex items-center gap-1.5 flex-nowrap overflow-x-auto no-scrollbar pb-1 sm:pb-0">
                @{
                    var pillBase = "inline-flex items-center justify-center gap-1.5 h-[28px] min-w-[95px] px-2 rounded-[4px] text-[0.8rem] font-bold tracking-[0.8px] whitespace-nowrap transition-all duration-300 border box-border";
                }
                <div class="@pillBase @(IsDroneActuallyTalking ? "bg-[rgba(0,200,80,0.12)] border-[#2ea043] text-[#3fb950]" : "bg-[rgba(80,80,80,0.10)] border-[#484f58] text-[#8b949e]")">
                    <i class="bi bi-router-fill"></i>
                    <span class="hidden sm:inline">
                        @if (IsDroneActuallyTalking)
                        {
                            @($"TELEM {Drone.State.RxPacketsPerSec:0}Hz")
                        }
                        else
                        {
                            @("NO LINK")
                        }
                    </span>
                </div>
                <div class="@pillBase @(Drone.State.GpsFixType >= 3 ? "bg-[rgba(0,200,80,0.10)] border-[#2ea043] text-[#3fb950]" : Drone.State.GpsFixType >= 2 ? "bg-[rgba(210,153,34,0.12)] border-[#d29922] text-[#e3a820]" : "bg-[rgba(80,80,80,0.10)] border-[#484f58] text-[#8b949e]")">
                    <i class="bi bi-reception-4"></i>
                    <span class="hidden sm:inline">@(Drone.State.SatCount > 0 ? $"{Drone.State.SatCount} SAT" : "NO GPS")</span>
                </div>
                <div class="@pillBase @(Drone.State.IsRcConnected ? "bg-[rgba(0,220,80,0.20)] border-[#00cc55] text-[#00ee66]" : "bg-[rgba(220,60,60,0.18)] border-[#cc3333] text-[#ff6666]")">
                    <i class="bi bi-controller"></i>
                    <span class="hidden sm:inline">@(Drone.State.IsRcConnected ? "RC" : "NO RC")</span>
                </div>
                @if (IsDroneActuallyTalking)
                {
                    <div class="@pillBase @(FirmwareSvc.ActiveFirmware == DivyaLink.Services.Firmware.FirmwareFamily.PX4 ? "bg-[rgba(0,212,170,0.10)] border-[#00d4aa] text-[#00d4aa]" : "bg-[rgba(88,166,255,0.10)] border-[#58a6ff] text-[#58a6ff]")">
                        <i class="bi bi-cpu-fill"></i>
                        <span class="hidden sm:inline">@FirmwareSvc.ActiveFirmwareDisplayName</span>
                    </div>
                }
                @if (IsDroneActuallyTalking && Drone.State.FlightMode != "Unknown")
                {
                    <div class="@pillBase bg-[rgba(88,166,255,0.10)] border-[#58a6ff] text-[#58a6ff]">
                        <i class="bi bi-airplane-fill"></i>
                        <span class="hidden sm:inline">@Drone.State.FlightMode</span>
                    </div>
                }
                @if (IsDroneActuallyTalking)
                {
                    <div class="@pillBase @(Drone.State.IsArmed ? "bg-[rgba(248,81,73,0.15)] border-[#f85149] text-[#ff8080]" : "bg-[rgba(46,160,67,0.10)] border-[#2ea043] text-[#3fb950]")">
                        <i class="bi @(Drone.State.IsArmed ? "bi-shield-fill-exclamation" : "bi-shield-fill-check")"></i>
                        <span class="hidden sm:inline">@(Drone.State.IsArmed ? "ARMED" : "DISARMED")</span>
                    </div>
                }
            </div>
        </div>

    <div class="flex items-center gap-2 md:gap-3">
        <div class="flex items-center gap-2 md:gap-3 overflow-x-auto no-scrollbar">
        @{
            @* FIX: explicitly locked to h-[36px] and text-[0.9rem] to prevent shrinking/jumping *@
            var inputBase = "h-[36px] bg-[#08090b] border border-[#242731] text-white px-3 rounded-[4px] text-[0.9rem] font-semibold outline-none focus:border-[#58a6ff]";
        }

        <select class="@inputBase cursor-pointer hidden md:block" @bind="selectedType">
            <option value="Serial">SERIAL</option>
            <option value="UDP">UDP</option>
            <option value="TCP">TCP</option>
        </select>

        @if (selectedType == "Serial")
        {
            <select class="@inputBase cursor-pointer min-w-[140px]" @onchange="OnPortChanged" value="@selectedPort">
                @if (availablePorts.Count == 0)
                {
                    <option value="" disabled selected>Scanning...</option>
                }
                else
                {
                    <option value="" disabled selected="@(string.IsNullOrEmpty(selectedPort))">-- Port --</option>
                    @foreach (var port in Drone.GetAvailablePorts())
                    {
                        <option value="@port.PortId">@port.DisplayName</option>
                    }
                }
            </select>
        }
        else
        {
            <input class="@inputBase w-[140px]" @bind="selectedPort" placeholder="127.0.0.1" />
        }

        <select class="@inputBase cursor-pointer hidden md:block" @bind="selectedBaud">
            <option value="9600">9600</option>
            <option value="57600">57600</option>
            <option value="115200">115200</option>
        </select>

        @* Scaled Status Indicator *@
        <span class="w-3 h-3 rounded-full shrink-0 mx-1 @(IsDroneActuallyTalking ? "bg-[#00ff00] shadow-[0_0_8px_#00ff00]" : "bg-[#ff0000]")"></span>

        @* Scaled Connect Button: h-[36px] matching the inputs exactly *@
        <button class="h-[36px] border-none p-2 rounded-[4px] font-extrabold cursor-pointer text-[0.9rem] tracking-[1px] transition-colors flex items-center justify-center @(IsDroneActuallyTalking ? "bg-[#ff3a3a] text-white hover:bg-red-600" : "bg-[#2b58ff] text-white hover:bg-blue-600")"
                @onclick="ToggleConnection" disabled="@isAttempting">
            @if (isAttempting)
            {
                <span>VERIFYING...</span>
            }
            else
            {
                @(IsDroneActuallyTalking ? "DISCONNECT" : "CONNECT")
            }
        </button>
        </div>

        @* Profile Dropdown Menu *@
        <div class="relative shrink-0 flex items-center ml-1">
            <button class="w-[36px] h-[36px] rounded-full bg-[#1c1f26] border border-[#30363d] flex items-center justify-center font-black text-[0.85rem] text-white hover:border-[#58a6ff] cursor-pointer transition-all duration-200"
                    @onclick="ToggleProfileMenu" id="profile-avatar-btn">
                @AvatarInitials
            </button>

            @if (isProfileMenuOpen)
            {
                <div class="fixed inset-0 z-[998] bg-transparent pointer-events-auto" @onclick="ToggleProfileMenu"></div>
                <div class="absolute top-[48px] right-0 w-[290px] bg-[#0f1117]/95 backdrop-blur-xl border border-[#30363d] rounded-[12px] p-4 shadow-[0_10px_35px_rgba(0,0,0,0.6)] z-[999] flex flex-col gap-3 text-white profile-dropdown-animate" id="profile-dropdown-menu">
                    <!-- Profile Row -->
                    <div class="flex items-center justify-between gap-3">
                        <div class="w-[44px] h-[44px] rounded-full bg-gradient-to-tr from-[#3a86ff] to-[#7e3ff2] flex items-center justify-center font-black text-[0.95rem] text-white shadow-inner shrink-0">
                            @AvatarInitials
                        </div>
                        <div class="flex-1 flex flex-col justify-center leading-tight">
                            @if (isEditingName)
                            {
                                <input class="bg-[#08090b] border border-[#30363d] text-white text-[0.9rem] rounded px-2 py-0.5 w-[140px] outline-none font-bold"
                                       @bind="tempOperatorName" @onblur="SaveOperatorName" @onkeyup="HandleNameKeyUp" autofocus />
                            }
                            else
                            {
                                <span class="text-white font-black text-[0.95rem] tracking-[-0.2px]">@operatorName</span>
                            }
                            <span class="text-[#3fb950] font-bold text-[0.65rem] uppercase tracking-[0.5px] mt-[2px]">@operatorRole</span>
                        </div>
                        <button class="text-[#8b949e] hover:text-white transition-colors cursor-pointer border-none bg-transparent p-1"
                                @onclick="ToggleEditName">
                            <i class="bi @(isEditingName ? "bi-check-lg text-[#3fb950] text-[1.2rem]" : "bi-pencil-square text-[1.05rem]")"></i>
                        </button>
                    </div>

                    <!-- License Tier -->
                    <div class="border-t border-[#242731] pt-3 flex flex-col gap-1.5">
                        <div class="flex justify-between items-center text-[0.68rem] tracking-[1.5px] font-black text-[#8b949e]">
                            <span>LICENSE TIER</span>
                            <span class="text-[#3a86ff] font-black uppercase text-[0.78rem] tracking-[1.2px]">@licenseTier</span>
                        </div>
                        <div class="flex justify-between items-center text-[0.68rem] tracking-[1.5px] font-black text-[#8b949e]">
                            <span>VALID FOR</span>
                            <span class="text-white font-black text-[0.78rem]">@licenseValidity</span>
                        </div>
                    </div>

                    <!-- Toggles & Select -->
                    <div class="border-t border-[#242731] pt-3 flex flex-col gap-3">
                        <div class="flex items-center justify-between gap-3">
                            <div class="flex items-center gap-2 flex-1">
                                <i class="bi bi-brightness-high text-[#8b949e] text-[1.05rem]"></i>
                                <span class="text-white font-semibold text-[0.82rem]">Outdoor Mode</span>
                            </div>
                            <label class="gcs-switch">
                                <input type="checkbox" @bind="isOutdoorMode" />
                                <span class="gcs-switch-slider"></span>
                            </label>
                        </div>

                        <div class="flex items-center justify-between gap-3">
                            <div class="flex items-center gap-2 flex-1">
                                <i class="bi bi-cloud-arrow-down text-[#8b949e] text-[1.05rem]"></i>
                                <span class="text-white font-semibold text-[0.82rem]">Live Map Auto-Cache</span>
                            </div>
                            <label class="gcs-switch">
                                <input type="checkbox" @bind="isLiveMapCache" />
                                <span class="gcs-switch-slider"></span>
                            </label>
                        </div>

                        <div class="flex flex-col gap-1">
                            <div class="flex items-center gap-2">
                                <i class="bi bi-map text-[#8b949e] text-[1.05rem]"></i>
                                <span class="text-white font-semibold text-[0.82rem]">Offline Base Map</span>
                            </div>
                            <div class="relative w-full mt-1">
                                <button class="w-full bg-[#08090b] border border-[#242731] text-white px-3 py-1.5 rounded-[4px] text-[0.8rem] font-semibold flex items-center justify-between cursor-pointer outline-none hover:border-[#58a6ff] transition-all"
                                        @onclick="ToggleMapDropdown" id="custom-map-dropdown-btn">
                                    <span class="truncate pr-2">@(string.IsNullOrEmpty(selectedOfflineMap) ? "No saved regions" : selectedOfflineMap)</span>
                                    <i class="bi bi-chevron-down text-[#8b949e] text-[0.75rem]"></i>
                                </button>
                                
                                @if (isMapDropdownOpen)
                                {
                                    <div class="fixed inset-0 z-[1000] bg-transparent" @onclick="ToggleMapDropdown"></div>
                                    <div class="absolute top-[34px] left-0 w-full bg-[#0f1117]/95 backdrop-blur-xl border border-[#30363d] rounded-[6px] shadow-[0_4px_20px_rgba(0,0,0,0.6)] z-[1001] max-h-[160px] overflow-y-auto p-1 flex flex-col gap-0.5 custom-scrollbar">
                                        @if (savedRegions.Count == 0)
                                        {
                                            <div class="text-[#8b949e] text-[0.75rem] p-2 text-center">No saved regions</div>
                                        }
                                        else
                                        {
                                            @foreach (var region in savedRegions)
                                            {
                                                var isSelected = region.Name == selectedOfflineMap;
                                                <div class="flex items-center justify-between px-2.5 py-1.5 rounded-[4px] transition-all duration-150 @(isSelected ? "bg-[#2b58ff]/15 text-[#58a6ff]" : "hover:bg-[#1f242c] text-[#c9d1d9]")">
                                                    <span class="text-[0.78rem] font-semibold cursor-pointer truncate flex-1 pr-2"
                                                          @onclick="() => SelectRegion(region)">
                                                        @region.Name
                                                    </span>
                                                    <div class="flex items-center gap-1.5 shrink-0 pointer-events-auto">
                                                        <button class="text-[#8b949e] hover:text-white transition-colors cursor-pointer border-none bg-transparent p-0.5 flex items-center justify-center text-[0.85rem]"
                                                                @onclick="() => RenameRegion(region)" title="Rename zone">
                                                            <i class="bi bi-pencil text-[0.85rem]"></i>
                                                        </button>
                                                        <button class="text-[#ff4a4a] hover:text-[#ff6b6b] transition-colors cursor-pointer border-none bg-transparent p-0.5 flex items-center justify-center text-[0.85rem]"
                                                                @onclick="() => DeleteRegion(region)" title="Delete zone">
                                                            <i class="bi bi-trash text-[0.85rem]"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                            </div>
                            @if (!isDrawing)
                            {
                                <button class="w-full mt-1.5 py-1.5 bg-[rgba(58,134,255,0.15)] hover:bg-[rgba(58,134,255,0.25)] text-[#58a6ff] border border-[#3a86ff]/30 rounded-[6px] text-[0.8rem] font-bold transition-all cursor-pointer flex items-center justify-center gap-1.5"
                                        @onclick="StartDrawingRegion" id="btn-draw-cache-zone">
                                    <i class="bi bi-pencil-square"></i>
                                    <span>DRAW CACHE ZONE</span>
                                </button>
                            }
                            else
                            {
                                <div class="flex gap-1.5 mt-1.5">
                                    <button class="flex-1 py-1.5 bg-[#3fb950]/20 hover:bg-[#3fb950]/30 text-[#3fb950] border border-[#3fb950]/30 rounded-[6px] text-[0.8rem] font-bold transition-all cursor-pointer flex items-center justify-center gap-1"
                                            @onclick="SaveDrawnRegion" id="btn-save-zone">
                                        <i class="bi bi-check-lg"></i>
                                        <span>SAVE ZONE</span>
                                    </button>
                                    <button class="flex-1 py-1.5 bg-[#ff4a4a]/20 hover:bg-[#ff4a4a]/30 text-[#ff4a4a] border border-[#ff4a4a]/30 rounded-[6px] text-[0.8rem] font-bold transition-all cursor-pointer flex items-center justify-center gap-1"
                                            @onclick="CancelDrawingRegion" id="btn-cancel-zone">
                                        <i class="bi bi-x-lg"></i>
                                        <span>CANCEL</span>
                                    </button>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Menu Buttons -->
                    <div class="border-t border-[#242731] pt-2.5 flex flex-col gap-0.5">
                        <button class="w-full flex items-center gap-2.5 px-2.5 py-1.5 rounded-[6px] text-left text-[#c9d1d9] text-[0.8rem] font-bold transition-all duration-150 hover:bg-[#1f242c]"
                                @onclick='() => ClickMenuItem("Operator Profile & Settings")'>
                            <i class="bi bi-sliders2 text-[#8b949e] text-[1rem] shrink-0"></i>
                            <span>Operator Profile & Settings</span>
                        </button>
                        <button class="w-full flex items-center gap-2.5 px-2.5 py-1.5 rounded-[6px] text-left text-[#c9d1d9] text-[0.8rem] font-bold transition-all duration-150 hover:bg-[#1f242c]"
                                @onclick='() => ClickMenuItem("Firmware Flashing")'>
                            <i class="bi bi-cpu text-[#8b949e] text-[1rem] shrink-0"></i>
                            <span>Firmware Flashing</span>
                        </button>
                        <button class="w-full flex items-center gap-2.5 px-2.5 py-1.5 rounded-[6px] text-left text-[#c9d1d9] text-[0.8rem] font-bold transition-all duration-150 hover:bg-[#1f242c]"
                                @onclick='() => ClickMenuItem("Manage License")'>
                            <i class="bi bi-shield-lock text-[#8b949e] text-[1rem] shrink-0"></i>
                            <span>Manage License</span>
                        </button>
                        <button class="w-full flex items-center gap-2.5 px-2.5 py-1.5 rounded-[6px] text-left text-[#ff4a4a] text-[0.8rem] font-bold transition-all duration-150 hover:bg-[#3a0d0d]/30 hover:text-white"
                                @onclick="PurgeOfflineStorage">
                            <i class="bi bi-trash text-[#ff4a4a] text-[1rem] shrink-0"></i>
                            <span>Purge All Offline Map Storage</span>
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
    </header>

    @* ── AIRSPACE WARNING BANNER ──────────────────────────────────────────────────
         Sits fixed at top-[60px] (just below the 60px header).
         z-[99] — below the header (z-100) but above everything else.
         Only rendered when _airspaceWarning is non-null.
         RED  → pulsing red background, white bold text (matches RESTRICTED severity).
         YELLOW → solid amber, no pulse (CONTROLLED / advisory).
    *@
    @if (_airspaceWarning is not null)
    {
        <div class="airspace-warning-banner @(_airspaceWarning == "RED" ? "banner-red" : "banner-yellow")"
             role="alert"
             aria-live="assertive">
            <span class="banner-icon">⚠️</span>
            <span class="banner-text">
                WARNING: AIRCRAFT INSIDE RESTRICTED
                <strong>@(_airspaceWarning == "RED" ? "PROHIBITED" : "CONTROLLED")</strong>
                AIRSPACE
            </span>
            @* Zone type label pill *@
            <span class="banner-zone-pill">@_airspaceWarning ZONE</span>
        </div>
    }

    @* THE ABSOLUTE WORKSPACE: inset-0 forces this container to the very top, restored the glass blur! *@
    <div class="absolute inset-0 flex flex-row pointer-events-none z-[10] transition-all duration-300">
        
        @* 1. THE DRAWER (Consolidated all visibility logic to inline styles, slides under header z-[90]) *@
        <div class="pointer-events-auto shrink-0 bg-[rgba(15,17,23,0.9)] backdrop-blur-xl border-r border-[rgba(255,255,255,0.1)] z-[90] transition-all duration-300 shadow-[20px_0_50px_rgba(0,0,0,0.3)] overflow-hidden flex flex-col h-full relative pt-[60px]"
     style="@GetDrawerStyle()">
             
            <button class="absolute top-[65px] right-[5px] bg-transparent border-none text-[rgba(255,255,255,0.7)] text-[26px] font-bold p-0 cursor-pointer z-[2000] leading-none transition-all duration-200 hover:text-[#ff3a3a] hover:scale-125" @onclick='() => HandleTabClick(activeTab)'>&times;</button>
            <div class="w-full h-full p-0 box-border overflow-y-auto overflow-x-hidden">
                @if (activeTab == "Quick") { <Quick /> }
                else if (activeTab == "Actions") { <Actions /> }
                else if (activeTab == "Messages") { <Messages /> }
                else if (activeTab == "FlightPlan") { <FlightPlan /> }
                else if (activeTab == "Pre Flight") { <PreFlight /> }
                else if (activeTab == "Setup") { <Setup /> }
                else if (activeTab == "Swarm") { <Swarm /> }
            </div>
        </div>

        @* 2. THE MAP CONTAINER (flex-1 handles the push, but it reaches top: 0!) *@
        <main class="flex-1 relative h-full pointer-events-none transition-all duration-300">
            <CascadingValue Value="activeTab">
                <div class="pointer-events-auto absolute inset-0 w-full h-full">
                    @Body
                </div>
            </CascadingValue>

            @* 3. THE FOOTER (Anchored strictly inside the shrinking map workspace) *@
            @if (IsOnDashboard)
            {
                <footer class="absolute bottom-0 left-0 w-full p-[15px_10px] flex justify-center z-[1000] transition-all duration-300 pointer-events-none">
                    <div class="flex gap-2 md:gap-[10px] w-full max-w-[750px] justify-center overflow-x-auto no-scrollbar pointer-events-auto px-2">
                        @foreach (var tab in tabs)
                        {
                            var isActive = activeTab == tab;
                            <button class="min-w-[70px] md:min-w-[95px] flex-1 rounded-[8px] text-white py-[4px] px-1 flex flex-col items-center justify-center cursor-pointer transition-all duration-200 shadow-lg @(isActive ? "bg-gradient-to-br from-[#2b58ff] to-[#7e3ff2] border border-transparent shadow-[0_0_15px_rgba(126,63,242,0.4)]" : "bg-[rgba(10,11,14,0.85)] backdrop-blur-md border border-[#30363d] hover:bg-[#1a1f2e] hover:border-[#58a6ff]")"
                                    @onclick="() => HandleTabClick(tab)">
                                <div class="h-[30px] flex items-center justify-center shrink-0">
                                    <i class="not-italic flex items-center justify-center @(isActive ? "text-white" : "text-[#00f2ff]") [&>svg]:w-[22px] [&>svg]:h-[22px]">
                                        @((MarkupString)GetIcon(tab))
                                    </i>
                                </div>
                                <span class="text-[1.1rem] md:text-[1.1rem] font-semibold tracking-tighter leading-none whitespace-nowrap mt-[1px]">@tab</span>
                            </button>
                        }
                    </div>
                </footer>
            }
            <MapOverlayHost />
        </main>
    </div>

    @if (isSettingsModalOpen)
    {
        <div class="fixed inset-0 z-[10000] bg-black/60 backdrop-blur-md flex items-center justify-center pointer-events-auto">
            <div class="w-[520px] max-w-[95vw] max-h-[90vh] bg-[#0f1117] border border-[#30363d] rounded-[16px] p-6 shadow-[0_15px_50px_rgba(0,0,0,0.8)] text-white flex flex-col gap-4 relative overflow-hidden">
                <!-- Header -->
                <div class="flex items-center justify-between border-b border-[#242731] pb-3 shrink-0">
