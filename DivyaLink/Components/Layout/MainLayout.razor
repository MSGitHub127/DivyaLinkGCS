    private async Task CancelDrawingRegion()
    {
        isDrawing = false;
        await JS.InvokeVoidAsync("stopDrawingPolygon", false);
        Drone.Toast("Drawing cancelled", MavlinkService.ToastLevel.Info, "❌");
    }

    private async Task SaveDrawnRegion()
    {
        try
        {
            var coordsJson = await JS.InvokeAsync<string>("stopDrawingPolygon", true);
            isDrawing = false;

            var points = System.Text.Json.JsonSerializer.Deserialize<List<double[]>>(coordsJson);
            if (points == null || points.Count < 3)
            {
                Drone.Toast("Save failed: Define at least 3 points for a zone.", MavlinkService.ToastLevel.Error, "❌");
                return;
            }

            var name = await JS.InvokeAsync<string>("prompt", "Enter a name for the new offline cache zone:", "");
            if (string.IsNullOrWhiteSpace(name))
            {
                Drone.Toast("Save cancelled or name cannot be empty.", MavlinkService.ToastLevel.Warning, "⚠️");
                return;
            }

            if (savedRegions.Any(r => r.Name.Equals(name, StringComparison.OrdinalIgnoreCase)))
            {
                Drone.Toast($"A region named '{name}' already exists.", MavlinkService.ToastLevel.Error, "❌");
                return;
            }

            var newRegion = new SavedRegion { Name = name, CoordsJson = coordsJson };
            savedRegions.Add(newRegion);
            offlineMaps = savedRegions.Select(r => r.Name).ToList();

            var json = System.Text.Json.JsonSerializer.Serialize(savedRegions);
            await JS.InvokeVoidAsync("localStorage.setItem", "gcs_saved_regions", json);

            _selectedOfflineMap = name;
            await JS.InvokeVoidAsync("localStorage.setItem", "gcs_offline_map", name);
            await JS.InvokeVoidAsync("showSavedPolygon", coordsJson);

            Drone.Toast($"Zone '{name}' saved successfully!", MavlinkService.ToastLevel.Success, "💾");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Draw] Save error: {ex.Message}");
            Drone.Toast("Error saving drawing zone.", MavlinkService.ToastLevel.Error, "❌");
        }
    }

