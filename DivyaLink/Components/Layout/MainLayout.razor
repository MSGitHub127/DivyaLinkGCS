    private async Task ActivateLicenseKey()
    {
        if (string.IsNullOrWhiteSpace(enteredLicenseKey))
        {
            Drone.Toast("License key cannot be empty", MavlinkService.ToastLevel.Warning, "⚠️");
            return;
        }

        isActivatingKey = true;
        await Task.Delay(1000);

        try
        {
            License.SaveLicenseKey(enteredLicenseKey);
            if (License.IsActive)
            {
                Drone.Toast($"Activated: {License.LicenseTier} ({License.RemainingDaysText})", MavlinkService.ToastLevel.Success, "🔑");
                enteredLicenseKey = "";
            }
            else
            {
                Drone.Toast("Invalid or expired license key.", MavlinkService.ToastLevel.Error, "❌");
            }
        }
        catch (Exception ex)
        {
            Drone.Toast($"Activation error: {ex.Message}", MavlinkService.ToastLevel.Error, "❌");
        }
        finally
        {
            isActivatingKey = false;
            await InvokeAsync(StateHasChanged);
        }
    }
