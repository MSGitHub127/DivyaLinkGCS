            }
        });
    }

    private void PurgeOfflineStorage()
    {
        try
        {
            AirspaceSvc.InvalidateCache();
            MetadataSvc.PurgeCache();
            Px4MetadataSvc.PurgeCache();
            _ = Task.Run(async () =>
            {
                try
                {
                    await JS.InvokeVoidAsync("localStorage.removeItem", "gcs_offline_map");
                    await JS.InvokeVoidAsync("localStorage.removeItem", "gcs_live_map_cache");
                    await JS.InvokeVoidAsync("localStorage.removeItem", "gcs_saved_regions");
                    await JS.InvokeVoidAsync("clearSavedPolygon");
                    await InvokeAsync(() =>
                    {
                        _selectedOfflineMap = "";
                        _isLiveMapCache = false;
                        savedRegions.Clear();
                        offlineMaps.Clear();
                        Drone.Toast("Map cache, parameter dictionary, and saved regions purged!", MavlinkService.ToastLevel.Success, "🗑️");
                        StateHasChanged();
                    });
                }
                catch { }
            });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Purge] Error: {ex.Message}");
            Drone.Toast("Error purging cache.", MavlinkService.ToastLevel.Error, "❌");
        }
        isProfileMenuOpen = false;
    }

