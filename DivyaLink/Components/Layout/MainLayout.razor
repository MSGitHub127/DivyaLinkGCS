    private List<SavedRegion> savedRegions = new();
    private List<string> offlineMaps = new();

    private async Task StartDrawingRegion()
    {
        isDrawing = true;
        isProfileMenuOpen = false;
        await JS.InvokeVoidAsync("startDrawingPolygon");
