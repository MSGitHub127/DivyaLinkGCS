    private void ClickMenuItem(string item)
    {
        if (item == "Operator Profile & Settings")
        {
            Navigation.NavigateTo("/operator-profile");
        }
        else if (item == "Manage License")
        {
            _ = Task.Run(async () =>
            {
                try
                {
                    await InvokeAsync(async () =>
                    {
                        var key = await JS.InvokeAsync<string>("prompt", $"Your GCS Hardware ID:\n{License.HardwareId}\n\nEnter License Key:", "");
                        if (key != null)
                        {
                            if (string.IsNullOrWhiteSpace(key))
                            {
                                Drone.Toast("License key cannot be empty", MavlinkService.ToastLevel.Warning, "⚠️");
                            }
                            else
                            {
                                License.SaveLicenseKey(key);
                                if (License.IsActive)
                                {
                                    Drone.Toast($"Activated: {License.LicenseTier} ({License.RemainingDaysText})", MavlinkService.ToastLevel.Success, "🔑");
                                }
                                else
                                {
                                    Drone.Toast("Invalid or expired license key.", MavlinkService.ToastLevel.Error, "❌");
                                }
                                StateHasChanged();
                            }
                        }
                    });
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"[License] Prompt error: {ex.Message}");
                }
            });
        }
        else if (item == "Firmware Flashing")
        {
            isSettingsModalOpen = true;
        }
        else
        {
            Drone.Toast($"{item} opened", MavlinkService.ToastLevel.Info, "⚙️");
        }
        isProfileMenuOpen = false;
    }

