<style>
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

    .gcs-wrapper.map-fullscreen .header { transform: translateY(-100%); opacity: 0; pointer-events: none; }
    .gcs-wrapper.map-fullscreen .footer { transform: translateY(100%); opacity: 0; pointer-events: none; }
    
    @* Restored original map pop-out logic for z-indexing, merges with absolute layout *@
    .gcs-wrapper.map-fullscreen main {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 1000; @* COVER EVERY ELEMENT WHEN FULLSCREEN *@
        pointer-events: auto;
    }

    /* ── AIRSPACE WARNING BANNER ────────────────────────────────────────────
       Fixed just below the 60px header.
       Highest possible z-index below the header itself.
    ─────────────────────────────────────────────────────────────────────── */
    .airspace-warning-banner {
        position: fixed;
        top: 60px;
        left: 0;
        width: 100%;
        z-index: 99;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 7px 20px;
        font-family: 'Rajdhani', 'Segoe UI', sans-serif;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        pointer-events: none;          /* never block map interaction */
        box-shadow: 0 2px 16px rgba(0,0,0,0.45);
        border-bottom: 1px solid rgba(255,255,255,0.12);
        transition: background 0.3s ease;
    }

    /* RED zone — pulsing red, high-contrast white text */
    .banner-red {
        background: rgba(200, 30, 30, 0.88);
        color: #ffffff;
        text-shadow: 0 1px 4px rgba(0,0,0,0.6);
        animation: bannerPulse 1.4s ease-in-out infinite;
    }

    /* YELLOW zone — solid amber, no pulse */
    .banner-yellow {
        background: rgba(210, 140, 0, 0.90);
        color: #ffffff;
        text-shadow: 0 1px 4px rgba(0,0,0,0.5);
        box-shadow: 0 2px 18px rgba(255, 180, 0, 0.30);
    }

    .banner-icon {
        font-size: 1rem;
        flex-shrink: 0;
    }

    .banner-text {
        flex: 1;
        text-align: center;
    }

    .banner-zone-pill {
        background: rgba(0,0,0,0.28);
        border: 1px solid rgba(255,255,255,0.30);
        border-radius: 3px;
        padding: 2px 8px;
        font-size: 0.68rem;
        letter-spacing: 1.5px;
        flex-shrink: 0;
    }

    /* Pulsing animation — RED only */
    @@keyframes bannerPulse {
        0%,100% { background: rgba(200, 30, 30, 0.88); }
        50%      { background: rgba(230, 20, 20, 0.98); }
    }

    /* Leaflet popup override — remove default white box, let our HTML style it */
    .dgca-popup .leaflet-popup-content-wrapper {
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
        padding: 0 !important;
        border-radius: 0 !important;
    }
    .dgca-popup .leaflet-popup-content {
        margin: 0 !important;
    }
    .dgca-popup .leaflet-popup-tip-container {
        display: none !important;
    }

    /* Beautiful Custom Toggle Switch */
    .gcs-switch {
        position: relative;
        display: inline-flex;
        align-items: center;
        cursor: pointer;
        user-select: none;
    }
    .gcs-switch input {
        display: none;
    }
    .gcs-switch-slider {
        position: relative;
        width: 32px;
        height: 18px;
        background-color: #242731;
        border: 1px solid #30363d;
        border-radius: 9px;
        transition: all 0.2s ease-in-out;
    }
    .gcs-switch-slider::after {
        content: '';
        position: absolute;
        top: 2px;
        left: 2px;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background-color: #8b949e;
        transition: all 0.2s ease-in-out;
    }
    .gcs-switch input:checked + .gcs-switch-slider {
        background-color: #1a3860;
        border-color: #58a6ff;
    }
    .gcs-switch input:checked + .gcs-switch-slider::after {
        transform: translateX(14px);
        background-color: #58a6ff;
    }

    /* Dropdown Animation */
    @@keyframes dropdownFadeIn {
        from {
            opacity: 0;
            transform: translateY(-8px) scale(0.98);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }
    .profile-dropdown-animate {
        animation: dropdownFadeIn 0.18s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
</style>

@code {
    // ── Existing state (unchanged) ────────────────────────────────────────
    private string activeTab = "";
    private string selectedType = "Serial";
    private string selectedPort = "";
    private int selectedBaud = 57600;
    [Inject] private IConfiguration Config { get; set; } = default!;

    private List<string> availablePorts = new();
    private bool isManualConnected = false;
    private bool isAttempting = false;
    private System.Threading.Timer? _autoDetectTimer;
    private string[] tabs = { "Quick", "Actions", "Messages", "FlightPlan", "Pre Flight", "Setup", "Swarm" };

    private bool IsConnected => Drone.State.ConnectionStatus.Contains("Receiving");
    private bool IsDroneActuallyTalking => Drone.IsLinkHealthy;

    // ── Airspace warning state ────────────────────────────────────────────
    // null  = no warning  |  "RED" = prohibited  |  "YELLOW" = controlled
    private string? _airspaceWarning = null;

    // DotNet reference passed to JS so airspace.js can invoke back
    private DotNetObjectReference<MainLayout>? _dotnetRef;

    // ── Proximity throttle: don't call JS on every telemetry packet ───────
    private DateTime _lastProximityCheck = DateTime.MinValue;
    private static readonly TimeSpan ProximityCheckInterval = TimeSpan.FromSeconds(2);

    // ── Airspace load throttle: reload when drone moves >5 km ─────────────
    private double _lastAirspaceLoadLat = double.NaN;
    private double _lastAirspaceLoadLon = double.NaN;
    private const double AirspaceReloadDistanceMeters = 5000;

    // ── Lifecycle ─────────────────────────────────────────────────────────

    protected override void OnInitialized()
    {
        _autoDetectTimer = new System.Threading.Timer(AutoDetectPorts, null, 0, 1000);
        Drone.OnTelemetryUpdated += RefreshUi;
        Drone.OnRcChannelsUpdated += OnRcUpdated;

        var defaultType = Config["TcpConnection:DefaultConnectionType"] ?? "Serial";
        if (Enum.TryParse<ConnectionType>(defaultType, out _))
            selectedType = defaultType;

        if (selectedType is "TCP" or "UDP")
        {
            var host = Config["TcpConnection:DefaultHost"] ?? "";
            var port = Config["TcpConnection:DefaultPort"] ?? "";
            selectedPort = string.IsNullOrEmpty(port) ? host : $"{host}:{port}";
        }
        Vehicle.OnAutoSnap += HandleVehicleAutoSnap;
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void HandleVehicleAutoSnap(AutoSnapEventArgs args)
    {
        try
        {
            _ = InvokeAsync(() =>
            {
                // ── Now on the Blazor circuit thread ──────────────────────────
                Drone.Toast(args.ToastMessage, MavlinkService.ToastLevel.Warning, "⚠️");
                // StateHasChanged not needed here — toast library manages its own render
            });
        }
        catch (ObjectDisposedException) { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _dotnetRef = DotNetObjectReference.Create(this);
        try
        {
            await JS.InvokeVoidAsync("airspace.setDotnetRef", _dotnetRef);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Airspace] JS not ready: {ex.Message}");
            // Non-fatal — proximity warnings won't fire but map still works
        }

        try
        {
            var savedName = await JS.InvokeAsync<string>("localStorage.getItem", "gcs_operator_name");
            if (!string.IsNullOrWhiteSpace(savedName))
            {
                operatorName = savedName;
                tempOperatorName = savedName;
            }

            var savedOutdoor = await JS.InvokeAsync<string>("localStorage.getItem", "gcs_outdoor_mode");
            if (bool.TryParse(savedOutdoor, out bool outdoor))
            {
                _isOutdoorMode = outdoor;
            }

            var savedCache = await JS.InvokeAsync<string>("localStorage.getItem", "gcs_live_map_cache");
            if (bool.TryParse(savedCache, out bool cache))
            {
                _isLiveMapCache = cache;
            }

            // Load saved regions
            try
            {
                var savedRegionsJson = await JS.InvokeAsync<string>("localStorage.getItem", "gcs_saved_regions");
                if (!string.IsNullOrEmpty(savedRegionsJson))
                {
                    var loaded = System.Text.Json.JsonSerializer.Deserialize<List<SavedRegion>>(savedRegionsJson);
                    if (loaded != null)
                    {
                        savedRegions = loaded;
                        offlineMaps = savedRegions.Select(r => r.Name).ToList();
                    }
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[Regions] Failed to load saved regions: {ex.Message}");
            }

            var savedMap = await JS.InvokeAsync<string>("localStorage.getItem", "gcs_offline_map");
            if (!string.IsNullOrWhiteSpace(savedMap) && offlineMaps.Contains(savedMap))
            {
                _selectedOfflineMap = savedMap;
            }

            // Global Settings
            var savedUnit = await JS.InvokeAsync<string>("localStorage.getItem", "gcs_units");
            if (!string.IsNullOrWhiteSpace(savedUnit)) settingsUnitSystem = savedUnit;

            var savedLogRate = await JS.InvokeAsync<string>("localStorage.getItem", "gcs_log_rate");
            if (!string.IsNullOrWhiteSpace(savedLogRate)) settingsLogRate = savedLogRate;

            var savedVoice = await JS.InvokeAsync<string>("localStorage.getItem", "gcs_voice_alerts");
            if (bool.TryParse(savedVoice, out bool voice)) settingsVoiceAlerts = voice;

            var savedAutoSave = await JS.InvokeAsync<string>("localStorage.getItem", "gcs_auto_save_logs");
            if (bool.TryParse(savedAutoSave, out bool autoSave)) settingsAutoSaveLogs = autoSave;

            var savedReconnect = await JS.InvokeAsync<string>("localStorage.getItem", "gcs_auto_reconnect");
            if (bool.TryParse(savedReconnect, out bool reconnect)) settingsAutoReconnect = reconnect;

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Settings] Failed to load from localStorage: {ex.Message}");
        }
    }

    // ── JSInvokable: called by airspace.js when proximity state changes ───
    [JSInvokable]
    public void UpdateAirspaceWarning(string? zoneType)
    {
        // zoneType is "RED", "YELLOW", or null (cleared)
        if (_airspaceWarning == zoneType) return;
        _airspaceWarning = zoneType;
        InvokeAsync(StateHasChanged);
    }

    // ── Called by Home.razor (or any page) to load zones for current region ─
    /// <summary>
    /// Fetches DGCA airspace GeoJSON for a bounding box and passes it to Leaflet.
    /// Call this from Home.razor after the map is initialized.
    /// </summary>
    public async Task LoadAirspaceForRegion(double lat, double lon)
    {
        // Only reload if drone has moved significantly
        if (!double.IsNaN(_lastAirspaceLoadLat))
        {
            double dLat = (lat - _lastAirspaceLoadLat) * 111320;
            double dLon = (lon - _lastAirspaceLoadLon) * 111320 * Math.Cos(lat * Math.PI / 180);
            double dist = Math.Sqrt(dLat * dLat + dLon * dLon);
            if (dist < AirspaceReloadDistanceMeters) return;
        }

        _lastAirspaceLoadLat = lat;
        _lastAirspaceLoadLon = lon;

        // Bounding box: ±0.5° (~55 km) around current position
        double pad = 0.5;
        string geoJson = await AirspaceSvc.GetAirspaceGeoJsonAsync(
            lat - pad, lon - pad, lat + pad, lon + pad);

        await JS.InvokeVoidAsync("airspace.loadZones", geoJson, _dotnetRef);
    }

    // ── Telemetry handler (throttled proximity check) ─────────────────────
    private void RefreshUi()
    {
        var now = DateTime.UtcNow;
        if ((now - _lastHeaderRender).TotalMilliseconds < 1000) return;
        _lastHeaderRender = now;

        // Piggyback proximity check on the 1-second header refresh
        // Only run if we have valid GPS and the check interval has elapsed
        if ((now - _lastProximityCheck) >= ProximityCheckInterval)
        {
            _lastProximityCheck = now;
            var lat = Drone.State.Latitude;
            var lon = Drone.State.Longitude;
            if (Math.Abs(lat) > 0.0001 || Math.Abs(lon) > 0.0001)
            {
                _ = JS.InvokeVoidAsync("airspace.checkProximity", lat, lon);
            }
        }

        InvokeAsync(StateHasChanged);
    }

    // ── Drawer logic (unchanged) ──────────────────────────────────────────

    private DateTime _lastHeaderRender = DateTime.MinValue;

    private int GetDrawerWidth() => activeTab switch { "Swarm" => 640, _ => 540 };

    private string GetDrawerStyle()
    {
        int width = GetDrawerWidth();
        if (string.IsNullOrEmpty(activeTab))
            return $"width: {width}px; margin-left: -{width}px;";

        var styles = $"width: {width}px; margin-left: 0;";
        if (activeTab == "Swarm")
            styles += " border-bottom-right-radius: 12px; border-top-right-radius: 12px;";
        return styles;
    }

    private void HandleTabClick(string tab)
    {
        activeTab = (activeTab == tab) ? "" : tab;
        _ = JS.InvokeVoidAsync("animateMapResize");
    }

    private void AutoDetectPorts(object? state)
    {
        try
        {
            var current = SerialPort.GetPortNames().Distinct().OrderBy(x => x).ToList();
            InvokeAsync(() =>
            {
                bool changed = false;

                if (isManualConnected && !string.IsNullOrEmpty(selectedPort)
                    && !current.Contains(selectedPort))
                {
                    Drone.StopConnection();
                    isManualConnected = false;
                    selectedPort = "";
                    changed = true;
                }

                if (!current.SequenceEqual(availablePorts.OrderBy(x => x)))
                {
                    availablePorts = current;
                    if (!isManualConnected && !string.IsNullOrEmpty(selectedPort)
                        && !availablePorts.Contains(selectedPort))
                        selectedPort = "";
                    changed = true;
                }

                if (changed) StateHasChanged();
            });
        }
        catch { }
    }

    private void OnPortChanged(ChangeEventArgs e)
    {
        selectedPort = e.Value?.ToString() ?? "";
        StateHasChanged();
    }

    private async Task ToggleConnection()
    {
        if (isAttempting) return;
        if (selectedType == "Serial" && string.IsNullOrEmpty(selectedPort)) return;

        isAttempting = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            if (isManualConnected)
            {
                Drone.StopConnection();
                isManualConnected = false;
            }
            else
            {
                Drone.Connect(Enum.Parse<ConnectionType>(selectedType), selectedPort, selectedBaud);
                for (int i = 0; i < 30; i++)
                {
                    if (IsDroneActuallyTalking) break;
                    if (Drone.State.ConnectionStatus == "Disconnected") break;
                    await Task.Delay(500);
                }
                if (IsDroneActuallyTalking)
                {
                    isManualConnected = true;
                    Drone.RequestDataStreams();
                }
                else
                {
                    Drone.StopConnection();
                    isManualConnected = false;
                    Drone.Toast("No response from vehicle. Check connection.", MavlinkService.ToastLevel.Warning, "⚠️");
                }
            }
        }
        catch (Exception) { isManualConnected = false; }
        finally { isAttempting = false; await InvokeAsync(StateHasChanged); }
